---
import Sidebar from '../components/Sidebar.astro';
import Topbar from '../components/Topbar.astro';
import '@goldshore/theme';
import type { AdminPermission, AdminRole } from '@goldshore/auth';

interface Props {
  title?: string;
  requiredPermission?: AdminPermission;
  requiredRole?: AdminRole;
}

const { title = 'GoldShore Admin', requiredPermission, requiredRole } = Astro.props;
const logoSrc = '/assets/logo.svg';

const session = Astro.locals.adminSession ?? {
  roles: [],
  permissions: [],
  isAuthenticated: false
};
const isRoleAllowed = requiredRole ? session.roles.includes(requiredRole) : true;
const isPermissionAllowed = requiredPermission
  ? session.permissions.includes(requiredPermission)
  : true;
const isAuthorized = isRoleAllowed && isPermissionAllowed;
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script>
      import { initTheme } from '@goldshore/theme/manager';
      initTheme();
    </script>
    <script src="../lib/layout.js"></script>
    <style is:global>
      .skip-link {
        position: absolute;
        top: -40px;
        left: 0;
        background: var(--gs-color-accent);
        color: white;
        padding: 8px;
        z-index: 9999;
        transition: top 0.3s;
      }

      .skip-link:focus {
        top: 0;
      }

      .sidebar-toggle {
        display: none;
        background: none;
        border: none;
        color: inherit;
        font-size: 1.5rem;
        cursor: pointer;
        margin-right: 1rem;
        padding: 0;
        line-height: 1;
      }

      .sidebar-close {
        display: none;
        background: none;
        border: 1px solid var(--gs-color-border);
        color: inherit;
        font-size: 1rem;
        cursor: pointer;
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
      }

      .sidebar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
      }

      .sidebar-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        z-index: 1090;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
      }

      .sidebar-overlay.is-visible {
        opacity: 1;
        pointer-events: auto;
      }

      @media (max-width: 1024px) {
        .gs-admin-grid {
          display: block !important;
        }

        .gs-admin-sidebar {
          position: fixed;
          inset: 0 auto 0 0;
          width: 280px;
          z-index: 1100;
          height: 100dvh;
          transform: translateX(-100%);
          transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
          box-shadow: 5px 0 25px rgba(0, 0, 0, 0.5);
          overflow-y: auto;
        }

        .gs-admin-sidebar.is-open {
          transform: translateX(0);
        }

        .sidebar-toggle {
          display: inline-flex;
        }

        .sidebar-close {
          display: block;
        }

        .gs-admin-main {
          min-height: 100vh;
          display: flex;
          flex-direction: column;
        }
      }
    </style>
  </head>
  <body>
    <a href="#admin-content" class="skip-link">Skip to content</a>
    <div class="gs-admin-grid">
      <Sidebar logo={logoSrc} permissions={session.permissions} />
      <div class="gs-admin-main">
        <Topbar title={title} session={session} />
        <main id="admin-content" class="gs-admin-content">
          {isAuthorized ? (
            <slot />
          ) : (
            <section class="max-w-4xl mx-auto py-24 px-6">
              <h1 class="text-3xl gs-heading mb-4">Access restricted</h1>
              <p class="text-[var(--gs-text-secondary)] mb-6">
                Your account does not have permission to view this section. Contact an administrator
                if you need expanded access.
              </p>
              <div class="gs-panel">
                <div class="section-title"><span>🔒</span><h3>Access summary</h3></div>
                <p class="gs-helper">Assigned roles: {session.roles.length ? session.roles.join(', ') : 'None'}</p>
                <p class="gs-helper">Required role: {requiredRole ?? 'None'}</p>
                <p class="gs-helper">Required permission: {requiredPermission ?? 'None'}</p>
              </div>
            </section>
          )}
        </main>
      </div>
    </div>
  </body>
</html>
