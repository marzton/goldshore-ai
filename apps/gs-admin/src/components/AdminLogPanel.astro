---
import { Card, Table } from '@goldshore/ui';

type AuditEvent = {
  timestamp: string;
  action: string;
  actor?: string;
  status: string;
};

interface Props {
  workerName: string;
  logs: AuditEvent[];
  loadError?: string | null;
}

const { workerName, logs, loadError = null } = Astro.props;
const hasLogs = logs.length > 0;
---
<Card class="gs-table-card" data-worker={workerName}>
  {loadError ? <p class="text-[var(--gs-danger)] mb-4">{loadError}</p> : null}

  <div class="section-title"><span>◎</span><h3>{workerName} events</h3></div>

  <div class="gs-form-row mb-3">
    <button type="button" class="gs-btn-secondary" data-role="refresh">Refresh</button>
    <label class="gs-helper">
      <input type="checkbox" data-role="auto-refresh" /> Auto refresh (30s)
    </label>
    <p class="gs-helper mb-0" data-role="status" aria-live="polite">Ready.</p>
  </div>

  <div data-role="empty-state" class:list={{ hidden: hasLogs }}>
    <p class="gs-helper">No logs found for this worker in the selected window.</p>
  </div>

  <div data-role="log-container" tabindex="0" aria-label="Log output" class:list={{ hidden: !hasLogs }}>
    <Table>
      <thead><tr><th>Timestamp</th><th>Level</th><th>Message</th></tr></thead>
      <tbody data-role="log-rows">
        {logs.map((log) => (
          <tr>
            <td>{new Date(log.timestamp).toLocaleString()}</td>
            <td><span class={`gs-badge ${log.status === 'error' ? 'danger' : log.status === 'warning' ? 'warning' : 'info'}`}>{log.status}</span></td>
            <td>{log.action} {log.actor ? `· ${log.actor}` : ''}</td>
          </tr>
        ))}
      </tbody>
    </Table>
  </div>
</Card>

<script>
  document.querySelectorAll('[data-worker]').forEach((panel) => {
    const refreshButton = panel.querySelector('[data-role="refresh"]');
    const autoRefreshInput = panel.querySelector('[data-role="auto-refresh"]');
    const statusEl = panel.querySelector('[data-role="status"]');
    const rows = panel.querySelector('[data-role="log-rows"]');
    const emptyState = panel.querySelector('[data-role="empty-state"]');
    const logContainer = panel.querySelector('[data-role="log-container"]');
    let autoRefreshTimer;

    const updateEmptyState = () => {
      const hasRows = Boolean(rows?.children.length);
      emptyState?.classList.toggle('hidden', hasRows);
      logContainer?.classList.toggle('hidden', !hasRows);
      if (statusEl) {
        statusEl.textContent = hasRows ? 'Logs loaded.' : 'No logs found.';
      }
    };

    refreshButton?.addEventListener('click', () => {
      if (statusEl) {
        statusEl.textContent = 'Refresh requested. Reload the page to fetch latest server logs.';
      }
      updateEmptyState();
    });

    autoRefreshInput?.addEventListener('change', () => {
      clearInterval(autoRefreshTimer);
      if (autoRefreshInput.checked) {
        autoRefreshTimer = window.setInterval(() => {
          if (statusEl) {
            statusEl.textContent = 'Auto-refresh enabled. Reload the page to fetch latest server logs.';
          }
          updateEmptyState();
        }, 30000);
      } else if (statusEl) {
        statusEl.textContent = 'Auto-refresh disabled.';
      }
    });

    updateEmptyState();
  });
</script>
