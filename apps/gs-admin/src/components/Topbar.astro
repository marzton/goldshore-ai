---
import { GSButton } from '@goldshore/ui';
import type { AdminSession } from '@goldshore/auth';

const { title, session } = Astro.props as {
  title: string;
  session: AdminSession & { actor?: string; isAuthenticated: boolean };
};
const envLabel =
  import.meta.env.PUBLIC_ENV === 'preview'
    ? 'Preview'
    : import.meta.env.PUBLIC_ENV === 'development'
    ? 'Development'
    : 'Production';
---
<header class="gs-admin-topbar">
  <div class="gs-row">
    <button id="sidebar-toggle" class="sidebar-toggle" aria-label="Toggle menu">☰</button>
    <h1 class="gs-no-margin">{title}</h1>
    <span class="gs-badge info">{envLabel}</span>
  </div>
  <div class="gs-row">
    {session.isAuthenticated ? (
      <span class="gs-helper">
        {session.actor ?? 'Authenticated'} · {session.roles.length ? session.roles.join(', ') : 'Unassigned'}
      </span>
    ) : (
      <span class="gs-helper">Unauthenticated</span>
    )}
    <div class="gs-preview-toggle" role="group" aria-label="Responsive preview">
      <button type="button" class="gs-preview-button" data-preview="auto">Auto</button>
      <button type="button" class="gs-preview-button" data-preview="desktop">Desktop</button>
      <button type="button" class="gs-preview-button" data-preview="tablet">Tablet</button>
      <button type="button" class="gs-preview-button" data-preview="mobile">Mobile</button>
    </div>
    <GSButton href="/" variant="secondary" class="gs-button--small">View site</GSButton>
  </div>
</header>
