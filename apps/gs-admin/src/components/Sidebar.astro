---
import { SharedHeader } from '@goldshore/ui';
import type { AdminPermission } from '@goldshore/auth';

interface NavLink {
  href: string;
  label: string;
  requiredPermission?: AdminPermission;
}

interface NavGroup {
  id: string;
  label: string;
  links: NavLink[];
}

const navGroups: NavGroup[] = [
  {
    id: 'platform',
    label: 'Platform',
    links: [
      { href: '/admin/overview', label: 'Overview' },
      { href: '/appearance/hero', label: 'Hero Configuration' },
      { href: '/admin/system', label: 'API Status' },
      { href: '/admin/agent-feed', label: 'Agent Feed' }
    ]
  },
  {
    id: 'content',
    label: 'Content',
    links: [
      { href: '/admin/pages/editor', label: 'Home Editor' },
      { href: '/admin/pages', label: 'Team Profiles' },
      { href: '/admin/content', label: 'Advisory Services' },
      { href: '/admin/content', label: 'Content Studio' },
      { href: '/admin/pages/editor', label: 'Page Editor' }
    ]
  },
  {
    id: 'intake-crm',
    label: 'Intake & CRM',
    links: [
      { href: '/admin/forms', label: 'Briefing Requests', requiredPermission: 'forms:read' },
      { href: '/admin/workers', label: 'CRM Logic' },
      { href: '/admin/agent-feed', label: 'Agent Feed', requiredPermission: 'audit:read' }
    ]
  },
  {
    id: 'insights',
    label: 'Insights',
    links: [
      { href: '/admin/analytics', label: 'Analytics' },
      { href: '/admin/monetization', label: 'Monetization' }
    ]
  },
  {
    id: 'management',
    label: 'Management',
    links: [
      { href: '/admin/pages', label: 'Pages' },
      { href: '/admin/media', label: 'Media Library', requiredPermission: 'media:read' },
      { href: '/admin/pii-scans', label: 'PII Scans' },
      { href: '/admin/workers', label: 'Workers' },
      { href: '/admin/users', label: 'Users', requiredPermission: 'users:read' }
    ]
  },
  {
    id: 'system',
    label: 'System',
    links: [
      { href: '/admin/settings', label: 'Settings' },
      { href: '/admin/system', label: 'System Health' },
      { href: '/admin/logs', label: 'Logs', requiredPermission: 'audit:read' }
    ]
  }
];

const { logo, permissions = [] } = Astro.props;

const visibleGroups = navGroups
  .map((group) => ({
    ...group,
    links: group.links.filter((link) =>
      link.requiredPermission ? permissions.includes(link.requiredPermission) : true
    )
  }))
  .filter((group) => group.links.length > 0);

const isActive = (href: string) => {
  const currentPath = Astro.url.pathname;
  const cleanCurrent = currentPath.endsWith('/') ? currentPath.slice(0, -1) : currentPath;
  const cleanHref = href.endsWith('/') ? href.slice(0, -1) : href;

  if (cleanCurrent === cleanHref) return true;
  return cleanCurrent.startsWith(cleanHref + '/');
};

const isGroupActive = (group: NavGroup) => group.links.some((link) => isActive(link.href));
---

<aside class="gs-admin-sidebar" id="admin-sidebar" aria-label="Admin navigation">
  <SharedHeader
    class="sidebar-header"
    href="https://goldshore.ai"
    target="_blank"
    rel="noopener noreferrer"
    logoSrc={logo?.src || logo || '/assets/logo.svg'}
    logoAlt="GoldShore logo"
  >
    <span slot="brand-text">GoldShore</span>
    <button id="sidebar-close" class="sidebar-close" aria-label="Close menu">✕</button>
  </SharedHeader>

  <nav class="gs-sidebar-links" aria-label="Admin sections">
    {visibleGroups.map((group) => {
      const groupActive = isGroupActive(group);
      const panelId = `sidebar-group-panel-${group.id}`;

      return (
        <section class={`gs-sidebar-group ${groupActive ? 'is-open is-active' : ''}`}>
          <h2 class="gs-sidebar-group-title">
            <button
              type="button"
              class="gs-sidebar-group-trigger"
              data-sidebar-group-trigger
              data-panel-id={panelId}
              aria-expanded={groupActive ? 'true' : 'false'}
              aria-controls={panelId}
            >
              <span>{group.label}</span>
              <span class="gs-sidebar-group-chevron" aria-hidden="true">▾</span>
            </button>
          </h2>

          <div
            id={panelId}
            class={`gs-sidebar-group-panel ${groupActive ? 'is-open' : ''}`}
            data-sidebar-group-panel
          >
            <div class="gs-sidebar-group-panel-inner">
              {group.links.map((link) => {
                const linkActive = isActive(link.href);

                return (
                  <a
                    class={`gs-nav-block ${linkActive ? 'active' : ''}`}
                    href={link.href}
                    aria-current={linkActive ? 'page' : undefined}
                  >
                    {link.label}
                  </a>
                );
              })}
            </div>
          </div>
        </section>
      );
    })}
  </nav>
</aside>

<script>
  const sidebarGroupTriggers = Array.from(document.querySelectorAll('[data-sidebar-group-trigger]'));

  const updateGroupState = (trigger, expand) => {
    const panelId = trigger.getAttribute('data-panel-id');
    const panel = panelId ? document.getElementById(panelId) : null;
    const group = trigger.closest('.gs-sidebar-group');

    if (!panel || !group) return;

    trigger.setAttribute('aria-expanded', String(expand));
    panel.classList.toggle('is-open', expand);
    group.classList.toggle('is-open', expand);

    if (expand) {
      panel.style.maxHeight = `${panel.scrollHeight}px`;
    } else {
      panel.style.maxHeight = '0px';
    }
  };

  sidebarGroupTriggers.forEach((trigger) => {
    const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
    updateGroupState(trigger, isExpanded);

    trigger.addEventListener('click', () => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      updateGroupState(trigger, !expanded);
    });

    trigger.addEventListener('keydown', (event) => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';

      if (event.key === 'ArrowRight' && !expanded) {
        event.preventDefault();
        updateGroupState(trigger, true);
      }

      if (event.key === 'ArrowLeft' && expanded) {
        event.preventDefault();
        updateGroupState(trigger, false);
      }
    });
  });

  window.addEventListener('resize', () => {
    sidebarGroupTriggers.forEach((trigger) => {
      const expanded = trigger.getAttribute('aria-expanded') === 'true';
      if (expanded) updateGroupState(trigger, true);
    });
  });
</script>

<style>
  .gs-admin-sidebar {
    height: 100dvh;
    overflow-y: auto;
    background: rgba(5, 6, 10, 0.72);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .gs-sidebar-links {
    display: grid;
    gap: 0.35rem;
  }

  .gs-sidebar-group {
    border-radius: 0.6rem;
  }

  .gs-sidebar-group.is-open,
  .gs-sidebar-group.is-active {
    background: color-mix(in oklab, var(--gs-surface, #111) 86%, white 14%);
  }

  .gs-sidebar-group-title {
    margin: 0;
  }

  .gs-sidebar-group-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.7rem 0.8rem;
    border: 0;
    background: transparent;
    color: var(--gs-text-primary);
    font: inherit;
    font-weight: 600;
    text-align: left;
    cursor: pointer;
    border-radius: 0.6rem;
  }

  .gs-sidebar-group-trigger:focus-visible {
    outline: 2px solid var(--gs-color-accent, #7ea2ff);
    outline-offset: 2px;
  }

  .gs-sidebar-group-chevron {
    font-size: 0.9rem;
    transition: transform 0.24s ease;
  }

  .gs-sidebar-group-trigger[aria-expanded='true'] .gs-sidebar-group-chevron {
    transform: rotate(180deg);
  }

  .gs-sidebar-group-panel {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.24s ease, opacity 0.2s ease;
  }

  .gs-sidebar-group-panel.is-open {
    opacity: 1;
  }

  .gs-sidebar-group-panel-inner {
    display: grid;
    gap: 0.2rem;
    padding: 0 0.4rem 0.55rem;
  }

  .gs-nav-block {
    border-radius: 0.45rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .gs-sidebar-group-chevron,
    .gs-sidebar-group-panel {
      transition: none;
    }
  }
</style>
