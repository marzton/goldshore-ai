<div class="gs-card space-y-4 lg:col-span-2">
  <div class="flex items-center justify-between">
    <div>
      <h2 class="text-xl font-semibold">Inbox Status</h2>
      <p class="text-sm gs-text-subtle">Recent emails logged by gs-mail from <code>mail.goldshore.ai</code>.</p>
    </div>
    <span id="inbox-count" class="text-sm gs-text-subtle">Loading…</span>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-left">
      <thead>
        <tr class="text-sm gs-text-subtle border-b border-[var(--gs-color-border)]">
          <th class="pb-2">Timestamp</th>
          <th class="pb-2">Sender</th>
          <th class="pb-2">Subject</th>
        </tr>
      </thead>
      <tbody id="inbox-table-body">
        <tr><td class="py-3 text-sm gs-text-subtle" colspan="3">Loading inbox logs…</td></tr>
      </tbody>
    </table>
  </div>
</div>

<script>
  const body = document.getElementById('inbox-table-body');
  const count = document.getElementById('inbox-count');

  const renderRow = (mail) => {
    const tr = document.createElement('tr');
    tr.className = 'border-b border-[var(--gs-color-border)]/50';

    const tdTime = document.createElement('td');
    tdTime.className = 'py-2 text-xs gs-text-subtle';
    tdTime.textContent = new Date(mail.timestamp).toLocaleString();

    const tdSender = document.createElement('td');
    tdSender.className = 'py-2';
    tdSender.textContent = mail.from;

    const tdSubject = document.createElement('td');
    tdSubject.className = 'py-2 gs-text-subtle';
    tdSubject.textContent = mail.subject;

    tr.appendChild(tdTime);
    tr.appendChild(tdSender);
    tr.appendChild(tdSubject);
    return tr;
  };

  const setStatusRow = (message, toneClass = 'gs-text-subtle') => {
    if (!body) return;
    body.innerHTML = '';
    const tr = document.createElement('tr');
    const td = document.createElement('td');
    td.className = `py-3 text-sm ${toneClass}`;
    td.colSpan = 3;
    td.textContent = message;
    tr.appendChild(td);
    body.appendChild(tr);
  };

  const renderError = (message) => {
    setStatusRow(message, 'gs-text-danger');
    if (count) count.textContent = 'Unavailable';
  };

  fetch('https://api.goldshore.ai/internal/inbox-status')
    .then((res) => res.json())
    .then((data) => {
      const recent = data?.inbox?.recent ?? [];
      const total = data?.inbox?.count ?? 0;
      if (count) count.textContent = `${total} logged`; 

      if (!recent.length) {
        setStatusRow('No incoming messages detected.');
        return;
      }

      if (body) {
        body.innerHTML = '';
        recent.forEach((mail) => {
          body.appendChild(renderRow(mail));
        });
      }
    })
    .catch(() => {
      renderError('Failed to load inbox logs.');
    });
</script>
