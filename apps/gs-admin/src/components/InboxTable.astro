<div class="gs-card space-y-4 lg:col-span-2">
  <div class="flex items-center justify-between">
    <div>
      <h2 class="text-xl font-semibold">Inbox Status</h2>
      <p class="text-sm gs-text-subtle">Recent emails logged by gs-mail from <code>mail.goldshore.ai</code>.</p>
    </div>
    <span id="inbox-count" class="text-sm gs-text-subtle">Loading…</span>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-left">
      <thead>
        <tr class="text-sm gs-text-subtle border-b border-[var(--gs-color-border)]">
          <th class="pb-2">Timestamp</th>
          <th class="pb-2">Sender</th>
          <th class="pb-2">Subject</th>
        </tr>
      </thead>
      <tbody id="inbox-table-body">
        <tr><td class="py-3 text-sm gs-text-subtle" colspan="3">Loading inbox logs…</td></tr>
      </tbody>
    </table>
  </div>
</div>

<script>
  const body = document.getElementById('inbox-table-body');
  const count = document.getElementById('inbox-count');

  const renderRow = (mail) => {
    const tr = document.createElement('tr');
    tr.className = 'border-b border-[var(--gs-color-border)]/50';

    const timestampCell = document.createElement('td');
    timestampCell.className = 'py-2 text-xs gs-text-subtle';
    timestampCell.textContent = new Date(mail.timestamp).toLocaleString();
    tr.appendChild(timestampCell);

    const fromCell = document.createElement('td');
    fromCell.className = 'py-2';
    fromCell.textContent = mail.from ?? '';
    tr.appendChild(fromCell);

    const subjectCell = document.createElement('td');
    subjectCell.className = 'py-2 gs-text-subtle';
    subjectCell.textContent = mail.subject ?? '';
    tr.appendChild(subjectCell);

    return tr;
  };

  const renderError = (message) => {
    if (body) {
      body.innerHTML = '';
      const tr = document.createElement('tr');
      const td = document.createElement('td');
      td.className = 'py-3 text-sm gs-text-danger';
      td.colSpan = 3;
      td.textContent = message;
      tr.appendChild(td);
      body.appendChild(tr);
    }
    if (count) count.textContent = 'Unavailable';
  };

  fetch('/api/gs-api/inbox-status')
    .then((res) => res.json())
    .then((data) => {
      const recent = data?.inbox?.recent ?? [];
      const total = data?.inbox?.count ?? 0;
      if (count) count.textContent = `${total} logged`;

      if (!body) {
        return;
      }

      // Clear any existing rows (e.g., loading state)
      body.innerHTML = '';

      if (!recent.length) {
        const tr = document.createElement('tr');
        const td = document.createElement('td');
        td.className = 'py-3 text-sm gs-text-subtle';
        td.colSpan = 3;
        td.textContent = 'No incoming messages detected.';
        tr.appendChild(td);
        body.appendChild(tr);
        return;
      }

      recent.forEach((mail) => {
        body.appendChild(renderRow(mail));
      });
    })
    .catch(() => {
      renderError('Failed to load inbox logs.');
    });
</script>
