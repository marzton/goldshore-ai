---
import AdminLayout from '../../../layouts/AdminLayout.astro';

const deploymentGuard = Astro.locals.deploymentGuard;
---
<AdminLayout title="Worker Status | GoldShore Admin">
    <section class="max-w-5xl mx-auto py-24 px-6 space-y-6">
        <h1 class="text-3xl gs-heading mb-4">Worker Status</h1>
        <p class="text-[var(--gs-text-secondary)]">
            Health checks and uptime metrics for each worker will appear here.
        </p>

        <div class="gs-card space-y-4">
            <div class="flex items-center justify-between gap-4">
                <h2 class="text-xl font-semibold">Deployment Guard</h2>
                <span class={`gs-pill ${deploymentGuard?.ready ? 'bg-emerald-500/15 text-emerald-300' : 'bg-amber-500/15 text-amber-300'}`}>
                    {deploymentGuard?.ready ? 'Ready to Deploy' : 'Missing Configuration'}
                </span>
            </div>
            <p class="text-sm gs-text-subtle">
                Quick validation for gateway ↔ API inheritance before reconnecting the GitHub deployment.
            </p>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="text-sm gs-text-subtle border-b border-[var(--gs-color-border)]">
                            <th class="pb-2">Config Key</th>
                            <th class="pb-2">Purpose</th>
                            <th class="pb-2">Required By</th>
                            <th class="pb-2">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        {(deploymentGuard?.checks ?? []).map((check) => (
                            <tr class="border-b border-[var(--gs-color-border)]/50">
                                <td class="py-2 font-mono text-xs">{check.key}</td>
                                <td class="py-2 text-sm">{check.label}</td>
                                <td class="py-2 uppercase text-xs gs-text-subtle">{check.requiredBy}</td>
                                <td class={`py-2 text-sm ${check.present ? 'text-emerald-300' : 'text-amber-300'}`}>
                                    {check.present ? 'Present' : 'Missing'}
                                </td>
                            </tr>
                        ))}
                    </tbody>
                </table>
            </div>
            <p class="text-xs gs-text-subtle">Checked at: {deploymentGuard?.checkedAt ? new Date(deploymentGuard.checkedAt).toLocaleString() : 'N/A'}</p>
        </div>

        <div class="gs-card space-y-4">
            <div class="flex items-center justify-between gap-4">
                <h2 class="text-xl font-semibold">MASTER_CONFIG Sync Telemetry</h2>
                <span id="sync-source-pill" class="gs-pill">Loading…</span>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="text-sm gs-text-subtle border-b border-[var(--gs-color-border)]">
                            <th class="pb-2">Last Sync Timestamp (verified)</th>
                            <th class="pb-2">Sync Source (durable vs inferred)</th>
                            <th class="pb-2">Drift Status (computed)</th>
                        </tr>
                    </thead>
                    <tbody id="master-config-report-body">
                        <tr><td class="py-3 text-sm gs-text-subtle" colspan="3">Loading sync telemetry…</td></tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="gs-card space-y-4">
            <h2 class="text-xl font-semibold">Per-host DNS / Routing Results</h2>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="text-sm gs-text-subtle border-b border-[var(--gs-color-border)]">
                            <th class="pb-2">Hostname</th>
                            <th class="pb-2">Result</th>
                            <th class="pb-2">Drift Notes</th>
                        </tr>
                    </thead>
                    <tbody id="host-sync-results-body">
                        <tr><td class="py-3 text-sm gs-text-subtle" colspan="3">Loading host results…</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <script>
        const reportBody = document.getElementById('master-config-report-body');
        const hostBody = document.getElementById('host-sync-results-body');
        const sourcePill = document.getElementById('sync-source-pill');

        const renderError = (message) => {
            if (reportBody) {
                reportBody.innerHTML = `<tr><td class="py-3 text-sm gs-text-danger" colspan="3">${message}</td></tr>`;
            }
            if (hostBody) {
                hostBody.innerHTML = `<tr><td class="py-3 text-sm gs-text-danger" colspan="3">${message}</td></tr>`;
            }
            if (sourcePill) sourcePill.textContent = 'Unavailable';
        };

        fetch('/api/gs-api/dns-sync-status')
            .then((res) => res.json())
            .then((data) => {
                const report = data?.masterConfigReport;
                const latestRun = data?.latestRun;
                const results = latestRun?.results ?? [];

                if (sourcePill) {
                    sourcePill.textContent = report?.syncSource ?? 'none';
                }

                if (reportBody) {
                    reportBody.innerHTML = `<tr class="border-b border-[var(--gs-color-border)]/50">
                        <td class="py-2 text-xs gs-text-subtle">${report?.lastSyncTimestampVerified ? new Date(report.lastSyncTimestampVerified).toLocaleString() : 'N/A'}</td>
                        <td class="py-2">${report?.syncSource ?? 'none'}</td>
                        <td class="py-2">${report?.driftStatusComputed ?? 'unknown'}</td>
                    </tr>`;
                }

                if (!results.length) {
                    if (hostBody) {
                        hostBody.innerHTML = '<tr><td class="py-3 text-sm gs-text-subtle" colspan="3">No durable DNS sync runs were found.</td></tr>';
                    }
                    return;
                }

                if (hostBody) {
                    hostBody.innerHTML = results.map((item) => `<tr class="border-b border-[var(--gs-color-border)]/50">
                        <td class="py-2">${item.hostname}</td>
                        <td class="py-2">${item.success ? 'success' : 'failure'}</td>
                        <td class="py-2 text-xs gs-text-subtle">${(item.driftNotes ?? []).length ? item.driftNotes.join(' | ') : 'None'}</td>
                    </tr>`).join('');
                }
            })
            .catch(() => renderError('Failed to load DNS sync telemetry.'));
    </script>
</AdminLayout>
