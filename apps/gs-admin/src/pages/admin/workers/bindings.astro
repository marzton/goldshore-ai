---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---
<AdminLayout title="Worker Bindings | GoldShore Admin">
    <section class="max-w-5xl mx-auto py-24 px-6 space-y-6">
        <h1 class="text-3xl gs-heading mb-4">Worker Bindings</h1>
        <div class="gs-card space-y-3 border border-[var(--gs-color-border)]">
            <span class="gs-pill">roadmap-only</span>
            <p class="text-sm gs-text-subtle">
                This page is not yet wired to a live bindings inventory. Operators should not rely on it for current environment configuration.
            </p>
        </div>
        <p class="text-[var(--gs-text-secondary)]">
            Resource bindings, environment variables, and secrets mapping will be listed here.
        </p>
    </section>
</AdminLayout>
