---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---
<AdminLayout title="Worker Routes | GoldShore Admin">
    <section class="max-w-5xl mx-auto py-24 px-6 space-y-6">
        <h1 class="text-3xl gs-heading mb-4">Worker Routes</h1>
        <div class="gs-card space-y-3 border border-[var(--gs-color-border)]">
            <span class="gs-pill">roadmap-only</span>
            <p class="text-sm gs-text-subtle">
                This route remains a placeholder and is not backed by live routing data or management controls yet.
            </p>
        </div>
        <p class="text-[var(--gs-text-secondary)]">
            Route tables, domains, and traffic rules will be managed here.
        </p>
    </section>
</AdminLayout>
