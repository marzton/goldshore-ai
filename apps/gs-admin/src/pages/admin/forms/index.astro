---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { formConfigs } from '../../../data/forms';
---
<AdminLayout title="Forms Dashboard | GoldShore Admin" requiredPermission="forms:read">
  <section class="max-w-6xl mx-auto py-16 px-6 space-y-8">
    <header class="space-y-3">
      <h1 class="text-3xl gs-heading">Forms Dashboard</h1>
      <p class="text-[var(--gs-text-secondary)]">
        Monitor form configurations, recipients, integrations, and submission health for each intake surface.
      </p>
    </header>

    <div class="grid gap-6 md:grid-cols-2">
      {formConfigs.map((config) => (
        <div class="gs-card space-y-4">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-xl font-semibold">{config.name}</h2>
              <p class="text-sm gs-text-subtle">/{config.slug}</p>
            </div>
            <span class={`rounded-full px-3 py-1 text-xs font-semibold ${
              config.status === 'active'
                ? 'bg-emerald-500/20 text-emerald-200'
                : config.status === 'paused'
                ? 'bg-amber-500/20 text-amber-200'
                : 'bg-slate-500/20 text-slate-200'
            }`}>
              {config.status}
            </span>
          </div>
          <p class="text-sm text-[var(--gs-text-secondary)]">{config.description}</p>
          <div class="grid gap-3 text-sm">
            <div class="flex items-center justify-between">
              <span class="gs-text-subtle">Recipients</span>
              <span class="font-semibold">{config.recipients.length}</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="gs-text-subtle">Integrations</span>
              <span class="font-semibold">{config.integrations.length}</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="gs-text-subtle">Last updated</span>
              <span>{config.lastUpdated}</span>
            </div>
          </div>
          <div class="pt-2">
            <a class="gs-button" href={`/admin/forms/${config.slug}`}>
              View configuration
            </a>
          </div>
        </div>
      ))}
    </div>

    <div class="gs-card space-y-4">
      <h2 class="text-xl font-semibold">Submission Health</h2>
      <div class="grid gap-4 md:grid-cols-4">
        {formConfigs.map((config) => (
          <div class="rounded-2xl border border-white/10 p-4 space-y-2">
            <p class="text-sm gs-text-subtle">{config.name}</p>
            <div class="text-2xl font-semibold">{config.submissionStatus.received}</div>
            <div class="text-xs text-[var(--gs-text-secondary)]">
              {config.submissionStatus.stored} stored · {config.submissionStatus.routed} routed · {config.submissionStatus.failed} failed
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</AdminLayout>
