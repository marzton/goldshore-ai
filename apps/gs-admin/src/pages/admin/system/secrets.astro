---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---
<AdminLayout title="System Secrets | GoldShore Admin">
    <section class="max-w-5xl mx-auto py-24 px-6 space-y-6">
        <h1 class="text-3xl gs-heading mb-4">Secrets Management</h1>
        <div class="gs-card space-y-3 border border-[var(--gs-color-border)]">
            <span class="gs-pill">roadmap-only</span>
            <p class="text-sm gs-text-subtle">
                This page is not backed by live secret inventory or rotation controls yet and should not be treated as an operational control surface.
            </p>
        </div>
        <p class="text-[var(--gs-text-secondary)]">
            Secret rotation schedules, access policies, and audit logs will appear here.
        </p>
    </section>
</AdminLayout>
