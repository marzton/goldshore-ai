---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---
<AdminLayout title="System DNS | GoldShore Admin">
    <section class="max-w-5xl mx-auto py-24 px-6 space-y-6">
        <h1 class="text-3xl gs-heading mb-4">DNS Configuration</h1>
        <div class="gs-card space-y-3 border border-[var(--gs-color-border)]">
            <span class="gs-pill">roadmap-only</span>
            <p class="text-sm gs-text-subtle">
                This route is not wired to live DNS controls yet. Operators should use the live DNS panels on
                <a class="underline underline-offset-4" href="/admin/system">System Configuration</a>.
            </p>
        </div>
        <p class="text-[var(--gs-text-secondary)]">
            DNS records, zones, and propagation status will be displayed here.
        </p>
    </section>
</AdminLayout>
