---
import AdminLayout from '../../layouts/AdminLayout.astro';

const services = [
  {
    name: 'gs-gateway',
    env: 'production',
    route: 'goldshore.ai/*',
    runtime: 'Cloudflare Workers',
    status: 'Healthy'
  },
  {
    name: 'gs-admin',
    env: 'production',
    route: 'admin.goldshore.ai/*',
    runtime: 'Cloudflare Workers',
    status: 'Healthy'
  }
] as const;

const bindings = [
  { type: 'KV', name: 'GS_CONFIG', service: 'gs-gateway', state: 'Bound' },
  { type: 'KV', name: 'SESSION', service: 'gs-admin', state: 'Bound' },
  { type: 'R2', name: 'MEDIA_BUCKET', service: 'gs-gateway', state: 'Pending' },
  { type: 'D1', name: 'LOGS_DB', service: 'gs-admin', state: 'Planned' }
] as const;

const stateStyles = {
  Bound: 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300',
  Pending: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/40 dark:text-yellow-300',
  Planned: 'bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300'
} as const;
---

<AdminLayout title="Infrastructure">
  <section class="space-y-6">
    <header class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Infrastructure</h1>
        <p class="text-sm text-slate-500">Manage Cloudflare Worker services, routes, and runtime bindings.</p>
      </div>
      <a
        href="/admin/workers/bindings"
        class="inline-flex items-center px-3 py-2 rounded-md text-sm font-medium bg-slate-900 text-white dark:bg-slate-100 dark:text-slate-900"
      >
        Open bindings console
      </a>
    </header>

    <div class="grid gap-4 lg:grid-cols-2">
      {services.map((service) => (
        <article class="p-4 rounded-xl border border-slate-200 bg-white dark:bg-slate-800 dark:border-slate-700 shadow-sm">
          <div class="flex items-center justify-between">
            <h2 class="text-base font-semibold text-slate-900 dark:text-white">{service.name}</h2>
            <span class="text-xs px-2 py-1 rounded-full bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300">
              {service.status}
            </span>
          </div>
          <dl class="mt-3 space-y-1 text-sm text-slate-600 dark:text-slate-300">
            <div class="flex justify-between"><dt>Environment</dt><dd class="font-medium">{service.env}</dd></div>
            <div class="flex justify-between"><dt>Route</dt><dd class="font-mono text-xs">{service.route}</dd></div>
            <div class="flex justify-between"><dt>Runtime</dt><dd>{service.runtime}</dd></div>
          </dl>
        </article>
      ))}
    </div>

    <section class="p-4 rounded-xl border border-slate-200 bg-white dark:bg-slate-800 dark:border-slate-700 shadow-sm">
      <h2 class="text-base font-semibold text-slate-900 dark:text-white mb-3">Worker bindings</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-slate-500 border-b border-slate-200 dark:border-slate-700">
              <th class="py-2 pr-3">Type</th>
              <th class="py-2 pr-3">Binding</th>
              <th class="py-2 pr-3">Service</th>
              <th class="py-2">State</th>
            </tr>
          </thead>
          <tbody>
            {bindings.map((binding) => (
              <tr class="border-b border-slate-100 dark:border-slate-700/60">
                <td class="py-2 pr-3">{binding.type}</td>
                <td class="py-2 pr-3 font-mono text-xs">{binding.name}</td>
                <td class="py-2 pr-3">{binding.service}</td>
                <td class="py-2">
                  <span class={`inline-flex px-2 py-1 rounded-full text-xs font-medium ${stateStyles[binding.state]}`}>
                    {binding.state}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  </section>
</AdminLayout>
