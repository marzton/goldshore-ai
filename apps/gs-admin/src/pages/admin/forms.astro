---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { Card, Table } from '@goldshore/ui';

const forms = [
  { id: 'form-120', name: 'Enterprise Intake', status: 'active', submissions: 18 },
  { id: 'form-121', name: 'Partner Onboarding', status: 'draft', submissions: 4 },
  { id: 'form-122', name: 'Security Review', status: 'active', submissions: 9 }
];
---
<AdminLayout title="Forms | GoldShore Admin" requiredPermission="forms:read">
  <section class="max-w-6xl mx-auto py-16 px-6">
    <h1 class="text-3xl gs-heading mb-4">Forms</h1>
    <p class="text-[var(--gs-text-secondary)] mb-8">
      Maintain intake workflows and review submission activity aligned to role-based permissions.
    </p>

    <Card class="gs-table-card">
      <Table>
        <thead>
          <tr>
            <th>Form ID</th>
            <th>Name</th>
            <th>Status</th>
            <th>Submissions</th>
          </tr>
        </thead>
        <tbody>
          {forms.map((form) => (
            <tr>
              <td>{form.id}</td>
              <td>{form.name}</td>
              <td class="capitalize">{form.status}</td>
              <td>{form.submissions}</td>
            </tr>
          ))}
        </tbody>
      </Table>
    </Card>
  </section>
</AdminLayout>
