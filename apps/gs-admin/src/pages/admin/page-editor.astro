---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { GSButton } from '@goldshore/ui';

const API_BASE = import.meta.env.PUBLIC_API;
---
<AdminLayout title="Page Editor | GoldShore Admin">
  <section class="max-w-6xl mx-auto py-16 px-6 space-y-10">
    <header class="space-y-3">
      <h1 class="text-3xl gs-heading">Page Editor</h1>
      <p class="text-[var(--gs-text-secondary)]">
        Draft content blocks and insert approved media assets directly from the library.
      </p>
    </header>

    <div class="gs-card space-y-4">
      <div class="flex flex-wrap items-center gap-3">
        <GSButton id="open-media-picker" variant="secondary">Insert media</GSButton>
        <GSButton id="preview-toggle" variant="ghost">Toggle preview</GSButton>
      </div>
      <textarea
        id="page-editor-input"
        class="gs-input min-h-[240px]"
        placeholder="Write content here... Use Markdown or HTML."
      ></textarea>
    </div>

    <section class="gs-card space-y-4" id="preview-section">
      <h2 class="text-xl font-semibold">Preview</h2>
      <div id="page-preview" class="page-preview"></div>
    </section>
  </section>

  <div id="media-modal" class="media-modal" aria-hidden="true" role="dialog" aria-label="Media picker">
    <div class="media-modal__content">
      <div class="media-modal__header">
        <h2 class="text-xl font-semibold">Choose media</h2>
        <button id="media-modal-close" class="media-modal__close" aria-label="Close media picker">✕</button>
      </div>
      <div id="media-modal-grid" class="media-modal__grid"></div>
    </div>
  </div>

  <style>
    .page-preview {
      border: 1px solid var(--gs-border-subtle, #233041);
      border-radius: 12px;
      padding: 1.5rem;
      min-height: 200px;
      background: #0f172a;
    }

    .media-modal {
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, 0.72);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 2rem;
      z-index: 50;
    }

    .media-modal[aria-hidden='false'] {
      display: flex;
    }

    .media-modal__content {
      background: #0b1220;
      border: 1px solid var(--gs-border-subtle, #1f2937);
      border-radius: 16px;
      width: min(920px, 100%);
      max-height: 80vh;
      overflow: hidden;
      display: grid;
      grid-template-rows: auto 1fr;
    }

    .media-modal__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 1.5rem;
      border-bottom: 1px solid var(--gs-border-subtle, #1f2937);
    }

    .media-modal__close {
      background: transparent;
      border: none;
      color: #e2e8f0;
      font-size: 1.2rem;
      cursor: pointer;
    }

    .media-modal__grid {
      padding: 1.5rem;
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      overflow-y: auto;
    }

    .media-modal__card {
      border: 1px solid var(--gs-border-subtle, #233041);
      border-radius: 12px;
      padding: 0.75rem;
      display: grid;
      gap: 0.5rem;
      cursor: pointer;
      background: rgba(15, 23, 42, 0.65);
      transition: transform 0.2s ease, border-color 0.2s ease;
    }

    .media-modal__card:hover {
      transform: translateY(-2px);
      border-color: rgba(148, 163, 184, 0.8);
    }

    .media-modal__preview {
      height: 120px;
      background: #0f172a;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .media-modal__preview img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .media-modal__meta {
      font-size: 0.75rem;
      color: var(--gs-text-secondary);
      word-break: break-word;
    }
  </style>

  <script>
    const apiBase = `${API_BASE}`.replace(/\/$/, '');
    const modal = document.getElementById('media-modal');
    const modalGrid = document.getElementById('media-modal-grid');
    const editor = document.getElementById('page-editor-input');
    const preview = document.getElementById('page-preview');
    const previewSection = document.getElementById('preview-section');

    const openModal = () => {
      if (!modal) return;
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };

    const closeModal = () => {
      if (!modal) return;
      modal.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    const insertAtCursor = (text) => {
      if (!(editor instanceof HTMLTextAreaElement)) return;
      const start = editor.selectionStart ?? editor.value.length;
      const end = editor.selectionEnd ?? editor.value.length;
      editor.setRangeText(text, start, end, 'end');
      editor.focus();
      updatePreview();
    };

    const updatePreview = () => {
      if (!(editor instanceof HTMLTextAreaElement) || !preview) return;
      const value = editor.value;
      preview.innerHTML = value
        .replace(/\\n/g, '<br />')
        .replace(/\\*\\*(.*?)\\*\\*/g, '<strong>$1</strong>');
    };

    const createMediaCard = (item) => {
      const card = document.createElement('button');
      card.type = 'button';
      card.className = 'media-modal__card';

      const previewDiv = document.createElement('div');
      previewDiv.className = 'media-modal__preview';

      const img = document.createElement('img');
      img.src = item.url;
      img.alt = item.filename;
      previewDiv.appendChild(img);

      const metaDiv = document.createElement('div');
      metaDiv.className = 'media-modal__meta';
      metaDiv.textContent = item.filename;

      card.appendChild(previewDiv);
      card.appendChild(metaDiv);

      card.addEventListener('click', () => {
        insertAtCursor(`\\n<img src=\"${item.url}\" alt=\"${item.filename}\" />\\n`);
        closeModal();
      });
      return card;
    };

    const loadMedia = async () => {
      if (!modalGrid) return;
      modalGrid.innerHTML = '<div class="gs-helper">Loading media library...</div>';
      try {
        const response = await fetch(`${apiBase}/media`);
        const data = await response.json();
        const items = data.items ?? [];
        if (!items.length) {
          modalGrid.innerHTML = '<div class="gs-helper">No media available. Upload assets first.</div>';
          return;
        }
        modalGrid.innerHTML = '';
        items.forEach((item) => modalGrid.appendChild(createMediaCard(item)));
      } catch (error) {
        console.error('Failed to load media', error);
        modalGrid.innerHTML = '<div class="gs-helper">Unable to load media library.</div>';
      }
    };

    document.getElementById('open-media-picker')?.addEventListener('click', () => {
      openModal();
      loadMedia();
    });

    document.getElementById('media-modal-close')?.addEventListener('click', closeModal);
    modal?.addEventListener('click', (event) => {
      if (event.target === modal) closeModal();
    });

    document.getElementById('preview-toggle')?.addEventListener('click', () => {
      if (!previewSection) return;
      const isHidden = previewSection.toggleAttribute('hidden');
      previewSection.setAttribute('aria-hidden', String(isHidden));
    });

    editor?.addEventListener('input', updatePreview);
    updatePreview();
  </script>
</AdminLayout>
