---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { Card } from '@goldshore/ui';
---
<AdminLayout title="Users | GoldShore Admin" requiredPermission="users:read">
    <section class="max-w-5xl mx-auto py-16 px-6">
        <h1 class="text-3xl gs-heading mb-4">User Management</h1>
        <p class="text-[var(--gs-text-secondary)] mb-8">
            Manage team access, keep permission sets aligned to content, media, and forms, and review
            administrative activity.
        </p>
        <div class="gs-grid columns-3">
            <Card>
                <h2 class="text-lg font-semibold mb-2">User Directory</h2>
                <p class="gs-helper mb-4">Invite or deactivate members with admin control.</p>
                <a class="gs-link" href="/admin/users/list">View users →</a>
            </Card>
            <Card>
                <h2 class="text-lg font-semibold mb-2">Permissions Matrix</h2>
                <p class="gs-helper mb-4">Review role access for content, media, and forms.</p>
                <a class="gs-link" href="/admin/users/permissions">View permissions →</a>
            </Card>
            <Card>
                <h2 class="text-lg font-semibold mb-2">Audit Trail</h2>
                <p class="gs-helper mb-4">Track administrative changes and approvals.</p>
                <a class="gs-link" href="/admin/logs">View audit logs →</a>
            </Card>
        </div>
---
<AdminLayout title="Users | GoldShore Admin">
    <section class="max-w-5xl mx-auto py-24 px-6">
        <h1 class="text-3xl gs-heading mb-4">User Management</h1>
        <p class="text-[var(--gs-text-secondary)]">
            User listings, sessions, permissions and Access sync will live here.
        </p>
    </section>
</AdminLayout>
