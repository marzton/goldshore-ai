---
import AdminLayout from '../../layouts/AdminLayout.astro';
import StatCard from '../../components/StatCard.astro';
import { getCloudflareMetrics, type CloudflareMetrics } from '../../lib/cloudflare';

const metrics: CloudflareMetrics = await getCloudflareMetrics();

const formatMetricValue: { [Key in keyof CloudflareMetrics]: (value: CloudflareMetrics[Key]) => string } = {
  requests: (value) => value.toLocaleString(),
  bandwidth: (value) => `${value.toLocaleString()} GB`,
  threats: (value) => value.toLocaleString(),
  pageViews: (value) => value.toLocaleString(),
};

const statCards: Array<{
  key: keyof CloudflareMetrics;
  label: string;
  help: string;
}> = [
  { key: 'requests', label: 'Requests', help: 'Total edge requests in the current payload' },
  { key: 'bandwidth', label: 'Bandwidth', help: 'Bandwidth reported by the current payload' },
  { key: 'threats', label: 'Threats', help: 'Security events reported by the current payload' },
  { key: 'pageViews', label: 'Page Views', help: 'Page views reported by the current payload' },
];
---
<AdminLayout title="Cloudflare Analytics | GoldShore Admin" requiredRole="admin">
  <section class="max-w-7xl mx-auto px-6 py-10 space-y-10">
    <header class="space-y-3">
      <p class="text-sm uppercase tracking-[0.3em] gs-text-subtle">Cloudflare</p>
      <h1 class="text-3xl gs-heading">Edge Analytics Overview</h1>
      <p class="text-lg gs-text-subtle">
        The admin dashboard currently renders only the Cloudflare analytics fields returned by
        <code>getCloudflareMetrics()</code> so the page stays aligned with the real runtime payload.
      </p>
    </header>

    <section class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {statCards.map((card) => (
        <StatCard
          label={card.label}
          value={formatMetricValue[card.key](metrics[card.key])}
          help={card.help}
        />
      ))}
    </section>
  </section>
</AdminLayout>
