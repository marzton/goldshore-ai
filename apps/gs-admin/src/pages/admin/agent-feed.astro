---
import AdminLayout from '../../../../src/layouts/AdminLayout.astro';
import SecurityAudit from '../../components/SecurityAudit.astro';

const activeTasks = [
  { agent: 'Jules', task: 'Optimizing Cloudflare Routing', status: 'In-Progress', time: '2m ago', tone: 'jules' },
  { agent: 'Codex', task: 'Refactoring AdminSidebar.astro', status: 'Completed', time: '15m ago', tone: 'codex' },
  { agent: 'Jules', task: 'Security Audit: media.ts regex', status: 'Flagged', time: '1h ago', tone: 'alert' }
] as const;

const agentStyles = {
  jules: 'bg-blue-100 text-blue-600 dark:bg-blue-900/20 dark:text-blue-400',
  codex: 'bg-purple-100 text-purple-600 dark:bg-purple-900/20 dark:text-purple-400',
  alert: 'bg-red-100 text-red-600 dark:bg-red-900/20 dark:text-red-400'
} as const;

const statusStyles = {
  'In-Progress': 'bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300',
  Completed: 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300',
  Flagged: 'bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300'
} as const;
---

<AdminLayout title="Agent Feed | GoldShore Admin">
  <section class="max-w-6xl mx-auto py-10 px-6 space-y-8">
    <div class="flex justify-between items-center gap-4 flex-wrap">
      <div>
        <h1 class="text-3xl gs-heading">Live Agent Activity</h1>
        <p class="text-sm gs-text-subtle">Real-time monitoring of Goldshore autonomous units</p>
      </div>
      <div class="flex items-center px-3 py-1 bg-green-50 dark:bg-green-900/30 rounded-full">
        <span class="w-2 h-2 bg-green-500 rounded-full mr-2 animate-ping"></span>
        <span class="text-xs font-medium text-green-700 dark:text-green-400">Live Stream Active</span>
      </div>
    </div>

    <div class="space-y-4">
      {activeTasks.map((task) => (
        <div class="p-4 bg-white border border-slate-200 rounded-lg shadow-sm dark:bg-slate-800 dark:border-slate-700 flex justify-between items-center transition-all hover:border-blue-400 gap-3">
          <div class="flex items-center space-x-4 min-w-0">
            <div class={`w-10 h-10 rounded-full flex items-center justify-center font-bold ${agentStyles[task.tone]}`}>
              {task.agent[0]}
            </div>
            <div class="min-w-0">
              <p class="font-semibold text-slate-900 dark:text-white truncate">{task.task}</p>
              <p class="text-xs text-slate-500">{task.agent} Unit • {task.time}</p>
            </div>
          </div>
          <span class={`px-3 py-1 rounded-full text-xs font-medium ${statusStyles[task.status]}`}>
            {task.status}
          </span>
        </div>
      ))}
    </div>

    <SecurityAudit />

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-500 mb-3">Raw Logic Stream</h3>
      <div class="bg-slate-950 text-slate-300 p-5 rounded-xl font-mono text-xs h-96 overflow-y-auto border border-slate-800 shadow-2xl">
        <div class="space-y-1">
          <p class="text-slate-500">[{new Date().toISOString()}] System initialized.</p>
          <p><span class="text-blue-400">[Jules]</span> Accessing <span class="text-slate-100">goldshore-ai</span> monorepo context...</p>
          <p><span class="text-purple-400">[Codex]</span> Context match in <span class="text-yellow-200">AGENTS.md</span>. Validating path <span class="text-slate-100">/apps/gs-api</span>.</p>
          <p><span class="text-blue-400">[Jules]</span> Initializing VM for <span class="text-blue-300">pull request #3268</span>.</p>
          <p><span class="text-yellow-400">[System]</span> Syncing variables from <span class="text-slate-100">GS_ROUTING_API_BASE</span>...</p>
          <p><span class="text-green-400">[Success]</span> Build environment verified. Deploying to <span class="text-slate-100">admin.goldshore.ai</span>.</p>
          <p class="animate-pulse text-white mt-2">▋</p>
        </div>
      </div>
    </div>
  </section>
</AdminLayout>
