---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { Card } from '@goldshore/ui';
import SecurityAudit from '../../components/SecurityAudit.astro';

const activeTasks = [
  {
    id: 'TASK-934',
    agent: 'ops-router',
    stream: 'Customer intake',
    state: 'running',
    summary: 'Scoring newly submitted briefing forms for assignment.',
    startedAt: '2026-03-11T07:48:00.000Z'
  },
  {
    id: 'TASK-928',
    agent: 'ledger-auditor',
    stream: 'Monetization checks',
    state: 'review',
    summary: 'Reconciling ad partner attribution drift across regions.',
    startedAt: '2026-03-11T07:23:00.000Z'
  },
  {
    id: 'TASK-917',
    agent: 'infra-watch',
    stream: 'Worker reliability',
    state: 'running',
    summary: 'Monitoring cold start spikes and queue depth alerts.',
    startedAt: '2026-03-11T06:50:00.000Z'
  }
];

const securityAuditItems = [
  {
    id: 'AUD-342',
    title: 'Rotate stale service-token for media webhook pipeline',
    severity: 'critical',
    owner: 'security-bot',
    status: 'open',
    updatedAt: '2026-03-11T07:41:00.000Z'
  },
  {
    id: 'AUD-336',
    title: 'Restrict public metadata endpoint to admin IP range',
    severity: 'high',
    owner: 'gateway-policy',
    status: 'in-progress',
    updatedAt: '2026-03-11T07:15:00.000Z'
  },
  {
    id: 'AUD-330',
    title: 'Confirm origin-pull mTLS enforcement on fallback zone',
    severity: 'medium',
    owner: 'platform-team',
    status: 'mitigated',
    updatedAt: '2026-03-11T05:58:00.000Z'
  }
] as const;
---

<AdminLayout title="Agent Feed">
  <section class="gs-grid columns-2">
    <Card>
      <div class="section-title"><span>⚙️</span><h3>Active task stream</h3></div>
      <ul class="task-stream" aria-label="Current active tasks">
        {activeTasks.map((task) => (
          <li class="task-row">
            <div>
              <p class="task-title">{task.stream}</p>
              <p class="gs-helper">{task.summary}</p>
              <p class="gs-helper">{task.agent} · {task.id}</p>
            </div>
            <div class="task-meta">
              <span class={`gs-badge ${task.state === 'running' ? 'info' : 'warning'}`}>{task.state}</span>
              <time class="gs-helper" datetime={task.startedAt}>{new Date(task.startedAt).toLocaleTimeString()}</time>
            </div>
          </li>
        ))}
      </ul>
    </Card>

    <Card>
      <SecurityAudit items={securityAuditItems} />
    </Card>
  </section>
</AdminLayout>

<style>
  .task-stream {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }

  .task-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-radius: 0.7rem;
    border: 1px solid var(--gs-border, #2a2d38);
    padding: 0.75rem 0.9rem;
    background: color-mix(in oklab, var(--gs-surface, #111) 88%, white 12%);
  }

  .task-title {
    margin: 0;
    font-weight: 600;
  }

  .task-meta {
    display: grid;
    gap: 0.35rem;
    justify-items: end;
  }
</style>

const feedItems = [
  {
    id: 'evt-1',
    source: 'jules',
    summary: 'Policy drift detected in deployment workflow.',
    severity: 'flagged',
    status: 'open',
    timestamp: '2026-03-10T14:02:00Z',
  },
  {
    id: 'evt-2',
    source: 'codex',
    summary: 'Agent coordination latency recovered after retry.',
    severity: 'info',
    status: 'resolved',
    timestamp: '2026-03-10T13:44:00Z',
  },
  {
    id: 'evt-3',
    source: 'jules',
    summary: 'Manual review requested for elevated risk response.',
    severity: 'review',
    status: 'investigating',
    timestamp: '2026-03-10T13:22:00Z',
  },
];

const sourceStyles = {
  jules: 'bg-fuchsia-500/15 text-fuchsia-200 border border-fuchsia-400/40',
  codex: 'bg-cyan-500/15 text-cyan-200 border border-cyan-400/40',
};

const severityStyles = {
  flagged: 'bg-red-500/15 text-red-200 border border-red-400/40',
  review: 'bg-amber-500/15 text-amber-200 border border-amber-400/40',
  info: 'bg-emerald-500/15 text-emerald-200 border border-emerald-400/40',
};

const statusBadgeStyles = {
  open: 'bg-red-500/15 text-red-200 border border-red-400/40',
  investigating: 'bg-yellow-500/15 text-yellow-200 border border-yellow-400/40',
  resolved: 'bg-green-500/15 text-green-200 border border-green-400/40',
};
---

<AdminLayout title="Agent Feed | GoldShore Admin">
  <section class="max-w-6xl mx-auto py-12 px-6 space-y-6">
    <header>
      <h1 class="text-3xl gs-heading">Agent Feed</h1>
      <p class="text-[var(--gs-text-secondary)]">
        Recent activity from Jules and Codex across workflows.
      </p>
    </header>

    <div class="card overflow-hidden">
      <table class="min-w-full text-left text-sm">
        <thead
          class="border-b border-white/10 text-xs uppercase tracking-wide text-[var(--gs-text-tertiary)]"
        >
          <tr>
            <th class="px-4 py-3">Source</th>
            <th class="px-4 py-3">Summary</th>
            <th class="px-4 py-3">Severity</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Timestamp</th>
          </tr>
        </thead>
        <tbody>
          {
            feedItems.map((item) => (
              <tr class="border-b border-white/5">
                <td class="px-4 py-3">
                  <span
                    class={`inline-flex rounded-full px-2.5 py-1 text-xs font-medium ${sourceStyles[item.source]}`}
                  >
                    {item.source}
                  </span>
                </td>
                <td class="px-4 py-3 text-[var(--gs-text-primary)]">
                  {item.summary}
                </td>
                <td class="px-4 py-3">
                  <span
                    class={`inline-flex rounded-full px-2.5 py-1 text-xs font-medium ${severityStyles[item.severity]}`}
                  >
                    {item.severity}
                  </span>
                </td>
                <td class="px-4 py-3">
                  <span
                    class={`inline-flex rounded-full px-2.5 py-1 text-xs font-medium ${statusBadgeStyles[item.status]}`}
                  >
                    {item.status}
                  </span>
                </td>
                <td class="px-4 py-3 text-[var(--gs-text-secondary)]">
                  {new Date(item.timestamp).toLocaleString()}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>
</AdminLayout>
