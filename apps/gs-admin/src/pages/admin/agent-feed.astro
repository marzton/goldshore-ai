---
import AdminLayout from '../../layouts/AdminLayout.astro';

const colorClasses = {
  blue: 'bg-blue-100 text-blue-600 dark:bg-blue-900/20 dark:text-blue-400',
  purple: 'bg-purple-100 text-purple-600 dark:bg-purple-900/20 dark:text-purple-400',
  red: 'bg-red-100 text-red-600 dark:bg-red-900/20 dark:text-red-400'
} as const;

const statusClasses = {
  'In-Progress': 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300',
  Completed: 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300',
  Flagged: 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300'
} as const;

const activeTasks = [
  {
    agent: 'Jules',
    task: 'Optimizing Cloudflare Routing',
    status: 'In-Progress',
    time: '2m ago',
    color: 'blue'
  },
  {
    agent: 'Codex',
    task: 'Refactoring AdminSidebar.astro',
    status: 'Completed',
    time: '15m ago',
    color: 'purple'
  },
  {
    agent: 'Jules',
    task: 'Security Audit: media.ts regex',
    status: 'Flagged',
    time: '1h ago',
    color: 'red'
  }
] as const;
---

<AdminLayout title="Agent Feed">
  <div class="space-y-4">
    {activeTasks.map((task) => (
      <div class="flex items-center justify-between rounded-lg border border-slate-200 bg-white p-4 shadow-sm transition-all hover:border-blue-400 dark:border-slate-700 dark:bg-slate-800">
        <div class="flex items-center space-x-4">
          <div
            class={`flex h-10 w-10 items-center justify-center rounded-full font-bold ${colorClasses[task.color] ?? colorClasses.blue}`}
          >
            {task.agent[0]}
          </div>
          <div>
            <p class="font-semibold text-slate-900 dark:text-white">{task.task}</p>
            <p class="text-xs text-slate-500">{task.agent} Unit • {task.time}</p>
          </div>
        </div>
        <span
          class={`rounded-full px-3 py-1 text-xs font-medium ${statusClasses[task.status] ?? 'bg-slate-100 text-slate-700 dark:bg-slate-700 dark:text-slate-200'}`}
        >
          {task.status}
        </span>
      </div>
    ))}
  </div>
</AdminLayout>
