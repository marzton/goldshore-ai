---
import AdminLayout from '../../layouts/AdminLayout.astro';

type AgentColor = 'blue' | 'purple' | 'red';
type AgentStatus = 'In-Progress' | 'Completed' | 'Flagged';

type ActiveTask = {
  agent: string;
  task: string;
  status: AgentStatus;
  updatedAtLabel: string;
  color: AgentColor;
};

const colorClasses: Record<AgentColor, string> = {
  blue: 'bg-blue-100 text-blue-600 dark:bg-blue-900/20 dark:text-blue-400',
  purple: 'bg-purple-100 text-purple-600 dark:bg-purple-900/20 dark:text-purple-400',
  red: 'bg-red-100 text-red-600 dark:bg-red-900/20 dark:text-red-400'
};

const statusClasses: Record<AgentStatus, string> = {
  'In-Progress': 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300',
  Completed: 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300',
  Flagged: 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300'
};

const fallbackAvatarClass = 'bg-slate-100 text-slate-700 dark:bg-slate-700 dark:text-slate-200';
const fallbackStatusClass = 'bg-slate-100 text-slate-700 dark:bg-slate-700 dark:text-slate-200';

const activeTasks: ActiveTask[] = [
  {
    agent: 'Jules',
    task: 'Optimizing Cloudflare Routing',
    status: 'In-Progress',
    updatedAtLabel: '2m ago',
    color: 'blue'
  },
  {
    agent: 'Codex',
    task: 'Refactoring AdminSidebar.astro',
    status: 'Completed',
    updatedAtLabel: '15m ago',
    color: 'purple'
  },
  {
    agent: 'Jules',
    task: 'Security Audit: media.ts regex',
    status: 'Flagged',
    updatedAtLabel: '1h ago',
    color: 'red'
  }
];

const getAvatarClass = (color: string) => colorClasses[color as AgentColor] ?? fallbackAvatarClass;
const getStatusClass = (status: string) => statusClasses[status as AgentStatus] ?? fallbackStatusClass;
const getAgentInitial = (agent: string) => (agent?.trim().charAt(0) || '?').toUpperCase();
---

<AdminLayout title="Agent Feed">
  <section class="space-y-4" aria-labelledby="agent-feed-heading">
    <header class="space-y-1">
      <h1 id="agent-feed-heading" class="text-xl font-semibold text-slate-900 dark:text-white">Agent Feed</h1>
      <p class="text-sm text-slate-600 dark:text-slate-300">
        Live operational tasks with color-coded priority and status indicators.
      </p>
    </header>

    <ul class="space-y-4" role="list">
      {activeTasks.map((task) => (
        <li class="flex items-center justify-between rounded-lg border border-slate-200 bg-white p-4 shadow-sm transition-all hover:border-blue-400 dark:border-slate-700 dark:bg-slate-800">
          <div class="flex items-center space-x-4">
            <div
              class={`flex h-10 w-10 items-center justify-center rounded-full font-bold ${getAvatarClass(task.color)}`}
              aria-label={`Agent ${task.agent}`}
            >
              {getAgentInitial(task.agent)}
            </div>
            <div>
              <p class="font-semibold text-slate-900 dark:text-white">{task.task}</p>
              <p class="text-xs text-slate-500 dark:text-slate-400">{task.agent} Unit • {task.updatedAtLabel}</p>
            </div>
          </div>
          <span class={`rounded-full px-3 py-1 text-xs font-medium ${getStatusClass(task.status)}`}>
            {task.status}
          </span>
        </li>
      ))}
    </ul>
  </section>
</AdminLayout>
