---
import SecurityAudit from '../../components/SecurityAudit.astro';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { Card } from '@goldshore/ui';
import SecurityAudit from '../../components/SecurityAudit.astro';

const activeTasks = [
  {
    id: 'TASK-934',
    agent: 'ops-router',
    stream: 'Customer intake',
    state: 'running',
    summary: 'Scoring newly submitted briefing forms for assignment.',
    startedAt: '2026-03-11T07:48:00.000Z'
  },
  {
    id: 'TASK-928',
    agent: 'ledger-auditor',
    stream: 'Monetization checks',
    state: 'review',
    summary: 'Reconciling ad partner attribution drift across regions.',
    startedAt: '2026-03-11T07:23:00.000Z'
  },
  {
    id: 'TASK-917',
    agent: 'infra-watch',
    stream: 'Worker reliability',
    state: 'running',
    summary: 'Monitoring cold start spikes and queue depth alerts.',
    startedAt: '2026-03-11T06:50:00.000Z'
  }
];

const securityAuditItems = [
  {
    id: 'AUD-342',
    title: 'Rotate stale service-token for media webhook pipeline',
    severity: 'critical',
    owner: 'security-bot',
    status: 'open',
    updatedAt: '2026-03-11T07:41:00.000Z'
  },
  {
    id: 'AUD-336',
    title: 'Restrict public metadata endpoint to admin IP range',
    severity: 'high',
    owner: 'gateway-policy',
    status: 'in-progress',
    updatedAt: '2026-03-11T07:15:00.000Z'
  },
  {
    id: 'AUD-330',
    title: 'Confirm origin-pull mTLS enforcement on fallback zone',
    severity: 'medium',
    owner: 'platform-team',
    status: 'mitigated',
    updatedAt: '2026-03-11T05:58:00.000Z'
  }
] as const;
---

<AdminLayout title="Agent Feed">
  <section class="gs-grid columns-2">
    <Card>
      <div class="section-title"><span>⚙️</span><h3>Active task stream</h3></div>
      <ul class="task-stream" aria-label="Current active tasks">
        {activeTasks.map((task) => (
          <li class="task-row">
            <div>
              <p class="task-title">{task.stream}</p>
              <p class="gs-helper">{task.summary}</p>
              <p class="gs-helper">{task.agent} · {task.id}</p>
            </div>
            <div class="task-meta">
              <span class={`gs-badge ${task.state === 'running' ? 'info' : 'warning'}`}>{task.state}</span>
              <time class="gs-helper" datetime={task.startedAt}>{new Date(task.startedAt).toLocaleTimeString()}</time>
            </div>
          </li>
        ))}
      </ul>
    </Card>

    <Card>
      <SecurityAudit items={securityAuditItems} />
    </Card>
  </section>
</AdminLayout>

<style>
  .task-stream {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.75rem;
  }

  .task-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-radius: 0.7rem;
    border: 1px solid var(--gs-border, #2a2d38);
    padding: 0.75rem 0.9rem;
    background: color-mix(in oklab, var(--gs-surface, #111) 88%, white 12%);
  }

  .task-title {
    margin: 0;
    font-weight: 600;
  }

  .task-meta {
    display: grid;
    gap: 0.35rem;
    justify-items: end;
  }
</style>

const activeTasks = [
  {
    agent: 'Jules',
    task: 'Optimizing Cloudflare Routing',
    status: 'In-Progress',
    time: '2m ago',
    color: 'blue'
  },
  {
    agent: 'Codex',
    task: 'Refactoring Sidebar.astro',
    status: 'Completed',
    time: '15m ago',
    color: 'purple'
  },
  {
    agent: 'Jules',
    task: 'Security Audit: media.ts regex',
    status: 'Flagged',
    time: '1h ago',
    color: 'red'
  }
] as const;

const colorClasses = {
  blue: 'bg-blue-100 text-blue-600 dark:bg-blue-900/20 dark:text-blue-400',
  purple: 'bg-purple-100 text-purple-600 dark:bg-purple-900/20 dark:text-purple-400',
  red: 'bg-red-100 text-red-600 dark:bg-red-900/20 dark:text-red-400'
} as const;
---

<AdminLayout title="Agent Feed">
  <div class="mb-6 flex justify-between items-center">
    <div>
      <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Live Agent Activity</h1>
      <p class="text-sm text-slate-500">Real-time monitoring of Goldshore autonomous units</p>
    </div>
    <div class="flex items-center px-3 py-1 bg-green-50 dark:bg-green-900/30 rounded-full">
      <span class="w-2 h-2 bg-green-500 rounded-full mr-2 animate-ping"></span>
      <span class="text-xs font-medium text-green-700 dark:text-green-400">Live Stream Active</span>
    </div>
  </div>

  <div class="space-y-4">
    {activeTasks.map((task) => (
      <div class="p-4 bg-white border border-slate-200 rounded-lg shadow-sm dark:bg-slate-800 dark:border-slate-700 flex justify-between items-center transition-all hover:border-blue-400">
        <div class="flex items-center space-x-4">
          <div
            class={`w-10 h-10 rounded-full flex items-center justify-center font-bold ${colorClasses[task.color]}`}
          >
            {task.agent[0]}
          </div>
          <div>
            <p class="font-semibold text-slate-900 dark:text-white">{task.task}</p>
            <p class="text-xs text-slate-500">{task.agent} Unit • {task.time}</p>
          </div>
        </div>
        <span
          class={`px-3 py-1 rounded-full text-xs font-medium ${
            task.status === 'Completed'
              ? 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300'
              : task.status === 'Flagged'
                ? 'bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300'
                : 'bg-blue-100 text-blue-800 dark:bg-blue-900/40 dark:text-blue-300'
          }`}
        >
          {task.status}
        </span>
      </div>
    ))}
  </div>

  <div class="mt-8">
    <SecurityAudit />
  </div>

  <div class="mt-8">
    <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-500 mb-3 flex items-center">
      <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
        ></path>
      </svg>
      Raw Logic Stream
    </h3>
    <div class="bg-slate-950 text-slate-300 p-5 rounded-xl font-mono text-xs h-96 overflow-y-auto border border-slate-800 shadow-2xl">
      <div class="space-y-1">
        <p class="text-slate-500">[<span id="logic-timestamp">{new Date().toISOString()}</span>] System initialized.</p>
        <p><span class="text-blue-400">[Jules]</span> Accessing <span class="text-slate-100">goldshore-ai</span> monorepo context...</p>
        <p><span class="text-purple-400">[Codex]</span> Context match in <span class="text-yellow-200">AGENTS.md</span>. Validating path <span class="text-slate-100">/apps/gs-api</span>.</p>
        <p><span class="text-blue-400">[Jules]</span> Initializing VM for <span class="text-blue-300">pull request #3268</span>.</p>
        <p><span class="text-yellow-400">[System]</span> Syncing variables from <span class="text-slate-100">GS_ROUTING_API_BASE</span>...</p>
        <p><span class="text-green-400">[Success]</span> Build environment verified. Deploying to <span class="text-slate-100">admin.goldshore.ai</span>.</p>
        <p class="animate-pulse text-white mt-2">▋</p>
      </div>
    </div>
  </div>

  <script is:inline>
    const timestampNode = document.getElementById('logic-timestamp');

    const updateTimestamp = () => {
      if (timestampNode) {
        timestampNode.textContent = new Date().toISOString();
      }
    };

    updateTimestamp();
    setInterval(updateTimestamp, 1000);
  </script>
</AdminLayout>
