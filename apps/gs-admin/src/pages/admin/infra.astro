---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { Card } from '@goldshore/ui';
import { getDeploymentGuardState } from '../../lib/deployment-guard';

const guard = getDeploymentGuardState();

const workerBindings = [
  { name: 'GS_ROUTING_API_BASE', type: 'Environment Variable', value: 'api.goldshore.ai', status: 'Bound' },
  { name: 'CF_API_TOKEN', type: 'Secret', value: '••••••••', status: 'Secure' },
  { name: 'GS_CONFIG_KV', type: 'KV Namespace', value: 'goldshore_prod_kv', status: 'Active' },
  { name: 'GS_D1_DB', type: 'D1 Database', value: 'goldshore_core_db', status: 'Active' }
];
---

<AdminLayout title="Infrastructure">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Worker Bindings</h1>
    <p class="text-sm text-slate-500 dark:text-slate-400">Manage Cloudflare resources for goldshore-gateway.</p>
  </div>

  <div class="relative overflow-x-auto rounded-lg border border-slate-200 shadow-md dark:border-slate-700">
    <table class="w-full text-left text-sm text-slate-500 dark:text-slate-400">
      <thead class="bg-slate-50 text-xs uppercase text-slate-700 dark:bg-slate-700 dark:text-slate-400">
        <tr>
          <th scope="col" class="px-6 py-3">Binding Name</th>
          <th scope="col" class="px-6 py-3">Type</th>
          <th scope="col" class="px-6 py-3">Value</th>
          <th scope="col" class="px-6 py-3">Status</th>
          <th scope="col" class="px-6 py-3 text-right">Action</th>
        </tr>
      </thead>
      <tbody>
        {
          workerBindings.map((binding) => (
            <tr class="border-b bg-white hover:bg-slate-50 dark:border-slate-700 dark:bg-slate-800 dark:hover:bg-slate-600">
              <th scope="row" class="whitespace-nowrap px-6 py-4 font-mono font-medium text-slate-900 dark:text-white">
                {binding.name}
              </th>
              <td class="px-6 py-4">{binding.type}</td>
              <td class="px-6 py-4 font-mono text-xs">{binding.value}</td>
              <td class="px-6 py-4">
                <span class="flex items-center">
                  <span class="mr-2 h-2.5 w-2.5 rounded-full bg-green-500"></span>
                  {binding.status}
                </span>
              </td>
              <td class="px-6 py-4 text-right">
                <button type="button" class="font-medium text-blue-600 hover:underline dark:text-blue-500">Edit</button>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2">
    <Card>
      <h3 class="mb-4 text-lg font-bold">Deployment Sync</h3>
      <p class="mb-4 text-sm text-slate-500 dark:text-slate-300">
        Last successful deploy to <span class="font-mono">gateway.goldshore.ai</span> was 4h ago.
      </p>
      <button
        type="button"
        class={`rounded-lg px-5 py-2.5 text-sm font-medium text-white ${guard.isLocked ? 'cursor-not-allowed bg-slate-500 opacity-70' : 'bg-blue-700 hover:bg-blue-800'}`}
        disabled={guard.isLocked}
        aria-disabled={guard.isLocked ? 'true' : 'false'}
        title={guard.reason}
      >
        {guard.isLocked ? 'Build Locked by Security Guard' : 'Trigger Production Build'}
      </button>
      <p class={`mt-3 text-xs ${guard.isLocked ? 'text-red-600 dark:text-red-400' : 'text-emerald-600 dark:text-emerald-400'}`}>
        {guard.reason}
      </p>
      {
        guard.generatedAt ? (
          <p class="mt-1 text-xs text-slate-500 dark:text-slate-300">
            Last audit snapshot: <span class="font-mono">{guard.generatedAt}</span>
          </p>
        ) : null
      }
    </Card>

    <div class="rounded-xl border border-slate-700 bg-slate-900 p-6">
      <h3 class="mb-2 text-xs font-bold uppercase tracking-widest text-white">Wrangler Preview</h3>
      <pre class="overflow-x-auto font-mono text-xs text-green-400">[vars]
GS_ROUTING_API_BASE = "https://api.goldshore.ai"

[[kv_namespaces]]
binding = "GS_CONFIG_KV"
id = "goldshore_prod_kv"

[[d1_databases]]
binding = "GS_D1_DB"
database_name = "goldshore_core_db"</pre>
    </div>
  </div>
</AdminLayout>
