---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { Card, GSButton } from '@goldshore/ui';

const infrastructureReferences = {
  domains: [
    'goldshore.ai → gs-web (Cloudflare Pages)',
    'admin.goldshore.ai → gs-admin',
    'api.goldshore.ai → gs-api',
    'gw.goldshore.ai → gs-gateway',
    'ops.goldshore.ai → gs-control',
    'Mail routing → gs-mail worker'
  ],
  access: [
    'Admin access is enforced through Cloudflare Access and OTP.',
    'Worker-to-worker calls validate the Access JWT audience.',
    'Tenant-specific policy segmentation is still planned.'
  ],
  emailRouting: [
    'noreply@goldshore.ai → archive / log only',
    'ops@goldshore.ai → primary admin inbox',
    'support@goldshore.ai → unified support inbox',
    'Catch-all routed through classification worker'
  ]
};
---
<AdminLayout title="Settings">
  <section class="gs-page-header">
    <h2 class="gs-heading">Settings</h2>
    <p class="gs-helper">
      Local UI preferences can be changed here. Operational configuration is managed through protected
      infrastructure pages and is shown below as reference-only context.
    </p>
  </section>

  <section class="gs-grid columns-2 gs-mt-6">
    <Card>
      <div class="section-title"><span>🎨</span><h3>Local UI preferences</h3></div>
      <p class="gs-helper">
        These controls are stored locally in your browser profile and apply instantly across admin pages.
      </p>
      <form id="theme-form" class="gs-form-row">
        <div class="gs-input-group">
          <label for="mode">Theme mode</label>
          <select id="mode" name="mode">
            <option value="dark">Dark</option>
            <option value="light">Light</option>
            <option value="slate">Slate</option>
          </select>
        </div>
        <div class="gs-input-group">
          <label for="density">Density</label>
          <select id="density" name="density">
            <option value="comfortable">Comfortable</option>
            <option value="compact">Compact</option>
          </select>
        </div>
        <div class="gs-input-group">
          <label for="accent">Accent</label>
          <select id="accent" name="accent">
            <option value="blue">Blue</option>
            <option value="gold">Gold</option>
            <option value="cyan">Cyan</option>
            <option value="violet">Violet</option>
          </select>
        </div>
      </form>
      <div class="gs-helper">Changes persist locally and apply instantly across admin pages.</div>
      <div class="gs-form-actions">
        <GSButton id="reset-theme" type="button" variant="secondary" class="gs-button--small">Reset to defaults</GSButton>
      </div>
    </Card>

    <Card>
      <div class="section-title"><span>🧭</span><h3>Operational configuration</h3></div>
      <p class="gs-helper">
        Domain, Access, and routing changes are not editable from this page unless a backend-managed save flow exists.
      </p>
      <div class="gs-pill-list gs-mt-4">
        <span class="gs-badge info">Reference only</span>
        <span class="gs-badge">Backend-managed elsewhere</span>
      </div>
      <div class="gs-form-actions gs-mt-4">
        <GSButton href="/admin/system" variant="primary">Open infrastructure overview</GSButton>
        <GSButton href="/admin/overview" variant="secondary">Open operational overview</GSButton>
      </div>
    </Card>
  </section>

  <section class="gs-mt-6 operational-reference">
    <div class="section-title"><span>🔒</span><h3>Infrastructure reference data</h3></div>
    <p class="gs-helper">
      The following sections summarize current operational mappings for quick review. They are read-only on this page.
    </p>

    <div class="gs-grid columns-3 gs-mt-4">
      <Card>
        <div class="section-title"><span>🌐</span><h3>Domains</h3></div>
        <p class="gs-helper">Read-only routing summary. Use the infrastructure overview for managed DNS workflows.</p>
        <ul>
          {infrastructureReferences.domains.map((domain) => (
            <li>{domain}</li>
          ))}
        </ul>
      </Card>

      <Card>
        <div class="section-title"><span>🛡</span><h3>Access</h3></div>
        <p class="gs-helper">Read-only policy summary. Cloudflare Access checks and policy tools live in infrastructure pages.</p>
        <ul>
          {infrastructureReferences.access.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </Card>

      <Card>
        <div class="section-title"><span>✉</span><h3>Email routing</h3></div>
        <p class="gs-helper">Read-only mailbox map. Delivery and worker routing are managed outside this settings page.</p>
        <ul>
          {infrastructureReferences.emailRouting.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </Card>
    </div>
  </section>
</AdminLayout>

<script type="module">
  import { loadThemeSettings, setTheme } from '@goldshore/theme/manager';

  const form = document.getElementById('theme-form');
  const reset = document.getElementById('reset-theme');
  const settings = loadThemeSettings();

  if (form) {
    form.mode.value = settings.mode;
    form.density.value = settings.density;
    form.accent.value = settings.accent;

    form.addEventListener('change', () => {
      const mode = form.mode.value;
      const density = form.density.value;
      const accent = form.accent.value;
      setTheme({ mode, density, accent });
    });
  }

  reset?.addEventListener('click', () => {
    setTheme({ mode: 'dark', density: 'comfortable', accent: 'blue' });
    if (form) {
      form.mode.value = 'dark';
      form.density.value = 'comfortable';
      form.accent.value = 'blue';
    }
  });
</script>

<style>
  .gs-page-header {
    display: grid;
    gap: 0.5rem;
  }

  .operational-reference {
    display: grid;
    gap: 0.75rem;
  }
</style>
