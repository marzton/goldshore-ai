---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { Card, GSButton } from '@goldshore/ui';

const domains = [
  'goldshore.ai → gs-web (Cloudflare Pages)',
  'admin.goldshore.ai → gs-admin',
  'api.goldshore.ai → gs-api',
  'gw.goldshore.ai → gs-gateway',
  'ops.goldshore.ai → gs-control',
  'Mail routing → gs-mail worker'
];
---
<AdminLayout title="Settings">
  <section class="gs-grid columns-2">
    <Card>
      <div class="section-title"><span>🌐</span><h3>Domain & DNS</h3></div>
      <ul>
        {domains.map((domain) => (
          <li>{domain}</li>
        ))}
      </ul>
    </Card>
    <Card>
      <div class="section-title"><span>🛡</span><h3>Access & Identity</h3></div>
      <p class="gs-helper">Cloudflare Access policies for admin, workers, and developer endpoints.</p>
      <ul>
        <li>Admin locked behind Access and OTP.</li>
        <li>Workers restricted with Access JWT audience.</li>
        <li>Per-client tenants planned.</li>
      </ul>
    </Card>
  </section>

  <section class="gs-grid columns-2 gs-mt-6">
    <Card>
      <div class="section-title"><span>🎨</span><h3>Theme</h3></div>
      <form id="theme-form" class="gs-form-row">
        <div class="gs-input-group">
          <label for="mode">Mode</label>
          <select id="mode" name="mode">
            <option value="dark">Dark</option>
            <option value="light">Light</option>
            <option value="slate">Slate</option>
          </select>
        </div>
        <div class="gs-input-group">
          <label for="density">Density</label>
          <select id="density" name="density">
            <option value="comfortable">Comfortable</option>
            <option value="compact">Compact</option>
          </select>
        </div>
        <div class="gs-input-group">
          <label for="accent">Accent</label>
          <select id="accent" name="accent">
            <option value="blue">Blue</option>
            <option value="gold">Gold</option>
            <option value="cyan">Cyan</option>
            <option value="violet">Violet</option>
          </select>
        </div>
      </form>
      <div class="gs-helper">Changes persist locally and apply instantly across admin pages.</div>
      <div class="gs-form-actions">
        <GSButton id="reset-theme" type="button" variant="secondary" class="gs-button--small">Reset to defaults</GSButton>
      </div>
    </Card>

    <Card>
      <div class="section-title"><span>✉</span><h3>Email Routing</h3></div>
      <ul>
        <li>noreply@goldshore.ai → archive / log only</li>
        <li>ops@goldshore.ai → primary admin inbox</li>
        <li>support@goldshore.ai → unified support inbox</li>
        <li>Catch-all routed through classification worker</li>
      </ul>
    </Card>
  </section>
</AdminLayout>

<script type="module">
  const form = document.getElementById('theme-form');
  const reset = document.getElementById('reset-theme');
  const key = 'gs-admin-theme-settings';

  const defaults = { mode: 'dark', density: 'comfortable', accent: 'blue' };

  const loadThemeSettings = () => {
    try {
      const raw = localStorage.getItem(key);
      return raw ? { ...defaults, ...JSON.parse(raw) } : defaults;
    } catch {
      return defaults;
    }
  };

  const applyTheme = (settings) => {
    document.documentElement.dataset.themeMode = settings.mode;
    document.documentElement.dataset.themeDensity = settings.density;
    document.documentElement.dataset.themeAccent = settings.accent;
    localStorage.setItem(key, JSON.stringify(settings));
  };

  const settings = loadThemeSettings();

  if (form) {
    form.mode.value = settings.mode;
    form.density.value = settings.density;
    form.accent.value = settings.accent;

    form.addEventListener('change', () => {
      applyTheme({
        mode: form.mode.value,
        density: form.density.value,
        accent: form.accent.value
      });
    });
  }

  applyTheme(settings);

  reset?.addEventListener('click', () => {
    applyTheme(defaults);
    if (form) {
      form.mode.value = defaults.mode;
      form.density.value = defaults.density;
      form.accent.value = defaults.accent;
    }
  });
</script>
