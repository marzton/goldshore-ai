---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { Card } from '@goldshore/ui';
import AdminLogPanel from '../../components/AdminLogPanel.astro';

type AuditEvent = {
  timestamp: string;
  action: string;
  actor?: string;
  status: string;
};

const API_BASE = import.meta.env.PUBLIC_API;
const accessToken = Astro.request.headers.get('CF-Access-Jwt-Assertion');

let logs: AuditEvent[] = [
  { timestamp: '2024-05-12T10:40:12Z', action: 'admin.login', actor: 'gs-api', status: 'success' },
  { timestamp: '2024-05-12T10:35:02Z', action: 'admin.rate-limit', actor: 'gs-gateway', status: 'warning' },
  { timestamp: '2024-05-12T10:15:22Z', action: 'admin.gateway.latency', actor: 'gs-gateway', status: 'error' }
];
let loadError: string | null = null;

if (API_BASE && accessToken) {
  try {
    const response = await fetch(`${API_BASE}/admin/audit`, {
      headers: {
        'CF-Access-Jwt-Assertion': accessToken
      }
    });
    if (response.ok) {
      logs = (await response.json()) as AuditEvent[];
    } else {
      loadError = `Failed to load audit logs (${response.status}).`;
    }
  } catch (error) {
    loadError = 'Unable to reach the admin audit endpoint.';
  }
}

const apiLogs = logs.filter((log) => (log.actor ?? '').includes('api'));
const gatewayLogs = logs.filter((log) => (log.actor ?? '').includes('gateway'));
---
<AdminLayout title="Logs" requiredPermission="audit:read">
  <section class="gs-grid columns-2">
    <Card>
      <div class="section-title"><span>☰</span><h3>Filters</h3></div>
      <p class="gs-helper">Use refresh controls in each worker panel below.</p>
    </Card>

    <AdminLogPanel workerName="gs-api" logs={apiLogs} loadError={loadError} />
    <AdminLogPanel workerName="gs-gateway" logs={gatewayLogs} loadError={loadError} />
  </section>
</AdminLayout>
