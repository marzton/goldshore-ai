---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { Card, Table } from '@goldshore/ui';

type AuditEvent = {
  timestamp: string;
  action: string;
  actor?: string;
  status: string;
};

const API_BASE = import.meta.env.PUBLIC_API;
const accessToken = Astro.request.headers.get('CF-Access-Jwt-Assertion');

let logs: AuditEvent[] = [
  { timestamp: '2024-05-12T10:40:12Z', action: 'admin.login', actor: 'okta-session', status: 'success' },
  { timestamp: '2024-05-12T10:35:02Z', action: 'admin.rate-limit', actor: 'gateway', status: 'warning' },
  { timestamp: '2024-05-12T10:15:22Z', action: 'admin.gateway.latency', actor: 'gw-us-east', status: 'error' }
];
let loadError: string | null = null;

if (API_BASE && accessToken) {
  try {
    const response = await fetch(`${API_BASE}/admin/audit`, {
      headers: {
        'CF-Access-Jwt-Assertion': accessToken
      }
    });
    if (response.ok) {
      logs = (await response.json()) as AuditEvent[];
    } else {
      loadError = `Failed to load audit logs (${response.status}).`;
    }
  } catch {
    loadError = 'Unable to reach the admin audit endpoint.';
  }
}
---
<AdminLayout title="Logs" requiredPermission="audit:read">
  <section class="gs-grid columns-2">
    <Card>
      <div class="section-title"><span>☰</span><h3>Filters</h3></div>
      <div class="gs-form-row">
        <div class="gs-input-group">
          <label for="level">Level</label>
          <select id="level" name="level">
            <option>All</option>
            <option>Info</option>
            <option>Warning</option>
            <option>Error</option>
          </select>
        </div>
        <div class="gs-input-group">
          <label for="range">Range</label>
          <select id="range" name="range">
            <option>Last hour</option>
            <option>Last 24h</option>
            <option>Last 7d</option>
          </select>
        </div>
      </div>
      <p class="gs-helper">Filters are illustrative and wired to the shared theme for spacing and focus states.</p>
    </Card>

    <Card class="gs-table-card">
      {loadError ? <p class="text-[var(--gs-danger)] mb-4">{loadError}</p> : null}
      <div class="section-title"><span>◎</span><h3>Recent events</h3></div>
      <Table>
        <thead><tr><th>Timestamp</th><th>Level</th><th>Message</th></tr></thead>
        <tbody>
          {logs.map((log) => (
            <tr>
              <td>{new Date(log.timestamp).toLocaleString()}</td>
              <td><span class={`gs-badge ${log.status === 'error' ? 'danger' : log.status === 'warning' ? 'warning' : 'info'}`}>{log.status}</span></td>
              <td>{log.action} {log.actor ? `· ${log.actor}` : ''}</td>
            </tr>
          ))}
        </tbody>
      </Table>
    </Card>
  </section>
</AdminLayout>
