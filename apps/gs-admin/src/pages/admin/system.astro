---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { GSButton } from '@goldshore/ui';
import InboxTable from '../../components/InboxTable.astro';

const linkedPages = [
  {
    href: '/admin/system',
    title: 'System Configuration',
    status: 'implemented and backed by live data',
    detail: 'Live Cloudflare controls routed through adminService for DNS, Workers, Pages, KV, R2, D1, and Access reads.'
  },
  {
    href: '/admin/workers',
    title: 'Workers Overview',
    status: 'placeholder/incomplete',
    detail: 'Overview page now directs operators to the live status screen and labels unfinished sections as roadmap-only.'
  },
  {
    href: '/admin/workers/status',
    title: 'Worker Status',
    status: 'implemented and backed by live data',
    detail: 'Backed by /api/gs-api/dns-sync-status and renders current sync telemetry.'
  },
  {
    href: '/admin/settings',
    title: 'Settings',
    status: 'intentionally read-only informational',
    detail: 'Infrastructure, access, and email sections are reference-only; theme controls affect local admin UI preferences only.'
  },
  {
    href: '/admin/system/dns',
    title: 'System DNS',
    status: 'placeholder/incomplete',
    detail: 'Roadmap-only route; operators should use the live controls on this System Configuration page instead.'
  },
  {
    href: '/admin/system/pages',
    title: 'System Pages',
    status: 'placeholder/incomplete',
    detail: 'Roadmap-only route; operators should use the live Pages Projects panel on this page instead.'
  },
  {
    href: '/admin/system/secrets',
    title: 'System Secrets',
    status: 'placeholder/incomplete',
    detail: 'Roadmap-only route with no live secret controls yet.'
  },
  {
    href: '/admin/system/storage',
    title: 'System Storage',
    status: 'placeholder/incomplete',
    detail: 'Roadmap-only route; operators should use the live KV, R2, and D1 panels on this page instead.'
  },
  {
    href: '/admin/workers/bindings',
    title: 'Worker Bindings',
    status: 'placeholder/incomplete',
    detail: 'Roadmap-only route with no live bindings inventory or edit controls yet.'
  },
  {
    href: '/admin/workers/routes',
    title: 'Worker Routes',
    status: 'placeholder/incomplete',
    detail: 'Roadmap-only route with no live route management controls yet.'
  }
];
---
<AdminLayout title="System | GoldShore Admin" requiredRole="admin">
    <section class="max-w-6xl mx-auto py-16 px-6 space-y-10">
        <header class="space-y-3">
            <h1 class="text-3xl gs-heading">System Configuration</h1>
            <p class="text-[var(--gs-text-secondary)]">
                Review Cloudflare infrastructure data and trigger controlled updates from the admin console.
            </p>
            <p class="text-sm gs-text-subtle">
                Cloudflare API credentials are stored as worker secrets and never exposed to the browser. All requests
                flow through the secured control worker.
            </p>
        </header>

        <div class="grid gap-6 lg:grid-cols-2">
            <InboxTable />
            <div class="gs-card space-y-4 lg:col-span-2">
                <div>
                    <h2 class="text-xl font-semibold">Managed Resources</h2>
                    <p class="text-sm gs-text-subtle">Cloudflare resources managed via the ops control worker.</p>
                </div>
                <div class="flex flex-wrap gap-2 text-sm">
                    <span class="gs-pill">Pages</span>
                    <span class="gs-pill">Workers</span>
                    <span class="gs-pill">KV</span>
                    <span class="gs-pill">R2</span>
                    <span class="gs-pill">D1</span>
                    <span class="gs-pill">DNS</span>
                </div>
            </div>

            <div class="gs-card space-y-4 lg:col-span-2">
                <div>
                    <h2 class="text-xl font-semibold">Linked Page Inventory</h2>
                    <p class="text-sm gs-text-subtle">
                        Classification for related settings and system routes so operators can distinguish live tools from roadmap-only pages.
                    </p>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr class="text-sm gs-text-subtle border-b border-[var(--gs-color-border)]">
                                <th class="py-2 pr-4">Page</th>
                                <th class="py-2 pr-4">Classification</th>
                                <th class="py-2">Operator Note</th>
                            </tr>
                        </thead>
                        <tbody>
                            {linkedPages.map((page) => (
                                <tr class="border-b border-[var(--gs-color-border)]/50">
                                    <td class="py-3 pr-4 align-top">
                                        <a class="font-medium underline underline-offset-4" href={page.href}>{page.title}</a>
                                        <div class="text-xs gs-text-subtle">{page.href}</div>
                                    </td>
                                    <td class="py-3 pr-4 align-top">
                                        <span class="gs-pill">{page.status}</span>
                                    </td>
                                    <td class="py-3 text-sm gs-text-subtle">{page.detail}</td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="gs-card space-y-4">
                <div>
                    <h2 class="text-xl font-semibold">DNS Records</h2>
                    <p class="text-sm gs-text-subtle">List Cloudflare DNS records for the primary zone.</p>
                </div>
                <GSButton variant="secondary" id="dns-list">Fetch DNS Records</GSButton>
                <textarea id="dns-output" class="w-full min-h-[180px] gs-input" readonly></textarea>
            </div>

            <div class="gs-card space-y-4">
                <div>
                    <h2 class="text-xl font-semibold">Update DNS Record</h2>
                    <p class="text-sm gs-text-subtle">Submit a targeted DNS record update.</p>
                </div>
                <div class="grid gap-3">
                    <input id="dns-record-id" class="gs-input" placeholder="DNS Record ID" />
                    <input id="dns-record-content" class="gs-input" placeholder="New content (e.g. 192.0.2.10)" />
                    <GSButton variant="primary" id="dns-update">Update Record</GSButton>
                </div>
                <textarea id="dns-update-output" class="w-full min-h-[140px] gs-input" readonly></textarea>
            </div>

            <div class="gs-card space-y-4">
                <div>
                    <h2 class="text-xl font-semibold">Workers Status</h2>
                    <p class="text-sm gs-text-subtle">Inspect Cloudflare Workers services in the account.</p>
                </div>
                <GSButton variant="secondary" id="workers-status">Fetch Workers Status</GSButton>
                <textarea id="workers-output" class="w-full min-h-[180px] gs-input" readonly></textarea>
            </div>

            <div class="gs-card space-y-4">
                <div>
                    <h2 class="text-xl font-semibold">Pages Projects</h2>
                    <p class="text-sm gs-text-subtle">Review Cloudflare Pages projects and deployment metadata.</p>
                </div>
                <GSButton variant="secondary" id="pages-projects">Fetch Pages Projects</GSButton>
                <textarea id="pages-output" class="w-full min-h-[180px] gs-input" readonly></textarea>
            </div>

            <div class="gs-card space-y-4">
                <div>
                    <h2 class="text-xl font-semibold">KV Namespaces</h2>
                    <p class="text-sm gs-text-subtle">List KV namespaces backing runtime configuration.</p>
                </div>
                <GSButton variant="secondary" id="kv-namespaces">Fetch KV Namespaces</GSButton>
                <textarea id="kv-output" class="w-full min-h-[180px] gs-input" readonly></textarea>
            </div>

            <div class="gs-card space-y-4">
                <div>
                    <h2 class="text-xl font-semibold">R2 Buckets</h2>
                    <p class="text-sm gs-text-subtle">Inspect R2 buckets used for state and storage.</p>
                </div>
                <GSButton variant="secondary" id="r2-buckets">Fetch R2 Buckets</GSButton>
                <textarea id="r2-output" class="w-full min-h-[180px] gs-input" readonly></textarea>
            </div>

            <div class="gs-card space-y-4">
                <div>
                    <h2 class="text-xl font-semibold">D1 Databases</h2>
                    <p class="text-sm gs-text-subtle">List D1 databases available to Cloudflare Workers.</p>
                </div>
                <GSButton variant="secondary" id="d1-databases">Fetch D1 Databases</GSButton>
                <textarea id="d1-output" class="w-full min-h-[180px] gs-input" readonly></textarea>
            </div>

            <div class="gs-card space-y-4">
                <div>
                    <h2 class="text-xl font-semibold">Access Policies</h2>
                    <p class="text-sm gs-text-subtle">List Cloudflare Access policies for a specific app.</p>
                </div>
                <div class="grid gap-3">
                    <input id="access-app-id" class="gs-input" placeholder="Access App ID" />
                    <GSButton variant="secondary" id="access-list">Fetch Policies</GSButton>
                </div>
                <textarea id="access-output" class="w-full min-h-[180px] gs-input" readonly></textarea>
            </div>
        </div>
    </section>

    <script>
        import { createAdminService } from '@goldshore/integrations';

        const opsBase = 'https://ops.goldshore.ai/cloudflare';
        const auditEndpoint = import.meta.env.PUBLIC_ADMIN_AUDIT_ENDPOINT;
        const adminService = createAdminService({
            apiBaseUrl: opsBase,
            auditEndpoint,
            actor: 'admin-system'
        });

        const setOutput = (elementId, data) => {
            const el = document.getElementById(elementId);
            if (el) {
                el.value = typeof data === 'string' ? data : JSON.stringify(data, null, 2);
            }
        };

        const runAction = async (elementId, pendingMessage, action) => {
            setOutput(elementId, pendingMessage);
            const result = await action();
            setOutput(elementId, result?.payload ?? 'No data returned.');
        };

        document.getElementById('dns-list')?.addEventListener('click', async () => {
            await runAction('dns-output', 'Loading...', () => adminService.listDnsRecords());
        });

        document.getElementById('dns-update')?.addEventListener('click', async () => {
            const recordId = document.getElementById('dns-record-id')?.value;
            const content = document.getElementById('dns-record-content')?.value;
            if (!recordId || !content) {
                setOutput('dns-update-output', 'Record ID and content are required.');
                return;
            }
            await runAction('dns-update-output', 'Updating...', () => adminService.updateDnsRecord(recordId, content));
        });

        document.getElementById('workers-status')?.addEventListener('click', async () => {
            await runAction('workers-output', 'Loading...', () => adminService.getWorkersStatus());
        });

        document.getElementById('pages-projects')?.addEventListener('click', async () => {
            await runAction('pages-output', 'Loading...', () => adminService.listPagesProjects());
        });

        document.getElementById('kv-namespaces')?.addEventListener('click', async () => {
            await runAction('kv-output', 'Loading...', () => adminService.listKvNamespaces());
        });

        document.getElementById('r2-buckets')?.addEventListener('click', async () => {
            await runAction('r2-output', 'Loading...', () => adminService.listR2Buckets());
        });

        document.getElementById('d1-databases')?.addEventListener('click', async () => {
            await runAction('d1-output', 'Loading...', () => adminService.listD1Databases());
        });

        document.getElementById('access-list')?.addEventListener('click', async () => {
            const appId = document.getElementById('access-app-id')?.value;
            if (!appId) {
                setOutput('access-output', 'Access App ID is required.');
                return;
            }
            await runAction('access-output', 'Loading...', () => adminService.listAccessPolicies(appId));
        });
    </script>
</AdminLayout>
