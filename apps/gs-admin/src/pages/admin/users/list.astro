---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { Card, Table, GSButton } from '@goldshore/ui';

type AdminUser = {
  id: string;
  email: string;
  role: string;
  status: string;
  createdAt?: string;
};

const API_BASE = import.meta.env.PUBLIC_API;
const accessToken = Astro.request.headers.get('CF-Access-Jwt-Assertion');

let users: AdminUser[] = [
  { id: 'seed-1', email: 'marin@goldshore.ai', role: 'admin', status: 'active' },
  { id: 'seed-2', email: 'alex@goldshore.ai', role: 'editor', status: 'active' },
  { id: 'seed-3', email: 'priya@goldshore.ai', role: 'viewer', status: 'invited' }
];
let loadError: string | null = null;

if (API_BASE && accessToken) {
  try {
    const response = await fetch(`${API_BASE}/admin/users`, {
      headers: {
        'CF-Access-Jwt-Assertion': accessToken
      }
    });
    if (response.ok) {
      users = (await response.json()) as AdminUser[];
    } else {
      loadError = `Failed to load users (${response.status}).`;
    }
  } catch (error) {
    loadError = 'Unable to reach the admin API.';
  }
}
---
<AdminLayout title="User List | GoldShore Admin" requiredPermission="users:read">
    <section class="max-w-6xl mx-auto py-16 px-6">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h1 class="text-3xl gs-heading mb-2">User List</h1>
            <p class="text-[var(--gs-text-secondary)]">
              Track invitations, role assignments, and account status for admin access.
            </p>
          </div>
          <GSButton href="/admin/users/permissions" variant="secondary">Review permissions</GSButton>
        </div>

        {loadError ? (
          <Card class="mb-6">
            <p class="text-[var(--gs-danger)]">{loadError}</p>
          </Card>
        ) : null}

        <Card class="gs-table-card">
          <Table>
            <thead>
              <tr>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Created</th>
              </tr>
            </thead>
            <tbody>
              {users.map((user) => (
                <tr>
                  <td>{user.email}</td>
                  <td class="capitalize">{user.role}</td>
                  <td>
                    <span class={`gs-badge ${user.status === 'active' ? 'success' : user.status === 'invited' ? 'info' : 'warning'}`}>
                      {user.status}
                    </span>
                  </td>
                  <td>{user.createdAt ? new Date(user.createdAt).toLocaleDateString() : '—'}</td>
                </tr>
              ))}
            </tbody>
          </Table>
        </Card>
---
<AdminLayout title="User List | GoldShore Admin">
    <section class="max-w-5xl mx-auto py-24 px-6">
        <h1 class="text-3xl gs-heading mb-4">User List</h1>
        <p class="text-[var(--gs-text-secondary)]">
            User records, roles, and account status will be available here.
        </p>
    </section>
</AdminLayout>
