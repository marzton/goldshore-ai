---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { Card, Table } from '@goldshore/ui';
import { ADMIN_ROLES, ROLE_PERMISSIONS, type AdminPermission } from '@goldshore/auth';

const permissionGroups: Array<{ label: string; permissions: AdminPermission[] }> = [
  {
    label: 'Content',
    permissions: ['content:read', 'content:write', 'content:publish']
  },
  {
    label: 'Media',
    permissions: ['media:read', 'media:write', 'media:delete']
  },
  {
    label: 'Forms',
    permissions: ['forms:read', 'forms:write', 'forms:publish']
  },
  {
    label: 'User Management & Audit',
    permissions: ['users:read', 'users:manage', 'audit:read']
  }
];
---
<AdminLayout title="User Permissions | GoldShore Admin" requiredPermission="users:manage">
    <section class="max-w-6xl mx-auto py-16 px-6">
        <h1 class="text-3xl gs-heading mb-4">User Permissions</h1>
        <p class="text-[var(--gs-text-secondary)] mb-8">
            Roles map directly to content, media, and forms access. Admins inherit full control, editors
            can create and update assets, and viewers remain read-only.
        </p>

        <Card class="gs-table-card">
          <Table>
            <thead>
              <tr>
                <th>Permission</th>
                {ADMIN_ROLES.map((role) => (
                  <th class="capitalize">{role}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {permissionGroups.map((group) => (
                <>
                  <tr>
                    <td colSpan={ADMIN_ROLES.length + 1} class="text-sm uppercase text-[var(--gs-text-secondary)]">
                      {group.label}
                    </td>
                  </tr>
                  {group.permissions.map((permission) => (
                    <tr>
                      <td>{permission}</td>
                      {ADMIN_ROLES.map((role) => (
                        <td>
                          {ROLE_PERMISSIONS[role].includes(permission) ? '✅' : '—'}
                        </td>
                      ))}
                    </tr>
                  ))}
                </>
              ))}
            </tbody>
          </Table>
        </Card>
---
<AdminLayout title="User Permissions | GoldShore Admin">
    <section class="max-w-5xl mx-auto py-24 px-6">
        <h1 class="text-3xl gs-heading mb-4">User Permissions</h1>
        <p class="text-[var(--gs-text-secondary)]">
            Permission sets, access requests, and audit trails will appear here.
        </p>
    </section>
</AdminLayout>
