---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { Card, Table, GSButton } from '@goldshore/ui';
import scanResults from '../../data/pii-scan-results.json';

const { summary, sources, findings, remediation, generatedAt, alerts } = scanResults;

const statusClass = summary.status === 'Critical'
  ? 'danger'
  : summary.status === 'Warning'
  ? 'warning'
  : 'success';

const severityClass = (severity) => {
  if (severity === 'high') return 'danger';
  if (severity === 'medium') return 'warning';
  return 'success';
};

const formattedDate = new Date(generatedAt).toLocaleString('en-US', {
  dateStyle: 'medium',
  timeStyle: 'short'
});
---
<AdminLayout title="PII Scan Results" requiredRole="admin">
  <section class="gs-grid columns-3">
    <Card>
      <div class="section-title"><span>⚠</span><h3>Alert Status</h3></div>
      <p class="gs-helper">Last scan: {formattedDate}</p>
      <span class={`gs-badge ${statusClass}`}>{summary.status}</span>
    </Card>
    <Card>
      <div class="section-title"><span>◎</span><h3>Total Findings</h3></div>
      <p class="gs-helper">Across code + web surfaces</p>
      <p class="gs-mt-2 gs-display">{summary.totalFindings}</p>
    </Card>
    <Card>
      <div class="section-title"><span>✓</span><h3>Severity Mix</h3></div>
      <div class="gs-pill-list">
        <span class="gs-badge danger">High: {summary.high}</span>
        <span class="gs-badge warning">Medium: {summary.medium}</span>
        <span class="gs-badge success">Low: {summary.low}</span>
      </div>
    </Card>
  </section>

  <section class="gs-grid columns-2 gs-mt-6">
    <Card class="gs-table-card">
      <div class="section-title"><span>↳</span><h3>Scan coverage</h3></div>
      <Table>
        <thead>
          <tr>
            <th>Source</th>
            <th>Files scanned</th>
            <th>Findings</th>
          </tr>
        </thead>
        <tbody>
          {sources.map((source) => (
            <tr>
              <td>{source.name}</td>
              <td>{source.scannedFiles}</td>
              <td>{source.findings}</td>
            </tr>
          ))}
        </tbody>
      </Table>
    </Card>
    <Card>
      <div class="section-title"><span>↺</span><h3>Remediation guidance</h3></div>
      <p class="gs-helper">Recommended actions for analysts and owners.</p>
      <ul class="gs-mt-2">
        {remediation.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
      <div class="gs-form-actions gs-mt-4">
        <GSButton class="gs-button--small">Escalate</GSButton>
        <GSButton variant="secondary" class="gs-button--small">Export report</GSButton>
      </div>
    </Card>
  </section>

  <section class="gs-mt-6">
    <Card class="gs-table-card">
      <div class="section-title"><span>⚑</span><h3>Alert routing</h3></div>
      <p class="gs-helper">Escalation paths for this scan run.</p>
      <div class="gs-pill-list gs-mt-2">
        <span class={`gs-badge ${statusClass}`}>{alerts.status}</span>
      </div>
      <Table class="gs-mt-3">
        <thead>
          <tr>
            <th>Channel</th>
            <th>Owner</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          {alerts.channels.map((channel) => (
            <tr>
              <td>{channel.channel}</td>
              <td>{channel.owner}</td>
              <td>{channel.action}</td>
            </tr>
          ))}
        </tbody>
      </Table>
    </Card>
  </section>

  <section class="gs-mt-6">
    <Card class="gs-table-card">
      <div class="section-title"><span>✸</span><h3>Findings</h3></div>
      <Table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Type</th>
            <th>Severity</th>
            <th>Location</th>
            <th>Snippet</th>
            <th>Guidance</th>
          </tr>
        </thead>
        <tbody>
          {findings.map((finding) => (
            <tr>
              <td>{finding.id}</td>
              <td>{finding.type}</td>
              <td><span class={`gs-badge ${severityClass(finding.severity)}`}>{finding.severity}</span></td>
              <td>{finding.location}</td>
              <td>{finding.snippet}</td>
              <td>{finding.guidance}</td>
            </tr>
          ))}
        </tbody>
      </Table>
    </Card>
  </section>
</AdminLayout>
