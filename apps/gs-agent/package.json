{
  "name": "@goldshore/gs-agent",
  "version": "0.0.1",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev --env dev --config wrangler.toml",
    "deploy": "wrangler deploy --env prod --config wrangler.toml",
    "build": "wrangler deploy --dry-run --outdir=dist --env prod --config wrangler.toml"
  },
  "dependencies": {
    "@goldshore/auth": "workspace:*",
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260207.0",
    "typescript": "^5.4.0",
    "wrangler": "^4.63.0"
    "dev": "wrangler dev src/index.ts",
    "deploy": "wrangler deploy --minify src/index.ts",
    "build": "wrangler deploy src/index.ts --dry-run --outdir=dist"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260214.0",
    "typescript": "^5.0.0",
    "wrangler": "^4.65.0"
  }
}
