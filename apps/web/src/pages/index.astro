---
import '@goldshore/theme/tokens';
import { GSButton } from '@goldshore/ui';
import MarketingLayout from '../layouts/MarketingLayout.astro';
import '../styles/home.css';

export const prerender = true;

const features = [
  {
    title: 'Vibe Coding',
    body: 'Aesthetic-driven development where code flows like fluid dynamics. Provable experience.',
    icon: 'palette'
  },
  {
    title: 'Cinematic Ops',
    body: 'Infrastructure monitoring that feels like a sci-fi HUD. Real-time, responsive, and beautiful.',
    icon: 'monitor_heart'
  },
  {
    title: 'Applied Intelligence',
    body: "AI agents that don't just work—they perform. Seamless integration into your workflow.",
    icon: 'psychology'
  }
];

const highlights = [
  { label: 'System Health', value: '97%', tone: 'success' },
  { label: 'Latency', value: '48.5ms', tone: 'info' },
  { label: 'Tasks/sec', value: '1,210', tone: 'success' },
  { label: 'Uptime', value: '99.98%', tone: 'success' }
];
---

<MarketingLayout title="GoldShore | Shaping Waves" description="Unified AI infrastructure for trading and intelligent operations.">
  <div class="home-shell">
    <section class="gs-hero home-hero parallax-section">
      <div class="starfield" aria-hidden="true"></div>
      <div class="parallax-layer layer-grid" data-parallax="0.08" aria-hidden="true"></div>
      <div class="parallax-layer layer-glow" data-parallax="0.14" aria-hidden="true"></div>
      <div class="parallax-layer layer-orbit" data-parallax="0.2" aria-hidden="true"></div>
      <div class="hero-content reveal">
        <p class="gs-badge hero-badge">System online</p>
        <h1>Shaping Waves with Applied Intelligence</h1>
        <p>
          GoldShore isn&apos;t just code. It&apos;s a provable experience. We build resilient, cinematic systems where automation
          meets art.
        </p>
        <div class="hero-actions">
          <GSButton href="/services" class="home-primary-btn">Start the Experience</GSButton>
          <GSButton href="/contact" variant="secondary">Contact sales</GSButton>
        </div>
      </div>
      <div class="gs-card gs-pulse-frame hero-card reveal">
        <div class="card-header">
          <div class="lights" aria-hidden="true">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <span class="panel-title">Goldshore Agent</span>
        </div>
        <div class="gs-grid columns-2">
          {highlights.map((item) => (
            <div class="gs-kpi">
              <span>{item.label}</span>
              <strong>{item.value}</strong>
              <div class={`gs-badge ${item.tone ?? ''}`}>Live</div>
            </div>
          ))}
        </div>
        <div class="bars" aria-hidden="true">
          <span style="height: 38%"></span>
          <span style="height: 70%"></span>
          <span style="height: 50%"></span>
          <span style="height: 88%"></span>
          <span style="height: 62%"></span>
        </div>
        <p class="gs-helper">Backed by global routing, automated rollbacks, and human-in-the-loop controls.</p>
      </div>
    </section>

    <section class="wave-band" aria-hidden="true">
      <div class="wave-globe"></div>
    </section>

    <section class="prism-band" aria-hidden="true">
      <div class="prism"></div>
    </section>

    <section class="home-features parallax-section">
      <div class="parallax-layer layer-grid" data-parallax="0.05" aria-hidden="true"></div>
      <div class="parallax-layer layer-glow" data-parallax="0.1" aria-hidden="true"></div>
      <div class="max-w-7xl mx-auto py-24 px-6 section-content">
        <p class="gs-badge reveal">Main theme sections</p>
        <div class="features-grid">
          {features.map((feature) => (
            <div class="feature-card reveal">
              <div class="icon-box" style="margin-bottom: var(--gs-space-4);">
                <span class="material-symbols-rounded">{feature.icon}</span>
              </div>
              <h3 class="text-xl font-semibold" style="color: var(--gs-text-primary);">{feature.title}</h3>
              <p class="text-[var(--gs-text-secondary)]">{feature.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</MarketingLayout>

<script is:inline>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion) {
    const revealTargets = document.querySelectorAll('.reveal');
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.18 }
    );
    revealTargets.forEach((el) => revealObserver.observe(el));

    const parallaxLayers = Array.from(document.querySelectorAll('[data-parallax]'));
    const updateParallax = () => {
      const scrollY = window.scrollY || window.pageYOffset;
      parallaxLayers.forEach((layer) => {
        const speed = parseFloat(layer.dataset.parallax || '0');
        layer.style.transform = `translate3d(0, ${scrollY * speed * -0.12}px, 0)`;
      });
    };
    updateParallax();
    window.addEventListener('scroll', () => requestAnimationFrame(updateParallax), { passive: true });
  } else {
    document.querySelectorAll('.reveal').forEach((el) => el.classList.add('is-visible'));
  }
</script>
