---
import '@goldshore/theme/tokens';
import { GSButton } from '@goldshore/ui';
import MarketingLayout from '../layouts/MarketingLayout.astro';

// Goldshore Landing Page
// Aesthetic: Military x Tech, Sports Car, Utility

export const prerender = true;

const features = [
  {
    title: 'Algorithmic Precision',
    body: 'High-frequency execution modeled on fluid dynamics. Zero latency expectations.',
  },
  {
    title: 'Military Grade',
    body: 'Infrastructure built to withstand extreme volatility. Security first architecture.',
  },
  {
    title: 'Global Reach',
    body: 'Connected to major liquidity pools across all timezones. 24/7 operations.',
  },
];

const highlights = [
  { label: 'Uptime', value: '99.99%', tone: 'positive' },
  { label: 'Latency', value: '< 20ms', tone: 'neutral' },
  { label: 'Requests', value: '2.4M', tone: 'positive' },
  { label: 'Security', value: 'Active', tone: 'warning' }
];
---

<MarketingLayout title="GoldShore | Shaping Waves" description="Unified AI infrastructure for trading and intelligent operations.">
  <section class="gs-hero">
    <div>
      <p class="gs-badge" style="margin-bottom: var(--gs-space-3);">Modern ops for fluid markets</p>
      <h1>Shaping Waves with Applied Intelligence</h1>
      <p>
        GoldShore builds resilient, automation-first systems for trading, control, and applied intelligence. Each surface ships with observability, safety, and responsive design baked in.
      </p>
      <div style="display:flex; gap: var(--gs-space-3); flex-wrap: wrap;">
        <GSButton href="/services">View Services</GSButton>
        <GSButton href="/contact" variant="secondary">Book a call</GSButton>
      </div>
    </div>
  </section>

  <div class="border-t-[var(--gs-border)]"></div>

  <section class="max-w-7xl mx-auto py-24 px-6 grid grid-cols-1 md:grid-cols-3 gap-12">
    {features.map((feature) => (
      <div class="space-y-4">
        <h3 class="text-xl font-semibold" style="color: var(--gs-text-primary);">{feature.title}</h3>
        <p class="text-[var(--gs-text-secondary)]">
          {feature.body}
        </p>
      </div>
    ))}
  </section>
</MarketingLayout>
