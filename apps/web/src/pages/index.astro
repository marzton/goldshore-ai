---
import '@goldshore/theme/tokens';
import { GSButton } from '@goldshore/ui';
import MarketingLayout from '../layouts/MarketingLayout.astro';
import '../styles/home.css';

export const prerender = true;

const features = [
  {
    title: 'Vibe Coding',
    body: 'Aesthetic-driven development where code flows like fluid dynamics. Provable experience.',
    icon: 'palette'
  },
  {
    title: 'Cinematic Ops',
    body: 'Infrastructure monitoring that feels like a sci-fi HUD. Real-time, responsive, and beautiful.',
    icon: 'monitor_heart'
  },
  {
    title: 'Applied Intelligence',
    body: 'AI agents that don\'t just work—they perform. Seamless integration into your workflow.',
    icon: 'psychology'
  },
];

const highlights = [
  { label: 'Uptime', value: '99.99%', tone: 'gs-badge--success' },
  { label: 'Latency', value: '<25ms', tone: 'gs-badge--info' },
  { label: 'Security', value: 'Shielded', tone: 'gs-badge--warning' },
];
---

<MarketingLayout title="GoldShore | Shaping Waves" description="Unified AI infrastructure for trading and intelligent operations.">
  <div class="cinematic-wrapper">
    <!-- Starfield Background -->
    <div class="stars-container">
      <div class="stars"></div>
    </div>

    <section class="gs-hero home-hero parallax-section">
      <div class="parallax-layer layer-grid" data-parallax="0.08" aria-hidden="true"></div>
      <div class="parallax-layer layer-glow" data-parallax="0.14" aria-hidden="true"></div>
      <div class="parallax-layer layer-orbit" data-parallax="0.2" aria-hidden="true"></div>

      <div class="hero-content reveal">
        <div class="badge-container fade-in-up" style="animation-delay: 0.2s;">
          <span class="vibe-badge">
            <span class="pulse-dot"></span>
            System Operational
          </span>
        </div>

        <h1 class="fade-in-up" style="animation-delay: 0.4s;">
          Shaping Waves with <br/>
          <span class="text-gradient">Applied Intelligence</span>
        </h1>

        <p class="hero-desc fade-in-up" style="animation-delay: 0.6s;">
          GoldShore isn't just code. It's a provable experience. We build resilient, cinematic systems where automation meets art.
        </p>

        <div class="cta-group fade-in-up" style="animation-delay: 0.8s;">
          <GSButton href="/services" class="glow-button">Start the Experience</GSButton>
          <GSButton href="/contact" variant="secondary" class="glass-button">Contact Sales</GSButton>
        </div>
      </div>

      <!-- 3D/Parallax Element -->
      <div class="hero-visual fade-in-up" style="animation-delay: 1s;">
        <div class="glass-card tilt-card">
          <div class="card-header">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
            <span class="card-title">GoldShore Agent</span>
          </div>
          <div class="card-body">
            <div class="data-row">
              <span class="label">STATUS</span>
              <span class="value success">ACTIVE</span>
            </div>
            <div class="data-row">
              <span class="label">MODE</span>
              <span class="value info">VIBE_CODING</span>
            </div>
            <div class="chart-viz">
              <div class="bar" style="height: 40%"></div>
              <div class="bar" style="height: 70%"></div>
              <div class="bar" style="height: 55%"></div>
              <div class="bar" style="height: 90%"></div>
              <div class="bar" style="height: 60%"></div>
            </div>
            <div class="terminal-output">
              > Initializing cinematic protocols...<br/>
              > Optimizing user experience...<br/>
              > Done.
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="gs-card gs-pulse-frame hero-card reveal" style="max-width: 1280px; margin: 0 auto 4rem; position: relative; z-index: 10;">
      <h3 class="section-title"><span>⇄</span>Performance at a glance</h3>
      <div class="gs-grid columns-3">
        {highlights.map((item) => (
          <div class="gs-kpi">
            <span>{item.label}</span>
            <strong>{item.value}</strong>
            <div class={`gs-badge ${item.tone ?? ''}`}>Live</div>
          </div>
        ))}
      </div>
      <div class="gs-helper" style="margin-top: var(--gs-space-4);">Backed by global routing, automated rollbacks, and human-in-the-loop controls.</div>
    </div>

    <!-- Features Section -->
    <section class="features-section">
      <div class="features-grid">
        {features.map((feature, i) => (
          <div class="feature-card glass-panel fade-in-up" style={`animation-delay: ${1.2 + (i * 0.2)}s;`}>
            <div class="icon-box">
              <span class="material-symbols-rounded">{feature.icon}</span>
            </div>
            <h3>{feature.title}</h3>
            <p>{feature.body}</p>
          </div>
        ))}
      </div>
    </section>
  </div>
</MarketingLayout>

<style>
  :global(body) {
    background-color: #050505;
    color: #e5e7eb;
    overflow-x: hidden;
  }

  /* Cinematic Wrapper */
  .cinematic-wrapper {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
  }

  /* Starfield Animation */
  .stars-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    background: radial-gradient(ellipse at bottom, #1B2735 0%, #090A0F 100%);
    overflow: hidden;
  }

  .stars {
    width: 2px;
    height: 2px;
    background: transparent;
    box-shadow:
        10vw 10vh #fff, 20vw 80vh #fff, 30vw 30vh #fff, 40vw 50vh #fff,
        50vw 90vh #fff, 60vw 20vh #fff, 70vw 60vh #fff, 80vw 40vh #fff,
        90vw 10vh #fff, 15vw 65vh #fff, 25vw 15vh #fff, 35vw 95vh #fff,
        45vw 45vh #fff, 55vw 85vh #fff, 65vw 35vh #fff, 75vw 55vh #fff,
        85vw 25vh #fff, 95vw 75vh #fff, 5vw 5vh #fff, 50vw 50vh #fff;
    animation: animStar 100s linear infinite;
    opacity: 0.5;
  }

  @keyframes animStar {
    from { transform: translateY(0); }
    to { transform: translateY(-100vh); }
  }

  /* Hero Section */
  .cinematic-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    padding: 8rem 2rem 4rem;
    max-width: 1280px;
    margin: 0 auto;
    min-height: 90vh;
    align-items: center;
  }

  .hero-content {
    z-index: 10;
  }

  h1 {
    font-size: 4.5rem;
    line-height: 1.1;
    font-weight: 800;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .text-gradient {
    background: linear-gradient(135deg, #fff 0%, #94a3b8 50%, #22d3ee 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-desc {
    font-size: 1.25rem;
    line-height: 1.6;
    color: #94a3b8;
    margin-bottom: 2.5rem;
    max-width: 540px;
  }

  /* Badge */
  .vibe-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: rgba(34, 211, 238, 0.1);
    border: 1px solid rgba(34, 211, 238, 0.2);
    border-radius: 99px;
    color: #22d3ee;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    background: #22d3ee;
    border-radius: 50%;
    box-shadow: 0 0 10px #22d3ee;
    animation: pulse 2s infinite;
  }

  /* Buttons */
  .cta-group {
    display: flex;
    gap: 1rem;
  }

  /* We use global here because GSButton might apply styles we want to override or augment */
  :global(.glow-button) {
    box-shadow: 0 0 20px rgba(34, 211, 238, 0.3) !important;
    transition: transform 0.2s, box-shadow 0.2s !important;
    border: 1px solid rgba(34, 211, 238, 0.5) !important;
  }

  :global(.glow-button:hover) {
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(34, 211, 238, 0.5) !important;
  }

  /* 3D Card */
  .hero-visual {
    perspective: 1000px;
    display: flex;
    justify-content: center;
  }

  .glass-card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1rem;
    padding: 1.5rem;
    width: 100%;
    max-width: 400px;
    transform: rotateY(-10deg) rotateX(5deg);
    transition: transform 0.5s ease;
    box-shadow: 20px 20px 50px rgba(0,0,0,0.5);
  }

  .glass-card:hover {
    transform: rotateY(0deg) rotateX(0deg);
  }

  .card-header {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    align-items: center;
  }

  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .red { background: #ef4444; }
  .yellow { background: #eab308; }
  .green { background: #22c55e; }
  .card-title { margin-left: auto; color: #64748b; font-size: 0.8rem; font-family: monospace; }

  .data-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.75rem;
    font-family: monospace;
    font-size: 0.9rem;
  }

  .value.success { color: #22c55e; text-shadow: 0 0 10px rgba(34,197,94,0.5); }
  .value.info { color: #22d3ee; text-shadow: 0 0 10px rgba(34,211,238,0.5); }

  .chart-viz {
    display: flex;
    align-items: flex-end;
    gap: 0.5rem;
    height: 60px;
    margin: 1.5rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding-bottom: 2px;
  }

  .bar {
    flex: 1;
    background: #22d3ee;
    opacity: 0.6;
    border-radius: 2px 2px 0 0;
  }

  .terminal-output {
    font-family: monospace;
    font-size: 0.8rem;
    color: #94a3b8;
    line-height: 1.4;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 1rem;
  }

  /* Features */
  .features-section {
    padding: 4rem 2rem;
    max-width: 1280px;
    margin: 0 auto;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .glass-panel {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 2rem;
    border-radius: 1rem;
    transition: all 0.3s;
  }

  .glass-panel:hover {
    background: rgba(255, 255, 255, 0.05);
    transform: translateY(-5px);
    border-color: rgba(34, 211, 238, 0.3);
  }

  .icon-box {
    width: 48px;
    height: 48px;
    background: rgba(34, 211, 238, 0.1);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #22d3ee;
    margin-bottom: 1.5rem;
  }

  .glass-panel h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: #fff;
  }

  .glass-panel p {
    color: #94a3b8;
    line-height: 1.6;
  }

  /* Animations */
  @keyframes pulse {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(34, 211, 238, 0.7); }
    70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(34, 211, 238, 0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(34, 211, 238, 0); }
  }

  .fade-in-up {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.8s forwards;
  }

  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .cinematic-hero { grid-template-columns: 1fr; text-align: center; padding-top: 6rem; }
    .hero-visual { display: none; }
    h1 { font-size: 2.5rem; }
    .cta-group { justify-content: center; }
  }
</style>

<script is:inline>
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion) {
    const revealTargets = document.querySelectorAll('.reveal');
    const revealObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            revealObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.18 }
    );
    revealTargets.forEach((el) => revealObserver.observe(el));

    const parallaxLayers = Array.from(document.querySelectorAll('[data-parallax]'));
    const updateParallax = () => {
      const scrollY = window.scrollY || window.pageYOffset;
      parallaxLayers.forEach((layer) => {
        const speed = parseFloat(layer.dataset.parallax || '0');
        layer.style.transform = `translate3d(0, ${scrollY * speed * -0.12}px, 0)`;
      });
    };
    updateParallax();
    window.addEventListener('scroll', () => requestAnimationFrame(updateParallax), { passive: true });
  } else {
    document.querySelectorAll('.reveal').forEach((el) => el.classList.add('is-visible'));
  }
</script>
