---
import ApiSidebar from '../../../components/ApiSidebar.astro';
import ApiEndpoint from '../../../components/ApiEndpoint.astro';
// @ts-ignore
import openapi from '../../../content/openapi/v1.json';

const { slug = [] } = Astro.params;
const endpointId = Array.isArray(slug) ? slug.join('/') : slug;
const hasEndpoint = Boolean(endpointId);
---

<div class="api-container">
  <ApiSidebar openapi={openapi} />
  <main>
    {hasEndpoint ? (
      <ApiEndpoint openapi={openapi} endpointId={endpointId} />
    ) : (
      <h1>API Reference — v1</h1>
    )}
  </main>
</div>

<style>
  .api-container { display: flex; min-height: 100vh; }
  main { flex: 1; }
</style>
