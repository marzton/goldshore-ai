---
// apps/web/src/components/DocsSearch.astro
---
<div class="search-box" role="search">
  <label for="docs-search-input" class="sr-only">Search documentation</label>
  <input type="search" placeholder="Search docs…" id="docs-search-input" aria-controls="results" aria-expanded="false" />
  <div id="search-status" class="search-status" role="status" aria-live="polite"></div>
  <ul id="results" class="search-results" aria-label="Search results"></ul>
</div>

<style>
  .search-box { position: relative; width: 100%; }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); border: 0; }
  .search-status { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); font-size: 0.85rem; color: var(--gs-color-subtle); pointer-events: none; }
  .search-results { position: absolute; top: 100%; left: 0; width: 100%; background: var(--gs-color-surface); border: 1px solid var(--gs-color-border); border-radius: var(--gs-radius-sm); margin: 0.5rem 0 0 0; padding: 0; list-style: none; max-height: 300px; overflow-y: auto; z-index: 50; display: none; box-shadow: var(--gs-shadow-soft); }
  .search-results:not(:empty) { display: block; padding: 0.5rem 0; }
  :global(.search-results a) { display: block; padding: 0.5rem 1rem; color: var(--gs-color-text); text-decoration: none; transition: background 0.1s; }
  :global(.search-results a:hover), :global(.search-results a:focus) { background: var(--gs-color-muted-surface); color: var(--gs-accent); outline: none; }
  :global(.search-results .search-error) { padding: 0.5rem 1rem; color: var(--gs-danger); font-size: 0.9rem; }
</style>

<script>
  const input = document.getElementById('docs-search-input') as HTMLInputElement;
  const list = document.getElementById('results');
  const status = document.getElementById('search-status');
  let ctrl;

  function setLoad(loading) {
    if (status) status.textContent = loading ? 'Searching...' : '';
    if (input) input.setAttribute('aria-busy', String(loading));
  }

  async function search(q) {
    if (ctrl) ctrl.abort();
    if (!q.trim()) { if(list) list.textContent = ''; setLoad(false); return; }

    ctrl = new AbortController();
    setLoad(true);
    try {
      const res = await fetch('/api/docs-search?q=' + encodeURIComponent(q), { signal: ctrl.signal });
      const data = await res.json();
      setLoad(false);
      if (list) {
        list.textContent = '';
        if (data.length === 0) {
           const li = document.createElement('li');
           li.innerHTML = '<div class="search-error" style="color:var(--gs-color-subtle)">No results found.</div>';
           list.appendChild(li);
        } else {
            data.forEach(r => {
                const li = document.createElement('li');
                const a = document.createElement('a');
                a.href = r.url && !r.url.startsWith('javascript:') ? r.url : '#';
                a.textContent = r.title;
                li.appendChild(a);
                list.appendChild(li);
            });
        }
        if (input) input.setAttribute('aria-expanded', 'true');
      }
    } catch (e) {
      if (e.name === 'AbortError') return;
      setLoad(false);
      if (list) list.innerHTML = '<li><div class="search-error">Search failed.</div></li>';
  interface SearchResult {
    title: string;
    url: string;
  }

  const input = document.getElementById('docs-search-input') as HTMLInputElement | null;
  const resultsList = document.getElementById('search-results-list');
  const loader = document.getElementById('search-loader');
  const status = document.getElementById('search-status');

<script lang="ts">
  const input = document.getElementById('docs-search-input');
  const resultsDiv = document.getElementById('results');

  // Optimization: Debounce function to prevent API calls on every keystroke
  function debounce(func: Function, wait: number) {
    let timeout: ReturnType<typeof setTimeout>;
    return function(this: any, ...args: any[]) {
      const context = this;
      clearTimeout(timeout);
      timeout = setTimeout(() => func.apply(context, args), wait);
    };
  }

  function showLoader(show: boolean) {
    if (loader) {
      if (show) loader.classList.remove('hidden');
      else loader.classList.add('hidden');
    }
  }

  function showResults(show: boolean) {
    if (resultsList && input) {
      if (show) {
        resultsList.classList.remove('hidden');
        input.setAttribute('aria-expanded', 'true');
      } else {
        resultsList.classList.add('hidden');
        input.setAttribute('aria-expanded', 'false');
      }
    }
  }

  function updateStatus(message: string) {
    if (status) status.textContent = message;
  }

  let searchController: AbortController | null = null;

  async function runSearch(query: string) {
    if (searchController) {
      searchController.abort();
    }
    searchController = new AbortController();
    const signal = searchController.signal;

    if (!query.trim()) {
      if(resultsList) resultsList.innerHTML = '';
      showResults(false);
      updateStatus('');
      return;
    }

    showLoader(true);
    updateStatus('Searching...');

    try {
      const res = await fetch('/api/docs-search?q=' + encodeURIComponent(query), { signal });

      if (!res.ok) {
        throw new Error(`Status ${res.status}`);
      }

      const results = await res.json() as SearchResult[];
      showLoader(false);

      if (resultsList) {
        resultsList.innerHTML = ''; // Clear previous results

        if (results.length === 0) {
            const li = document.createElement('li');
            li.className = 'search-message';
            li.textContent = 'No results found.';
            resultsList.appendChild(li);
            updateStatus('No results found.');
            showResults(true);
            return;
        }

        updateStatus(`Found ${results.length} results.`);

        results.forEach((r: SearchResult, index: number) => {
            const li = document.createElement('li');
            li.className = 'search-result-item';
            li.role = 'option';

            const a = document.createElement('a');
            a.id = `search-result-${index}`;
            // Sentinel: Basic protection against javascript: URIs
            if (r.url && !r.url.trim().toLowerCase().startsWith('javascript:')) {
        results.forEach((r: any) => {
            const a = document.createElement('a');

            // Sentinel: Stronger protection (Allowlist)
            // Only allow http, https, mailto protocols.
            // Relative paths resolve to the current origin (http/https), so they pass.
            const isSafeUrl = (url: string) => {
                try {
                    const parsed = new URL(url, window.location.origin);
                    return ['http:', 'https:', 'mailto:'].includes(parsed.protocol);
                } catch (e) {
                    return false;
                }
            };

            if (r.url && isSafeUrl(r.url)) {
                a.href = r.url;
            } else {
                a.href = '#';
                console.warn('Blocked potentially unsafe URL in search results');
            }
            a.textContent = r.title; // Sentinel: Prevent XSS
            a.tabIndex = -1; // Manage focus manually with arrows

            li.appendChild(a);
            resultsList.appendChild(li);
        });

        showResults(true);
      }
    } catch (e: unknown) {
      if (e instanceof Error && e.name === 'AbortError') return;
      showLoader(false);
      if (resultsList) {
        resultsList.innerHTML = '';
        const li = document.createElement('li');
        li.className = 'search-message search-error-msg';
        li.textContent = 'Search failed. Please try again.';
        resultsList.appendChild(li);
        showResults(true);
        updateStatus('Search failed.');
    } catch (e: any) {
      if (e.name === 'AbortError') return; // Ignore aborted requests
      if (resultsDiv) {
        resultsDiv.textContent = '';
        const err = document.createElement('div');
        err.className = 'search-error';
        err.style.color = 'var(--gs-error, #ef4444)';
        err.style.marginTop = '0.5em';
        err.textContent = 'Sorry, search failed. Please try again.';
        resultsDiv.appendChild(err);
      }
      console.error("Search failed", e);
    }
  }

  if (input) {
    let t;
    input.addEventListener('input', (e) => {
      clearTimeout(t);
      t = setTimeout(() => search((e.target as HTMLInputElement).value), 300);
    });
    input.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') { if (list) list.textContent = ''; input.setAttribute('aria-expanded', 'false'); input.blur(); }
    });
    document.addEventListener('click', (e) => {
        if (!input.contains(e.target as Node) && list && !list.contains(e.target as Node)) {
             list.textContent = ''; input.setAttribute('aria-expanded', 'false');
    // Wait 300ms after user stops typing before searching
    const debouncedSearch = debounce((e: Event) => {
      runSearch((e.target as HTMLInputElement).value);
    }, 300);

    input.addEventListener('input', debouncedSearch as EventListener);

    // Keyboard navigation
    input.addEventListener('keydown', (e: KeyboardEvent) => {
      if (!resultsList || resultsList.classList.contains('hidden')) return;

      const items = resultsList.querySelectorAll('a');
      if (items.length === 0) return;

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        (items[0] as HTMLElement).focus();
      } else if (e.key === 'Escape') {
        e.preventDefault();
        showResults(false);
        input.value = '';
        updateStatus('Search cleared.');
      }
    });

    // Close on click outside
    document.addEventListener('click', (e: MouseEvent) => {
        if (!input.contains(e.target as Node) && !resultsList?.contains(e.target as Node)) {
            showResults(false);
        }
    });
  }

  if (resultsList) {
    resultsList.addEventListener('keydown', (e: KeyboardEvent) => {
        const items = Array.from(resultsList.querySelectorAll('a'));
        const activeElement = document.activeElement as HTMLElement;
        const index = items.indexOf(activeElement as HTMLAnchorElement);

        if (e.key === 'ArrowDown') {
            e.preventDefault();
            if (index < items.length - 1) {
                (items[index + 1] as HTMLElement).focus();
            }
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            if (index > 0) {
                (items[index - 1] as HTMLElement).focus();
            } else {
                input?.focus();
            }
        } else if (e.key === 'Escape') {
            e.preventDefault();
            showResults(false);
            input?.focus();
        }
    });
  }

  // Palette: Add keyboard shortcut for search
  console.log('DocsSearch: script loaded');
  document.addEventListener('keydown', (e) => {
    // console.log('Key pressed:', e.key, 'Meta:', e.metaKey, 'Ctrl:', e.ctrlKey);
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      console.log('DocsSearch: Shortcut triggered');
      e.preventDefault();
      const searchInput = document.getElementById('docs-search-input');
      if (searchInput) {
        searchInput.focus();
        console.log('DocsSearch: Input focused');
      } else {
        console.error('DocsSearch: Input not found');
      }
    }
  });
</script>

<style>
  .search-box {
    margin-bottom: 1.5rem;
  }

  .search-input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  input[type="search"] {
    width: 100%;
    padding: 0.75rem 1rem;
    padding-right: 3.5rem; /* Space for the shortcut */
    border: 1px solid var(--gs-color-border, #e2e8f0);
    border-radius: var(--gs-radius-sm, 0.375rem);
    background: var(--gs-color-surface, #fff);
    font-size: 0.95rem;
    transition: all 0.2s ease;
  }

  input[type="search"]:focus {
    outline: none;
    border-color: var(--gs-primary, #0f172a);
    box-shadow: 0 0 0 2px var(--gs-primary-alpha, rgba(15, 23, 42, 0.1));
  }

  .search-shortcut {
    position: absolute;
    right: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 1.5rem;
    padding: 0 0.4rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--gs-color-subtle, #94a3b8);
    background: var(--gs-color-bg, #f8fafc);
    border: 1px solid var(--gs-color-border, #e2e8f0);
    border-radius: 4px;
    pointer-events: none;
    user-select: none;
  }

  :global(.dark) .search-shortcut {
    background: #1e293b;
    border-color: #334155;
  }

  #results {
    margin-top: 0.5rem;
  }

  :global(.search-result-link) {
    display: block;
    padding: 0.5rem 0.75rem;
    text-decoration: none;
    color: var(--gs-color-text, #334155);
    border-radius: 4px;
    font-size: 0.9rem;
  }

  :global(.search-result-link:hover) {
    background: var(--gs-color-bg-hover, #f1f5f9);
    color: var(--gs-primary, #0f172a);
  }
</style>
