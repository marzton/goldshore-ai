---
---
<div class="search-wrap">
  <input type="search" id="ds-input" placeholder="Search docs..." aria-label="Search docs" autocomplete="off" />
  <ul id="ds-results" hidden></ul>
</div>

<script>
  const inp = document.getElementById('ds-input') as HTMLInputElement;
  const list = document.getElementById('ds-results');
  let t;
  let ctrl;

  inp?.addEventListener('input', () => {
    clearTimeout(t);
    // @ts-ignore
    t = setTimeout(async () => {
      const q = inp.value.trim();
      if (!q) { list.hidden = true; return; }

      if (ctrl) ctrl.abort();
      ctrl = new AbortController();

      try {
        const res = await fetch(`/api/docs-search?q=${encodeURIComponent(q)}`, { signal: ctrl.signal });
        if (!res.ok) return;
        const items = await res.json();

        list.innerHTML = '';
        if (items.length) {
            items.forEach(i => {
                const li = document.createElement('li');
                const a = document.createElement('a');
                a.href = i.url;
                a.textContent = i.title;
                li.appendChild(a);
                list.appendChild(li);
            });
        } else {
            const li = document.createElement('li');
            li.className = 'no-res';
            li.textContent = 'No results';
            list.appendChild(li);
        }
        list.hidden = false;
      } catch (e) {
        if (e.name !== 'AbortError') console.error(e);
      }
    }, 300);
  });

  document.addEventListener('click', (e) => {
    // @ts-ignore
    if (!inp.contains(e.target) && !list.contains(e.target)) list.hidden = true;
  });
</script>

<style>
  .search-wrap { position: relative; margin-bottom: 1rem; }
  input {
    width: 100%; padding: 0.5rem 0.75rem; border-radius: var(--gs-radius-sm);
    border: 1px solid var(--gs-color-border);
    background: var(--gs-color-surface);
    color: var(--gs-color-text);
    font-size: 0.875rem;
  }
  input:focus { outline: 2px solid var(--gs-accent); border-color: transparent; }
  ul {
    position: absolute; width: 100%; margin-top: 4px; padding: 0;
    background: var(--gs-color-surface); border: 1px solid var(--gs-color-border);
    border-radius: var(--gs-radius-sm); list-style: none; z-index: 50;
    box-shadow: var(--gs-shadow-lg);
    max-height: 200px; overflow-y: auto;
  }
  /* Global styles for dynamic elements */
  :global(#ds-results li a) { display: block; padding: 0.5rem 0.75rem; color: var(--gs-color-text); text-decoration: none; font-size: 0.875rem; }
  :global(#ds-results li a:hover) { background: var(--gs-color-muted-surface); color: var(--gs-accent); }
  :global(#ds-results .no-res) { padding: 0.5rem 0.75rem; color: var(--gs-color-subtle); font-size: 0.875rem; }
</style>
