---
let q = '';
let results = [];

// Note: In a real implementation, this would likely be a client-side component or use a framework specific way to handle state.
// Since this is an Astro component, the script below handles the client-side logic.
---

<div class="search-box" role="search">
  <input
    type="search"
    placeholder="Search docs…"
    id="docs-search-input"
    aria-label="Search documentation"
    aria-controls="docs-search-results"
    aria-expanded="false"
  />
  <div
    id="docs-search-status"
    class="sr-only"
    aria-live="polite"
    aria-atomic="true"
  ></div>

  <ul id="docs-search-results" class="search-results" aria-label="Search results">
  </ul>
</div>

<script>
  const input = document.getElementById('docs-search-input');
  const resultsList = document.getElementById('docs-search-results');
  const statusRegion = document.getElementById('docs-search-status');

  // Optimization: Debounce function to prevent API calls on every keystroke
  function debounce(func, wait) {
    let timeout;
    return function(...args) {
      const context = this;
      clearTimeout(timeout);
      timeout = setTimeout(() => func.apply(context, args), wait);
    };
  }

  function updateStatus(message) {
    if (statusRegion) statusRegion.textContent = message;
  }

  let searchController;

  async function runSearch(query) {
    // Abort previous request if it exists
    if (searchController) {
      searchController.abort();
    }
    searchController = new AbortController();
    const signal = searchController.signal;

    if (!query.trim()) {
      if(resultsList) resultsList.innerHTML = '';
      if(input) input.setAttribute('aria-expanded', 'false');
      updateStatus('');
      return;
    }

    // Show loading state
    if (resultsList) {
       // Keep old results or show specific loading UI if preferred
       // For now, let's just use the status region for screen readers
       updateStatus('Searching...');
       input?.setAttribute('aria-busy', 'true');
    }

    try {
      const res = await fetch('/api/docs-search?q=' + encodeURIComponent(query), { signal });
      if (!res.ok) {
        if (resultsList) resultsList.innerHTML = '';
        input?.setAttribute('aria-expanded', 'false');
        console.error(`Search request failed with status ${res.status}: ${res.statusText}`);
        updateStatus('Search failed. Please try again.');
        input?.removeAttribute('aria-busy');
        return;
      }
      const results = await res.json();
      input?.removeAttribute('aria-busy');

      if (resultsList) {
        resultsList.innerHTML = ''; // Clear previous results

        if (results.length === 0) {
            const li = document.createElement('li');
            li.textContent = 'No results found.';
            li.style.padding = '0.5em 0';
            resultsList.appendChild(li);
            updateStatus('No results found.');
            input?.setAttribute('aria-expanded', 'true');
        } else {
            results.forEach((r) => {
                const li = document.createElement('li');
                const a = document.createElement('a');
                // Sentinel: Basic protection against javascript: URIs
                if (r.url && !r.url.trim().toLowerCase().startsWith('javascript:')) {
                    a.href = r.url;
                } else {
                    a.href = '#';
                    console.warn('Blocked potentially unsafe URL in search results');
                }
                a.textContent = r.title; // Sentinel: Prevent XSS by using textContent instead of innerHTML
                a.style.display = 'block'; // Ensure hit area is good
                a.style.padding = '0.25em 0'; // Add some breathing room
                li.appendChild(a);
                resultsList.appendChild(li);
            });
            updateStatus(`${results.length} results found.`);
            input?.setAttribute('aria-expanded', 'true');
        }
      }
    } catch (e) {
      if (e.name === 'AbortError') return; // Ignore aborted requests
      input?.removeAttribute('aria-busy');
      if (resultsList) {
        resultsList.innerHTML = '';
        const li = document.createElement('li');
        li.className = 'search-error';
        li.style.color = 'red';
        li.style.marginTop = '0.5em';
        li.textContent = 'Sorry, search failed. Please try again.';
        resultsList.appendChild(li);
      }
      updateStatus('Search error.');
      console.error("Search failed", e);
    }
  }

  if (input) {
    // Wait 300ms after user stops typing before searching
    const debouncedSearch = debounce((e) => {
      runSearch((e.target as HTMLInputElement).value);
    }, 300);

    input.addEventListener('input', debouncedSearch);
  }
</script>
