---
const props = Astro.props;
---

<div class="code-block group">
  <button class="copy-btn" aria-label="Copy code to clipboard" title="Copy code">
    <span class="icon copy-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
    </span>
    <span class="icon check-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
    </span>
  </button>
  <pre {...props}><slot /></pre>
</div>

<style>
  .code-block {
    position: relative;
    background: #1e1e1e;
    background: var(--gs-color-surface-dark, #1e1e1e);
    border-radius: 4px;
    margin: 1rem 0;
  }

  .code-block pre {
    margin: 0;
    padding: 1rem;
    overflow-x: auto;
    color: #e4e4e7;
    font-family: var(--gs-font-mono, monospace);
  }

  /* Copy Button - Hidden by default, visible on hover/focus */
  .copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: white;
    padding: 0.25rem;
    width: 2rem;
    height: 2rem;
    border-radius: 4px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: all 0.2s ease;
    z-index: 10;
  }

  /* Accessibility: Show on hover OR focus */
  .code-block:hover .copy-btn,
  .copy-btn:focus,
  .copy-btn:focus-visible {
    opacity: 1;
  }

  .copy-btn:hover {
    background: rgba(255,255,255,0.2);
  }

  .copy-btn:active {
    transform: translateY(1px);
  }

  .icon {
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none; /* Let clicks pass to button */
  }

  .check-icon {
    display: none;
    color: #4ade80; /* Green-400 */
  }

  /* Success State */
  .copy-btn.copied .copy-icon {
    display: none;
  }

  .copy-btn.copied .check-icon {
    display: flex;
  }

  .copy-btn.copied {
    border-color: #4ade80;
    background: rgba(74, 222, 128, 0.1);
    opacity: 1; /* Keep visible while showing success */
  }
</style>

<script>
  // One-time event delegation setup
  if (!(window as any)._codeBlockCopyInitialized) {
      (window as any)._codeBlockCopyInitialized = true;

      document.addEventListener('click', async (e) => {
          const target = e.target as HTMLElement;
          const btn = target.closest('.copy-btn');
          if (!btn) return;

          const pre = btn.parentElement?.querySelector('pre') as HTMLElement;
          if (!pre) return;

          try {
             await navigator.clipboard.writeText(pre.innerText);

             // Visual feedback
             btn.classList.add('copied');
             btn.setAttribute('aria-label', 'Copied!');

             // Reset after 2s
             setTimeout(() => {
                btn.classList.remove('copied');
                btn.setAttribute('aria-label', 'Copy code to clipboard');
             }, 2000);
          } catch(err) {
              console.error('Copy failed', err);
          }
      });
  }
</script>
