---
const props = Astro.props;
---

<div class="code-block">
  <button class="copy" aria-label="Copy code">Copy</button>
  <pre {...props}><slot /></pre>
</div>

<script>
  // Use event delegation for better performance and to handle dynamically added blocks if any
  document.addEventListener('click', async (e) => {
    const target = (e.target as HTMLElement).closest('.copy') as HTMLElement | null;
    if (!target) return;

    const codeBlock = target.closest('.code-block');
    if (!codeBlock) return;

    const pre = codeBlock.querySelector('pre') as HTMLElement | null;
    if (!pre) return;

    const code = pre.innerText;

    try {
      await navigator.clipboard.writeText(code);
      const originalText = target.innerText;
      target.innerText = 'Copied!';
      target.setAttribute('aria-label', 'Copied to clipboard');

      setTimeout(() => {
        target.innerText = originalText;
        target.setAttribute('aria-label', 'Copy code');
      }, 2000);
    } catch (err) {
      console.error('Failed to copy:', err);
      target.innerText = 'Error';
      setTimeout(() => {
        target.innerText = 'Copy';
      }, 2000);
    }
  });
</script>

<style>
  .code-block {
    position: relative;
    background: #1e1e1e; /* Example dark theme */
    border-radius: 4px;
    margin: 1rem 0;
  }
  .code-block pre {
    margin: 0;
    padding: 1rem;
    overflow-x: auto;
    color: #e4e4e7;
  }
  .code-block .copy {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: rgba(255,255,255,0.1);
    border: none;
    color: white;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.8rem;
    opacity: 0;
    transition: opacity 0.2s, background-color 0.2s;
  }
  .code-block:hover .copy,
  .code-block:focus-within .copy {
    opacity: 1;
  }
  .code-block .copy:focus-visible {
    opacity: 1;
    outline: 2px solid white;
    outline-offset: 2px;
  }
  .code-block .copy:hover {
    background: rgba(255,255,255,0.2);
  }
</style>
