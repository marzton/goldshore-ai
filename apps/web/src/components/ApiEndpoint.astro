---
import ApiSchema from './ApiSchema.astro';
import TryItConsole from './TryItConsole.astro';

const { openapi, endpoint, endpointId } = Astro.props;
// Support legacy endpointId prop if needed
const targetEndpoint = endpoint || endpointId;

// Support both props for compatibility
const targetEndpoint = endpointId || endpoint;

// normalize endpoint to look up in paths
// endpoint from props might be "system/status"
// path keys in openapi are usually "/system/status"
const pathKey = targetEndpoint.startsWith('/') ? targetEndpoint : '/' + targetEndpoint;

const pathItem = openapi?.paths?.[pathKey];
const methods = ['get', 'post', 'put', 'delete', 'patch'];
---

<section class="api-endpoint">
  {pathItem ? (
    <>
      <h2>{pathKey}</h2>
      <div class="methods">
        {methods.map((method) => {
          const op = pathItem[method];
          if (!op) return null;
          return (
            <article class="method-block">
              <header>
                <span class={`method-badge ${method}`}>{method.toUpperCase()}</span>
                <h3>{op.summary || op.operationId}</h3>
              </header>
              <p>{op.description}</p>

              <div class="op-details">
                {op.parameters && (
                  <div>
                    <h4>Parameters</h4>
                    <pre>{JSON.stringify(op.parameters, null, 2)}</pre>
                  </div>
                )}
              </div>

              <TryItConsole method={method} path={pathKey} openapi={openapi} />
            </article>
          );
        })}
      </div>
    </>
  ) : (
    <div class="endpoint-not-found">
        <h2>{targetEndpoint}</h2>
        <p>Endpoint not found in specification.</p>
    </div>
  )}
</section>

<style>
  .api-endpoint {
    padding: 1rem;
  }
  .method-block {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: var(--gs-surface-2, #f8fafc);
    border: 1px solid var(--gs-border, #e2e8f0);
    border-radius: 0.5rem;
  }
  .method-badge {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-weight: bold;
    font-size: 0.8rem;
    margin-right: 1rem;
    text-transform: uppercase;
  }
  .method-badge.get { background: #0ea5e9; color: white; }
  .method-badge.post { background: #22c55e; color: white; }
  .method-badge.put { background: #eab308; color: black; }
  .method-badge.delete { background: #ef4444; color: white; }

  pre {
    background: #1e293b;
    color: #e2e8f0;
    padding: 1rem;
    border-radius: 0.375rem;
    overflow-x: auto;
  }
</style>
