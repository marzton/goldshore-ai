---
import ApiSchema from './ApiSchema.astro';
import TryItConsole from './TryItConsole.astro';

const { openapi, endpointId } = Astro.props;

const methods = ['get', 'post', 'put', 'delete', 'patch'];

const match = endpointId
  ? Object.entries(openapi.paths || {}).find(([path]) => path.replace(/^\//, '') === endpointId)
  : null;

const path = match?.[0];
const ops = match?.[1];
---

{match ? (
  <section class="api-endpoint">
    <h1>{path}</h1>

    {methods.map((method) => (
      ops[method] && (
        <article class="method-block">
          <h2>{method.toUpperCase()}</h2>
          <p>{ops[method].description}</p>

          <h3>Parameters</h3>
          <ApiSchema schema={ops[method].parameters} />

          <h3>Request Body</h3>
          {ops[method].requestBody && (
            <ApiSchema schema={ops[method].requestBody.content} />
          )}

          <h3>Responses</h3>
          <ApiSchema schema={ops[method].responses} />

          <h3>Try It</h3>
          <TryItConsole method={method} path={path} openapi={openapi} />
        </article>
      )
    ))}
  </section>
) : (
  <p class="endpoint-empty">Endpoint not found.</p>
)}

<style>
  .method-block {
    margin-bottom: 2.5rem;
    padding: 1.5rem;
    border-radius: 1rem;
    background: rgba(15, 23, 42, 0.8);
    border: 1px solid rgba(148, 163, 184, 0.3);
  }

  .endpoint-empty {
    padding: 2rem;
  }
</style>
