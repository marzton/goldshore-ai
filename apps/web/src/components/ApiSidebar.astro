---
const { openapi } = Astro.props;
const paths = Object.keys(openapi.paths ?? {}).sort();
---
<aside class="api-sidebar">
  <h3>{openapi.info.title}</h3>
  <ul>
    {paths.length ? paths.map((path) => (
      <li><a href={encodeURI(`/developer/api${path}`)}>{path}</a></li>
    )) : (
      <li>No endpoints available.</li>
    ))}
  </ul>
</aside>
<style>
  .api-sidebar { width: 250px; border-right: 1px solid var(--gs-border); padding: 1rem; }
  ul { list-style: none; padding: 0; }
  li { margin-bottom: 0.5rem; }
</style>
