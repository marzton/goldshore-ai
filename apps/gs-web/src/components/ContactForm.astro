---
const { heading = 'Contact operations', compact = false } = Astro.props;
---

<form data-contact-form class:list={['contact-form', compact && 'contact-form--compact']} action="/api/contact" method="post">
  <input type="hidden" name="formType" value="contact" />
  <input type="hidden" name="redirectTo" value="/thank-you" />
  <input type="hidden" name="formStartedAt" value="" />

  <div class="contact-form__header">
    <p class="gs-eyebrow">Direct channel</p>
    <h2>{heading}</h2>
    <p>Share your brief. GoldShore responds with scope, next steps, and operating cadence.</p>
  </div>

  <div class="contact-form__honeypot" aria-hidden="true">
    <label>
      <span>Company website</span>
      <input name="companyWebsite" type="text" autocomplete="off" tabindex="-1" />
    </label>
  </div>

  <div class="contact-form__grid">
    <label class="form-field">
      <span class="label-text">Name</span>
      <input name="name" type="text" placeholder="Your full name" autocomplete="name" required />
    </label>
    <label class="form-field">
      <span class="label-text">Work email</span>
      <input name="email" type="email" placeholder="name@company.com" autocomplete="email" spellcheck="false" required />
    </label>
    <label class="form-field">
      <span class="label-text">Inquiry type</span>
      <div class="select-wrapper">
        <select name="inquiry">
          <option value="general">General inquiry</option>
          <option value="strategy-call">Strategy call</option>
          <option value="project-scope">Project scoping</option>
          <option value="support">Support</option>
        </select>
      </div>
    </label>
    <label class="form-field">
      <span class="label-text">Timeline</span>
      <input name="timeline" type="text" placeholder="e.g. 2-6 weeks" />
    </label>
    <label class="form-field contact-form__message">
      <span class="label-text">Project brief</span>
      <textarea
        name="message"
        rows="5"
        placeholder="Outline the system, risk, or AI workflow you need to operationalize."
        required
      ></textarea>
    </label>
  </div>

  <div class="contact-form__footer">
    <div data-contact-form-status class="contact-form__status" aria-live="polite" role="status"></div>
    <button type="submit" class="contact-form__submit">
      <span data-contact-form-submit-text>Send brief</span>
      <svg class="submit-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M3.33331 8H12.6666M12.6666 8L7.99998 3.33334M12.6666 8L7.99998 12.6667" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</form>

<script>
  const contactFormGlobal = window as typeof window & {
    __gsContactFormsBound?: boolean;
  };

  const initContactForm = (form: HTMLFormElement) => {
    if (form.dataset.contactFormBound === 'true') return;
    form.dataset.contactFormBound = 'true';

    const status = form.querySelector('[data-contact-form-status]');
    const button = form.querySelector('button[type="submit"]');
    const submitText = form.querySelector('[data-contact-form-submit-text]');
    if (!(button instanceof HTMLButtonElement)) return;

    const setStatus = (message, type) => {
      if (!(status instanceof HTMLElement)) return;
      status.textContent = message;
      status.className = 'contact-form__status';
      if (type) status.classList.add(`contact-form__status--${type}`);
    };

    const startedAtField = form.querySelector('[name="formStartedAt"]');
    if (startedAtField instanceof HTMLInputElement) {
      startedAtField.value = String(Date.now());
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (button.disabled) return;

      if (!form.checkValidity()) {
        form.reportValidity();
        setStatus('Please complete the required fields.', 'error');
        return;
      }

      const originalText = submitText instanceof HTMLElement ? submitText.textContent ?? 'Send brief' : 'Send brief';
      button.disabled = true;
      button.setAttribute('aria-busy', 'true');
      if (submitText instanceof HTMLElement) submitText.textContent = 'Sending…';
      setStatus('Sending your brief…', 'progress');

      try {
        const response = await fetch(form.getAttribute('action') || '/api/contact', {
          method: form.getAttribute('method') || 'POST',
          body: new FormData(form),
        });

        if (!response.ok && !response.redirected) {
          throw new Error(`Submission failed: ${response.status}`);
        }

        const redirectField = form.querySelector('[name="redirectTo"]');
        const redirectTarget =
          response.redirected && response.url
            ? response.url
            : redirectField instanceof HTMLInputElement && redirectField.value
              ? redirectField.value
              : '/thank-you';

        window.location.href = redirectTarget;
      } catch (error) {
        console.error(error);
        button.disabled = false;
        button.removeAttribute('aria-busy');
        if (submitText instanceof HTMLElement) submitText.textContent = originalText;
        setStatus('Unable to send. Please email hello@goldshore.ai.', 'error');
      }
    });
  };

  const bindContactForms = () => {
    document.querySelectorAll('[data-contact-form]').forEach((node) => {
      if (node instanceof HTMLFormElement) {
        initContactForm(node);
      }
    });
  };

  if (!contactFormGlobal.__gsContactFormsBound) {
    contactFormGlobal.__gsContactFormsBound = true;
    document.addEventListener('astro:page-load', bindContactForms);
  }

  bindContactForms();
</script>

<style>
  .contact-form {
    position: relative;
    display: grid;
    gap: 2.5rem;
    padding: clamp(1.5rem, 5vw, 3.5rem);
    border-radius: 32px;
    background: #0a0f1b;
    border: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.4);
  }

  .contact-form--compact {
    gap: 1.5rem;
    padding: 2rem;
  }

  .contact-form__header {
    text-align: center;
    max-width: 50ch;
    margin: 0 auto;
  }

  .contact-form__header h2 {
    margin: 0.75rem 0 1rem;
    font-family: 'Lexend', var(--font-sans);
    font-weight: 700;
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  .contact-form__header p {
    margin: 0;
    color: var(--gs-text-dim);
    line-height: 1.6;
    font-size: 1.1rem;
  }

  .contact-form__honeypot {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }

  .contact-form__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .label-text {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gs-primary);
    padding-left: 0.2rem;
  }

  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    width: 100%;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.03);
    color: #ffffff;
    padding: 1rem 1.2rem;
    font-size: 1rem;
    outline: none;
    transition: all 160ms ease;
  }

  .contact-form input::placeholder,
  .contact-form textarea::placeholder {
    color: rgba(255, 255, 255, 0.2);
  }

  .contact-form input:hover,
  .contact-form select:hover,
  .contact-form textarea:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.12);
  }

  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    background: rgba(255, 255, 255, 0.06);
    border-color: var(--gs-primary);
    box-shadow: 0 0 0 4px rgba(90, 162, 255, 0.1);
  }

  .select-wrapper {
    position: relative;
  }

  .select-wrapper::after {
    content: '';
    position: absolute;
    right: 1.2rem;
    top: 50%;
    transform: translateY(-50%);
    width: 10px;
    height: 6px;
    background-color: var(--gs-text-dim);
    clip-path: polygon(0 0, 100% 0, 50% 100%);
    pointer-events: none;
  }

  .contact-form select {
    appearance: none;
    padding-right: 3rem;
  }

  .contact-form textarea {
    min-height: 140px;
    resize: vertical;
    line-height: 1.5;
  }

  .contact-form__message {
    grid-column: 1 / -1;
  }

  .contact-form__footer {
    display: flex;
    gap: 2rem;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 2rem;
  }

  .contact-form__status {
    flex: 1;
    color: var(--gs-text-dim);
    font-size: 0.95rem;
    font-weight: 500;
  }

  .contact-form__status--progress {
    color: var(--gs-primary);
  }

  .contact-form__status--error {
    color: #ff5f56;
  }

  .contact-form__submit {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    border: none;
    border-radius: 999px;
    background: var(--gs-primary);
    color: #020617;
    padding: 1rem 2rem;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    transition: all 160ms ease;
    box-shadow: 0 8px 20px rgba(90, 162, 255, 0.2);
  }

  .contact-form__submit:hover:not(:disabled) {
    transform: translateY(-2px);
    filter: brightness(1.1);
    box-shadow: 0 12px 28px rgba(90, 162, 255, 0.3);
  }

  .submit-arrow {
    transition: transform 160ms ease;
  }

  .contact-form__submit:hover .submit-arrow {
    transform: translateX(3px);
  }

  .contact-form__submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    background: var(--gs-text-dim);
    box-shadow: none;
  }

  @media (max-width: 768px) {
    .contact-form__grid {
      grid-template-columns: 1fr;
    }

    .contact-form__footer {
      flex-direction: column;
      gap: 1.5rem;
      text-align: center;
    }

    .contact-form__submit {
      width: 100%;
      justify-content: center;
    }
  }
</style>
