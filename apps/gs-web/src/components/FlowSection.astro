---
const { variant = 'section', class: className = '', id } = Astro.props;
const innerClass =
  variant === 'hero' ? 'gs-hero' : 'gs-section';
const sectionClass = [
  'gs-flow-section',
  `gs-flow-section--${variant}`,
  className
]
  .filter(Boolean)
  .join(' ');
---
<section id={id} class={sectionClass}>
  <div class="gs-flow-section__bg" aria-hidden="true">
    <span class="gs-flow-section__layer gs-flow-section__layer--a"></span>
    <span class="gs-flow-section__layer gs-flow-section__layer--b"></span>
    <span class="gs-flow-section__flow gs-flow-section__flow--top"></span>
    <span class="gs-flow-section__flow gs-flow-section__flow--bottom"></span>
  </div>
  <div class={`gs-flow-section__inner ${innerClass}`}>
    <slot />
  </div>
</section>
