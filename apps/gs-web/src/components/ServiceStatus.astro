---
// This component can be used in your Dashboard or Settings pages
interface Props {
  serviceUrl: string; // e.g., "https://api.goldshore.ai/health"
}

const { serviceUrl } = Astro.props;
---

<div class="service-status-card p-6 rounded-2xl border border-[var(--gs-border-primary)] bg-white shadow-sm">
  <div class="flex items-center justify-between mb-6">
    <h3 class="text-lg font-bold gs-heading">System Vitality</h3>
    <div id="status-indicator" class="flex items-center gap-2">
      <span class="h-3 w-3 rounded-full bg-gray-300 animate-pulse"></span>
      <span class="text-sm font-medium text-gray-500">Initializing...</span>
    </div>
  </div>

  

  <div class="space-y-4">
    <div class="flex justify-between items-center py-2 border-b border-[var(--gs-border-primary)]">
      <span class="text-sm text-[var(--gs-text-secondary)]">API Gateway</span>
      <span id="api-val" class="text-sm font-mono text-gray-400">--</span>
    </div>
    <div class="flex justify-between items-center py-2 border-b border-[var(--gs-border-primary)]">
      <span class="text-sm text-[var(--gs-text-secondary)]">KV Store (Edge)</span>
      <span id="kv-val" class="text-sm font-mono text-gray-400">--</span>
    </div>
    <div class="flex justify-between items-center py-2">
      <span class="text-sm text-[var(--gs-text-secondary)]">D1 Database</span>
      <span id="db-val" class="text-sm font-mono text-gray-400">--</span>
    </div>
  </div>

  <button 
    type="button"
    id="trigger-deep-check"
    class="mt-6 w-full py-2 bg-[var(--gs-bg-secondary)] border border-[var(--gs-border-primary)] rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-gray-100 transition-colors"
  >
    Perform Deep Validation
  </button>
</div>

<script define:vars={{ serviceUrl }}>
  const btn = document.getElementById('trigger-deep-check');
  const indicator = document.getElementById('status-indicator');

  async function checkHealth(type = 'shallow') {
    try {
      const res = await fetch(`${serviceUrl}?type=${type}`);
      const data = await res.json();
      
      // Update UI based on response
      const color = data.status === 'ok' ? 'bg-emerald-500' : 'bg-red-500';
      indicator.innerHTML = `<span class="h-3 w-3 rounded-full ${color}"></span><span class="text-sm font-bold uppercase">${data.status}</span>`;
      
      if (data.kv !== undefined && data.kv !== null) {
        const kvString = typeof data.kv === 'string' ? data.kv : String(data.kv);
        document.getElementById('kv-val').innerText = kvString.toUpperCase();
      }
      if (data.db !== undefined && data.db !== null) {
        const dbString = typeof data.db === 'string' ? data.db : String(data.db);
        document.getElementById('db-val').innerText = dbString.toUpperCase();
      }
    } catch (e) {
      indicator.innerHTML = `<span class="h-3 w-3 rounded-full bg-red-500"></span><span class="text-sm font-bold uppercase">OFFLINE</span>`;
    }
  }

  btn.addEventListener('click', () => checkHealth('deep'));
  // Initial shallow check
  checkHealth();
</script>

<style>
  :root {
    --gs-border-primary: #e5e7eb;
    --gs-text-secondary: #6b7280;
    --gs-bg-secondary: #f9fafb;
  }
</style>
