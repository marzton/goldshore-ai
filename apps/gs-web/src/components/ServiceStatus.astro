---
// This component can be used in your Dashboard or Settings pages
interface Props {
  serviceUrl: string; // e.g., "https://api.goldshore.ai/health"
}

const { serviceUrl } = Astro.props;
---

<div
  class="service-status-card p-6 rounded-2xl border border-[var(--gs-border-primary)] bg-white shadow-sm"
>
  <div class="flex items-center justify-between mb-6">
    <h3 class="text-lg font-bold gs-heading">System Vitality</h3>
    <div
      id="status-indicator"
      class="flex items-center gap-2"
      aria-live="polite"
    >
      <span class="status-dot h-3 w-3 rounded-full bg-gray-300 animate-pulse"
      ></span>
      <span class="status-text text-sm font-medium text-gray-500"
        >Initializing...</span
      >
    </div>
  </div>

  <div class="space-y-4">
    <div
      class="flex justify-between items-center py-2 border-b border-[var(--gs-border-primary)]"
    >
      <span class="text-sm text-[var(--gs-text-secondary)]">API Gateway</span>
      <span id="api-val" class="text-sm font-mono text-gray-400">--</span>
    </div>
    <div
      class="flex justify-between items-center py-2 border-b border-[var(--gs-border-primary)]"
    >
      <span class="text-sm text-[var(--gs-text-secondary)]"
        >KV Store (Edge)</span
      >
      <span id="kv-val" class="text-sm font-mono text-gray-400">--</span>
    </div>
    <div class="flex justify-between items-center py-2">
      <span class="text-sm text-[var(--gs-text-secondary)]">D1 Database</span>
      <span id="db-val" class="text-sm font-mono text-gray-400">--</span>
    </div>
  </div>

  <button
    id="trigger-deep-check"
    class="mt-6 w-full py-2 bg-[var(--gs-bg-secondary)] border border-[var(--gs-border-primary)] rounded-lg text-xs font-bold uppercase tracking-widest hover:bg-gray-100 transition-colors flex items-center justify-center gap-2 disabled:cursor-not-allowed disabled:opacity-70"
  >
    <span class="btn-text">Perform Deep Validation</span>
    <svg
      class="spinner h-4 w-4 animate-spin hidden"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      <circle
        class="opacity-25"
        cx="12"
        cy="12"
        r="10"
        stroke="currentColor"
        stroke-width="4"
        fill="none"></circle>
      <path
        class="opacity-75"
        fill="currentColor"
        d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
      ></path>
    </svg>
  </button>
</div>

<script is:inline define:vars={{ serviceUrl }}>
  const btn = document.getElementById('trigger-deep-check');
  const btnText = btn.querySelector('.btn-text');
  const spinner = btn.querySelector('.spinner');
  const indicator = document.getElementById('status-indicator');
  const dot = indicator.querySelector('.status-dot');
  const text = indicator.querySelector('.status-text');
  let activeRequestController;

  async function checkHealth(type = 'shallow') {
    activeRequestController?.abort();
    activeRequestController = new AbortController();
    const { signal } = activeRequestController;

    if (type === 'deep') {
      btn.disabled = true;
      btnText.textContent = 'Validating...';
      spinner.classList.remove('hidden');
    }

    try {
      const res = await fetch(`${serviceUrl}?type=${type}`, { signal });
      const data = await res.json();

      // Update UI based on response
      const color = data.status === 'ok' ? 'bg-emerald-500' : 'bg-red-500';
      dot.className = `status-dot h-3 w-3 rounded-full ${color}`;
      text.className = 'status-text text-sm font-bold uppercase';
      text.textContent = data.status;

      document.getElementById('api-val').innerText = 'CONNECTED';
      if (data.kv)
        document.getElementById('kv-val').innerText = data.kv.toUpperCase();
      if (data.db)
        document.getElementById('db-val').innerText = data.db.toUpperCase();
    } catch (error) {
      if (error instanceof DOMException && error.name === 'AbortError') {
        return;
      }

      dot.className = 'status-dot h-3 w-3 rounded-full bg-red-500';
      text.className = 'status-text text-sm font-bold uppercase';
      text.textContent = 'OFFLINE';
    } finally {
      if (signal === activeRequestController?.signal) {
        activeRequestController = undefined;
      }

      if (type === 'deep' && !signal.aborted) {
        btn.disabled = false;
        btnText.textContent = 'Perform Deep Validation';
        spinner.classList.add('hidden');
      }
    }
  }

  btn.addEventListener('click', () => checkHealth('deep'));
  // Initial shallow check
  checkHealth();
</script>
