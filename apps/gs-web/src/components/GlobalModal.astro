<div
  class="gs-modal"
  data-gs-modal
  role="dialog"
  aria-modal="true"
  aria-labelledby="gs-modal-title"
  aria-describedby="gs-modal-desc"
  tabindex="-1"
>
  <div class="gs-modal-backdrop" data-gs-modal-backdrop></div>
  <div class="gs-modal-panel gs-mirror-frame">
    <button class="gs-modal-close gs-icon-btn" data-gs-modal-close aria-label="Close">×</button>
    <h2 id="gs-modal-title" class="sr-only">Modal</h2>
    <p id="gs-modal-desc" class="sr-only">Modal Content</p>
    <div class="gs-modal-body" data-gs-modal-body></div>
  </div>
</div>

<style>
  .gs-modal {
    position: fixed;
    inset: 0;
    display: grid;
    place-items: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--gs-mid) var(--gs-ease);
    z-index: 80;
  }
  .gs-modal.is-open {
    opacity: 1;
    pointer-events: auto;
  }
  .gs-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(10px);
  }
  .gs-modal-panel {
    position: relative;
    width: min(560px, 92vw);
    padding: 1.7rem;
    transform: translateY(26px);
    transition: transform var(--gs-mid) var(--gs-ease);
    z-index: 1;
  }
  .gs-modal.is-open .gs-modal-panel { transform: translateY(0); }
  .gs-modal-close { position: absolute; top: 14px; right: 14px; }
  .gs-modal-title { margin-top: 0.2rem; }
</style>

<script>
  document.addEventListener("keydown", (e) => {
    if (e.key !== "Escape") return;
    const openModal = document.querySelector(".gs-modal.is-open");
    if (!openModal) return;
    openModal.querySelector("[data-gs-modal-close],.gs-modal-close")?.click();
  });
</script>
