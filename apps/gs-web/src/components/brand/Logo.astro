---
const {
  title = 'Gold Shore logo',
  class: className,
  ariaHidden = false,
  variant = 'mark',
} = Astro.props;

const isLockup = variant === 'lockup';
const viewBox = isLockup ? '0 0 440 128' : '0 0 128 128';
---

<svg
  viewBox={viewBox}
  role={ariaHidden ? undefined : 'img'}
  aria-hidden={ariaHidden ? 'true' : undefined}
  aria-label={ariaHidden ? undefined : title}
  class:list={[className, 'gs-brand-logo', isLockup && 'gs-brand-logo--lockup']}
  xmlns="http://www.w3.org/2000/svg"
  fill="none"
>
  {!ariaHidden && <title>{title}</title>}

  <style>
    .gs-brand-logo {
      overflow: visible;
    }

    .gs-brand-logo__mark-fill {
      fill: currentColor;
    }

    .gs-brand-logo__mark-stroke {
      stroke: currentColor;
      stroke-width: 2.4;
      stroke-linejoin: round;
    }

    .gs-brand-logo__wordmark {
      fill: currentColor;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      font-size: 42px;
      font-weight: 800;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }

    .gs-brand-logo__wordmark-accent {
      opacity: 0.9;
    }
  </style>

  <g class="gs-brand-logo__mark" transform={isLockup ? 'translate(0 0)' : undefined}>
    <g class="gs-brand-logo__mark-fill">
      <path d="M64 12 22 86h18.5L72 30.5H64Z" />
      <path d="M64 12h8l33.8 58.4-9.3 16.2L64 30.5Z" opacity="0.94" />
      <path d="M22 86h74.5L87.2 102H31.2z" opacity="0.88" />
    </g>
    <path
      class="gs-brand-logo__mark-stroke"
      d="M64 12 22 86h18.5L72 30.5H64Zm8 0h-8l33.8 58.4-9.3 16.2L64 30.5Zm-50 74 9.2 16h56l9.3-16H22Z"
    />
  </g>

  {
    isLockup && (
      <g transform="translate(146 76)">
        <text class="gs-brand-logo__wordmark">
          <tspan class="gs-brand-logo__wordmark-accent" x="0" y="0">GOLD</tspan>
          <tspan x="142" y="0">SHORE</tspan>
        </text>
      </g>
    )
  }
</svg>
