---
interface Props {
  name: 'radar' | 'ops' | 'hub';
  class?: string;
}

const { name = 'radar', class: className } = Astro.props;

const icons: Record<Props['name'], string> = {
  radar:
    '<path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke-width="2" /><path d="M12 12H19" stroke-width="2" stroke-linecap="round" /><circle cx="12" cy="12" r="2" fill="currentColor" />',
  ops:
    '<path d="M12 15V17M12 7V9M7 12H9M15 12H17" stroke-width="2" stroke-linecap="round" /><path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z" stroke-width="2" />',
  hub:
    '<path d="M12 3L4 9V21H20V9L12 3Z" stroke-width="2" /><path d="M9 14H15V21H9V14Z" stroke-width="2" />',
};

const iconContent = icons[name] ?? icons.radar;
---

<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  aria-hidden="true"
  class={className}
  set:html={iconContent}
/>
