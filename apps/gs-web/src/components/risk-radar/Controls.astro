---
interface Tier {
  id: string;
  label: string;
}

interface Props {
  tiers: Tier[];
  selectedTier: string;
  state: string;
}

const { tiers, selectedTier = 'all', state = 'ready' } = Astro.props;
---

<section class="gs-card rounded-3xl border border-[var(--gs-border-primary)] bg-white p-6">
  <h3 class="mb-4 text-lg font-bold">Controls</h3>
  <div class="space-y-4">
    <label class="block">
      <span class="mb-2 block text-xs font-semibold uppercase tracking-[0.12em] text-[var(--gs-text-secondary)]">Tier Filter</span>
      <select class="w-full rounded-xl border border-[var(--gs-border-primary)] bg-[var(--gs-bg-tertiary)] px-3 py-2" value={selectedTier}>
        <option value="all">All Tiers</option>
        {tiers.map((tier) => (
          <option value={tier.id}>{tier.label}</option>
        ))}
      </select>
    </label>

    <div class="rounded-xl border border-[var(--gs-border-primary)] bg-[var(--gs-bg-tertiary)] p-3">
      <p class="text-xs font-semibold uppercase tracking-[0.12em] text-[var(--gs-text-secondary)]">Scaffold State</p>
      <p class="mt-1 font-mono text-sm text-blue-700">{state}</p>
    </div>
  </div>
</section>
