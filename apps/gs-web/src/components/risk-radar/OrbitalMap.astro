---
interface Tier {
  id: string;
  label: string;
  radius: number;
}

interface Node {
  id: string;
  label: string;
  tier: string;
  status: 'stable' | 'monitoring' | 'critical';
  metrics: {
    exposure: number;
  };
}

interface Props {
  tiers: Tier[];
  nodes: Node[];
  state: string;
}

const { tiers = [], nodes = [], state = 'ready' } = Astro.props;
const center = 240;
const statusColor = {
  stable: '#10b981',
  monitoring: '#f59e0b',
  critical: '#ef4444'
};

const nodesByTier = tiers.map((tier) => ({
  ...tier,
  nodes: nodes.filter((node) => node.tier === tier.id)
}));
---

<section class="gs-card relative rounded-3xl border border-[var(--gs-border-primary)] bg-black/95 p-6 text-white min-h-[460px]">
  <header class="mb-4 flex items-center justify-between">
    <h3 class="text-lg font-bold">Orbital Map</h3>
    <span class="rounded-full border border-blue-500/50 bg-blue-500/20 px-3 py-1 text-xs uppercase tracking-[0.12em] text-blue-200">
      {state}
    </span>
  </header>

  {state === 'loading' && (
    <div class="flex h-[380px] items-center justify-center rounded-2xl border border-blue-500/30 bg-blue-950/30">
      <p class="font-mono text-blue-200">Loading telemetry snapshot…</p>
    </div>
  )}

  {state === 'error' && (
    <div class="flex h-[380px] items-center justify-center rounded-2xl border border-red-500/30 bg-red-950/20">
      <p class="font-mono text-red-200">Telemetry unavailable. Retry data ingest pipeline.</p>
    </div>
  )}

  {state !== 'loading' && state !== 'error' && nodes.length === 0 && (
    <div class="flex h-[380px] items-center justify-center rounded-2xl border border-slate-500/30 bg-slate-900/50">
      <p class="font-mono text-slate-300">No risk nodes found for the selected scope.</p>
    </div>
  )}

  {state !== 'loading' && state !== 'error' && nodes.length > 0 && (
    <svg viewBox="0 0 480 480" class="h-[380px] w-full rounded-2xl border border-blue-500/25 bg-slate-950/90">
      {tiers.map((tier) => (
        <g>
          <circle cx={center} cy={center} r={tier.radius} fill="none" stroke="#1d4ed8" stroke-opacity="0.4" stroke-width="1.5"></circle>
          <text x={center + tier.radius + 8} y={center} fill="#93c5fd" font-size="10">{tier.label}</text>
        </g>
      ))}

      {nodesByTier.map((tierGroup) =>
        tierGroup.nodes.map((node, index) => {
          const angle = (Math.PI * 2 * index) / Math.max(tierGroup.nodes.length, 1);
          const x = center + Math.cos(angle) * tierGroup.radius;
          const y = center + Math.sin(angle) * tierGroup.radius;
          const fill = statusColor[node.status] ?? '#60a5fa';

          return (
            <g>
              <circle cx={x} cy={y} r="11" fill={fill}></circle>
              <text x={x + 14} y={y + 3} fill="#e2e8f0" font-size="10">{node.id}</text>
            </g>
          );
        })
      )}
    </svg>
  )}
</section>
