---
interface Node {
  id: string;
  label: string;
  status: string;
  metrics: {
    exposure: number;
    volatility: number;
    signalStrength: number;
  };
  dependencies: string[];
}

interface Props {
  nodes: Node[];
}

const { nodes = [] } = Astro.props;
---

<section class="gs-card rounded-3xl border border-[var(--gs-border-primary)] bg-white p-6">
  <h3 class="mb-4 text-lg font-bold">Details Panel</h3>
  <div class="space-y-4">
    {nodes.map((node) => (
      <article class="rounded-xl border border-[var(--gs-border-primary)] bg-[var(--gs-bg-tertiary)] p-4">
        <div class="mb-2 flex items-start justify-between gap-2">
          <div>
            <p class="text-xs font-mono text-[var(--gs-text-secondary)]">{node.id}</p>
            <h4 class="font-semibold">{node.label}</h4>
          </div>
          <span class="text-xs font-bold uppercase">{node.status}</span>
        </div>
        <dl class="grid grid-cols-3 gap-3 text-xs">
          <div><dt class="text-[var(--gs-text-secondary)]">Exposure</dt><dd>{node.metrics.exposure}%</dd></div>
          <div><dt class="text-[var(--gs-text-secondary)]">Volatility</dt><dd>{node.metrics.volatility}%</dd></div>
          <div><dt class="text-[var(--gs-text-secondary)]">Signal</dt><dd>{node.metrics.signalStrength}%</dd></div>
        </dl>
        <p class="mt-3 text-xs text-[var(--gs-text-secondary)]">
          Dependencies: {node.dependencies.length > 0 ? node.dependencies.join(', ') : 'None'}
        </p>
      </article>
    ))}
  </div>
</section>
