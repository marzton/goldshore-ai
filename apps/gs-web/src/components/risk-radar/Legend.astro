---
interface Props {
  statusLegend: Record<string, string>;
  metricLegend: Record<string, string>;
}

const { statusLegend = {}, metricLegend = {} } = Astro.props;
---

<section class="gs-card rounded-3xl border border-[var(--gs-border-primary)] bg-white p-6">
  <h3 class="mb-4 text-lg font-bold">Legend</h3>
  <div class="space-y-4 text-sm">
    <div>
      <h4 class="mb-2 text-xs font-semibold uppercase tracking-[0.12em] text-[var(--gs-text-secondary)]">Status</h4>
      <ul class="space-y-2">
        {Object.entries(statusLegend).map(([key, text]) => (
          <li><strong class="capitalize">{key}:</strong> {text}</li>
        ))}
      </ul>
    </div>
    <div>
      <h4 class="mb-2 text-xs font-semibold uppercase tracking-[0.12em] text-[var(--gs-text-secondary)]">Metrics</h4>
      <ul class="space-y-2">
        {Object.entries(metricLegend).map(([key, text]) => (
          <li><strong>{key}:</strong> {text}</li>
        ))}
      </ul>
    </div>
  </div>
</section>
