---
const links = [
  { href: "/", label: "Home" },
  { href: "/workflows", label: "Workflows" },
  { href: "/services", label: "Services" },
  { href: "/risk-radar", label: "Risk Radar" },
  { href: "/developer", label: "Developer Hub" },
  { href: "/about", label: "About" },
  { href: "/team", label: "Team" },
  { href: "/contact", label: "Contact" }
];
---

<header class="gs-header">
  <div class="gs-container gs-nav-inner">
    <a class="gs-brand" href="/">
      @-- Replace with your real SVG path --
      <img class="gs-logo" src="/packages/brand/logo-penrose.svg" alt="Gold Shore" />
      <span class="gs-brand-text">GOLD SHORE</span>
    </a>

    <nav class="gs-nav" aria-label="Primary">
      {links.map(l => <a href={l.href}>{l.label}</a>)}
      <button class="gs-button gs-button-outline" type="button" data-gs-modal-open="admin" aria-haspopup="dialog">Admin</button>
      <button class="gs-button gs-button-solid" type="button" data-gs-modal-open="subscribe" aria-haspopup="dialog">Subscribe</button>
    </nav>

    <button class="gs-nav-toggle" type="button" data-gs-nav-toggle aria-expanded="false" aria-controls="gs-mobile-panel" aria-label="Open menu">
      <span aria-hidden="true">☰</span>
      <span class="sr-only">Open menu</span>
    </button>
  </div>
</header>

@-- Mobile overlay panel --
<div class="gs-mobile-panel" id="gs-mobile-panel" data-gs-mobile-panel>
  <div class="gs-mobile-top">
    <div class="gs-brand">
      <img class="gs-logo" src="/packages/brand/logo-penrose.svg" alt="Gold Shore" />
      <span class="gs-brand-text">GOLD SHORE</span>
    </div>
    <button class="gs-icon-btn" data-gs-nav-close aria-label="Close menu">×</button>
  </div>

  <div class="gs-mobile-panel-inner">
    <nav class="gs-mobile-links" aria-label="Mobile Primary">
      {links.map(l => <a href={l.href}>{l.label}</a>)}
      <button type="button" data-gs-modal-open="admin" aria-haspopup="dialog">Admin Login</button>
      <button type="button" data-gs-modal-open="subscribe" aria-haspopup="dialog">Subscribe</button>
    </nav>
  </div>
</div>
