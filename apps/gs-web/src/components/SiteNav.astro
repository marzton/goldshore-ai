---
const links = [
  { href: '/', label: 'Home' },
  { href: '/workflows', label: 'Workflows' },
  { href: '/services', label: 'Services' },
  { href: '/risk-radar', label: 'Risk Radar' },
  { href: '/developer', label: 'Developer Hub' },
  { href: '/about', label: 'About' },
  { href: '/team', label: 'Team' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="gs-header">
  <div class="gs-container gs-nav-inner">
    <a class="gs-brand" href="/">
      <img
        class="gs-logo"
        src="/assets/brand/logo-penrose.svg"
        alt="Gold Shore"
      />
      <span class="gs-brand-text">GOLD SHORE</span>
    </a>

    <nav class="gs-nav" aria-label="Primary">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
      <button
        class="gs-button gs-button-outline"
        type="button"
        data-gs-modal-open="admin"
        aria-haspopup="dialog">Admin</button
      >
      <button
        class="gs-button gs-button-outline"
        type="button"
        data-gs-modal-open="subscribe"
        aria-haspopup="dialog">Subscribe</button
      >
      <a class="gs-button gs-button-solid" href="/contact">Request Briefing</a>
    </nav>

    <button
      class="gs-nav-toggle"
      type="button"
      data-gs-nav-toggle
      aria-expanded="false"
      aria-controls="gs-mobile-panel"
      aria-label="Open menu"
    >
      <span aria-hidden="true">☰</span>
      <span class="sr-only">Open menu</span>
    </button>
  </div>
</header>

<div
  class="gs-mobile-panel"
  id="gs-mobile-panel"
  data-gs-mobile-panel
  aria-hidden="true"
>
  <div class="gs-mobile-top">
    <div class="gs-brand">
      <img
        class="gs-logo"
        src="/assets/brand/logo-penrose.svg"
        alt="Gold Shore"
      />
      <span class="gs-brand-text">GOLD SHORE</span>
    </div>
    <button
      class="gs-icon-btn gs-mobile-close"
      data-gs-nav-close
      aria-label="Close menu">×</button
    >
  </div>

  <div class="gs-mobile-panel-inner">
    <nav class="gs-mobile-links" aria-label="Mobile Primary">
      {
        links.map((link) => (
          <a class="gs-mobile-link-item" href={link.href}>
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="gs-mobile-actions" aria-label="Mobile actions">
      <a class="gs-button gs-button-solid" href="/contact">Request Briefing</a>
      <div class="gs-mobile-actions-secondary">
        <button
          class="gs-mobile-link-item gs-mobile-link-trigger"
          type="button"
          data-gs-modal-open="admin"
          aria-haspopup="dialog"
        >
          Admin Login
        </button>
        <button
          class="gs-mobile-link-item gs-mobile-link-trigger"
          type="button"
          data-gs-modal-open="subscribe"
          aria-haspopup="dialog"
        >
          Subscribe
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .gs-mobile-links .gs-mobile-link-trigger {
    appearance: none;
    background: none;
    border: 0;
    border-radius: 0;
    cursor: pointer;
    padding: 0;
    text-align: left;
    width: 100%;
  }

  .gs-mobile-actions {
    display: grid;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .gs-mobile-actions > .gs-button {
    justify-content: center;
  }

  .gs-mobile-actions-secondary {
    border-top: 1px solid var(--gs-border-subtle, rgba(255, 255, 255, 0.16));
    display: grid;
    gap: 0.75rem;
    padding-top: 0.75rem;
  }
</style>
