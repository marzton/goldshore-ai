---
import Logo from './brand/Logo.astro';

const { currentPath = '/', navLinks = [] } = Astro.props;
---

<header class="header" data-menu-open="false">
  <a href="/" class="gs-logo-link" aria-label="Gold Shore home">
    <Logo class="gs-logo gs-logo--lockup" title="Gold Shore" variant="lockup" />
  </a>

  <button
    class="menu-button"
    type="button"
    aria-expanded="false"
    aria-controls="primary-navigation"
    aria-label="Open navigation"
  >
    <span></span>
    <span></span>
    <span></span>
  </button>

  <nav
    id="primary-navigation"
    class="menu-panel"
    aria-label="Primary navigation"
  >
    <div class="menu-panel__inner">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            aria-current={currentPath === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script is:inline>
  const menuGlobal = window;

  const bindMenu = () => {
    if (menuGlobal.__gsMenuBound) return;
    menuGlobal.__gsMenuBound = true;

    const setMenu = (isOpen) => {
      const header = document.querySelector('.header');
      const toggle = document.querySelector('.menu-button');
      if (
        !(header instanceof HTMLElement) ||
        !(toggle instanceof HTMLButtonElement)
      ) {
        return;
      }
      header.dataset.menuOpen = String(isOpen);
      toggle.setAttribute('aria-expanded', String(isOpen));
      document.body.classList.toggle('menu-open', isOpen);
    };

    const handleToggle = () => {
      const header = document.querySelector('.header');
      const next = header?.dataset.menuOpen !== 'true';
      setMenu(next);
    };

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      if (target.closest('.menu-button')) {
        handleToggle();
        return;
      }

      if (
        target.closest('.menu-panel a') ||
        target.classList.contains('menu-panel')
      ) {
        setMenu(false);
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        setMenu(false);
      }
    });

    document.addEventListener('astro:before-swap', () => {
      setMenu(false);
    });
  };

  bindMenu();
</script>

<style is:global>
  .header {
    position: sticky;
    top: 0;
    z-index: 1100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem clamp(1rem, 3vw, 2rem);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: rgba(8, 12, 22, 0.65);
    border-bottom: 2px solid rgba(255, 255, 255, 0.08);
  }

  .gs-logo-link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    min-width: 0;
  }

  .gs-logo {
    width: clamp(20px, 3vw, 36px);
    height: auto;
    color: var(--gs-primary);
  }

  .gs-logo--lockup {
    width: clamp(188px, 24vw, 260px);
    color: var(--gs-primary);
  }

  .menu-button {
    position: relative;
    z-index: 1102;
    width: 46px;
    height: 46px;
    display: inline-grid;
    place-items: center;
    gap: 4px;
    border-radius: 999px;
    border: 1px solid var(--gs-border);
    background: rgba(90, 162, 255, 0.08);
    cursor: pointer;
  }

  .menu-button span {
    display: block;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: var(--gs-text);
    transition:
      transform 160ms ease,
      opacity 160ms ease;
  }

  .header[data-menu-open='true'] .menu-button span:nth-child(1) {
    transform: translateY(5.5px) rotate(45deg);
  }

  .header[data-menu-open='true'] .menu-button span:nth-child(2) {
    opacity: 0;
  }

  .header[data-menu-open='true'] .menu-button span:nth-child(3) {
    transform: translateY(-5.5px) rotate(-45deg);
  }

  .menu-panel {
    position: fixed;
    inset: 0;
    display: grid;
    justify-items: end;
    background: rgba(5, 8, 14, 0);
    pointer-events: none;
    transition: background 180ms ease;
  }

  .menu-panel__inner {
    width: min(360px, 100vw);
    height: 100%;
    padding: 6rem 1.5rem 1.5rem;
    display: grid;
    align-content: start;
    gap: 0.75rem;
    transform: translateX(100%);
    transition: transform 180ms ease;
    background: rgba(7, 14, 28, 0.94);
    border-left: 1px solid var(--gs-border);
    box-shadow: -24px 0 80px rgba(0, 0, 0, 0.38);
  }

  .menu-panel a {
    padding: 0.95rem 1rem;
    border-radius: 14px;
    color: var(--gs-text-dim);
    text-decoration: none;
    border: 1px solid transparent;
    background: rgba(255, 255, 255, 0.02);
  }

  .menu-panel a:hover,
  .menu-panel a[aria-current='page'] {
    color: var(--gs-text);
    border-color: var(--gs-border);
    background: rgba(90, 162, 255, 0.08);
  }

  .header[data-menu-open='true'] .menu-panel {
    pointer-events: auto;
    background: rgba(5, 8, 14, 0.42);
  }

  .header[data-menu-open='true'] .menu-panel__inner {
    transform: translateX(0);
  }
</style>
