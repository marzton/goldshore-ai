---
import Logo from '@goldshore/theme/components/Logo.astro';

const links = [
  { href: '/', label: 'Home' },
  { href: '/workflows', label: 'Workflows' },
  { href: '/services', label: 'Services' },
  { href: '/risk-radar', label: 'Risk Radar' },
  { href: '/developer-hub', label: 'Developer' },
  { href: '/about', label: 'About' },
  { href: '/team', label: 'Team' },
];
---

<header class="gs-header">
  <div class="gs-container gs-nav-inner">
    <a class="gs-brand" href="/">
      <Logo />
      <span class="gs-brand-text">GOLD SHORE</span>
    </a>

    <nav class="gs-nav" aria-label="Primary">
      {links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="gs-nav-utility" aria-label="Utility">
      <button
        class="gs-nav-utility-link"
        type="button"
        data-gs-modal-open="subscribe"
        aria-haspopup="dialog">Subscribe</button
      >
      <a class="gs-button gs-button-solid gs-nav-cta" href="/contact"
        >Request Briefing</a
      >
    </div>

    <button
      class="gs-nav-toggle"
      type="button"
      data-gs-nav-toggle
      aria-expanded="false"
      aria-controls="gs-mobile-panel"
      aria-label="Open menu"
    >
      <span aria-hidden="true">☰</span>
      <span class="sr-only">Open menu</span>
    </button>
  </div>
</header>

<div
  class="gs-mobile-panel"
  id="gs-mobile-panel"
  data-gs-mobile-panel
  aria-hidden="true"
>
  <div class="gs-mobile-top">
    <a class="gs-brand" href="/">
      <Logo />
      <span class="gs-brand-text">GOLD SHORE</span>
    </a>
    <button
      class="gs-icon-btn gs-mobile-close"
      data-gs-nav-close
      aria-label="Close menu">×</button
    >
  </div>

  <div class="gs-mobile-panel-inner">
    <nav class="gs-mobile-links" aria-label="Mobile Primary">
      {
        links.map((l) => (
          <a class="gs-mobile-link-item" href={l.href}>
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="gs-mobile-actions" aria-label="Mobile actions">
      <a class="gs-button gs-button-solid" href="/contact">Request Briefing</a>
      <button
        class="gs-mobile-link-item gs-mobile-link-trigger"
        type="button"
        data-gs-modal-open="subscribe"
        aria-haspopup="dialog"
      >
        Subscribe
      </button>
    </div>
  </div>
</div>

<style>
  .gs-nav-utility {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-left: 0.6rem;
  }

  .gs-nav-utility-link {
    appearance: none;
    border: 0;
    background: transparent;
    color: var(--gs-muted, rgba(224, 232, 248, 0.82));
    cursor: pointer;
    font: inherit;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    padding: 0.2rem;
  }

  .gs-nav-utility-link:hover {
    color: var(--gs-text, #fff);
  }

  .gs-mobile-links .gs-mobile-link-trigger {
    appearance: none;
    background: none;
    border: 0;
    border-radius: 0;
    cursor: pointer;
    padding: 0;
    text-align: left;
    width: 100%;
  }

  .gs-mobile-actions {
    display: grid;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .gs-mobile-actions > .gs-button {
    justify-content: center;
  }

  .gs-mobile-top {
    align-items: center;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  .gs-mobile-close {
    flex-shrink: 0;
    margin-left: auto;
  }

  @media (max-width: 1200px) {
    .gs-nav-utility {
      display: none;
    }
  }

  @media (max-width: 900px) {
    .gs-mobile-panel {
      padding: max(1rem, env(safe-area-inset-top)) 1rem 1.5rem;
    }

    .gs-mobile-panel-inner {
      margin-top: 1rem;
    }

    .gs-mobile-links {
      display: grid;
      gap: 0.85rem;
    }
  }
</style>
