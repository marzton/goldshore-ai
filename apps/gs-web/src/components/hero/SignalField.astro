<div class="signal-field" aria-hidden="true">
  <div class="signal-field__grid"></div>
  <div class="signal-field__particles" data-signal-field></div>
  <div class="signal-field__grid gs-parallax" data-parallax="0.32"></div>
  <div
    class="signal-field__particles gs-parallax"
    data-signal-field
    data-parallax="0.18"
  >
  </div>
  <svg
    class="signal-field__wave signal-field__wave--primary"
    viewBox="0 0 800 200"
    preserveAspectRatio="none"
  >
    <path d="M0 100 Q 100 40 200 100 T 400 100 T 600 100 T 800 100"></path>
  </svg>
  <svg
    class="signal-field__wave signal-field__wave--secondary"
    viewBox="0 0 800 200"
    preserveAspectRatio="none"
  >
    <path d="M0 120 Q 100 70 200 120 T 400 120 T 600 120 T 800 120"></path>
  </svg>
</div>

<script>
  // @ts-nocheck
  import * as THREE from 'three';

  const instances = new WeakMap();
  const reducedMotionQuery = window.matchMedia(
    '(prefers-reduced-motion: reduce)',
  );
  const prefersReducedMotion = () => reducedMotionQuery.matches;

  function applyReducedMotionFallback(root) {
    root.classList.add('signal-field__particles--fallback');
    root.replaceChildren();
  }
  const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
  const prefersReducedMotion = () => motionQuery.matches;

  function applyReducedMotionFallback(root) {
    root.replaceChildren();
    root.dataset.motionMode = 'reduced';
  }

  function clearReducedMotionFallback(root) {
    delete root.dataset.motionMode;
  }
  const prefersReducedMotion = () =>
    window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function initSignalField(root) {
    if (instances.has(root)) return;

    if (prefersReducedMotion()) {
      applyReducedMotionFallback(root);
      return;
    }

    root.classList.remove('signal-field__particles--fallback');

    const renderer = new THREE.WebGLRenderer({
      alpha: true,
      antialias: true,
      powerPreference: 'high-performance',
    });
    clearReducedMotionFallback(root);

    const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true, powerPreference: 'high-performance' });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
    renderer.setClearColor(0x000000, 0);
    root.replaceChildren(renderer.domElement);

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(48, 1, 0.1, 100);
    camera.position.z = 8;

    const particleCount = 1200;
    const positions = new Float32Array(particleCount * 3);
    for (let i = 0; i < particleCount; i += 1) {
      const stride = i * 3;
      positions[stride] = (Math.random() - 0.5) * 14;
      positions[stride + 1] = (Math.random() - 0.5) * 8;
      positions[stride + 2] = (Math.random() - 0.5) * 6;
    }

    const geometry = new THREE.BufferGeometry();
    geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));

    const material = new THREE.PointsMaterial({
      color: '#5FA8FF',
      size: 0.045,
      transparent: true,
      opacity: 0.72,
      depthWrite: false,
      blending: THREE.AdditiveBlending,
      sizeAttenuation: true,
    });

    const points = new THREE.Points(geometry, material);
    points.rotation.x = 0.28;
    scene.add(points);

    const halo = new THREE.Mesh(
      new THREE.PlaneGeometry(18, 9),
      new THREE.MeshBasicMaterial({
        color: '#1E3A8A',
        transparent: true,
        opacity: 0.08,
      }),
    );
    halo.position.z = -2.4;
    scene.add(halo);

    const resize = () => {
      const { clientWidth, clientHeight } = root;
      if (!clientWidth || !clientHeight) return;
      renderer.setSize(clientWidth, clientHeight, false);
      camera.aspect = clientWidth / clientHeight;
      camera.updateProjectionMatrix();
    };

    let frame = 0;
    const clock = new THREE.Clock();

    const renderFrame = () => {
      if (prefersReducedMotion()) {
        return;
      }

      const elapsed = clock.getElapsedTime();
      points.rotation.y = elapsed * 0.04;
      points.rotation.z = Math.sin(elapsed * 0.18) * 0.08;
      points.position.y = Math.sin(elapsed * 0.42) * 0.08;
      halo.material.opacity = 0.06 + (Math.sin(elapsed * 0.65) + 1) * 0.025;
      renderer.render(scene, camera);
      frame = window.requestAnimationFrame(renderFrame);
    };

    const observer = new ResizeObserver(resize);
    observer.observe(root);
    resize();
    renderFrame();

    const cleanup = () => {
      window.cancelAnimationFrame(frame);
      observer.disconnect();
      geometry.dispose();
      material.dispose();
      halo.geometry.dispose();
      halo.material.dispose();
      renderer.dispose();
      if (renderer.domElement.parentNode === root) {
        root.removeChild(renderer.domElement);
      }
      applyReducedMotionFallback(root);
      if (prefersReducedMotion()) {
        applyReducedMotionFallback(root);
      } else {
        clearReducedMotionFallback(root);
      }
      instances.delete(root);
    };

    instances.set(root, cleanup);
  }

  function syncSignalField(root) {
    if (prefersReducedMotion()) {
      const cleanup = instances.get(root);
      cleanup?.();
      if (!instances.has(root)) {
        applyReducedMotionFallback(root);
      }
      return;
    }

    clearReducedMotionFallback(root);
    initSignalField(root);
  }

  function initSignalFields() {
    document
      .querySelectorAll('[data-signal-field]')
      .forEach((root) => initSignalField(root));
    document.querySelectorAll('[data-signal-field]').forEach((root) => syncSignalField(root));
  }

  function cleanupSignalFields() {
    document.querySelectorAll('[data-signal-field]').forEach((root) => {
      const cleanup = instances.get(root);
      cleanup?.();
      if (!cleanup) {
        applyReducedMotionFallback(root);
      }
    });
  }

  const handleMotionPreferenceChange = () => {
    document.querySelectorAll('[data-signal-field]').forEach((root) => {
      if (prefersReducedMotion()) {
        const cleanup = instances.get(root);
        cleanup?.();
        if (!cleanup) {
          applyReducedMotionFallback(root);
        }
        return;
      }

      initSignalField(root);
    });
  };

    document.querySelectorAll('[data-signal-field]').forEach((root) => syncSignalField(root));
  };

  if (!window.__signalFieldMotionListenerRegistered) {
    if (typeof motionQuery.addEventListener === 'function') {
      motionQuery.addEventListener('change', handleMotionPreferenceChange);
    } else {
      motionQuery.addListener(handleMotionPreferenceChange);
    }
    window.__signalFieldMotionListenerRegistered = true;
  }

  document.addEventListener('astro:page-load', initSignalFields);
  document.addEventListener('astro:before-swap', cleanupSignalFields);
  reducedMotionQuery.addEventListener('change', handleMotionPreferenceChange);

  if (document.readyState !== 'loading') {
    initSignalFields();
  } else {
    document.addEventListener('DOMContentLoaded', initSignalFields, {
      once: true,
    });
  }
</script>

<style>
  .signal-field {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    isolation: isolate;
  }

  .signal-field__grid,
  .signal-field__particles,
  .signal-field__wave {
    position: absolute;
    inset: 0;
  }

  .signal-field__grid {
    background:
      linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0.45;
    mask-image: radial-gradient(circle at 55% 40%, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(
      circle at 55% 40%,
      black 30%,
      transparent 80%
    );
  }

  .signal-field__particles {
    background:
      radial-gradient(
        circle at 50% 42%,
        rgba(95, 168, 255, 0.14),
        transparent 28%
      ),
      radial-gradient(
        circle at 58% 44%,
        rgba(95, 168, 255, 0.2) 0,
        rgba(95, 168, 255, 0.08) 2px,
        transparent 3px
      ),
      radial-gradient(
        circle at 44% 38%,
        rgba(30, 58, 138, 0.18),
        transparent 32%
      );
    opacity: 0.9;
  }

  .signal-field__particles--fallback {
    background:
      radial-gradient(
        circle at 52% 42%,
        rgba(95, 168, 255, 0.16),
        transparent 26%
      ),
      radial-gradient(
        circle at 58% 44%,
        rgba(95, 168, 255, 0.22) 0,
        rgba(95, 168, 255, 0.1) 2px,
        transparent 3px
      ),
      radial-gradient(
        circle at 48% 46%,
        rgba(95, 168, 255, 0.1) 0,
        rgba(95, 168, 255, 0.06) 1px,
        transparent 2px
      ),
      radial-gradient(
        circle at 44% 38%,
        rgba(30, 58, 138, 0.18),
        transparent 32%
      );
    background-size:
      auto,
      180px 180px,
      240px 240px,
      auto;
    background-position:
      center,
      center,
      15% 20%,
      center;
    opacity: 0.95;
      radial-gradient(circle at 50% 48%, rgba(95, 168, 255, 0.16), transparent 44%),
      radial-gradient(circle at 60% 42%, rgba(30, 58, 138, 0.2), transparent 58%);
    opacity: 0.9;
  }

  .signal-field__particles[data-motion-mode='reduced'] {
    background:
      radial-gradient(circle at 50% 48%, rgba(95, 168, 255, 0.12), transparent 42%),
      radial-gradient(circle at 60% 42%, rgba(30, 58, 138, 0.18), transparent 56%),
      linear-gradient(180deg, rgba(10, 20, 40, 0), rgba(10, 20, 40, 0.18));
    opacity: 0.82;
  }

  .signal-field__grid,
  .signal-field__particles {
    transform-origin: center;
  }

  .signal-field__particles :global(canvas) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .signal-field__wave {
    width: 140%;
    height: 46%;
    left: -20%;
    top: 36%;
    overflow: visible;
    animation: waveMove 6s linear infinite;
  }

  .signal-field__wave path {
    fill: none;
    stroke: rgba(95, 168, 255, 0.38);
    stroke-width: 2;
    filter: drop-shadow(0 0 16px rgba(95, 168, 255, 0.22));
  }

  .signal-field__wave--secondary {
    top: 48%;
    animation-duration: 8s;
    opacity: 0.55;
  }

  .signal-field__wave--secondary path {
    stroke: rgba(30, 58, 138, 0.45);
    stroke-width: 1.35;
  }

  @keyframes waveMove {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-200px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .signal-field__wave {
      animation: none;
    }
  }
</style>
