<section class="gs-hero gs-hero-canonical" data-gs-hero>
  <div class="gs-container gs-hero-shell">
    <div class="gs-hero-copy">
      <p class="gs-kicker">System Status · Operational</p>
      <h1 class="gs-display gs-hero-title">Shaping Waves with Applied Intelligence</h1>
      <p class="gs-hero-sub">
        Institutional systems for resilient capital operations across volatile regimes.
      </p>
      <div class="gs-hero-actions">
        <a href="/contact" class="gs-button gs-button-solid">Request Briefing</a>
        <a href="/services" class="gs-button gs-button-outline">Explore Services</a>
      </div>
    </div>

    <aside class="gs-terminal-panel" aria-label="Cinematic operations preview">
      <div class="gs-terminal-head">
        <span class="gs-terminal-dot"></span>
        <span class="gs-terminal-dot"></span>
        <span class="gs-terminal-dot"></span>
        <span class="gs-terminal-label">ops/live-stream</span>
      </div>
      <pre class="gs-terminal-body"><code>[00:14:28] signal.ingest         ok     latency 14ms
[00:14:29] portfolio.guardrails   pass   risk-budget 0.61
[00:14:31] execution.route        live   venue x4
[00:14:33] anomaly.scan           clear  priority low
[00:14:34] advisory.brief         ready  dispatching</code></pre>
    </aside>
---
import HeroLogo from './HeroLogo.astro';
---

<section
  class="hero gs-canonical-hero"
  data-hero-root
  aria-label="Gold Shore hero"
>
  <div class="hero-bg" aria-hidden="true">
    <canvas class="hero-canvas" data-stars></canvas>
    <canvas class="hero-canvas" data-shooting></canvas>
    <div class="hero-grid-field"></div>
    <div class="hero-vignette"></div>
  </div>

  <div class="hero-container">
    <div class="hero-top-nav">
      <div class="system-status">
        <span class="status-dot"></span>
        <span class="status-text">SYSTEM STATUS: OPERATIONAL</span>
      </div>
    </div>

    <div class="hero-content">
      <div class="hero-watermark">
        <HeroLogo />
      </div>

      <h1 class="hero-headline">
        Shaping Waves with <br />
        Applied Intelligence
      </h1>

      <p class="hero-supporting">
        Institutional-grade automation, infrastructure, and intelligence systems for real-time operations.
      </p>

      <div class="hero-actions">
        <a class="btn primary btn-large" href="/experience">Start the Experience</a>
        <a class="btn ghost btn-large" href="/sales">Contact Sales</a>
      </div>
    </div>

    <div class="hero-panel-preview">
      <div class="preview-panel">
        <div class="panel-header">
          <div class="panel-dots">
            <span></span><span></span><span></span>
          </div>
          <div class="panel-title">GoldShore Agent / Deployment Pulse</div>
        </div>
        <div class="panel-body">
          <div class="terminal-line">
            <span class="prompt">></span>
            <span class="command">gs-agent --status</span>
          </div>
          <div class="terminal-output">
            NODE_01: ONLINE | LATENCY: 12ms | THROUGHPUT: 4.8B signals/sec
          </div>
          <div class="terminal-line">
            <span class="prompt">></span>
            <span class="command">gs-deploy --pulse --all</span>
          </div>
          <div class="terminal-grid">
            <div class="grid-item active"></div>
            <div class="grid-item active"></div>
            <div class="grid-item active"></div>
            <div class="grid-item active"></div>
            <div class="grid-item pulse"></div>
            <div class="grid-item active"></div>
            <div class="grid-item active"></div>
            <div class="grid-item active"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .gs-hero-canonical {
    padding: 4rem 0 2rem;
  }

  .gs-hero-shell {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 2rem;
    align-items: center;
  }

  .gs-kicker {
    color: #93c5fd;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.78rem;
  }

  .gs-hero-title {
    max-width: 18ch;
    margin: 0.4rem 0 0.8rem;
  }

  .gs-hero-sub {
    color: #cbd5e1;
    max-width: 54ch;
  }

  .gs-hero-actions {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.2rem;
    flex-wrap: wrap;
  }

  .gs-terminal-panel {
    border: 1px solid rgba(148, 163, 184, 0.35);
    background: rgba(2, 6, 23, 0.82);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
  }

  .gs-terminal-head {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 0.8rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.2);
    background: rgba(15, 23, 42, 0.9);
  }

  .gs-terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: #334155;
  }

  .gs-terminal-dot:first-child { background: #ef4444; }
  .gs-terminal-dot:nth-child(2) { background: #f59e0b; }
  .gs-terminal-dot:nth-child(3) { background: #22c55e; }

  .gs-terminal-label {
    margin-left: 0.3rem;
    font-size: 0.78rem;
    color: #94a3b8;
  }

  .gs-terminal-body {
    margin: 0;
    padding: 1rem;
    font-size: 0.78rem;
    line-height: 1.5;
    color: #e2e8f0;
    overflow-x: auto;
  }

  @media (max-width: 920px) {
    .gs-hero-shell {
      grid-template-columns: 1fr;
    }
  }
</style>
  .gs-canonical-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    background: #020408;
    color: #f1f5f9;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-grid-field {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    background-position: center center;
    mask-image: radial-gradient(circle at center, black, transparent 80%);
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, transparent 20%, #020408 90%);
  }

  .hero-container {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-top-nav {
    margin-bottom: 4rem;
  }

  .system-status {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 100px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.6);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    background: #10b981;
    border-radius: 50%;
    box-shadow: 0 0 10px #10b981;
    animation: status-pulse 2s infinite;
  }

  @keyframes status-pulse {
    0% { opacity: 1; }
    50% { opacity: 0.4; }
    100% { opacity: 1; }
  }

  .hero-content {
    margin-bottom: 6rem;
  }

  .hero-watermark {
    opacity: 0.15;
    width: 80px;
    height: 80px;
    margin: 0 auto 2rem;
    filter: grayscale(1);
  }

  .hero-headline {
    font-family: "Ibarra Real Nova", serif;
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    line-height: 1.1;
    font-weight: 400;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .hero-supporting {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.6);
    max-width: 60ch;
    margin: 0 auto 3rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: 500;
    transition: all 0.2s;
    text-decoration: none;
    font-size: 0.95rem;
  }

  .btn-large {
    padding: 1rem 2rem;
    font-size: 1rem;
  }

  .btn.primary {
    background: #f1f5f9;
    color: #020408;
  }

  .btn.primary:hover {
    background: #ffffff;
    transform: translateY(-1px);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
  }

  .btn.ghost {
    background: transparent;
    color: #f1f5f9;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .btn.ghost:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .hero-panel-preview {
    width: 100%;
    max-width: 800px;
    perspective: 1000px;
  }

  .preview-panel {
    background: rgba(10, 15, 30, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    overflow: hidden;
    backdrop-filter: blur(20px);
    transform: rotateX(5deg);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5);
    text-align: left;
  }

  .panel-header {
    background: rgba(255, 255, 255, 0.05);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .panel-dots {
    display: flex;
    gap: 0.4rem;
  }

  .panel-dots span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
  }

  .panel-title {
    font-family: ui-monospace, monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.4);
  }

  .panel-body {
    padding: 1.5rem;
    font-family: ui-monospace, monospace;
    font-size: 0.85rem;
  }

  .terminal-line {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .prompt { color: #3b82f6; }
  .command { color: #f1f5f9; }
  .terminal-output {
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .terminal-grid {
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .grid-item {
    aspect-ratio: 1;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 2px;
  }

  .grid-item.active {
    background: rgba(59, 130, 246, 0.3);
  }

  .grid-item.pulse {
    background: #3b82f6;
    box-shadow: 0 0 15px #3b82f6;
    animation: status-pulse 1s infinite;
  }
</style>

<script>
  import { mountHero } from './mountHero';

  mountHero();
</script>
