---
import HeroLogo from './HeroLogo.astro';
---

<section
  class="hero gs-canonical-hero"
  data-hero-root
  aria-label="Gold Shore hero"
>
  <div class="hero-bg" aria-hidden="true">
    <canvas class="hero-canvas" data-stars></canvas>
    <canvas class="hero-canvas" data-shooting></canvas>
    <img
      class="hero-wave-overlay"
      src="/assets/starfield.svg"
      alt="Abstract telemetry wave field representing live operational signals"
      loading="lazy"
      decoding="async"
    />
    <div class="hero-grid-field"></div>
    <div class="hero-vignette"></div>
  </div>

  <div class="hero-container">
    <div class="system-status" aria-live="polite">
      <span class="status-dot" aria-hidden="true"></span>
      <span class="status-text">System Status: Operational</span>
    </div>

    <div class="hero-watermark" aria-hidden="true">
      <HeroLogo />
    </div>

    <h1 class="hero-headline">Shaping Waves with Applied Intelligence</h1>
    <p class="hero-supporting">
      Institutional-grade automation, infrastructure, and intelligence systems
      for real-time operations.
    </p>

    <div class="hero-actions">
      <a class="btn primary" href="/contact">Request Briefing</a>
      <a class="btn ghost" href="/services">Explore Services</a>
    </div>
  </div>
</section>

<style>
  .gs-canonical-hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    background: #020408;
    color: #fff;
  }

  .hero-bg,
  .hero-canvas,
  .hero-wave-overlay,
  .hero-grid-field,
  .hero-vignette {
    position: absolute;
    inset: 0;
  }

  .hero-wave-overlay {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.14;
    mix-blend-mode: screen;
  }

  .hero-grid-field {
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(circle at center, black, transparent 80%);
  }

  .hero-vignette {
    background: radial-gradient(circle at center, transparent 20%, #020408 90%);
  }

  .hero-container {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 860px;
    padding: 2rem;
  }

  .system-status {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 99px;
    background: rgba(255, 255, 255, 0.06);
    padding: 0.5rem 0.9rem;
    margin-bottom: 1.5rem;
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #22c55e;
    box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.65);
    animation: status-pulse 2s ease-in-out infinite;
  }

  .hero-watermark {
    opacity: 0.35;
    width: 64px;
    margin: 0 auto 1.25rem;
  }

  .hero-headline {
    color: #fff;
    font-size: clamp(2.4rem, 8vw, 4.6rem);
    line-height: 1.1;
    margin: 0;
    font-weight: 500;
  }

  .hero-supporting {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.125rem;
    max-width: 58ch;
    margin: 1.2rem auto 0;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-top: 1.8rem;
  }

  .btn {
    border-radius: 10px;
    padding: 0.9rem 1.35rem;
    text-decoration: none;
    font-weight: 600;
  }

  .btn.primary {
    background: #fff;
    color: #020408;
  }

  .btn.ghost {
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.24);
  }

  @keyframes status-pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.65);
    }
    50% {
      box-shadow: 0 0 0 8px rgba(34, 197, 94, 0);
    }
  }
</style>
