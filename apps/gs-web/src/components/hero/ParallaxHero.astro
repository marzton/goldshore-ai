---
import Logo from '../brand/Logo.astro';

const {
  eyebrow      = 'System Operational',
  headline     = 'Shaping Waves with\nApplied Intelligence',
  sub          = 'GoldShore builds resilient systems with applied intelligence, responsive operations, and disciplined control surfaces that move like instruments—not ornaments.',
  ctaPrimary   = { label: 'Start the Experience', href: '/intake' },
  ctaSecondary = { label: 'Contact Sales',        href: '/contact' },
} = Astro.props;

const lines = headline.split('\n');
---

<section class="gs-hero" data-gs-hero aria-label="Hero">

  <!-- Background layers -->
  <div class="gs-hero__bg" aria-hidden="true">
    <canvas class="gs-hero__wave" data-gs-wave></canvas>
    <div class="gs-hero__grid" data-gs-grid></div>
    <div class="gs-hero__glow"></div>
    <div class="gs-hero__vignette"></div>
  </div>

  <!-- Penrose mark — floats behind copy at its own parallax depth -->
  <div class="gs-hero__mark-wrap" data-gs-mark aria-hidden="true">
    <Logo variant="mark" ariaHidden={true} class="gs-hero__mark" />
  </div>

  <!-- Copy -->
  <div class="gs-hero__copy" data-gs-copy>

    <div class="gs-hero__eyebrow" role="status">
      <span class="gs-hero__dot" aria-hidden="true"></span>
      {eyebrow}
    </div>

    <h1 class="gs-hero__headline">
      {lines.map((line, i) => (
        <span class="gs-hero__headline-line" style={`animation-delay:${i * 120}ms`}>
          {line}
        </span>
      ))}
    </h1>

    <p class="gs-hero__sub">{sub}</p>

    <div class="gs-hero__actions">
      <a class="gs-btn gs-btn--primary" href={ctaPrimary.href}>
        {ctaPrimary.label}
        <svg class="gs-btn__arrow" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5"
                stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a class="gs-btn gs-btn--ghost" href={ctaSecondary.href}>
        {ctaSecondary.label}
      </a>
    </div>

  </div>

  <script>
    import { mountHero } from './mountHero';

    const ns = window as typeof window & {
      __gsHeroCleanup?: (() => void) | null;
      __gsHeroBound?: boolean;
    };

    const cleanup = () => { ns.__gsHeroCleanup?.(); ns.__gsHeroCleanup = null; };
    const boot    = () => { cleanup(); ns.__gsHeroCleanup = mountHero(document); };

    if (!ns.__gsHeroBound) {
      ns.__gsHeroBound = true;
      document.addEventListener('astro:page-load', boot);
      document.addEventListener('astro:before-swap', cleanup);
    }
    boot();
  </script>
</section>

<style>
  /* shell */
  .gs-hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #070b14;
  }

  /* background stack */
  .gs-hero__bg,
  .gs-hero__wave,
  .gs-hero__grid,
  .gs-hero__glow,
  .gs-hero__vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .gs-hero__wave {
    width: 100%;
    height: 100%;
    transform-origin: center center;
    will-change: transform;
  }

  .gs-hero__grid {
    background:
      linear-gradient(rgba(148,163,184,0.07) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148,163,184,0.07) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 50%, black 20%, transparent 80%);
    opacity: 0.55;
    will-change: transform;
  }

  .gs-hero__glow {
    background:
      radial-gradient(ellipse 55% 45% at 50% 42%, rgba(90,162,255,0.13) 0%, transparent 70%),
      radial-gradient(ellipse 30% 30% at 50% 42%, rgba(90,162,255,0.07) 0%, transparent 60%);
  }

  .gs-hero__vignette {
    background:
      linear-gradient(to bottom,
        rgba(7,11,20,0.55) 0%, transparent 28%,
        transparent 72%, rgba(7,11,20,0.88) 100%),
      linear-gradient(to right,
        rgba(7,11,20,0.38) 0%, transparent 18%,
        transparent 82%, rgba(7,11,20,0.38) 100%);
  }

  /* Penrose mark */
  .gs-hero__mark-wrap {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
    pointer-events: none;
    will-change: transform;
  }

  .gs-hero__mark {
    width: clamp(220px, 28vw, 380px);
    height: auto;
    opacity: 0.18;
    filter: blur(0.5px) drop-shadow(0 0 48px rgba(90,162,255,0.32));
    transition: opacity 600ms ease, filter 600ms ease;
  }

  .gs-hero:hover .gs-hero__mark {
    opacity: 0.26;
    filter: blur(0px) drop-shadow(0 0 72px rgba(90,162,255,0.50));
  }

  /* copy */
  .gs-hero__copy {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: min(680px, calc(100% - 48px));
    will-change: transform;
  }

  /* eyebrow */
  .gs-hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 9px 18px;
    border-radius: 999px;
    border: 1px solid rgba(90,162,255,0.28);
    background: rgba(7,11,20,0.48);
    backdrop-filter: blur(12px);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(90,162,255,0.92);
    margin-bottom: 28px;
  }

  .gs-hero__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #5aa2ff;
    box-shadow: 0 0 10px 2px rgba(90,162,255,0.7);
    animation: dot-pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 1;   box-shadow: 0 0 10px 2px rgba(90,162,255,0.7); }
    50%       { opacity: 0.6; box-shadow: 0 0 18px 4px rgba(90,162,255,0.35); }
  }

  /* headline */
  .gs-hero__headline {
    display: flex;
    flex-direction: column;
    font-family: var(--gs-font-display, Georgia, serif);
    font-size: clamp(44px, 6vw, 80px);
    font-weight: 600;
    line-height: 1.06;
    color: rgba(226,232,240,0.97);
    text-shadow: 0 8px 40px rgba(0,0,0,0.5);
    margin: 0 0 24px;
    gap: 4px;
  }

  .gs-hero__headline-line {
    display: block;
    opacity: 0;
    transform: translateY(16px);
    animation: gs-fade-up 680ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes gs-fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  /* sub */
  .gs-hero__sub {
    max-width: 52ch;
    color: rgba(148,163,184,0.82);
    font-size: clamp(15px, 1.5vw, 17px);
    line-height: 1.65;
    margin: 0 0 38px;
  }

  /* actions */
  .gs-hero__actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .gs-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    height: 46px;
    padding: 0 22px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: transform 200ms ease, box-shadow 200ms ease, border-color 200ms ease;
  }

  .gs-btn--primary {
    background: linear-gradient(135deg, rgba(90,162,255,0.28), rgba(59,130,246,0.16));
    border: 1px solid rgba(90,162,255,0.42);
    color: rgba(226,232,240,0.96);
    box-shadow:
      0 0 24px rgba(90,162,255,0.18),
      inset 0 1px 0 rgba(255,255,255,0.08);
    backdrop-filter: blur(12px);
  }

  .gs-btn--primary:hover {
    transform: translateY(-2px);
    box-shadow:
      0 8px 32px rgba(90,162,255,0.30),
      inset 0 1px 0 rgba(255,255,255,0.10);
    border-color: rgba(90,162,255,0.65);
  }

  .gs-btn--ghost {
    background: rgba(7,11,20,0.38);
    border: 1px solid rgba(148,163,184,0.18);
    color: rgba(148,163,184,0.80);
    backdrop-filter: blur(12px);
  }

  .gs-btn--ghost:hover {
    transform: translateY(-2px);
    border-color: rgba(148,163,184,0.36);
    color: rgba(226,232,240,0.90);
  }

  .gs-btn__arrow {
    width: 16px;
    height: 16px;
    transition: transform 200ms ease;
    flex-shrink: 0;
  }

  .gs-btn--primary:hover .gs-btn__arrow { transform: translateX(3px); }

  /* reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .gs-hero__headline-line { animation: none; opacity: 1; transform: none; }
    .gs-hero__dot           { animation: none; }
    .gs-hero__wave,
    .gs-hero__mark-wrap,
    .gs-hero__copy          { will-change: auto; }
  }

  /* mobile */
  @media (max-width: 640px) {
    .gs-hero__mark {
      width: clamp(160px, 55vw, 240px);
      opacity: 0.12;
    }
  }
</style>
