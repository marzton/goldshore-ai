---
const { title = "Shaping Waves with Applied Intelligence" } = Astro.props;
---

<section class="gs-hero gs-hero-reactive" aria-label="Hero" data-reactive-hero>
  <div class="gs-hero-bg" aria-hidden="true">
    <canvas class="gs-wave-field" data-wave-bg></canvas>
    <div class="gs-grid"></div>
    <div class="gs-vignette"></div>
  </div>

  <div class="hero-mark-wrap" aria-hidden="true">
    <svg
      class="gs-logo-reactive"
      viewBox="0 0 128 160"
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linejoin="round"
      stroke-linecap="square"
      vector-effect="non-scaling-stroke"
      shape-rendering="geometricPrecision"
      data-reactive-logo
    >
      <path
        class="gs-logo-path"
        d="M64 20 L17 93 H103 L64 20 M64 20 L103 93 M64 20 L17 93"
      />
      <path class="gs-logo-path gs-logo-seam" d="M64 58 L49 83 H79 L64 58" />
    </svg>
  </div>

  <div class="gs-hero-inner">
    <div class="gs-hero-left">
      <div class="gs-pill"><span class="dot"></span> SYSTEM OPERATIONAL</div>
      <div class="hero-logo-wrapper">
        <svg
          class="gs-logo-reactive"
          data-reactive-logo
          viewBox="0 0 128 160"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linejoin="round"
          stroke-linecap="square"
          vector-effect="non-scaling-stroke"
          shape-rendering="geometricPrecision"
          role="img"
          aria-label="GoldShore Penrose mark"
        >
          <path
            class="gs-logo-path"
            d="M64 20 L17 93 H103 L64 20 M64 20 L103 93 M64 20 L17 93 M64 58 L49 83 H79 L64 58"
          />
          <path class="gs-logo-seam" d="M64 58 L49 83" />
        </svg>
      </div>
      <h1>{title}</h1>
      <p class="sub">
        GoldShore isn’t just code. It’s a provable experience. We build resilient, cinematic systems where automation meets art.
      </p>

      <div class="actions">
        <a class="btn primary" href="/intake">Start the Experience</a>
        <a class="btn ghost" href="/contact">Contact Sales</a>
      </div>
    </div>

    <div class="gs-hero-right">
      <div class="panel">
        <div class="panel-top">
          <div class="lights"><span></span><span></span><span></span></div>
          <div class="panel-title">GoldShore Agent</div>
        </div>
        <div class="panel-body">
          <div class="kv">
            <div><span>STATUS</span><b class="ok">ACTIVE</b></div>
            <div><span>MODE</span><b class="mode">VIBE_CODING</b></div>
          </div>
          <div class="bars" aria-hidden="true">
            <i></i><i></i><i></i><i></i><i></i>
          </div>
          <div class="terminal" aria-hidden="true">
            <div>&gt; Initializing cinematic protocols…</div>
            <div>&gt; Synchronizing wave field…</div>
            <div>&gt; Signal resonance stable.</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { mountHero } from "./mountHero";

    let cleanup;

    const boot = () => {
      cleanup?.();
      cleanup = mountHero(document);
    };

    if (document.readyState !== "loading") {
      boot();
    } else {
      document.addEventListener("DOMContentLoaded", boot, { once: true });
    }

    document.addEventListener("astro:page-load", boot);
    document.addEventListener("astro:before-swap", () => {
      cleanup?.();
      cleanup = undefined;
    });
  </script>
</section>
