---
import Logo from '../brand/Logo.astro';
---

<section class="hero" aria-label="Gold Shore hero">
  <div class="hero-bg" aria-hidden="true">
    <canvas id="gs-starfield" class="hero-canvas"></canvas>
    <canvas id="gs-shootingstars" class="hero-canvas"></canvas>
    <div class="hero-vignette"></div>
  </div>

  <div class="hero-content">
    <div class="hero-mark">
      <Logo />
    </div>

    <h1 class="hero-title">Gold Shore</h1>
    <p class="hero-subtitle">Designed not to manage capital, but to steer it.</p>

    <div class="hero-actions">
      <a class="btn primary" href="/intake">Start</a>
      <a class="btn ghost" href="/developer">Developer</a>
    </div>
  </div>
</section>

<script>
  import { mountHero } from './mountHero';

  mountHero();
</script>
