---
const { title = "Shaping Waves with Applied Intelligence" } = Astro.props;
---

<section class="gs-hero" data-reactive-hero aria-label="Hero">
  <div class="gs-hero-bg" aria-hidden="true">
    <canvas class="gs-wave-field" data-wave-bg></canvas>
    <div class="gs-grid"></div>
  </div>

  <div class="hero-mark-wrap" aria-hidden="true">
    <svg
      class="gs-logo-reactive"
      viewBox="0 0 128 160"
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linejoin="round"
      stroke-linecap="square"
      vector-effect="non-scaling-stroke"
      shape-rendering="geometricPrecision"
      data-reactive-logo
    >
      <path
        class="gs-logo-path"
        d="M64 20 L17 93 H103 L64 20 M64 20 L103 93 M64 20 L17 93"
      />
      <path class="gs-logo-path gs-logo-seam" d="M64 58 L49 83 H79 L64 58" />
    </svg>
  </div>

  <div class="gs-hero-inner">
    <div class="gs-hero-left hero-content">
      <div class="gs-pill"><span class="dot"></span> SYSTEM OPERATIONAL</div>
      <h1>{title}</h1>
      <p class="sub">
        GoldShore shapes resilient systems with applied intelligence, responsive operations,
        and disciplined control surfaces that move like instruments—not ornaments.
      </p>

      <div class="actions">
        <a class="btn primary" href="/intake">Start the Experience</a>
        <a class="btn ghost" href="/contact">Contact Sales</a>
      </div>
    </div>

    <div class="gs-hero-right hero-content">
      <div class="panel" data-tilt>
        <div class="panel-top">
          <div class="lights"><span></span><span></span><span></span></div>
          <div class="panel-title">GoldShore Control Surface</div>
        </div>
        <div class="panel-body">
          <div class="kv">
            <div><span>STATUS</span><b class="ok">ACTIVE</b></div>
            <div><span>MODE</span><b class="mode">SYSTEM_RESONANCE</b></div>
            <div><span>FIELD</span><b>WAVE_SYNC</b></div>
          </div>
          <div class="bars" aria-hidden="true">
            <i></i><i></i><i></i><i></i><i></i>
          </div>
          <div class="terminal" aria-hidden="true">
            <div>&gt; Sampling wave energy near hero mark…</div>
            <div>&gt; Penrose glow aligned to local field amplitude.</div>
            <div>&gt; Resonance stable within instrument limits.</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { mountHero } from "./mountHero";

    const globalState = window as typeof window & {
      __gsReactiveHeroCleanup?: (() => void) | null;
      __gsReactiveHeroBound?: boolean;
    };

    const cleanup = () => {
      globalState.__gsReactiveHeroCleanup?.();
      globalState.__gsReactiveHeroCleanup = null;
    };

    const boot = () => {
      cleanup();
      globalState.__gsReactiveHeroCleanup = mountHero(document);
    };

    if (!globalState.__gsReactiveHeroBound) {
      globalState.__gsReactiveHeroBound = true;
      document.addEventListener("astro:page-load", boot);
      document.addEventListener("astro:before-swap", cleanup);
    }

    boot();
  </script>
</section>

<style>
  .gs-hero {
    position: relative;
    overflow: hidden;
    min-height: calc(100vh - 80px);
    background: #0b0f18;
    border-bottom: 1px solid rgba(226, 232, 240, 0.05);
  }

  .gs-hero-bg {
    position: absolute;
    inset: 0;
  }

  .gs-wave-field {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    opacity: 0.4;
  }

  .gs-grid {
    position: absolute;
    inset: 0;
    z-index: 0;
    background:
      linear-gradient(rgba(148, 163, 184, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(148, 163, 184, 0.05) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(circle at 30% 30%, black 35%, transparent 85%);
    pointer-events: none;
  }

  .hero-mark-wrap {
    position: absolute;
    left: clamp(2rem, 10vw, 8rem);
    top: clamp(6rem, 20vh, 12rem);
    z-index: 1;
    pointer-events: none;
  }

  .gs-logo-reactive {
    width: clamp(120px, 15vw, 180px);
    height: auto;
    color: #5aa2ff;
    transform-origin: 50% 50%;
    will-change: transform, filter, opacity;
    transition:
      transform 120ms linear,
      filter 160ms linear,
      opacity 160ms linear;
    opacity: 0.9;
  }

  .gs-logo-path,
  .gs-logo-seam {
    vector-effect: non-scaling-stroke;
  }

  .gs-logo-seam {
    opacity: 0.6;
  }

  .gs-hero-inner {
    position: relative;
    z-index: 2;
    width: min(1200px, calc(100% - 4rem));
    margin: 0 auto;
    padding: 120px 0 80px;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 60px;
    align-items: center;
  }

  .hero-content {
    position: relative;
    z-index: 2;
  }

  .gs-pill {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--gs-primary);
    border: 1px solid rgba(90, 162, 255, 0.2);
    background: rgba(2, 6, 23, 0.4);
    padding: 8px 14px;
    border-radius: 999px;
    text-transform: uppercase;
  }

  .gs-pill .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--gs-primary);
    box-shadow: 0 0 10px var(--gs-primary);
  }

  .gs-hero h1 {
    margin: 24px 0 16px;
    font-family: 'Lexend', var(--font-sans);
    font-weight: 700;
    font-size: clamp(40px, 6vw, 84px);
    line-height: 0.95;
    letter-spacing: -0.03em;
    color: #ffffff;
  }

  .sub {
    max-width: 50ch;
    color: var(--gs-text-dim);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .actions {
    margin-top: 32px;
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 52px;
    padding: 0 28px;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: all 180ms ease;
  }

  .btn.primary {
    background: var(--gs-primary);
    color: #020617;
    box-shadow: 0 12px 30px rgba(90, 162, 255, 0.2);
  }

  .btn.ghost {
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #ffffff;
    background: rgba(255, 255, 255, 0.05);
  }

  .btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.1);
  }

  .panel {
    border-radius: 24px;
    background: rgba(10, 18, 36, 0.6);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 40px 100px rgba(0, 0, 0, 0.5);
    overflow: hidden;
  }

  .panel-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .lights {
    display: flex;
    gap: 8px;
  }

  .lights span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
  }

  .lights span:nth-child(1) { background: #ff5f56; }
  .lights span:nth-child(2) { background: #ffbd2e; }
  .lights span:nth-child(3) { background: #27c93f; }

  .panel-title {
    font-size: 11px;
    font-weight: 700;
    color: var(--gs-text-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .panel-body {
    padding: 24px;
  }

  .kv {
    display: grid;
    gap: 12px;
  }

  .kv div {
    display: flex;
    justify-content: space-between;
  }

  .kv span {
    font-size: 11px;
    font-weight: 600;
    color: var(--gs-text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .kv b {
    font-size: 11px;
    font-family: ui-monospace, monospace;
  }

  .kv .ok { color: #27c93f; }
  .kv .mode { color: var(--gs-primary); }

  .bars {
    margin: 24px 0 16px;
    display: flex;
    gap: 12px;
    align-items: flex-end;
    height: 80px;
  }

  .bars i {
    display: block;
    width: 100%;
    background: linear-gradient(180deg, var(--gs-primary), rgba(90, 162, 255, 0.2));
    border-radius: 4px;
    animation: bar 1.6s ease-in-out infinite;
  }

  .bars i:nth-child(1) { height: 40%; }
  .bars i:nth-child(2) { height: 70%; animation-delay: 0.1s; }
  .bars i:nth-child(3) { height: 50%; animation-delay: 0.2s; }
  .bars i:nth-child(4) { height: 90%; animation-delay: 0.3s; }
  .bars i:nth-child(5) { height: 60%; animation-delay: 0.4s; }

  @keyframes bar {
    0%, 100% { filter: brightness(1); transform: scaleY(1); }
    50% { filter: brightness(1.2); transform: scaleY(1.05); }
  }

  .terminal {
    margin-top: 16px;
    font-family: ui-monospace, monospace;
    font-size: 11px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.4);
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    padding-top: 16px;
  }

  @media (max-width: 980px) {
    .gs-hero-inner {
      grid-template-columns: 1fr;
      padding-top: 160px;
      gap: 48px;
      text-align: center;
    }

    .hero-mark-wrap {
      left: 50%;
      top: 3rem;
      transform: translateX(-50%);
    }

    .sub {
      margin: 0 auto;
    }

    .actions {
      justify-content: center;
    }

    .gs-grid {
      background-size: 40px 40px;
    }
  }
</style>
