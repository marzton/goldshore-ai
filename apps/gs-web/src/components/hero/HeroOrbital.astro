---
import HeroLogo from './HeroLogo.astro';
import statusCheckScriptUrl from '../../scripts/status-check.ts?url';

const runtimeEnv = Astro.locals.runtime?.env as { GS_SYSTEM_STATUS?: string } | undefined;
const systemStatus = runtimeEnv?.GS_SYSTEM_STATUS ?? 'Operational';
const isOperational = systemStatus.trim().toLowerCase() === 'operational';
---

<section class="gs-hero gs-hero-orbital gs-depth-bg" data-gs-hero>
  <canvas id="hero-stars" class="gs-hero-layer" aria-hidden="true" data-parallax="0.03"></canvas>
  <canvas id="hero-shooting-stars" class="gs-hero-layer gs-hero-layer-shooting" aria-hidden="true" data-parallax="0.04"></canvas>
  <div class="gs-grid-matrix" aria-hidden="true" data-parallax="0.02"></div>

  <div class="gs-container gs-seq gs-vt gs-hero-content" data-parallax="-0.015">
    <div class="gs-i-0 gs-kicker gs-signal">
      <span
        class:list={[
          'gs-status-dot',
          isOperational ? 'is-operational' : 'is-degraded',
        ]}
        data-gs-status-dot
        aria-hidden="true"
      ></span>
      <span data-gs-system-status>System Status: {systemStatus}</span>
    </div>

    <div class="gs-i-1 gs-hero-mark gs-hero-watermark">
      <HeroLogo />
    </div>

  <canvas id="pulsar-field" aria-hidden="true" data-parallax="0.03"></canvas>

  <div class="gs-container gs-seq gs-vt gs-hero-content" data-parallax="-0.015">
    <div class="gs-i-0 gs-kicker gs-signal">
      <span class="gs-status-dot" data-gs-status-dot aria-hidden="true"></span>
      <span data-gs-system-status>System Status: {systemStatus}</span>
    </div>

    <div class="gs-i-1 gs-hero-mark">
      <HeroLogo />
    </div>

    <h1 class="gs-i-2 gs-display gs-hero-title gs-vt-title">
      Shaping Waves with Applied Intelligence
    </h1>

    <p class="gs-i-3 gs-hero-sub">
      GoldShore builds institutional automation, deployment intelligence, and operational systems that stay calm under real pressure.
    </p>

    <div class="gs-i-4 gs-hero-actions">
      <a href="/workflows" class="gs-button gs-button-solid gs-edge-scan">Start the Experience</a>
      <a href="/contact" class="gs-button gs-button-outline">Contact Sales</a>
    </div>

    <div class="gs-i-5 gs-hero-preview" aria-label="Platform surface preview">
      <article class="gs-hero-preview-card">
        <h2>GoldShore Agent</h2>
        <p>Signal triage and response routing with operator-grade guardrails.</p>
      </article>
      <article class="gs-hero-preview-card">
        <h2>Deployment Pulse</h2>
        <p>Continuous checks across gs-web, gs-admin, and runtime workers.</p>
      </article>
      <article class="gs-hero-preview-card">
        <h2>Ops Surface</h2>
        <p>Control-plane visibility for incidents, workflows, and system health.</p>
      </article>
    </p>

    <div class="gs-i-4 gs-hero-actions">
      <a href="/workflows" class="gs-button gs-button-solid gs-edge-scan">Start the Experience</a>
      <a href="/contact" class="gs-button gs-button-outline">Contact Sales</a>
    </div>

    <div class="gs-i-5 gs-hero-preview" aria-label="Platform surface preview">
      <article class="gs-hero-preview-card">
        <h2>GoldShore Agent</h2>
        <p>Signal triage and response routing with operator-grade guardrails.</p>
      </article>
      <article class="gs-hero-preview-card">
        <h2>Deployment Pulse</h2>
        <p>Continuous checks across gs-web, gs-admin, and runtime workers.</p>
      </article>
      <article class="gs-hero-preview-card">
        <h2>Ops Surface</h2>
        <p>Control-plane visibility for incidents, workflows, and system health.</p>
      </article>
      Institutional-grade automation, infrastructure, and intelligence systems.
    </p>

    <div class="gs-i-4 gs-hero-actions">
      <a href="/contact" class="gs-button gs-button-solid gs-edge-scan"
        >Request Briefing</a
      >
    </div>
  </div>
</section>

<script type="module" src={statusCheckScriptUrl}></script>
<script type="module">
  import { mountStarfield } from './StarfieldCanvas';
  import { mountShootingStars } from './ShootingStarsCanvas';

  const starsCanvas = document.getElementById('hero-stars');
  const shootingCanvas = document.getElementById('hero-shooting-stars');

  const cleanups = [];

  if (starsCanvas instanceof HTMLCanvasElement) {
    cleanups.push(mountStarfield(starsCanvas));
  }

  if (shootingCanvas instanceof HTMLCanvasElement) {
    cleanups.push(mountShootingStars(shootingCanvas));
  }

  document.addEventListener('astro:before-swap', () => {
    cleanups.forEach((cleanup) => cleanup());
  }, { once: true });
</script>

<style>
  .gs-hero-orbital {
    min-height: min(92vh, 860px);
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(180deg, #020306 0%, #040915 100%);
  }

  .gs-hero-layer {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    opacity: 0.75;
  }

  .gs-hero-layer-shooting {
    opacity: 0.95;
  }

  .gs-grid-matrix {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.055) 1px, transparent 1px),
      radial-gradient(circle at center, rgba(114, 169, 255, 0.08), transparent 55%);
    background-size: 36px 36px, 36px 36px, 100% 100%;
    mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.62), rgba(0, 0, 0, 1));
  }

  .gs-hero-content {
    position: relative;
    z-index: 2;
    padding: 8.25rem 0 4.5rem;
    display: grid;
    gap: 1rem;
  }

  .gs-hero-watermark {
    opacity: 0.92;
    filter: drop-shadow(0 0 16px rgba(90, 140, 255, 0.2));
  }

  .gs-hero-title,
  .gs-hero-sub {
    max-width: 26ch;
  }

  .gs-hero-sub {
    color: rgba(232, 238, 250, 0.88);
  }

  .gs-hero-actions {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .gs-hero-preview {
    margin-top: 1.25rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .gs-hero-preview-card {
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: linear-gradient(180deg, rgba(9, 12, 24, 0.72), rgba(7, 10, 20, 0.62));
    border-radius: 12px;
    padding: 0.95rem 1rem;
    backdrop-filter: blur(4px);
  }

  .gs-hero-preview-card h2 {
    margin: 0;
    font-size: 0.95rem;
    letter-spacing: 0.01em;
  }

  .gs-hero-preview-card p {
    margin: 0.45rem 0 0;
    color: rgba(214, 224, 243, 0.85);
    font-size: 0.85rem;
    line-height: 1.4;
  }

  @media (max-width: 900px) {
    .gs-hero-content {
      padding-top: 7.25rem;
    }

    .gs-hero-preview {
      grid-template-columns: 1fr;
    }
  }
</style>

<script type="module" src={statusCheckScriptUrl}></script>
