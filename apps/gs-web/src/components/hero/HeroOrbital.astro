---
import HeroLogo from './HeroLogo.astro';

const runtimeEnv = Astro.locals.runtime?.env as { GS_SYSTEM_STATUS?: string } | undefined;
const systemStatus = runtimeEnv?.GS_SYSTEM_STATUS ?? 'Operational';
---

<section class="gs-hero gs-hero-orbital gs-depth-bg" data-gs-hero>
  <canvas id="pulsar-field" aria-hidden="true" data-parallax="0.03"></canvas>

  <div class="gs-container gs-seq gs-vt gs-hero-content" data-parallax="-0.015">
    <div class="gs-i-0 gs-kicker gs-signal">System Status: {systemStatus}</div>

    <div class="gs-i-1 gs-hero-mark">
      <HeroLogo />
    </div>

    <h1 class="gs-i-2 gs-display gs-hero-title gs-vt-title">
      Shaping Waves with Applied Intelligence
    </h1>

    <p class="gs-i-3 gs-hero-sub">
      Institutional-grade automation, infrastructure, and intelligence systems.
    </p>

    <div class="gs-i-4 gs-hero-actions">
      <a href="/contact" class="gs-button gs-button-solid gs-edge-scan"
        >Request Briefing</a
      >
    </div>
  </div>
</section>
