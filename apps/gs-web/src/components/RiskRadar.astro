---
import { radarBlips, radarSignals } from './RiskRadar.config';

const { title = 'Risk Radar', subtitle = 'Loopable surveillance surface for risk detection, social clips, and investor visuals.' } = Astro.props;
---

<section class="risk-radar-card">
  <div class="risk-radar-copy">
    <p class="gs-eyebrow">Social-ready visual</p>
    <h3>{title}</h3>
    <p>{subtitle}</p>
    <div class="risk-radar-signals">
      {radarSignals.map((signal) => (
        <div class="risk-radar-signal">
          <span>{signal.label}</span>
          <strong>{signal.value}</strong>
        </div>
      ))}
    </div>
  </div>

  <div class="risk-radar-stage" aria-label="Animated risk radar visual" role="img">
    <div class="risk-radar-grid"></div>
    <div class="risk-radar-rings"></div>
    <div class="risk-radar-crosshair"></div>
    <div class="risk-radar-sweep"></div>
    {radarBlips.map((blip) => (
      <span
        class="risk-radar-blip"
        style={`--x:${blip.x}%; --y:${blip.y}%; --delay:${blip.delay}s; --duration:${blip.duration}s; --size:${blip.size}px;`}
      ></span>
    ))}
    <div class="risk-radar-label">
      <strong>RISK SURFACE</strong>
      <span>Continuous sweep</span>
    </div>
  </div>
</section>

<style>
  .risk-radar-card {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(280px, 420px);
    gap: clamp(1.5rem, 3vw, 3rem);
    align-items: center;
    padding: clamp(1.5rem, 2vw, 2rem);
    border-radius: 24px;
    border: 1px solid var(--gs-border);
    background: linear-gradient(180deg, rgba(9, 16, 32, 0.92), rgba(7, 14, 28, 0.92));
    box-shadow: var(--gs-shadow);
  }

  .risk-radar-copy h3 {
    margin: 0.35rem 0 0.85rem;
    font-size: clamp(1.65rem, 3vw, 2.4rem);
  }

  .risk-radar-copy p {
    margin: 0;
    color: var(--gs-text-dim);
    line-height: 1.7;
  }

  .risk-radar-signals {
    display: grid;
    gap: 0.85rem;
    margin-top: 1.5rem;
  }

  .risk-radar-signal {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 1rem;
    border-radius: 14px;
    border: 1px solid rgba(90, 162, 255, 0.12);
    background: rgba(90, 162, 255, 0.06);
  }

  .risk-radar-signal span {
    color: var(--gs-text-dim);
    font-size: 0.92rem;
  }

  .risk-radar-signal strong {
    font-size: 0.92rem;
    letter-spacing: 0.08em;
  }

  .risk-radar-stage {
    --radar-size: min(100%, 420px);
    position: relative;
    width: var(--radar-size);
    aspect-ratio: 1;
    margin-inline: auto;
    border-radius: 50%;
    overflow: hidden;
    background:
      radial-gradient(circle at center, rgba(90, 162, 255, 0.2), rgba(90, 162, 255, 0.02) 42%, rgba(3, 8, 18, 0.98) 75%),
      #06101d;
    border: 1px solid rgba(90, 162, 255, 0.24);
    box-shadow:
      inset 0 0 80px rgba(90, 162, 255, 0.08),
      0 24px 80px rgba(0, 0, 0, 0.45);
  }

  .risk-radar-grid,
  .risk-radar-rings,
  .risk-radar-crosshair,
  .risk-radar-sweep,
  .risk-radar-stage::after {
    position: absolute;
    inset: 0;
  }

  .risk-radar-grid {
    background:
      linear-gradient(rgba(90, 162, 255, 0.08) 1px, transparent 1px),
      linear-gradient(90deg, rgba(90, 162, 255, 0.08) 1px, transparent 1px);
    background-size: 18% 18%;
    opacity: 0.45;
  }

  .risk-radar-rings {
    border-radius: 50%;
    background:
      radial-gradient(circle, transparent 18%, rgba(90, 162, 255, 0.18) 18.4%, transparent 19%),
      radial-gradient(circle, transparent 34%, rgba(90, 162, 255, 0.18) 34.4%, transparent 35%),
      radial-gradient(circle, transparent 50%, rgba(90, 162, 255, 0.18) 50.4%, transparent 51%),
      radial-gradient(circle, transparent 66%, rgba(90, 162, 255, 0.18) 66.4%, transparent 67%);
  }

  .risk-radar-crosshair {
    background:
      linear-gradient(rgba(90, 162, 255, 0.18), rgba(90, 162, 255, 0.18)) center/1px 100% no-repeat,
      linear-gradient(90deg, rgba(90, 162, 255, 0.18), rgba(90, 162, 255, 0.18)) center/100% 1px no-repeat;
  }

  .risk-radar-sweep {
    border-radius: 50%;
    background: conic-gradient(from 0deg, rgba(90, 162, 255, 0.34), rgba(90, 162, 255, 0.02) 18%, rgba(90, 162, 255, 0) 42%);
    mix-blend-mode: screen;
    animation: radar-spin 2.4s linear infinite;
    transform-origin: center;
  }

  .risk-radar-stage::after {
    content: '';
    border-radius: 50%;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.05);
    pointer-events: none;
  }

  .risk-radar-blip {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    margin-left: calc(var(--size) * -0.5);
    margin-top: calc(var(--size) * -0.5);
    border-radius: 999px;
    background: rgba(150, 214, 255, 0.98);
    box-shadow: 0 0 0 rgba(150, 214, 255, 0.5);
    animation:
      radar-blip var(--duration) ease-in-out infinite,
      radar-drift calc(var(--duration) * 1.35) ease-in-out infinite;
    animation-delay: var(--delay), calc(var(--delay) * -1);
  }

  .risk-radar-label {
    position: absolute;
    left: 9%;
    bottom: 10%;
    display: grid;
    gap: 0.2rem;
    padding: 0.8rem 0.95rem;
    border-radius: 14px;
    background: rgba(8, 14, 28, 0.82);
    border: 1px solid rgba(90, 162, 255, 0.18);
    backdrop-filter: blur(12px);
  }

  .risk-radar-label strong {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
  }

  .risk-radar-label span {
    color: var(--gs-text-dim);
    font-size: 0.85rem;
  }

  @keyframes radar-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes radar-blip {
    0%, 18%, 100% {
      opacity: 0.25;
      transform: scale(0.8);
      box-shadow: 0 0 0 0 rgba(150, 214, 255, 0);
    }

    24%, 38% {
      opacity: 1;
      transform: scale(1.2);
      box-shadow: 0 0 0 14px rgba(150, 214, 255, 0);
    }

    30% {
      box-shadow: 0 0 0 4px rgba(150, 214, 255, 0.3);
    }
  }

  @keyframes radar-drift {
    0%, 100% {
      translate: -3px -2px;
    }

    50% {
      translate: 3px 2px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .risk-radar-sweep,
    .risk-radar-blip {
      animation: none;
    }
  }

  @media (max-width: 900px) {
    .risk-radar-card {
      grid-template-columns: 1fr;
    }
  }
</style>
