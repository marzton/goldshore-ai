---
import BaseLayout from '../layouts/BaseLayout.astro';
import FlowSection from '../components/FlowSection.astro';

export const prerender = true;
---
<BaseLayout title="Solutions | GoldShore" description="Overview of GoldShore solution offerings">
  <FlowSection variant="hero">
    <div>
      <h1>Solutions</h1>
      <p class="gs-text-lg">Our solutions page is coming soon. We’re preparing a structured overview of solution packages, outcomes, and deployment models.</p>
    </div>
    <div class="gs-card">
      <h3>Temporary Intro</h3>
      <p>This placeholder ensures navigation is live while we finalize the full solutions catalog.</p>
    </div>
  </FlowSection>
</BaseLayout>
