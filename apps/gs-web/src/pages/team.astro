---
import WebLayout from '../layouts/WebLayout.astro';

export const prerender = true;
---

<WebLayout title="Team | Gold Shore" description="Meet the Gold Shore team.">
  <section class="gs-section">
    <div class="gs-container">
      <h1>Team</h1>
      <article class="gs-panel gs-edge-light gs-edge-scan">
        <h2>Robert Marston</h2>
        <p><strong>Managing Director, Strategic Advisory</strong></p>
        <p>
          Robert leads Gold Shore’s Strategic Advisory practice at the
          intersection of systematic risk management and institutional capital
          strategy. Focused on market regime analysis and risk-aware capital
          allocation, Robert transforms high-integrity market intelligence into
          actionable portfolio direction, helping allocators improve resilience,
          timing, and risk-adjusted outcomes across changing market conditions.
        </p>
      </article>
    </div>
  </section>
</WebLayout>
