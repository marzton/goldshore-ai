---
import WebLayout from '../layouts/WebLayout.astro';

export const prerender = true;
---

<WebLayout title="Team | Gold Shore" description="Engineering-first leadership and operational discipline.">
  <section class="gs-section gs-blueprint-bg">
    <div class="gs-container">
      <h1 class="gs-display" data-gs-reveal>Team</h1>
      <p data-gs-reveal>
        Gold Shore operates with an engineering-first mindset.
      </p>
      <p data-gs-reveal>
        Our leadership prioritizes infrastructure fluency, deployment governance, typed systems discipline,
        observability enforcement, and security-first surface design.
      </p>
      <p data-gs-reveal>
        This is not a marketing-led operation. It is engineering-led infrastructure development.
      </p>
    </div>
  </section>
</WebLayout>
