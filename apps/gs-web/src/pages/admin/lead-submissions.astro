---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = false;

type LeadSubmission = {
  id: string;
  form_type: string;
  name: string | null;
  email: string | null;
  company: string | null;
  role: string | null;
  website: string | null;
  team_size: string | null;
  industry: string | null;
  timeline: string | null;
  budget: string | null;
  goals: string | null;
  message: string | null;
  status: 'new' | 'read' | 'archived';
  received_at: string;
  ip_address: string | null;
  user_agent: string | null;
};

const runtime = Astro.locals.runtime as {
  env?: {
    DB?: {
      prepare(query: string): {
        bind(...values: string[]): { all(): Promise<{ results?: LeadSubmission[] }> };
        all(): Promise<{ results?: LeadSubmission[] }>;
      };
    };
  };
} | undefined;
const db = runtime?.env?.DB;
const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get('status');
const allowedStatuses = ['new', 'read', 'archived'] as const;
const filterStatus = allowedStatuses.includes(statusFilter as (typeof allowedStatuses)[number])
  ? statusFilter
  : null;
const redirectTo = `${url.pathname}${url.search}`;

let submissions: LeadSubmission[] = [];
let errorMessage = '';

if (!db) {
  errorMessage = 'Storage unavailable. Configure the DB binding for this environment.';
} else {
  const whereClause = filterStatus ? 'WHERE status = ?' : '';
  const query = `SELECT
    id,
    form_type,
    name,
    email,
    company,
    role,
    website,
    team_size,
    industry,
    timeline,
    budget,
    goals,
    message,
    status,
    received_at,
    ip_address,
    user_agent
  FROM lead_submissions
  ${whereClause}
  ORDER BY received_at DESC`;
  const statement = db.prepare(query);
  const response = filterStatus ? await statement.bind(filterStatus).all() : await statement.all();
  submissions = Array.isArray(response?.results) ? (response.results as LeadSubmission[]) : [];
}

const exportUrl = filterStatus
  ? `/api/admin/lead-submissions?format=csv&status=${encodeURIComponent(filterStatus)}`
  : '/api/admin/lead-submissions?format=csv';

const formatDate = (value: string) => new Date(value).toLocaleString();
const buildMailto = (email: string | null, name: string | null) => {
  if (!email) return '#';
  const subject = `GoldShore follow-up${name ? ` for ${name}` : ''}`;
  return `mailto:${email}?subject=${encodeURIComponent(subject)}`;
};
---

<BaseLayout title="Lead Submissions | GoldShore" description="Admin review for inbound leads">
  <section class="gs-section">
    <div class="gs-grid columns-2">
      <div>
        <h1>Lead submissions</h1>
        <p class="gs-text-lg">Review inbound requests, respond quickly, and archive resolved leads.</p>
      </div>
      <div class="gs-card">
        <h2 class="section-title"><span>◆</span>Actions</h2>
        <ul>
          <li><a href={exportUrl}>Export CSV</a></li>
          <li><a href="/contact">Open contact form</a></li>
        </ul>
      </div>
    </div>

    <div class="gs-card" style="margin-top: 2rem;">
      <form method="get" class="gs-grid" style="gap: 1rem; align-items: end;">
        <div class="gs-input-group">
          <label for="status-filter">Status filter</label>
          <select id="status-filter" name="status">
            <option value="" selected={!filterStatus}>All</option>
            {allowedStatuses.map((status) => (
              <option value={status} selected={filterStatus === status}>{status}</option>
            ))}
          </select>
        </div>
        <div>
          <button class="gs-button" type="submit">Apply filter</button>
        </div>
      </form>
    </div>

    {errorMessage ? (
      <div class="gs-card" style="margin-top: 2rem;">
        <p class="gs-text-lg">{errorMessage}</p>
      </div>
    ) : (
      <div class="gs-card" style="margin-top: 2rem; overflow-x: auto;">
        <table class="gs-table">
          <thead>
            <tr>
              <th>Received</th>
              <th>Contact</th>
              <th>Company</th>
              <th>Form</th>
              <th>Status</th>
              <th>Summary</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {submissions.length === 0 ? (
              <tr>
                <td colspan="7">No submissions yet.</td>
              </tr>
            ) : (
              submissions.map((submission) => (
                <tr>
                  <td>{formatDate(submission.received_at)}</td>
                  <td>
                    <div>
                      <strong>{submission.name || 'Unknown'}</strong>
                    </div>
                    <div>
                      {submission.email ? <a href={buildMailto(submission.email, submission.name)}>Email</a> : 'No email'}
                    </div>
                  </td>
                  <td>
                    <div>{submission.company || '—'}</div>
                    <div class="gs-text-sm">{submission.role || submission.team_size || '—'}</div>
                  </td>
                  <td>{submission.form_type}</td>
                  <td><span class={`gs-badge ${submission.status === 'new' ? 'info' : submission.status === 'read' ? 'success' : ''}`}>{submission.status}</span></td>
                  <td>{(submission.message || submission.goals || '').slice(0, 140) || '—'}</td>
                  <td>
                    <form method="post" action="/api/admin/lead-submissions" style="display: grid; gap: 0.5rem;">
                      <input type="hidden" name="id" value={submission.id} />
                      <input type="hidden" name="redirectTo" value={redirectTo} />
                      <select name="status" aria-label="Update status">
                        {allowedStatuses.map((status) => (
                          <option value={status} selected={status === submission.status}>{status}</option>
                        ))}
                      </select>
                      <button class="gs-button" type="submit">Update</button>
                    </form>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
    )}
  </section>
</BaseLayout>
