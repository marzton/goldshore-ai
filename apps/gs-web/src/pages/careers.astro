---
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;
---

<BaseLayout title="Careers | Gold Shore" description="Work with Gold Shore.">
  <section class="gs-section gs-section--padded">
    <div class="gs-container" style="max-width: 720px;">
      <h1>Careers</h1>
      <p>
        We are building systems that help institutions steer capital with clarity and resilience.
      </p>
      <p>
        To express interest, send your background and role focus to
        <a href="mailto:careers@goldshore.ai">careers@goldshore.ai</a>.
      </p>
    </div>
  </section>
</BaseLayout>
