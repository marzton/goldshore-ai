---
import WebLayout from '../layouts/WebLayout.astro';
import ContactForm from '../components/ContactForm.astro';

export const prerender = true;
---

<WebLayout
  title="Contact | GoldShore"
  description="Contact the GoldShore team for institutional AI systems and risk tooling."
>
  <main class="gs-shell-section contact-page">
    <div class="contact-grid">
      <div class="contact-info">
        <p class="gs-eyebrow">Engagement</p>
        <h1>Open a direct line with GoldShore.</h1>
        <p class="contact-lead">
          GoldShore responds with scope, next steps, and operating cadence for
          system engineering and AI operations.
        </p>

        <div class="contact-details">
          <div class="detail-item">
            <h3>Standard response</h3>
            <p>Within 24 hours for qualified briefings.</p>
          </div>
          <div class="detail-item">
            <h3>Operating hours</h3>
            <p>08:00 – 18:00 EST, Monday – Friday.</p>
          </div>
          <div class="detail-item">
            <h3>Direct email</h3>
            <p><a href="mailto:hello@goldshore.ai">hello@goldshore.ai</a></p>
          </div>
        </div>
      </div>

      <div class="contact-form-container">
        <ContactForm />
      </div>
    </div>
  </main>

  <style>
    .contact-page {
      padding: 8rem 0 6rem;
    }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 6rem;
      align-items: start;
    }

    .contact-info h1 {
      font-family: 'Lexend', var(--font-sans);
      font-weight: 700;
      font-size: clamp(2.5rem, 5vw, 4rem);
      line-height: 1.05;
      margin: 1.5rem 0 2rem;
      letter-spacing: -0.02em;
    }

    .contact-lead {
      font-size: 1.25rem;
      color: var(--gs-text-dim);
      line-height: 1.6;
      margin-bottom: 4rem;
      max-width: 32ch;
    }

    .contact-details {
      display: grid;
      gap: 2.5rem;
    }

    .detail-item h3 {
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gs-primary);
      margin-bottom: 0.5rem;
    }

    .detail-item p {
      font-size: 1.1rem;
      color: #fff;
    }

    .detail-item a {
      color: #fff;
      text-decoration: underline;
      text-underline-offset: 4px;
      text-decoration-color: rgba(255, 255, 255, 0.2);
    }

    .detail-item a:hover {
      text-decoration-color: var(--gs-primary);
    }

    @media (max-width: 1024px) {
      .contact-grid {
        grid-template-columns: 1fr;
        gap: 4rem;
      }

      .contact-page {
        padding-top: 6rem;
      }

      .contact-lead {
        max-width: none;
      }
    }
  </style>
</WebLayout>
