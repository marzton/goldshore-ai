---
import WebLayout from '../layouts/WebLayout.astro';

export const prerender = true;
---

<WebLayout title="Contact | Gold Shore" description="Contact Gold Shore.">
  <section class="gs-section gs-blueprint-bg">
    <div class="gs-container">
      <h1>Contact</h1>

    <form class="contact-form">
      <label for="name">Name</label>
      <input id="name" type="text" />

      <label for="email">Email</label>
      <input id="email" type="email" />

      <label for="brief">Project Brief</label>
      <textarea id="brief" rows="5"></textarea>

      <button type="submit">Send</button>
    </form>
  </section>
</WebLayout>

<style>
  .contact-form {
    display: grid;
    gap: 0.75rem;
    max-width: 620px;
  }

  input,
  textarea {
    border: 1px solid #1f2937;
    background: #020617;
    color: #e5e7eb;
    padding: 0.75rem;
  }

  button {
    justify-self: start;
    border: 1px solid #334155;
    background: transparent;
    color: #e5e7eb;
    padding: 0.75rem 1.25rem;
    cursor: pointer;
  }
</style>
