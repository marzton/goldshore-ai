---
import { GSButton } from '@goldshore/ui';
import BaseLayout from '../layouts/BaseLayout.astro';
import FlowSection from '../components/FlowSection.astro';

export const prerender = true;
---

<BaseLayout title="Contact | GoldShore" description="Reach the GoldShore team">
  <FlowSection variant="hero">
    <div>
      <h1>Contact</h1>
      <p>
        Tell us about your systems, service levels, or the experiences you want
        to build. We will respond with a tailored plan.
      </p>
      <p>
        Prefer a structured intake? Use our
        <a href="/intake">project qualification form</a>.
      </p>
    </div>
    <form id="contact-form" class="gs-card" action="/api/contact" method="post">
      <input type="hidden" name="formType" value="contact" />
      <input type="hidden" name="redirectTo" value="/thank-you" />
      <input type="hidden" name="formStartedAt" value="" />
      <div class="gs-honeypot" aria-hidden="true">
        <label for="companyWebsite">Company website</label>
        <input id="companyWebsite" name="companyWebsite" type="text" autocomplete="off" tabindex="-1" />
      </div>
      <div class="gs-input-group">
        <label for="name">Name</label>
        <input id="name" name="name" type="text" autocomplete="name" required />
      </div>
      <div class="gs-input-group">
        <label for="email">Work email</label>
        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          spellcheck="false"
          required
        />
      </div>
      <div class="gs-input-group">
        <label for="inquiry">Inquiry type</label>
        <select id="inquiry" name="inquiry" autocomplete="off">
          <option value="general">General inquiry</option>
          <option value="strategy-call">Strategy call</option>
          <option value="project-scope">Project scoping</option>
          <option value="support">Support</option>
        </select>
      </div>
      <div class="gs-input-group">
        <label for="message">Project brief</label>
        <textarea
          id="message"
          name="message"
          rows="4"
          aria-describedby="message-helper"
          required></textarea>
        <p id="message-helper" class="gs-helper">
          We read every request. Please avoid sensitive data.
        </p>
      </div>
      <GSButton type="submit">Send message</GSButton>
    </form>
  </FlowSection>

  <FlowSection>
    <div class="gs-grid columns-2">
      <div>
        <h2>Snapshot</h2>
        <p class="gs-text-lg">Direct, senior-led delivery that keeps programs steady and fast.</p>
        <GSButton href="#contact-form" variant="secondary">Send your brief</GSButton>
      </div>
      <div class="gs-card">
        <h3 class="section-title"><span>◆</span>Snapshot</h3>
        <ul>
          <li><strong>Current Focus:</strong> Automation layers, resilient infrastructure, and AI-assisted operations.</li>
          <li><strong>What I build:</strong> End-to-end platforms, secure integrations, and operator-facing tooling.</li>
          <li><strong>How I work:</strong> Clear scope, weekly checkpoints, and transparent delivery metrics.</li>
          <li><strong>Availability:</strong> Full-time or contract engagements.</li>
        </ul>
        <p class="gs-text-sm">Have a scope in mind? Send the brief and I’ll respond with a plan.</p>
      </div>
    </div>
  </FlowSection>

  <script>
    const form = document.getElementById('contact-form');
    const button = form?.querySelector('button[type="submit"]');

    if (form instanceof HTMLFormElement && button) {
      const startedAtField = form.querySelector('[name="formStartedAt"]');
      if (startedAtField instanceof HTMLInputElement) {
        startedAtField.value = String(Date.now());
      }

      const inquiryField = form.querySelector('[name="inquiry"]');
      const inquiryParam = new URLSearchParams(window.location.search).get('inquiry');
      const allowedInquiryTypes = new Set(['general', 'strategy-call', 'project-scope', 'support']);
      if (inquiryField instanceof HTMLSelectElement && inquiryParam && allowedInquiryTypes.has(inquiryParam)) {
        inquiryField.value = inquiryParam;
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (button.hasAttribute('disabled')) return;

        const originalText = button.innerHTML;
        button.setAttribute('disabled', 'true');
        button.innerHTML = '<span class="gs-loader" aria-hidden="true"></span> Sending...';

        try {
          const formData = new FormData(form);
          const response = await fetch(form.getAttribute('action') || '/api/contact', {
            method: 'POST',
            body: formData,
          });

          if (response.ok || response.redirected) {
             window.location.href = response.url;
          } else {
            throw new Error('Submission failed');
          }
        } catch (err) {
          console.error(err);
          button.removeAttribute('disabled');
          button.innerHTML = originalText;

          let errorMsg = form.querySelector('.gs-form-error');
          if (!errorMsg) {
             errorMsg = document.createElement('div');
             errorMsg.className = 'gs-form-error';
             form.appendChild(errorMsg);
          }
          if (errorMsg instanceof HTMLElement) {
             errorMsg.style.marginTop = '1rem';
             errorMsg.style.color = '#ef4444';
             errorMsg.textContent = 'Unable to send message. System may be busy.';
          }
        }
      });
    }
  </script>

  <style is:global>
    .gs-honeypot {
      position: absolute;
      left: -10000px;
      top: auto;
      width: 1px;
      height: 1px;
      overflow: hidden;
    }

    .gs-loader {
      display: inline-block;
      width: 1em;
      height: 1em;
      border: 2px solid currentColor;
      border-right-color: transparent;
      border-radius: 50%;
      animation: gs-spin 0.75s linear infinite;
      margin-right: 0.5em;
      vertical-align: text-bottom;
    }

    @keyframes gs-spin {
      to {
        transform: rotate(360deg);
      }
    }
  </style>
</BaseLayout>
