---
import WebLayout from '../layouts/WebLayout.astro';

export const prerender = true;
---

<WebLayout title="Contact | Gold Shore" description="Contact Gold Shore.">
  <section class="gs-section">
    <div class="gs-container">
      <h1>Contact</h1>

      <form class="contact-form">
        <label for="name">Name</label>
        <input id="name" type="text" />

        <label for="email">Email</label>
        <input id="email" type="email" />

        <label for="brief">Project Brief</label>
        <textarea id="brief" rows="5"></textarea>

        <button type="submit" class="gs-button gs-button--primary">Send</button>
      </form>
    </div>
  </section>
</WebLayout>

<style>
  .contact-form {
    display: grid;
    gap: 0.75rem;
    max-width: 620px;
  }

  input,
  textarea {
    border: 1px solid var(--gs-border-subtle);
    border-radius: var(--gs-radius-md);
    background: var(--gs-bg-secondary);
    color: var(--gs-text-primary);
    padding: 0.75rem;
  }

  button {
    border: 0;
    cursor: pointer;
    justify-self: start;
  }
</style>
