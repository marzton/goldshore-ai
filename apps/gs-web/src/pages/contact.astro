---
import WebLayout from '../layouts/WebLayout.astro';

export const prerender = true;
---

<WebLayout title="Contact | Gold Shore" description="Platform engagements, partnerships, and infrastructure advisory.">
  <section class="gs-section gs-blueprint-bg">
    <div class="gs-container">
      <h1 class="gs-display" data-gs-reveal>Contact</h1>
      <p data-gs-reveal>For platform engagements, developer partnerships, or infrastructure advisory:</p>
      <p data-gs-reveal><strong>Email:</strong> contact@goldshore.ai<br /><strong>Developer Access:</strong> developer@goldshore.ai</p>

      <div class="gs-panel" style="margin-top:2rem;" data-gs-reveal>
        <div class="gs-label">Inquiry Categories</div>
        <ul style="margin-top:0.8rem;">
          <li>Infrastructure Advisory</li>
          <li>Platform Architecture</li>
          <li>Automation &amp; CI/CD</li>
          <li>Secure Surface Design</li>
          <li>Risk Radar Access</li>
        </ul>
        <p style="margin-top:1rem;">All inquiries are reviewed with discretion and structured evaluation.</p>
      </div>
    </div>
  </section>
</WebLayout>
