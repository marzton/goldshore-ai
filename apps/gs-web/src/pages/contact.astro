---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';

export const prerender = true;
---

<BaseLayout title="Contact | GoldShore" description="Contact the GoldShore team.">
  <section class="page-shell gs-shell-section contact-page">
    <div class="contact-copy">
      <p class="gs-eyebrow">Contact</p>
      <h1>Open a direct line with GoldShore.</h1>
      <p>
        Start with the guided intake to receive a tailored service
        recommendation and week-one engagement outline.
      </p>
      <p>
        Prefer a structured intake? Use our
        <a href="/intake">project qualification form</a>.
      </p>
    </div>
    <form id="contact-form" class="gs-card" action="/api/contact" method="post">
      <input type="hidden" name="formType" value="contact" />
      <input type="hidden" name="redirectTo" value="/thank-you" />
      <input type="hidden" name="formStartedAt" value="" />
      <div class="gs-honeypot" aria-hidden="true">
        <label for="companyWebsite">Company website</label>
        <input id="companyWebsite" name="companyWebsite" type="text" autocomplete="off" tabindex="-1" />
      </div>
      <div class="gs-input-group">
        <label for="name">Name</label>
        <input id="name" name="name" type="text" autocomplete="name" required />
      </div>
      <div class="gs-input-group">
        <label for="email">Work email</label>
        <p id="email-help" class="field-help">
          Use the best email for project follow-up.
        </p>
        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          spellcheck="false"
          aria-describedby="email-help"
          required
        />
      </div>
      <div class="gs-input-group">
        <label for="inquiry">Inquiry type</label>
        <p id="inquiry-help" class="field-help">
          Choose the path that best matches the engagement you want to start.
        </p>
        <select id="inquiry" name="inquiry" aria-describedby="inquiry-help">
          <option value="general">General inquiry</option>
          <option value="strategy-call">Strategy call</option>
          <option value="project-scope">Project scoping</option>
          <option value="support">Support</option>
        </select>
      </div>
      <div class="gs-input-group">
        <label for="message">Project brief</label>
        <p id="message-helper" class="field-help">
          Share a short summary of your goals, timeline, and budget. We read every
          request, so please avoid sensitive data.
        </p>
        <textarea
          id="message"
          name="message"
          rows="5"
          placeholder="We need support with cloud architecture and security hardening over the next 8 weeks."
          aria-describedby="message-helper"
          required></textarea>
      </div>
      <div id="form-status" class="form-status" aria-live="polite" role="status"></div>
      <GSButton type="submit">
        <span id="submit-text">Send message</span>
      </GSButton>
    </form>
  </FlowSection>

  <FlowSection>
    <div class="gs-grid columns-2">
      <div>
        <h2>Snapshot</h2>
        <p class="gs-text-lg">Direct, senior-led delivery that keeps programs steady and fast.</p>
        <GSButton href="#contact-form" variant="secondary">Send your brief</GSButton>
      </div>
      <div class="gs-card">
        <h3 class="section-title"><span>◆</span>Snapshot</h3>
        <ul>
          <li><strong>Current Focus:</strong> Automation layers, resilient infrastructure, and AI-assisted operations.</li>
          <li><strong>What I build:</strong> End-to-end platforms, secure integrations, and operator-facing tooling.</li>
          <li><strong>How I work:</strong> Clear scope, weekly checkpoints, and transparent delivery metrics.</li>
          <li><strong>Availability:</strong> Full-time or contract engagements.</li>
        </ul>
        <p class="gs-text-sm">Have a scope in mind? Send the brief and I’ll respond with a plan.</p>
      </div>
    </div>
  </FlowSection>

  <script>
    const form = document.getElementById('contact-form');
    const button = form?.querySelector('button[type="submit"]');
    const submitText = form?.querySelector('#submit-text');
    const formStatus = document.getElementById('form-status');

    const setStatus = (message, type) => {
      if (!(formStatus instanceof HTMLElement)) return;
      formStatus.textContent = message;
      formStatus.classList.remove('success', 'error', 'progress');

      if (type) {
        formStatus.classList.add(type);
      }
    };

    if (form instanceof HTMLFormElement && button instanceof HTMLButtonElement) {
      const startedAtField = form.querySelector('[name="formStartedAt"]');
      if (startedAtField instanceof HTMLInputElement) {
        startedAtField.value = String(Date.now());
      }

      const inquiryField = form.querySelector('#inquiry');
      const inquiryParam = new URLSearchParams(window.location.search).get('inquiry');
      const allowedInquiryTypes = new Set([
        'general',
        'strategy-call',
        'project-scope',
        'support',
      ]);

      if (
        inquiryField instanceof HTMLSelectElement &&
        inquiryParam &&
        allowedInquiryTypes.has(inquiryParam)
      ) {
        inquiryField.value = inquiryParam;
      }

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (button.disabled) return;

        if (!form.checkValidity()) {
          form.reportValidity();
          setStatus('Please complete all required fields before submitting.', 'error');
          return;
        }

        const originalText =
          submitText instanceof HTMLElement ? submitText.textContent : button.textContent;
        button.disabled = true;
        button.setAttribute('aria-busy', 'true');
        if (submitText instanceof HTMLElement) {
          submitText.textContent = 'Sending...';
        }
        setStatus('Sending your message...', 'progress');

        try {
          const response = await fetch(form.getAttribute('action') || '/api/contact', {
            method: form.getAttribute('method') || 'POST',
            body: new FormData(form),
          });

          if (!response.ok && !response.redirected) {
            throw new Error(`Submission failed: ${response.status}`);
          }

          const redirectToField = form.querySelector('[name="redirectTo"]');
          const redirectTarget =
            response.redirected && response.url
              ? response.url
              : redirectToField instanceof HTMLInputElement && redirectToField.value
                ? redirectToField.value
                : '/thank-you';

          window.location.href = redirectTarget;
        } catch (err) {
          console.error(err);
          button.disabled = false;
          button.removeAttribute('aria-busy');
          if (submitText instanceof HTMLElement) {
            submitText.textContent = originalText || 'Send message';
          }
          setStatus(
            'Unable to send message right now. Please try again or email hello@goldshore.ai.',
            'error',
          );
        }
      });
        Share the system, workflow, or risk surface you need to operationalize. We respond with scope, cadence,
        and next actions.
      </p>
      <div class="contact-notes">
        <div>
          <span>Focus</span>
          <strong>Decision support, workflow orchestration, applied AI</strong>
        </div>
        <div>
          <span>Working style</span>
          <strong>Clear scopes, operator checkpoints, measurable delivery</strong>
        </div>
      </div>
    </div>

    <ContactForm heading="Send your brief" />
  </section>

  <style>
    .contact-page {
      padding: 4.5rem 0 5rem;
      display: grid;
      grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
      gap: 1.5rem;
      align-items: start;
    }

    .contact-copy h1 {
      margin: 0.75rem 0 1rem;
      font-size: clamp(2.5rem, 6vw, 4.6rem);
      line-height: 0.98;
      letter-spacing: -0.04em;
      max-width: 10ch;
    }

    .contact-copy > p {
      max-width: 56ch;
      color: var(--gs-text-dim);
      line-height: 1.75;
    }

    .contact-notes {
      display: grid;
      gap: 1rem;
      margin-top: 1.5rem;
    }

    .contact-notes div {
      padding: 1.2rem;
      border-radius: 18px;
      border: 1px solid rgba(255, 255, 255, 0.06);
      background: rgba(10, 18, 36, 0.7);
    }

    .field-help {
      margin: 0.25rem 0 0.5rem;
      color: var(--gs-color-text-muted, #94a3b8);
      font-size: 0.95rem;
    }

    .form-status {
      margin: 0.75rem 0;
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      border: 1px solid transparent;
      min-height: 1.25rem;
    }

    .form-status.progress {
      background: rgba(37, 52, 138, 0.12);
      border-color: rgba(96, 116, 211, 0.45);
      color: #c7d2fe;
    }

    .form-status.success {
      background: rgba(10, 95, 37, 0.14);
      border-color: rgba(110, 231, 183, 0.35);
      color: #bbf7d0;
    }

    .form-status.error {
      background: rgba(143, 23, 23, 0.14);
      border-color: rgba(248, 113, 113, 0.35);
      color: #fecaca;
    }

    #contact-form button[disabled] {
      opacity: 0.65;
      cursor: not-allowed;
    .contact-notes span {
      display: block;
      font-size: 0.78rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--gs-text-dim);
      margin-bottom: 0.5rem;
    }

    @media (max-width: 920px) {
      .contact-page {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
