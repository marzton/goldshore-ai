---
import WebLayout from '../../layouts/WebLayout.astro';

export const prerender = true;
---

<WebLayout title="Risk Radar | Gold Shore" description="Forthcoming operational threat visualization system.">
  <section class="gs-section">
    <h1>Risk Radar</h1>

    <p>
      Risk Radar is a forthcoming operational threat visualization system.
    </p>

    <div class="radar-preview">
      <div class="pulse"></div>
    </div>
  </section>
</WebLayout>

<style>
  .radar-preview {
    height: 400px;
    background: radial-gradient(circle, #0ea5e9 0%, #020617 70%);
    border-radius: 0;
    position: relative;
    overflow: hidden;
    margin-top: 2rem;
  }

  .pulse {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 180px;
    height: 180px;
    border: 1px solid rgba(186, 230, 253, 0.5);
    border-radius: 999px;
    transform: translate(-50%, -50%);
    animation: pulse 2.2s ease-out infinite;
  }

  @keyframes pulse {
    from {
      opacity: 0.9;
      transform: translate(-50%, -50%) scale(0.5);
    }
    to {
      opacity: 0;
      transform: translate(-50%, -50%) scale(2.3);
    }
  }
</style>
