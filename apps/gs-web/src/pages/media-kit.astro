---
import WebLayout from '../layouts/WebLayout.astro';
import { canonicalLogoPath } from '../lib/canonicalLogoPath';

export const prerender = true;
---

<WebLayout
  title="Media Kit | Gold Shore"
  description="Brand assets and press information for Gold Shore."
>
  <section class="gs-section">
    <div class="gs-container gs-panel gs-edge-light gs-edge-scan">
      <h1>Media Kit</h1>
      <p>
        Access Gold Shore brand assets, company boilerplate, and press contact
        guidance. For interview requests or partnership media opportunities,
        email
        <a href="mailto:hello@goldshore.ai">hello@goldshore.ai</a>.
      </p>
      <p>
        Download placeholder kit:
        <a href={canonicalLogoPath} download>Gold Shore Brand Asset Sample</a>
      </p>
    </div>
  </section>
</WebLayout>
