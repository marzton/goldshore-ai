---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import MDXCodeBlock from '../../../components/MDXCodeBlock.astro';

const description = 'Overview and quickstart for GoldShore developer documentation.';
const docsSchema = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  '@id': 'https://goldshore.ai/developer/docs#tech-article',
  headline: 'GoldShore Documentation Overview',
  description,
  url: 'https://goldshore.ai/developer/docs',
  mainEntityOfPage: 'https://goldshore.ai/developer/docs',
  author: {
    '@id': 'https://goldshore.ai#organization',
  },
  publisher: {
    '@id': 'https://goldshore.ai#organization',
  },
};
---

<DocsLayout
  title="GoldShore Documentation"
  description={description}
  structuredData={docsSchema}
  page={{ slug: 'index' }}
>
  <h1>Overview</h1>
  <p>Everything begins with the API.</p>

  <h2 id="api">API Base</h2>
  <MDXCodeBlock>
    GET {String(import.meta.env.PUBLIC_API || 'https://api.goldshore.dev')}/system/info
  </MDXCodeBlock>

  <h2 id="gateway">Gateway</h2>
  <MDXCodeBlock>
    {import.meta.env.PUBLIC_GATEWAY || 'https://gateway.goldshore.dev'}/api/* → gs-api
  </MDXCodeBlock>

  <h2 id="auth">Auth</h2>
  <p>Uses Cloudflare Access JWT (aud: goldshore-admin).</p>
</DocsLayout>
