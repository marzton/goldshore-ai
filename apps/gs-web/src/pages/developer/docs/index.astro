---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import MDXCodeBlock from '../../../components/MDXCodeBlock.astro';
---

<DocsLayout title="GoldShore Documentation" page={{ slug: 'index' }}>
  <h1>Overview</h1>
  <p>Everything begins with the API.</p>

  <h2 id="api">API Base</h2>
  <MDXCodeBlock>
    GET {String(import.meta.env.PUBLIC_API || 'https://api.goldshore.ai')}/system/info
  </MDXCodeBlock>

  <h2 id="gateway">Gateway</h2>
  <MDXCodeBlock>
    {import.meta.env.PUBLIC_GATEWAY || 'https://gw.goldshore.ai'}/api/* → gs-api
  </MDXCodeBlock>

  <h2 id="auth">Auth</h2>
  <p>Uses Cloudflare Access JWT (aud: goldshore-admin).</p>
</DocsLayout>
