---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="GoldShore SDK | Developer" description="Integrate GoldShore agents into your applications">
  <section class="gs-section gs-blueprint-bg gs-section--padded">
    <div class="max-w-4xl mx-auto">
      <h1 class="gs-heading text-4xl mb-4">GoldShore SDK</h1>
      <p class="text-lg text-[var(--gs-text-secondary)] mb-8">
        Build powerful agentic workflows with our TypeScript SDK.
      </p>

      <div class="p-6 border border-[var(--gs-border-color)] rounded-lg bg-[var(--gs-surface-2)]">
        <h2 class="text-xl font-semibold mb-2">Installation</h2>
        <pre class="bg-black p-4 rounded text-sm font-mono overflow-x-auto"><code>pnpm add @goldshore/sdk</code></pre>
        <p class="mt-4 text-sm text-[var(--gs-text-tertiary)]">Documentation coming soon.</p>
      </div>
    </div>
  </section>
</BaseLayout>
