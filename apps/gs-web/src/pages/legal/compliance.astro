---
import BaseLayout from '../../layouts/BaseLayout.astro';

const entityMeta = [
  ['FEIN / EIN', 'Shared in the onboarding packet under NDA.'],
  ['NYS entity ID', 'Shared in the onboarding packet under NDA.'],
  ['Registered address', 'Published in onboarding packet.'],
  ['Certificate of authority', 'Current; latest filing confirmation available on request.']
];
---

<BaseLayout title="Legal & Compliance | GoldShore" description="Entity and compliance disclosures.">
  <section class="gs-section gs-section--padded legal-compliance-section">
    <div class="gs-container">
      <h1>Legal &amp; Compliance</h1>
      <p>
        This page provides the trust surface for legal entity verification,
        disclosures, and baseline operating controls used in client engagements.
      </p>

      <div class="gs-card" style="margin: 1rem 0;">
        <h2>Entity profile</h2>
        <dl>
          {
            entityMeta.map(([label, value]) => (
              <div style="display:grid;grid-template-columns:220px 1fr;gap:0.75rem;padding:0.4rem 0;border-bottom:1px solid var(--gs-border-color);">
                <dt><strong>{label}</strong></dt>
                <dd>{value}</dd>
              </div>
            ))
          }
        </dl>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        <article class="gs-card">
          <h2>Security posture</h2>
          <ul>
            <li>Least-privilege access controls and role-based restrictions</li>
            <li>Change logging for operational and administrative actions</li>
            <li>Documented incident escalation workflow</li>
          </ul>
        </article>

        <article class="gs-card">
          <h2>Policy set</h2>
          <ul>
            <li><a href="/legal/privacy">Privacy policy</a></li>
            <li><a href="/legal/terms">Terms of service</a></li>
            <li><a href="/status">Service status and maintenance updates</a></li>
            <li><a href="/security-policy">Security policy</a></li>
            <li><a href="/disclosure-policy">Disclosure policy</a></li>
          </ul>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .legal-compliance-section {
    background: linear-gradient(180deg, var(--gs-bg-0) 0%, var(--gs-bg-1) 100%);
  }
</style>
