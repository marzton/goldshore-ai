---
import BaseLayout from '../../layouts/BaseLayout.astro';

const entityMeta = [
  ['Legal entity', 'Gold Shore AI, LLC'],
  ['Registered jurisdiction', 'New York, United States'],
  ['FEIN / EIN', 'Available under NDA during onboarding'],
  ['NYS entity ID', 'Available under NDA during onboarding'],
  ['Registered address', 'Published in onboarding packet'],
  [
    'Certificate of authority',
    'Current; latest filing confirmation available on request',
  ],
];
---

<BaseLayout
  title="Legal & Compliance | GoldShore"
  description="Entity and compliance disclosures."
>
  <section class="gs-section gs-blueprint-bg gs-section--padded">
    <div class="gs-container">
      <h1>Legal &amp; Compliance</h1>
      <p>
        This page provides the trust surface for legal entity verification,
        disclosures, and baseline operating controls used in client engagements.
      </p>

      <div class="gs-card compliance-entity-card">
        <h2>Entity profile</h2>
        <dl class="compliance-entity-list">
          {
            entityMeta.map(([label, value]) => (
              <div class="compliance-entity-row">
                <dt>
                  <strong>{label}</strong>
                </dt>
                <dd>{value}</dd>
              </div>
            ))
          }
        </dl>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        <article class="gs-card">
          <h2>Security posture</h2>
          <ul>
            <li>Least-privilege access controls and role-based restrictions</li>
            <li>Change logging for operational and administrative actions</li>
            <li>Documented incident escalation workflow</li>
          </ul>
        </article>

        <article class="gs-card">
          <h2>Policy set</h2>
          <ul>
            <li><a href="/legal/privacy">Privacy policy</a></li>
            <li><a href="/legal/terms">Terms of service</a></li>
            <li>
              <a href="/status">Service status and maintenance updates</a>
            </li>
          </ul>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
