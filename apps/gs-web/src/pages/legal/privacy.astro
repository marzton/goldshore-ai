---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Privacy Policy | GoldShore" description="Privacy policy overview">
  <section class="gs-section gs-blueprint-bg gs-section--padded">
    <div class="gs-container">
      <h1>Privacy Policy</h1>
      <p>
        GoldShore.ai processes only the information required to respond to
        inquiries, scope delivery, and operate contracted services.
      </p>
      <ul>
        <li>Contact forms are used for lead qualification and delivery follow-up.</li>
        <li>Operational telemetry is retained for reliability and security diagnostics.</li>
        <li>Sensitive engagement details are shared under contract controls and least-privilege access.</li>
      </ul>
      <p>
        For legal-entity verification and disclosure metadata, see
        <a href="/legal/compliance">Legal &amp; Compliance</a>.
      </p>
    </div>
  </section>
</BaseLayout>
