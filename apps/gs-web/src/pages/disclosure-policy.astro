---
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;
---

<BaseLayout title="Disclosure Policy | Gold Shore" description="Coordinated vulnerability disclosure guidance.">
  <section class="gs-section gs-section--padded">
    <div class="gs-container" style="max-width: 800px;">
      <h1>Disclosure Policy</h1>
      <p>
        Gold Shore follows a coordinated disclosure process. We ask researchers to provide us
        reasonable time to validate and remediate findings before public disclosure.
      </p>

      <ul>
        <li>Do not publicly disclose vulnerabilities before remediation or explicit approval.</li>
        <li>Do not access, alter, or retain data beyond what is required to demonstrate the issue.</li>
        <li>Use the reporting channel in our <a href="/security-policy">Security Policy</a>.</li>
      </ul>
    </div>
  </section>
</BaseLayout>
