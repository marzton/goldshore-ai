---
import BaseLayout from '../layouts/BaseLayout.astro';
export const prerender = true;
---
<BaseLayout title="Legal | GoldShore" description="Legal documents and policies">
  <section class="gs-section gs-blueprint-bg gs-section--padded">
    <div class="max-w-3xl mx-auto">
      <h1 class="gs-heading text-4xl mb-8">Legal</h1>

      <div class="grid gap-6">
        <a href="/legal/compliance" class="block p-6 border border-[var(--gs-border-color)] rounded-lg hover:border-[var(--gs-color-primary)] transition-colors">
          <h2 class="text-xl font-semibold mb-2">Legal &amp; Compliance</h2>
          <p class="text-[var(--gs-text-secondary)]">Entity metadata, disclosures, and trust controls.</p>
        </a>

        <a href="/legal/privacy" class="block p-6 border border-[var(--gs-border-color)] rounded-lg hover:border-[var(--gs-color-primary)] transition-colors">
          <h2 class="text-xl font-semibold mb-2">Privacy Policy</h2>
          <p class="text-[var(--gs-text-secondary)]">How we handle and protect your data.</p>
        </a>

        <a href="/legal/terms" class="block p-6 border border-[var(--gs-border-color)] rounded-lg hover:border-[var(--gs-color-primary)] transition-colors">
          <h2 class="text-xl font-semibold mb-2">Terms of Service</h2>
          <p class="text-[var(--gs-text-secondary)]">Service agreements and usage guidelines.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
