---
import RiskRadar from '../components/RiskRadar.astro';
import ParallaxHero from '../components/hero/ParallaxHero.astro';
import WebLayout from '../layouts/WebLayout.astro';

export const prerender = true;

const signals = [
  { label: 'System uptime', value: '99.98%' },
  { label: 'Operator latency', value: '< 45ms' },
  { label: 'Decision loops', value: 'Human + AI' },
];

const capabilities = [
  {
    title: 'Decision systems',
    body: 'Operator-grade AI workflows for scoring, routing, and intervention with traceable outcomes.',
  },
  {
    title: 'Risk tooling',
    body: 'Surveillance surfaces, monitoring loops, and alerting that keep uncertainty visible and actionable.',
  },
  {
    title: 'Resilient infrastructure',
    body: 'Applied platform engineering for control, observability, and dependable automation across teams.',
  },
];
---

<WebLayout
  title="GoldShore | Infrastructure for High-Trust AI"
  description="GoldShore builds resilient decision systems, risk tooling, and operator infrastructure."
>
  <ParallaxHero />

  <main class="gs-shell-section">
    <section class="signal-strip" aria-label="Signal strip">
      {signals.map((signal) => (
        <div class="signal-tile">
          <span>{signal.label}</span>
          <strong>{signal.value}</strong>
        </div>
      ))}
    </section>

    <section class="section-block" aria-labelledby="capabilities-title">
      <div class="section-copy">
        <p class="gs-eyebrow">Capabilities</p>
        <h2 id="capabilities-title">
          Institutional surfaces for operators, analysts, and systems teams.
        </h2>
        <p class="section-intro">
          GoldShore turns volatile runtime behavior into decision-ready
          workflows with stronger hierarchy, clearer ownership, and resilient
          delivery patterns.
        </p>
      </div>
      <div class="capability-grid">
        {capabilities.map((capability) => (
          <article class="capability-card">
            <h3>{capability.title}</h3>
            <p>{capability.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="section-block" aria-labelledby="risk-radar-title">
      <div class="section-copy">
        <p class="gs-eyebrow">Risk Radar</p>
        <h2 id="risk-radar-title">
          High-contrast motion designed for live demonstration and executive
          review.
        </h2>
        <p class="section-intro">
          The visualization system emphasizes readability first, so every sweep,
          pulse, and threshold communicates operational meaning.
        </p>
      </div>
      <RiskRadar />
    </section>

    <section class="section-block contact-cta" aria-labelledby="contact-cta-title">
      <div>
        <p class="gs-eyebrow">Contact</p>
        <h2 id="contact-cta-title">
          Ready to operationalize AI with trust, control, and signal clarity?
        </h2>
      </div>
      <a href="/contact" class="btn-primary">Start the Experience</a>
    </section>
  </main>

  <style>
    .signal-strip {
      margin-top: -3rem;
      position: relative;
      z-index: 10;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .signal-tile {
      padding: 1.5rem;
      border-radius: 20px;
      background: #0a0f1b;
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
    }

    .signal-tile span {
      display: block;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--gs-primary);
      margin-bottom: 0.5rem;
    }

    .signal-tile strong {
      font-size: 1.8rem;
      color: #fff;
    }

    .section-block {
      padding: 6rem 0;
    }

    .section-copy {
      margin-bottom: 3rem;
      max-width: 60rem;
    }

    .section-copy h2 {
      font-family: 'Lexend', var(--font-sans);
      font-weight: 700;
      font-size: clamp(2rem, 4vw, 3rem);
      margin: 1rem 0;
      line-height: 1.1;
    }

    .section-intro {
      color: var(--gs-text-dim);
      font-size: 1.1rem;
      line-height: 1.6;
    }

    .capability-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    .capability-card {
      padding: 2rem;
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(255, 255, 255, 0.06);
    }

    .capability-card h3 {
      font-family: 'Lexend', var(--font-sans);
      font-weight: 600;
      font-size: 1.25rem;
      margin-bottom: 1rem;
    }

    .capability-card p {
      color: var(--gs-text-dim);
      line-height: 1.6;
    }

    .contact-cta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 3rem;
      padding: 4rem;
      background: #0a0f1b;
      border-radius: 32px;
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .contact-cta h2 {
      font-family: 'Lexend', var(--font-sans);
      font-weight: 700;
      font-size: 2rem;
      margin: 0.5rem 0 0;
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      padding: 1rem 2rem;
      background: var(--gs-primary);
      color: #020617;
      font-weight: 700;
      text-decoration: none;
      border-radius: 999px;
      white-space: nowrap;
      transition: all 160ms ease;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      filter: brightness(1.1);
    }

    @media (max-width: 960px) {
      .signal-strip,
      .capability-grid,
      .contact-cta {
        grid-template-columns: 1fr;
      }

      .contact-cta {
        flex-direction: column;
        text-align: center;
        padding: 3rem 2rem;
      }
    }
  </style>
</WebLayout>
