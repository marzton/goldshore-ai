---
import WebLayout from '../layouts/WebLayout.astro';

export const prerender = true;
---

<WebLayout title="Gold Shore | Shaping Waves" description="Designed not to manage capital, but to steer it.">
  <section class="hero">
    <canvas id="starfield" aria-hidden="true"></canvas>
    <div class="hero-content">
      <h1>Gold Shore</h1>
      <p>Designed not to manage capital, but to steer it.</p>
      <div class="hero-actions">
        <a href="/contact">Start</a>
        <a href="/developer">Developer</a>
      </div>
    </div>
  </section>
</WebLayout>

<style>
  .hero {
    position: relative;
    height: calc(100svh - 72px);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: radial-gradient(circle at center, #0f172a 0%, #020617 100%);
    overflow: hidden;
  }

  #starfield {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.35;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 720px;
    padding: 1.5rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.5rem, 8vw, 5rem);
    letter-spacing: 0.03em;
  }

  .hero p {
    color: #cbd5e1;
    margin: 1rem 0 2rem;
    font-size: 1.1rem;
  }

  .hero-actions a {
    display: inline-block;
    margin: 0 0.5rem;
    padding: 0.75rem 1.25rem;
    border: 1px solid #334155;
    color: #f8fafc;
    text-decoration: none;
  }

  .hero-actions a:hover {
    border-color: #38bdf8;
  }
</style>
