---
import WebLayout from '../layouts/WebLayout.astro';

export const prerender = true;
---

<WebLayout title="Gold Shore | Shaping Waves" description="Shaping Systems. Steering Capital.">
  <section class="gs-section hero blueprint-bg">
    <div class="gs-container">
      <h1>Gold Shore</h1>
      <p class="hero-tagline">Shaping Systems. Steering Capital.</p>

      <div class="hero-actions">
        <a href="/contact" class="gs-button">Start</a>
      </div>
    </div>
  </section>

  <section class="gs-section gs-home-panels" aria-label="Core intelligence capabilities">
    <div class="gs-container gs-panel-grid">
      <article class="gs-panel gs-tilt">
        <h3 class="gs-section-title">Risk Radar</h3>
        <p>Macro-pattern intelligence infrastructure tuned for scenario clarity.</p>
      </article>
      <article class="gs-panel gs-tilt">
        <h3 class="gs-section-title">Resilience Mesh</h3>
        <p>Operational safeguards that harden critical paths without introducing drag.</p>
      </article>
      <article class="gs-panel gs-tilt">
        <h3 class="gs-section-title">Signal Governance</h3>
        <p>Decision cadence controls that preserve institutional discipline under pressure.</p>
      </article>
    </div>
  </section>
</WebLayout>
