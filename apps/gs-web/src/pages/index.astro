---
import RiskRadar from '../components/RiskRadar.astro';
import Logo from '../components/brand/Logo.astro';
import WebLayout from '../layouts/WebLayout.astro';

export const prerender = true;

const signals = [
  { label: 'Design modes', value: '4 kinetic scenes' },
  { label: 'Motion posture', value: 'Structured + precise' },
  { label: 'Brand system', value: 'Penrose-led' },
  { label: 'Response layer', value: 'Hover / focus / press' },
];

const capabilities = [
  {
    title: 'Brand-led systems',
    body: 'A single Penrose language now anchors navigation, hero presentation, and iconography without duplicate lockups or visual drift.',
  },
  {
    title: 'Structured kinetic hero',
    body: 'The opening surface cycles through engineered wave, star, storm, thermal, and vibration states while keeping the copy legible and authoritative.',
  },
  {
    title: 'Heavier visual infrastructure',
    body: 'Borders, shells, and grid divisions now carry more physical weight so the interface feels deliberate, machined, and screen-capture ready.',
  },
];

const proofPoints = [
  {
    title: 'Visual control',
    body: 'The hero engine can rotate between multiple atmospheres while preserving a strict layout, strong typography, and high-contrast framing.',
  },
  {
    title: 'Interactive states',
    body: 'The Penrose engine spins on load, throws a sheen on hover, deepens on focus, and compresses on press to make interaction feel intentional.',
  },
];
---

<WebLayout
  title="Gold Shore | Structured kinetic systems"
  description="Gold Shore presents a structured kinetic interface with an accurate Penrose mark, professional favicon system, and engineered hero motion."
>
  <main class="home-page">
    <section class="hero" data-hero-design="storm">
      <canvas id="wave-bg" aria-hidden="true"></canvas>
      <div class="hero-grid" aria-hidden="true"></div>
      <div class="hero-aurora hero-aurora--primary" aria-hidden="true"></div>
      <div class="hero-aurora hero-aurora--secondary" aria-hidden="true"></div>
      <div class="hero-particles" aria-hidden="true"></div>
      <div class="hero-lattice" aria-hidden="true"></div>
      <div class="hero-energy hero-energy--x" aria-hidden="true"></div>
      <div class="hero-energy hero-energy--y" aria-hidden="true"></div>

      <div class="hero-shell gs-shell-section">
        <div class="hero-content">
          <span class="eyebrow" id="hero-mode-label"
            >Storm / Wave / Vibration</span
          >

          <button
            class="hero-engine"
            id="hero-engine"
            type="button"
            aria-describedby="hero-engine-note hero-mode-label"
            aria-label="Cycle hero visual mode"
            title="Cycle hero visual mode"
          >
            <span class="hero-engine__sheen" aria-hidden="true"></span>
            <Logo class="hero-engine__mark" ariaHidden={true} />
          </button>

          <p class="hero-engine-note" id="hero-engine-note">
            Penrose engine · load spin · hover sheen · focus depth · click
            cycles scene
          </p>
          <h1 id="hero-title">Structured kinetic surfaces for Gold Shore.</h1>
          <p id="hero-body">
            Dark elemental motion overlays the landing area with engineered
            waves, pressure lines, and industrial glow rather than soft
            decorative noise.
          </p>
          <div class="hero-actions">
            <a href="/contact" class="hero-button hero-button--primary"
              >Open a workstream</a
            >
            <a href="/about" class="hero-button">View operating model</a>
          </div>
        </div>

        <aside class="hero-panel">
          <div>
            <p class="gs-eyebrow">Structured kinetic</p>
            <h2>One lockup in the header. One Penrose engine in the hero.</h2>
          </div>
          <ul>
            <li>
              Top-left branding uses a single Penrose + Gold Shore wordmark
              lockup for a cleaner hierarchy.
            </li>
            <li>
              The hero centers a larger standalone Penrose icon so the landing
              area has a clear visual engine.
            </li>
            <li>
              Elemental overlays can rotate through storm, astral, thermal, and
              buoyant layouts without changing the content structure.
            </li>
          </ul>
          <div class="hero-panel__meta">
            <span>Current mode</span>
            <strong id="hero-mode-chip">Storm / Wave / Vibration</strong>
          </div>
        </aside>
      </div>
    </section>

    <section class="signal-strip gs-shell-section" aria-label="Signal strip">
      {
        signals.map((signal) => (
          <div class="signal-tile">
            <span>{signal.label}</span>
            <strong>{signal.value}</strong>
          </div>
        ))
      }
    </section>

    <section class="section-block gs-shell-section">
      <div class="section-copy">
        <p class="gs-eyebrow">Capabilities</p>
        <h2>
          Institutional polish with cinematic energy, held inside a controlled
          operating frame.
        </h2>
      </div>
      <div class="capability-grid">
        {
          capabilities.map((capability) => (
            <article class="capability-card">
              <h3>{capability.title}</h3>
              <p>{capability.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section-block gs-shell-section">
      <div class="section-copy">
        <p class="gs-eyebrow">Risk Radar</p>
        <h2>
          Motion language that can sit beside live product surfaces without
          feeling ornamental.
        </h2>
      </div>
      <RiskRadar />
    </section>

    <section class="section-block gs-shell-section architecture-section">
      <div class="section-copy">
        <p class="gs-eyebrow">Architecture / Proof</p>
        <h2>
          Systems that look premium because they are disciplined, not because
          they are overloaded.
        </h2>
      </div>
      <div class="proof-grid">
        {
          proofPoints.map((point) => (
            <article class="proof-card">
              <h3>{point.title}</h3>
              <p>{point.body}</p>
            </article>
          ))
        }
        <article class="proof-card proof-card--metrics">
          <div>
            <span>Icon system</span>
            <strong>Accurate Penrose</strong>
          </div>
          <div>
            <span>Favicon posture</span>
            <strong>Single-symbol family</strong>
          </div>
          <div>
            <span>Hero behavior</span>
            <strong>Scene-aware overlays</strong>
          </div>
        </article>
      </div>
    </section>

    <section class="section-block gs-shell-section compact-team">
      <div class="section-copy">
        <p class="gs-eyebrow">Team</p>
        <h2>
          Built for teams that want their brand to feel as precise as the
          systems they ship.
        </h2>
      </div>
      <div class="team-row">
        <article class="team-card team-card--founder">
          <h3>Design direction</h3>
          <p>
            Industrial line weight, disciplined motion, and stronger information
            hierarchy across the landing experience.
          </p>
        </article>
        <article class="team-card">
          <h3>Motion system</h3>
          <p>
            Load, hover, focus, and click states that express energy without
            compromising clarity.
          </p>
        </article>
        <article class="team-card">
          <h3>Brand assets</h3>
          <p>
            Lockup, mark, and favicon symbols aligned around the same Penrose
            geometry.
          </p>
        </article>
      </div>
    </section>

    <section class="section-block gs-shell-section contact-cta">
      <div>
        <p class="gs-eyebrow">Contact</p>
        <h2>
          Ready to make Gold Shore feel sharper, heavier, and unmistakably
          premium?
        </h2>
      </div>
      <a href="/contact" class="hero-button hero-button--primary"
        >Start a conversation</a
      >
    </section>
  </main>

  <script>
    import { initWave } from '../scripts/init-wave';

    const heroModes = [
      {
        id: 'storm',
        eyebrow: 'Storm / Wave / Vibration',
        title: 'Structured kinetic surfaces for Gold Shore.',
        body: 'Dark elemental motion overlays the landing area with engineered waves, pressure lines, and industrial glow rather than soft decorative noise.',
      },
      {
        id: 'astral',
        eyebrow: 'Stars / Supersonic / Natural',
        title: 'A landing experience with signal, depth, and velocity.',
        body: 'Starfields, supersonic streaks, and layered atmospherics create visual impact while the interface stays balanced, crisp, and operational.',
      },
      {
        id: 'thermal',
        eyebrow: 'Ice / Heat / Wind',
        title: 'Physical contrast rendered as premium digital structure.',
        body: 'Thermal gradients, frost edges, and directional flow give the hero a high-end material quality with disciplined linework and spacing.',
      },
      {
        id: 'buoyant',
        eyebrow: 'Buoyant / Heavy / Supernatural',
        title: 'Motion that feels powerful without losing precision.',
        body: 'Dense lower-field mass and buoyant upper drift keep the page cinematic while every movement remains locked to a professional visual system.',
      },
    ];

    let homeCleanup;
    let sceneInterval;

    const cleanup = () => {
      homeCleanup?.();
      homeCleanup = undefined;
      if (sceneInterval) {
        window.clearInterval(sceneInterval);
        sceneInterval = undefined;
      }
    };

    const setHeroMode = (index) => {
      const hero = document.querySelector('.hero');
      const title = document.getElementById('hero-title');
      const body = document.getElementById('hero-body');
      const label = document.getElementById('hero-mode-label');
      const chip = document.getElementById('hero-mode-chip');
      if (!(hero instanceof HTMLElement) || !title || !body || !label || !chip)
        return;

      const mode = heroModes[index % heroModes.length];
      hero.dataset.heroDesign = mode.id;
      title.textContent = mode.title;
      body.textContent = mode.body;
      label.textContent = mode.eyebrow;
      chip.textContent = mode.eyebrow;
      hero.dataset.heroModeIndex = String(index % heroModes.length);
    };

    const initHeroEngine = () => {
      const hero = document.querySelector('.hero');
      const engine = document.getElementById('hero-engine');
      if (
        !(hero instanceof HTMLElement) ||
        !(engine instanceof HTMLButtonElement)
      )
        return () => {};

      let modeIndex = Number(hero.dataset.heroModeIndex || '0');
      let raf = 0;

      const renderProgress = (value) => {
        hero.style.setProperty('--hero-load-progress', `${value}`);
      };

      const animateLoad = () => {
        const duration = 1500;
        const start = performance.now();

        const tick = (now) => {
          const elapsed = Math.min((now - start) / duration, 1);
          const eased = 1 - Math.pow(1 - elapsed, 3);
          renderProgress(eased);
          if (elapsed < 1) {
            raf = window.requestAnimationFrame(tick);
          } else {
            hero.dataset.loadState = 'ready';
          }
        };

        hero.dataset.loadState = 'loading';
        renderProgress(0);
        raf = window.requestAnimationFrame(tick);
      };

      const advanceMode = () => {
        modeIndex = (modeIndex + 1) % heroModes.length;
        setHeroMode(modeIndex);
      };

      animateLoad();
      setHeroMode(modeIndex);
      sceneInterval = window.setInterval(advanceMode, 9000);

      const clickHandler = () => {
        advanceMode();
      };

      engine.addEventListener('click', clickHandler);

      return () => {
        window.cancelAnimationFrame(raf);
        engine.removeEventListener('click', clickHandler);
      };
    };

    const boot = () => {
      cleanup();
      const canvas = document.getElementById('wave-bg');
      if (!(canvas instanceof HTMLCanvasElement)) return;

      const wave = initWave(canvas);
      const destroyEngine = initHeroEngine();

      homeCleanup = () => {
        destroyEngine?.();
        wave.destroy();
      };
    };

    const homeGlobal = window;

    if (!homeGlobal.__gsHomeHeroBound) {
      homeGlobal.__gsHomeHeroBound = true;
      document.addEventListener('astro:before-swap', cleanup);
      document.addEventListener('astro:page-load', boot);
    }

    boot();
  </script>

  <style>
    .home-page {
      padding-bottom: 4rem;
    }

    .hero {
      --hero-load-progress: 0;
      position: relative;
      min-height: min(90vh, 920px);
      display: grid;
      align-items: end;
      overflow: hidden;
      border-bottom: 2px solid rgba(255, 255, 255, 0.08);
      background:
        radial-gradient(
          circle at 50% 10%,
          rgba(119, 180, 255, 0.12),
          transparent 30%
        ),
        linear-gradient(180deg, rgba(7, 12, 24, 0.32), rgba(6, 10, 20, 0.88));
      isolation: isolate;
    }

    #wave-bg,
    .hero-grid,
    .hero-aurora,
    .hero-particles,
    .hero-lattice,
    .hero-energy {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    #wave-bg {
      width: 100%;
      height: 100%;
      opacity: 0.52;
      mix-blend-mode: screen;
    }

    .hero-grid {
      background:
        linear-gradient(rgba(255, 255, 255, 0.08) 2px, transparent 2px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.08) 2px, transparent 2px);
      background-size: 72px 72px;
      mask-image: radial-gradient(
        circle at 50% 36%,
        black 34%,
        transparent 92%
      );
      opacity: 0.48;
    }

    .hero-aurora {
      filter: blur(22px);
      opacity: 0.8;
      transition:
        opacity 400ms ease,
        transform 500ms ease,
        background 400ms ease;
    }

    .hero-aurora--primary {
      background: radial-gradient(
        circle at 28% 26%,
        rgba(97, 164, 255, 0.22),
        transparent 28%
      );
      transform: translate3d(-2%, -1%, 0);
    }

    .hero-aurora--secondary {
      background: radial-gradient(
        circle at 76% 22%,
        rgba(255, 173, 82, 0.12),
        transparent 24%
      );
      transform: translate3d(2%, 1%, 0);
    }

    .hero-particles {
      opacity: 0.45;
      background-image:
        radial-gradient(
          circle at 18% 24%,
          rgba(255, 255, 255, 0.9) 0 1px,
          transparent 1.8px
        ),
        radial-gradient(
          circle at 74% 18%,
          rgba(173, 216, 255, 0.75) 0 1px,
          transparent 2px
        ),
        radial-gradient(
          circle at 84% 44%,
          rgba(255, 255, 255, 0.7) 0 1px,
          transparent 2px
        ),
        radial-gradient(
          circle at 58% 28%,
          rgba(255, 214, 160, 0.65) 0 1px,
          transparent 2px
        ),
        radial-gradient(
          circle at 38% 44%,
          rgba(255, 255, 255, 0.7) 0 1px,
          transparent 2px
        );
      background-size: 320px 220px;
      animation: particleDrift 18s linear infinite;
    }

    .hero-lattice {
      inset: 10% 8% 18%;
      border: 2px solid rgba(116, 174, 255, 0.08);
      border-radius: 40px;
      box-shadow:
        inset 0 0 0 2px rgba(255, 255, 255, 0.025),
        0 0 0 1px rgba(90, 162, 255, 0.08);
      opacity: 0.9;
    }

    .hero-energy--x {
      background: linear-gradient(
        90deg,
        transparent 0%,
        rgba(255, 255, 255, 0.05) 25%,
        transparent 50%,
        rgba(97, 164, 255, 0.1) 75%,
        transparent 100%
      );
      mask-image: linear-gradient(
        180deg,
        transparent 0%,
        black 18%,
        black 82%,
        transparent 100%
      );
      opacity: 0.5;
      animation: energySweepX 12s linear infinite;
    }

    .hero-energy--y {
      background: repeating-linear-gradient(
        90deg,
        transparent 0 12px,
        rgba(255, 255, 255, 0.05) 12px 16px,
        transparent 16px 44px
      );
      mask-image: linear-gradient(
        180deg,
        transparent,
        black 24%,
        black 80%,
        transparent
      );
      opacity: 0.22;
      animation: vibrationBars 2.8s ease-in-out infinite alternate;
      transform-origin: center;
    }

    .hero::after {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(
          circle at 50% 18%,
          rgba(255, 255, 255, 0.05),
          transparent 22%
        ),
        linear-gradient(180deg, rgba(7, 11, 20, 0.06), rgba(7, 11, 20, 0.88));
      pointer-events: none;
      z-index: 0;
    }

    .hero[data-hero-design='astral'] .hero-particles {
      opacity: 0.78;
      background-size: 220px 160px;
      animation-duration: 26s;
    }

    .hero[data-hero-design='astral'] .hero-energy--x {
      opacity: 0.68;
      background: linear-gradient(
        100deg,
        transparent 10%,
        rgba(255, 255, 255, 0.14) 34%,
        transparent 50%,
        rgba(90, 162, 255, 0.2) 72%,
        transparent 92%
      );
    }

    .hero[data-hero-design='thermal'] .hero-aurora--primary {
      background: radial-gradient(
        circle at 24% 30%,
        rgba(255, 120, 88, 0.24),
        transparent 26%
      );
    }

    .hero[data-hero-design='thermal'] .hero-aurora--secondary {
      background: radial-gradient(
        circle at 80% 18%,
        rgba(124, 208, 255, 0.18),
        transparent 24%
      );
    }

    .hero[data-hero-design='thermal'] .hero-energy--y {
      opacity: 0.28;
      background: repeating-linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.06) 0 10px,
        transparent 10px 28px
      );
      animation-duration: 6s;
    }

    .hero[data-hero-design='buoyant'] .hero-aurora--primary {
      background: radial-gradient(
        circle at 30% 78%,
        rgba(90, 162, 255, 0.18),
        transparent 26%
      );
      transform: translate3d(-1%, 3%, 0);
    }

    .hero[data-hero-design='buoyant'] .hero-aurora--secondary {
      background: radial-gradient(
        circle at 76% 24%,
        rgba(190, 126, 255, 0.12),
        transparent 28%
      );
    }

    .hero[data-hero-design='buoyant'] .hero-energy--x {
      opacity: 0.44;
      animation-duration: 18s;
    }

    .hero-shell {
      position: relative;
      z-index: 2;
      width: min(100% - 2rem, var(--gs-max-width));
      padding: clamp(7rem, 14vh, 10.5rem) 0 clamp(2rem, 5vw, 4rem);
      display: grid;
      grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
      gap: clamp(1.5rem, 4vw, 4rem);
      align-items: end;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      width: fit-content;
      padding: 0.65rem 0.95rem;
      border: 2px solid rgba(90, 162, 255, 0.28);
      border-radius: 999px;
      background: rgba(90, 162, 255, 0.08);
      color: var(--gs-primary);
      text-transform: uppercase;
      letter-spacing: 0.18em;
      font-size: 0.74rem;
      font-weight: 600;
    }

    .hero-content {
      display: grid;
      gap: 1.1rem;
      max-width: 43rem;
    }

    .hero-engine {
      --engine-size: clamp(132px, 18vw, 214px);
      position: relative;
      display: inline-grid;
      place-items: center;
      width: var(--engine-size);
      aspect-ratio: 1;
      margin-top: 0.25rem;
      padding: 0;
      border: 2px solid rgba(255, 255, 255, 0.12);
      border-radius: 32px;
      background:
        radial-gradient(
          circle at 50% 38%,
          rgba(255, 255, 255, 0.1),
          transparent 46%
        ),
        linear-gradient(180deg, rgba(15, 28, 52, 0.88), rgba(7, 13, 24, 0.96));
      box-shadow:
        0 30px 100px rgba(0, 0, 0, 0.36),
        inset 0 0 0 1px rgba(255, 255, 255, 0.05);
      cursor: pointer;
      transition:
        transform 180ms ease,
        box-shadow 180ms ease,
        border-color 180ms ease,
        background 180ms ease;
      isolation: isolate;
    }

    .hero-engine::before {
      content: '';
      position: absolute;
      inset: 10px;
      border-radius: 24px;
      border: 1px solid rgba(255, 255, 255, 0.06);
      opacity: 0.9;
    }

    .hero-engine__sheen {
      position: absolute;
      inset: 0;
      border-radius: inherit;
      background: linear-gradient(
        135deg,
        transparent 20%,
        rgba(255, 255, 255, 0.42) 50%,
        transparent 80%
      );
      transform: translateX(-170%) skewX(-18deg);
      opacity: 0;
      z-index: 2;
      pointer-events: none;
    }

    .hero-engine__mark {
      width: 58%;
      height: auto;
      z-index: 1;
      transform: rotate(calc(var(--hero-load-progress) * 360deg));
      filter: drop-shadow(0 18px 34px rgba(0, 0, 0, 0.45));
      transition:
        transform 240ms ease,
        filter 240ms ease;
    }

    .hero[data-load-state='loading'] .hero-engine__mark {
      transform: rotate(calc(var(--hero-load-progress) * 360deg));
    }

    .hero[data-load-state='ready'] .hero-engine__mark {
      transform: rotate(360deg);
    }

    .hero-engine:hover {
      border-color: rgba(255, 255, 255, 0.22);
      transform: translateY(-2px);
    }

    .hero-engine:hover .hero-engine__sheen {
      opacity: 1;
      animation: heroSheen 820ms ease forwards;
    }

    .hero-engine:focus-visible {
      outline: none;
      border-color: rgba(255, 183, 92, 0.55);
      box-shadow:
        0 0 0 4px rgba(255, 183, 92, 0.12),
        0 34px 110px rgba(0, 0, 0, 0.42),
        0 0 34px rgba(255, 183, 92, 0.16);
      background:
        radial-gradient(
          circle at 50% 38%,
          rgba(255, 196, 128, 0.18),
          transparent 42%
        ),
        linear-gradient(180deg, rgba(20, 35, 64, 0.94), rgba(8, 14, 26, 0.98));
    }

    .hero-engine:focus-visible .hero-engine__mark {
      filter: drop-shadow(0 22px 38px rgba(0, 0, 0, 0.54))
        drop-shadow(0 0 18px rgba(255, 183, 92, 0.24));
    }

    .hero-engine:active {
      transform: scale(0.95);
      box-shadow:
        0 18px 50px rgba(0, 0, 0, 0.42),
        0 0 28px rgba(255, 183, 92, 0.18);
    }

    .hero-engine-note {
      margin: 0;
      color: rgba(233, 238, 252, 0.68);
      text-transform: uppercase;
      letter-spacing: 0.22em;
      font-size: 0.72rem;
      font-weight: 600;
    }

    .hero-content h1,
    .section-copy h2,
    .contact-cta h2 {
      margin: 0;
      font-size: clamp(2.8rem, 7vw, 5.8rem);
      line-height: 0.94;
      letter-spacing: -0.05em;
      max-width: 13ch;
    }

    .hero-content > p:not(.hero-engine-note),
    .section-copy p,
    .hero-panel li,
    .proof-card p,
    .team-card p,
    .contact-cta p {
      margin: 0;
      color: var(--gs-text-dim);
      line-height: 1.75;
      font-size: 1rem;
    }

    .hero-actions {
      display: flex;
      gap: 0.9rem;
      flex-wrap: wrap;
      margin-top: 0.35rem;
    }

    .hero-button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 1rem 1.28rem;
      border-radius: 999px;
      border: 2px solid rgba(255, 255, 255, 0.12);
      background: rgba(255, 255, 255, 0.04);
      text-decoration: none;
      font-weight: 600;
      transition:
        transform 160ms ease,
        border-color 160ms ease,
        background 160ms ease,
        box-shadow 160ms ease;
    }

    .hero-button:hover,
    .hero-button:focus-visible {
      transform: translateY(-1px);
      border-color: rgba(90, 162, 255, 0.4);
      background: rgba(90, 162, 255, 0.14);
      box-shadow: 0 16px 42px rgba(0, 0, 0, 0.2);
    }

    .hero-button--primary {
      border-color: rgba(90, 162, 255, 0.34);
      background: rgba(90, 162, 255, 0.18);
    }

    .hero-panel {
      display: grid;
      gap: 1.25rem;
      padding: 1.6rem;
      border-radius: 28px;
      border: 2px solid rgba(255, 255, 255, 0.08);
      background: rgba(10, 18, 36, 0.76);
      backdrop-filter: blur(16px);
      box-shadow: var(--gs-shadow);
    }

    .hero-panel h2 {
