---
import WebLayout from '../layouts/WebLayout.astro';
---

<WebLayout title="Gold Shore | Shaping Waves" description="Designed not to manage capital, but to steer it.">
  <section class="gs-hero gs-blueprint-bg" data-gs-hero>
    <div class="gs-stars-deep" aria-hidden="true"></div>
    <div class="gs-stars" aria-hidden="true"></div>
    <div class="gs-grid-overlay" aria-hidden="true"></div>
    <div class="gs-vignette" aria-hidden="true"></div>

    <div class="gs-hero-parallax" data-gs-parallax="1.2" aria-hidden="true"></div>

export const prerender = true;
---

<WebLayout title="Gold Shore | Shaping Waves" description="Shaping Systems. Steering Capital.">
  <section class="gs-section hero blueprint-bg">
    <div class="gs-container">
      <h1>Gold Shore</h1>
      <p class="hero-tagline">Shaping Systems. Steering Capital.</p>

      <div class="hero-actions">
        <a href="/contact" class="gs-button">Start</a>
      <div style="margin-top: 2rem; display:grid; gap: 1rem; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));">
        <div class="gs-panel gs-hoverlift" data-gs-reveal>
          <div class="gs-label">Availability</div>
          <div style="font-size:2.2rem; font-weight:700; margin-top:0.4rem;">99.995%</div>
          <div class="gs-micro gs-muted">Measured across surfaces</div>
        </div>
        <div class="gs-panel gs-hoverlift" data-gs-reveal>
          <div class="gs-label">Deploys / Week</div>
          <div style="font-size:2.2rem; font-weight:700; margin-top:0.4rem;">48</div>
          <div class="gs-micro gs-muted">Change with control</div>
        </div>
        <div class="gs-panel gs-hoverlift" data-gs-reveal>
          <div class="gs-label">Signals / Day</div>
          <div style="font-size:2.2rem; font-weight:700; margin-top:0.4rem;">2.1B</div>
          <div class="gs-micro gs-muted">Routed & verified</div>
        </div>
      </div>
    </div>
  </section>
</WebLayout>

<style>
  .gs-hero-parallax {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    background: radial-gradient(circle at 20% 30%, rgba(90, 140, 255, 0.08), transparent 55%);
    mix-blend-mode: screen;
  }
</style>
