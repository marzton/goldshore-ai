---
import WebLayout from '../layouts/WebLayout.astro';

export const prerender = true;
---

<WebLayout title="Gold Shore | Designed to Steer Capital" description="Designed not to manage capital, but to steer it.">
  <section class="gs-hero gs-blueprint-bg" data-gs-hero>
    <canvas class="gs-webgl-field" data-gs-webgl aria-hidden="true"></canvas>
    <div class="gs-css-field" aria-hidden="true"></div>
    <div class="gs-stars-deep" aria-hidden="true"></div>
    <div class="gs-stars" aria-hidden="true"></div>
    <div class="gs-grid-overlay" aria-hidden="true"></div>
    <canvas class="gs-shooting-canvas" data-gs-shooting aria-hidden="true"></canvas>
    <div class="gs-vignette" aria-hidden="true"></div>

    <div class="gs-hero-parallax" data-gs-parallax="1.2" aria-hidden="true"></div>

    <div class="gs-container gs-hero-content gs-seq gs-vt">
      <div class="gs-status-pill gs-i-0" data-gs-reveal>
        <span class="gs-status-dot"></span>
        SYSTEM OPERATIONAL
      </div>

      <div class="gs-watermark" aria-hidden="true"></div>

      <h1 class="gs-hero-title gs-display gs-i-1" data-gs-reveal>Shaping Waves with Applied Intelligence</h1>
      <p class="gs-i-2" data-gs-reveal>
        GoldShore isn’t just code. It’s a provable experience. We build resilient, cinematic systems where automation
        meets art.
      </p>

      <div class="gs-hero-actions gs-i-3" data-gs-reveal>
        <a class="gs-button gs-button-solid" href="/intake">Start the Experience</a>
        <a class="gs-button gs-button-outline" href="/contact">Contact Sales</a>
      </div>

      <div class="gs-signal-divider" aria-hidden="true"></div>

      <div class="gs-preview-grid">
        <div class="gs-panel gs-hoverlift" data-gs-reveal>
          <div class="gs-label">GoldShore Agent</div>
          <div class="gs-panel-stat">Active</div>
          <div class="gs-micro gs-muted">Autonomous operational node</div>
        </div>
        <div class="gs-panel gs-hoverlift" data-gs-reveal>
          <div class="gs-label">Deployment Pulse</div>
          <div class="gs-panel-stat">Stable</div>
          <div class="gs-micro gs-muted">Continuous promotion cycle</div>
        </div>
        <div class="gs-panel gs-hoverlift" data-gs-reveal>
          <div class="gs-label">Ops Surface</div>
          <div class="gs-panel-stat">Nominal</div>
          <div class="gs-micro gs-muted">Real-time intelligence layer</div>
        </div>
      </div>
    </div>
  </section>

  <div class="gs-angle-divider"></div>

  <section class="gs-section">
    <div class="gs-container">
      <h2 class="gs-display" data-gs-reveal>Institutional Infrastructure</h2>
      <p data-gs-reveal>
        Modern systems do not fail because of lack of ambition — they fail because of uncontrolled complexity.
      </p>
      <p data-gs-reveal>
        Gold Shore architects resilient platforms engineered for deterministic deployment pipelines, high-availability
        surface management, controlled access hierarchies, observability-first operations, and real-time signal
        ingestion with enrichment.
      </p>
      <p data-gs-reveal>We design systems that remain stable under volatility, load, and regulatory pressure.</p>
    </div>
  </section>

  <section class="gs-section">
    <div class="gs-container">
      <h2 class="gs-display" data-gs-reveal>Operating Model</h2>
      <p data-gs-reveal>
        We operate with infrastructure-as-code discipline, typed service boundaries, controlled blast-radius
        deployments, and observability pipelines spanning metrics, tracing, and structured logs.
      </p>
      <p data-gs-reveal>
        Multi-environment promotion governance is enforced at every layer. Gold Shore is built for operators — not
        spectators.
      </p>
    </div>
  </section>
</WebLayout>

<script>
  import { mountShootingStars } from '../components/hero/ShootingStarsCanvas';

  const shootingCanvas = document.querySelector('[data-gs-shooting]');
  if (shootingCanvas instanceof HTMLCanvasElement) {
    mountShootingStars(shootingCanvas);
  }
</script>

<style>
  .gs-shooting-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .gs-hero-parallax {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    background: radial-gradient(circle at 20% 30%, rgba(90, 140, 255, 0.08), transparent 55%);
    mix-blend-mode: screen;
  }

  /* Status Pill */
  .gs-status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.75rem;
    background: rgba(10, 16, 28, 0.45);
    border: 1px solid var(--gs-border);
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--gs-muted);
    margin-bottom: 2rem;
  }

  .gs-status-dot {
    width: 6px;
    height: 6px;
    background: #22c55e;
    border-radius: 50%;
    box-shadow: 0 0 8px #22c55e;
  }

  /* Watermark */
  .gs-watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60%;
    height: 60%;
    background-image: url("/assets/penrose.svg");
    background-repeat: no-repeat;
    background-position: center;
    background-size: contain;
    opacity: 0.03;
    pointer-events: none;
    z-index: -1;
    filter: grayscale(1) invert(1);
  }

  /* Preview Grid */
  .gs-preview-grid {
    margin-top: 3.5rem;
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .gs-panel-stat {
    font-size: 2.2rem;
    font-weight: 700;
    margin-top: 0.4rem;
    color: var(--gs-text);
  }

  /* Typography Overrides */
  .gs-hero-title {
    font-family: "Fraunces", serif;
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  /* Restrained Glow */
  .gs-hero.gs-blueprint-bg {
    background: radial-gradient(circle at 50% 0%, rgba(90, 140, 255, 0.08), transparent 50%),
      linear-gradient(180deg, var(--gs-bg-0) 0%, var(--gs-bg-1) 100%);
  }
</style>
