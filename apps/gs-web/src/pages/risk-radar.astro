---
import WebLayout from "../layouts/WebLayout.astro";
import Controls from "../components/risk-radar/Controls.astro";
import OrbitalMap from "../components/risk-radar/OrbitalMap.astro";
import DetailsPanel from "../components/risk-radar/DetailsPanel.astro";
import Legend from "../components/risk-radar/Legend.astro";

export const prerender = true;

type RadarStatus = 'stable' | 'monitoring' | 'critical';

const radarData = {
  snapshot: {
    generatedAt: "2026-03-05T00:00:00Z",
    uiState: "ready",
  },
  tiers: [
    { id: "T1", label: "Core", radius: 92 },
    { id: "T2", label: "Critical Surface", radius: 158 },
    { id: "T3", label: "Extended Surface", radius: 224 },
  ],
  nodes: [
    {
      id: "CI-01",
      label: "Workflow Governance",
      tier: "T1",
      status: "stable",
      environment: "prod",
      pressure: 24,
      drift: 18,
      signal: 76,
      dependencies: ["OBS-02", "AUTH-10"],
    },
    {
      id: "OBS-02",
      label: "Signal Correlator",
      tier: "T1",
      status: "monitoring",
      environment: "staging",
      pressure: 43,
      drift: 51,
      signal: 62,
      dependencies: ["NET-07"],
    },
    {
      id: "SEC-04",
      label: "PII Leakage Guard",
      tier: "T2",
      status: "monitoring",
      environment: "prod",
      pressure: 58,
      drift: 63,
      signal: 57,
      dependencies: ["CI-01", "OPS-09"],
    },
    {
      id: "OPS-09",
      label: "Branch Divergence",
      tier: "T3",
      status: "critical",
      environment: "prod",
      pressure: 82,
      drift: 79,
      signal: 42,
      dependencies: [],
    },
    {
      id: "AUTH-10",
      label: "Identity Broker",
      tier: "T2",
      status: "stable",
      environment: "dev",
      pressure: 21,
      drift: 16,
      signal: 84,
      dependencies: ["NET-07"],
    },
    {
      id: "NET-07",
      label: "Gateway Firewall",
      tier: "T3",
      status: "stable",
      environment: "staging",
      pressure: 26,
      drift: 29,
      signal: 71,
      dependencies: [],
    },
  ],
  legend: {
    status: {
      stable: "Contained and operating within policy thresholds.",
      monitoring: "Active watch due to elevated drift or telemetry noise.",
      critical: "Immediate mitigation required. Breach likelihood elevated.",
    },
  },
};
---

<WebLayout title="Risk Radar | Gold Shore" description="Operational threat visualization system.">
  <section class="gs-section risk-radar gs-blueprint-bg">
    <div class="gs-container py-12">
      <header class="mb-8">
        <div class="gs-kicker gs-signal" data-gs-reveal>Forthcoming Surface</div>
        <h1 class="gs-display" data-gs-reveal>Risk Radar</h1>
        <p class="max-w-2xl text-xl text-[var(--gs-text-secondary)]" data-gs-reveal>
          Systemic exposure mapping and signal volatility monitoring in near real time.
        </p>
      </header>

      <div class="grid grid-cols-1 gap-6 xl:grid-cols-12" id="risk-radar-app" data-radar-data={radarDataEncoded}>
        <aside class="gs-card rounded-3xl border border-[var(--gs-border-primary)] bg-white p-6 xl:col-span-3">
          <Controls tiers={radarMockData.tiers} services={radarMockData.services} snapshot={radarMockData.snapshot} />
        </aside>

        <section class="gs-card relative rounded-3xl border border-[var(--gs-border-primary)] bg-black/95 p-6 text-white xl:col-span-6">
          <OrbitalMap center={{ x: 280, y: 280 }} tiers={radarMockData.tiers} />
        </section>

        <aside class="gs-card rounded-3xl border border-[var(--gs-border-primary)] bg-white p-6 xl:col-span-3">
          <DetailsPanel />
          <Legend status={radarMockData.legend.status} />
        </aside>
      </div>
    </div>
  </section>
</WebLayout>

<script>
  const root = document.getElementById('risk-radar-app');
  const encodedData = root?.dataset?.radarData ?? '';
  const data = encodedData ? JSON.parse(decodeURIComponent(encodedData)) : {};
  const svg = document.getElementById('risk-radar-graph');
  const detailsPanel = document.getElementById('details-panel');
  const visibleCount = document.getElementById('visible-count');
  const snapshotState = document.getElementById('snapshot-state');

  const tierSelect = document.getElementById('filter-tier') as HTMLSelectElement;
  const statusSelect = document.getElementById('filter-status') as HTMLSelectElement;
  const environmentSelect = document.getElementById('filter-environment') as HTMLSelectElement;
  const simulateButton = document.getElementById('simulate-event');

  const center = { x: 280, y: 280 };
  const statusColor: Record<string, string> = {
    stable: '#10b981',
    monitoring: '#f59e0b',
    critical: '#ef4444'
  };

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const state = {
    activeNodeId: null as string | null,
    hoveredNodeId: null as string | null,
    filters: {
      tier: 'all',
      status: 'all',
      environment: 'all'
    },
    simulatedNodeIds: new Set<string>(),
    simulationTimeoutId: null as number | null
  };

  const services = data.services ?? [];
  const tiers = data.tiers ?? [];
  const baseMetrics = new Map(services.map((service: any) => [service.id, { pressure: service.pressure, drift: service.drift }]));

  const dependencyMap = new Map(services.map((service: any) => [service.id, service]));

  const resetSimulation = () => {
    state.simulatedNodeIds.forEach((serviceId) => {
      const service = dependencyMap.get(serviceId);
      const baseline = baseMetrics.get(serviceId) as any;
      if (!service || !baseline) {
        return;
      }
      service.pressure = baseline.pressure;
      service.drift = baseline.drift;
    });

    state.simulatedNodeIds.clear();
    if (state.simulationTimeoutId) {
      window.clearTimeout(state.simulationTimeoutId);
      state.simulationTimeoutId = null;
    }
  };

  const getVisibleServices = () =>
    services.filter((service: any) =>
      (state.filters.tier === 'all' || service.tier === state.filters.tier) &&
      (state.filters.status === 'all' || service.status === state.filters.status) &&
      (state.filters.environment === 'all' || service.environment === state.filters.environment)
    );

  const computeNodePositions = (visibleServices: any[]) => {
    const byTier = tiers.map((tier: any) => ({
      ...tier,
      nodes: visibleServices.filter((service) => service.tier === tier.id)
    }));

    const positions = new Map();

    byTier.forEach((tierGroup: any) => {
      tierGroup.nodes.forEach((service: any, index: number) => {
        const angle = (Math.PI * 2 * index) / Math.max(tierGroup.nodes.length, 1) - Math.PI / 2;
        positions.set(service.id, {
          service,
          x: center.x + Math.cos(angle) * tierGroup.radius,
          y: center.y + Math.sin(angle) * tierGroup.radius
        });
      });
    });

    return positions;
  };

  const formatServiceDetails = (service: any) => {
    const dependencies = service.dependencies.length > 0 ? service.dependencies.join(', ') : 'None';
    const simulated = state.simulatedNodeIds.has(service.id) ? '<p class="mt-2 text-xs font-semibold text-red-600">Simulation spike active</p>' : '';

    return `
      <div class="mb-2 flex items-start justify-between gap-2">
        <div>
          <p class="text-xs font-mono text-[var(--gs-text-secondary)]">${service.id}</p>
          <h4 class="font-semibold">${service.label}</h4>
        </div>
        <span class="text-xs font-bold uppercase">${service.status}</span>
      </div>
      <dl class="grid grid-cols-3 gap-2 text-xs">
        <div><dt class="text-[var(--gs-text-secondary)]">Pressure</dt><dd>${service.pressure}%</dd></div>
        <div><dt class="text-[var(--gs-text-secondary)]">Drift</dt><dd>${service.drift}%</dd></div>
        <div><dt class="text-[var(--gs-text-secondary)]">Signal</dt><dd>${service.signal}%</dd></div>
      </dl>
      <p class="mt-3 text-xs">Environment: <strong>${service.environment}</strong></p>
      <p class="mt-1 text-xs text-[var(--gs-text-secondary)]">Dependencies: ${dependencies}</p>
      ${simulated}
    `;
  };

  const render = () => {
    if (!svg) return;
    const visibleServices = getVisibleServices();
    const positions = computeNodePositions(visibleServices);
    const visibleIds = new Set(visibleServices.map((service: any) => service.id));

    if (state.activeNodeId && !visibleIds.has(state.activeNodeId)) {
      state.activeNodeId = null;
    }

    const edges: any[] = [];
    visibleServices.forEach((service: any) => {
      service.dependencies.forEach((dependencyId: string) => {
        if (visibleIds.has(dependencyId)) {
          edges.push({ from: service.id, to: dependencyId });
        }
      });
    });

    let markup = '';

    tiers.forEach((tier: any) => {
      markup += `
        <g>
          <circle cx="${center.x}" cy="${center.y}" r="${tier.radius}" fill="none" stroke="#1d4ed8" stroke-opacity="0.35" stroke-width="1.5" />
          <text x="${center.x + tier.radius + 8}" y="${center.y}" fill="#93c5fd" font-size="11">${tier.label}</text>
        </g>
      `;
    });

    edges.forEach((edge) => {
      const from = positions.get(edge.from);
      const to = positions.get(edge.to);
      if (!from || !to) {
        return;
      }
      markup += `<line x1="${from.x}" y1="${from.y}" x2="${to.x}" y2="${to.y}" stroke="#60a5fa" stroke-opacity="0.35" stroke-width="1.5"/>`;
    });

    visibleServices.forEach((service: any) => {
      const point = positions.get(service.id);
      if (!point) {
        return;
      }

      const isFocus = service.id === state.activeNodeId || service.id === state.hoveredNodeId;
      const isSimulated = state.simulatedNodeIds.has(service.id);
      const radius = isFocus ? 15 : 12;
      const strokeWidth = isSimulated ? 4 : 2;
      const pulse = !prefersReducedMotion && isSimulated ? 'node-pulse' : '';
      const fill = statusColor[service.status] ?? '#38bdf8';

      markup += `
        <g class="node-group ${pulse}" data-node-id="${service.id}" tabindex="0" role="button" aria-label="${service.label}">
          <circle cx="${point.x}" cy="${point.y}" r="${radius}" fill="${fill}" stroke="#e2e8f0" stroke-width="${strokeWidth}"/>
          <text x="${point.x + 16}" y="${point.y + 4}" fill="#e2e8f0" font-size="10">${service.id}</text>
        </g>
      `;
    });

    svg.innerHTML = markup;
    if (visibleCount) visibleCount.textContent = `${visibleServices.length} services visible`;

    const selectedId = state.hoveredNodeId ?? state.activeNodeId;
    const selectedService = selectedId ? dependencyMap.get(selectedId) : null;
    if (detailsPanel) {
      detailsPanel.innerHTML = selectedService
        ? formatServiceDetails(selectedService)
        : 'Hover or click a service node to inspect pressure, drift, dependencies, and environment.';
    }
  };

  const onFilterChange = () => {
    state.filters = {
      tier: tierSelect?.value ?? 'all',
      status: statusSelect?.value ?? 'all',
      environment: environmentSelect?.value ?? 'all'
    };
    render();
  };

  tierSelect?.addEventListener('change', onFilterChange);
  statusSelect?.addEventListener('change', onFilterChange);
  environmentSelect?.addEventListener('change', onFilterChange);

  simulateButton?.addEventListener('click', () => {
    resetSimulation();
    const visibleServices = getVisibleServices();
    if (visibleServices.length === 0) {
      return;
    }

    const impacted = [...visibleServices]
      .sort((a, b) => b.pressure + b.drift - (a.pressure + a.drift))
      .slice(0, Math.min(2, visibleServices.length));

    impacted.forEach((service) => {
      state.simulatedNodeIds.add(service.id);
      service.pressure = Math.min(100, service.pressure + 18);
      service.drift = Math.min(100, service.drift + 22);
    });

    render();

    state.simulationTimeoutId = window.setTimeout(() => {
      resetSimulation();
      render();
    }, prefersReducedMotion ? 1200 : 2500);
  });

  svg?.addEventListener('mouseover', (event) => {
    const target = event.target as Element;
    const nodeElement = target.closest('.node-group');
    if (!nodeElement) {
      return;
    }

    const serviceId = nodeElement.getAttribute('data-node-id');
    if (!serviceId || state.hoveredNodeId === serviceId) {
      return;
    }

    state.hoveredNodeId = serviceId;
    render();
  });

  svg?.addEventListener('mouseout', (event) => {
    const target = event.target as Element;
    const fromNode = target.closest('.node-group');
    if (!fromNode) {
      return;
    }

    const related = event.relatedTarget;
    if (related instanceof Element && fromNode.contains(related)) {
      return;
    }

    if (state.hoveredNodeId !== null) {
      state.hoveredNodeId = null;
      render();
    }
  });

  svg?.addEventListener('click', (event) => {
    const target = event.target as Element;
    const nodeElement = target.closest('.node-group');
    if (!nodeElement) {
      return;
    }

    const serviceId = nodeElement.getAttribute('data-node-id');
    if (!serviceId) {
      return;
    }

    state.activeNodeId = serviceId;
    render();
  });

  svg?.addEventListener('keydown', (event: any) => {
    const target = event.target as Element;
    const nodeElement = target.closest('.node-group');
    if (!nodeElement) {
      return;
    }

    if (event.key !== 'Enter' && event.key !== ' ') {
      return;
    }

    event.preventDefault();
    const serviceId = nodeElement.getAttribute('data-node-id');
    if (!serviceId) {
      return;
    }

    state.activeNodeId = serviceId;
    render();
  });

  render();
</script>

<style>
  .blueprint-bg {
    background-image: radial-gradient(var(--gs-border-primary) 1px, transparent 1px);
    background-size: 32px 32px;
  }

  #risk-radar-graph .node-group {
    cursor: pointer;
    transition: opacity 180ms ease;
  }

  #risk-radar-graph .node-group:focus-visible {
    outline: 2px solid #93c5fd;
    outline-offset: 2px;
  }

  @keyframes nodePulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.6;
    }
  }

  .node-pulse {
    animation: nodePulse 1.1s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    #risk-radar-graph .node-group {
      transition: none;
    }

    .node-pulse {
      animation: none;
    }
  }
</style>
