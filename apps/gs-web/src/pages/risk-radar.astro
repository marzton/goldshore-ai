---
import WebLayout from '../layouts/WebLayout.astro';
import Controls from '../components/risk-radar/Controls.astro';
import OrbitalMap from '../components/risk-radar/OrbitalMap.astro';
import DetailsPanel from '../components/risk-radar/DetailsPanel.astro';
import Legend from '../components/risk-radar/Legend.astro';
import { readFile } from 'node:fs/promises';

export const prerender = true;

const radarData = JSON.parse(
  await readFile(new URL('../../public/data/risk-radar.sample.json', import.meta.url), 'utf-8')
);
const uiState = radarData?.snapshot?.uiState ?? 'loading';
---

<WebLayout title="Risk Radar | Gold Shore" description="Operational threat visualization system.">
  <section class="gs-section risk-radar blueprint-bg min-h-screen">
    <div class="gs-container py-12">
      <header class="mb-10">
        <h2 class="mb-4 text-5xl font-bold gs-heading">Risk Radar</h2>
        <p class="max-w-2xl text-xl text-[var(--gs-text-secondary)]">
          Systemic exposure mapping and signal volatility monitoring in near real time.
        </p>
      </header>

      <div class="grid grid-cols-1 gap-6 xl:grid-cols-12">
        <div class="xl:col-span-3">
          <Controls tiers={radarData.tiers} selectedTier="all" state={uiState} />
        </div>

        <div class="xl:col-span-6">
          <OrbitalMap tiers={radarData.tiers} nodes={radarData.nodes} state={uiState} />
        </div>

        <div class="xl:col-span-3">
          <DetailsPanel nodes={radarData.nodes} />
        </div>
      </div>

      <div class="mt-6">
        <Legend statusLegend={radarData.legend.status} metricLegend={radarData.legend.metrics} />
      </div>
    </div>
  </section>
</WebLayout>

<style>
  .blueprint-bg {
    background-image: radial-gradient(var(--gs-border-primary) 1px, transparent 1px);
    background-size: 32px 32px;
  }
</style>
