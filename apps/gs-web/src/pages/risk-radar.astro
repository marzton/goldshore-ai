---
import WebLayout from '../layouts/WebLayout.astro';
import Controls from '../components/risk-radar/Controls.astro';
import OrbitalMap from '../components/risk-radar/OrbitalMap.astro';
import DetailsPanel from '../components/risk-radar/DetailsPanel.astro';
import Legend from '../components/risk-radar/Legend.astro';

export const prerender = true;

type RadarStatus = 'stable' | 'monitoring' | 'critical';

const radarData = {
  snapshot: {
    generatedAt: '2026-03-05T00:00:00Z',
    environment: 'staging',
    uiState: 'ready',
  },
  tiers: [
    { id: 'T1', label: 'Core', radius: 72 },
    { id: 'T2', label: 'Critical Surface', radius: 136 },
    { id: 'T3', label: 'Extended Surface', radius: 200 },
  ],
  nodes: [
    {
      id: 'CI-01',
      label: 'Workflow Governance',
      tier: 'T1',
      status: 'stable' as RadarStatus,
      metrics: { exposure: 18, volatility: 21, signalStrength: 74 },
      dependencies: ['OPS-09'],
    },
    {
      id: 'SEC-04',
      label: 'PII Leakage',
      tier: 'T2',
      status: 'monitoring' as RadarStatus,
      metrics: { exposure: 47, volatility: 62, signalStrength: 58 },
      dependencies: ['CI-01', 'OPS-09'],
    },
    {
      id: 'OPS-09',
      label: 'Branch Divergence',
      tier: 'T3',
      status: 'critical' as RadarStatus,
      metrics: { exposure: 83, volatility: 79, signalStrength: 42 },
      dependencies: [],
    },
  ],
  legend: {
    status: {
      stable: 'Contained and operating within policy thresholds.',
      monitoring: 'Active watch due to elevated drift or telemetry noise.',
      critical: 'Immediate mitigation required. Breach likelihood elevated.',
    },
    metrics: {
      exposure: 'Estimated blast radius if compromised.',
      volatility: 'Observed change-rate across recent snapshots.',
      signalStrength: 'Confidence in current telemetry model.',
    },
  },
};
---

<WebLayout title="Risk Radar | Gold Shore" description="Operational threat visualization system.">
  <section class="gs-section risk-radar gs-blueprint-bg">
    <div class="gs-container py-12">
      <header class="mb-8">
        <div class="gs-kicker gs-signal" data-gs-reveal>Forthcoming Surface</div>
        <h1 class="gs-display" data-gs-reveal>Risk Radar</h1>
        <p class="max-w-2xl text-xl text-[var(--gs-text-secondary)]" data-gs-reveal>
          Systemic exposure mapping and signal volatility monitoring in near real time.
        </p>
      </header>

      <div class="grid grid-cols-1 gap-6 xl:grid-cols-12" data-gs-reveal>
        <aside class="xl:col-span-3">
          <Controls tiers={radarData.tiers} selectedTier="all" state={radarData.snapshot.uiState} />
        </aside>

        <section class="xl:col-span-6">
          <OrbitalMap tiers={radarData.tiers} nodes={radarData.nodes} state={radarData.snapshot.uiState} />
        </section>

        <aside class="xl:col-span-3 space-y-6">
          <DetailsPanel nodes={radarData.nodes} />
          <Legend statusLegend={radarData.legend.status} metricLegend={radarData.legend.metrics} />
        </aside>
      </div>
    </div>
  </section>
</WebLayout>
