---
import WebLayout from '../layouts/WebLayout.astro';
---

<WebLayout title="Risk Radar | Gold Shore" description="Forthcoming command interface for exposure and volatility intelligence.">
  <section class="gs-section gs-blueprint-bg">
    <div class="gs-container">
      <div class="gs-kicker gs-signal" data-gs-reveal>Forthcoming Surface</div>
      <h1 class="gs-display" data-gs-reveal>Risk Radar</h1>
      <p data-gs-reveal>
        Risk Radar is a forthcoming visualization and analytics surface designed to map systemic exposure, volatility
        pressure, and signal drift across operational environments.
      </p>

      <div class="gs-panel gs-hoverlift" style="margin-top:2rem;" data-gs-reveal>
        <div class="gs-label">Preview Module</div>
        <h2 class="gs-display" style="margin-top:0.75rem;">Operator Command Interface</h2>
        <p>
          Risk Radar will incorporate real-time event ingestion, weighted signal modeling, exposure heat mapping,
          deterministic calculation layers, and operator-grade panel architecture.
        </p>
        <p>
          It is not a dashboard. It is a command interface built with controlled motion, signal overlays, edge-lit
          frames, and scroll-driven enhancement.
        </p>
        <div style="display:flex; gap:0.9rem; flex-wrap:wrap; margin-top:1.2rem;">
          <button class="gs-button gs-button-solid" data-gs-modal-open="subscribe">Request Access</button>
          <a class="gs-button gs-button-outline" href="/developer">Developer Hub</a>
        </div>
      </div>
    </div>
  </section>
</WebLayout>
