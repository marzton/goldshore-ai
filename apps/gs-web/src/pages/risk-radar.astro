---
import WebLayout from "../layouts/WebLayout.astro";
---

<WebLayout>
  <section class="gs-section gs-blueprint-bg">
    <div class="gs-container">
      <div class="gs-kicker gs-signal" data-gs-reveal>Forthcoming Surface</div>
      <h1 class="gs-display" data-gs-reveal>Risk Radar</h1>
      <p data-gs-reveal>A visualization layer for systemic exposure, volatility pressure, and signal drift.</p>

      <div class="gs-panel gs-hoverlift" style="margin-top:2rem;" data-gs-reveal>
        <div class="gs-label">Preview Module</div>
        <h2 class="gs-display" style="margin-top:0.75rem;">Orbital Exposure Map</h2>
        <p>
          A panel-based operational view designed to ship with calibrated motion, status tags, and control-room density.
        </p>
        <div style="display:flex; gap:0.9rem; flex-wrap:wrap; margin-top:1.2rem;">
          <button class="gs-button gs-button-solid" data-gs-modal-open="subscribe">Request Access</button>
          <a class="gs-button gs-button-outline" href="/developer">Developer Hub</a>
        </div>
      </div>
    </div>
  </section>
</WebLayout>
