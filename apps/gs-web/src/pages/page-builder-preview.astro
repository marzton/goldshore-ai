---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionRenderer from '../components/sections/SectionRenderer.astro';
const pageSections = await import('../data/sections/home.json');
const { sections } = pageSections;
---
<BaseLayout
  title="GoldShore | Section Builder Preview"
  description="Debugging surface for rendering section-builder JSON through Astro components."
>
  <main class="page-builder-preview">
    <header class="preview-header">
      <p class="preview-eyebrow">Debugging Surface · Section Builder / JSON Renderer</p>
      <h1>Section Builder Preview</h1>
      <p>
        Internal preview route for validating structured JSON, section mapping, and Astro component rendering.
        If this page looks unusual, it is functioning as a builder tool rather than a customer-facing page.
      </p>
    </header>

    <section class="preview-panel" aria-labelledby="preview-output-heading">
      <div class="preview-panel__header">
        <h2 id="preview-output-heading">Rendered output</h2>
        <p>Source: <code>src/data/sections/home.json</code></p>
      </div>
      <SectionRenderer sections={sections} />
    </section>
  </main>
</BaseLayout>

<style>
  .page-builder-preview {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .preview-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .preview-eyebrow {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gs-brand-gold);
  }

  .preview-header h1 {
    font-size: clamp(2.2rem, 3.2vw, 3.2rem);
  }

  .preview-header p {
    color: #64748b;
    max-width: 56rem;
    margin: 0 auto;
  }

  .preview-panel {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1.5rem;
    border-radius: 1.5rem;
    border: 1px solid rgba(148, 163, 184, 0.2);
    background: rgba(15, 23, 42, 0.24);
  }

  .preview-panel__header {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: baseline;
  }

  .preview-panel__header h2 {
    font-size: 1.125rem;
    margin: 0;
  }

  .preview-panel__header p {
    margin: 0;
    color: #94a3b8;
  }

  .preview-panel code {
    font-family: var(--gs-font-mono, 'SFMono-Regular', Consolas, 'Liberation Mono', Menlo, monospace);
    color: #e2e8f0;
  }
</style>
