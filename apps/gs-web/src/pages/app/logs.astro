---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Mock data reflecting the services in your ALLOWED_APPS list
const logs = [
  { timestamp: '2026-03-04 17:30:12', service: 'gs-api', event: 'Stabilization Sync Check', status: 'success' },
  { timestamp: '2026-03-04 16:45:00', service: 'gs-web', event: 'Preview deployment', status: 'pending' },
  { timestamp: '2026-03-04 14:20:15', service: 'gs-admin', event: 'Auth Token Rotation', status: 'warning' },
  { timestamp: '2026-03-04 12:00:01', service: 'system', event: 'Cron: pii-scan.yml', status: 'success' },
];

const getStatusClass = (status) => {
  switch(status) {
    case 'success': return 'bg-emerald-100 text-emerald-700 border-emerald-200';
    case 'warning': return 'bg-amber-100 text-amber-700 border-amber-200';
    case 'fail': return 'bg-red-100 text-red-700 border-red-200';
    default: return 'bg-blue-100 text-blue-700 border-blue-200';
  }
};
---

<BaseLayout title="Logs | GoldShore">
  <main class="max-w-6xl mx-auto py-16 px-6">
    <header class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-4">
      <div>
        <h1 class="text-4xl font-bold gs-heading mb-2">Activity Logs</h1>
        <p class="text-[var(--gs-text-secondary)]">
          Real-time audit trail of system events and governance checks.
        </p>
      </div>
      <div class="flex gap-2">
        <button class="px-4 py-2 text-sm font-medium border border-[var(--gs-border-primary)] rounded-md hover:bg-gray-50">Export CSV</button>
        <button class="px-4 py-2 text-sm font-medium bg-black text-white rounded-md">Refresh</button>
      </div>
    </header>

    

    <section class="bg-white border border-[var(--gs-border-primary)] rounded-2xl overflow-hidden shadow-sm">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-[var(--gs-bg-tertiary)] border-b border-[var(--gs-border-primary)]">
              <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[var(--gs-text-secondary)]">Timestamp (UTC)</th>
              <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[var(--gs-text-secondary)]">Service</th>
              <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[var(--gs-text-secondary)]">Event Description</th>
              <th class="px-6 py-4 text-xs font-semibold uppercase tracking-wider text-[var(--gs-text-secondary)] text-right">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-[var(--gs-border-primary)]">
            {logs.map((log) => (
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-6 py-4 font-mono text-xs whitespace-nowrap">{log.timestamp}</td>
                <td class="px-6 py-4 whitespace-nowrap">
                  <span class="px-2 py-1 bg-gray-100 rounded text-xs font-medium uppercase">{log.service}</span>
                </td>
                <td class="px-6 py-4 text-sm font-medium">{log.event}</td>
                <td class="px-6 py-4 text-right">
                  <span class={`inline-block px-3 py-1 rounded-full text-xs font-bold border ${getStatusClass(log.status)}`}>
                    {log.status.toUpperCase()}
                  </span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      
      <footer class="p-4 bg-[var(--gs-bg-tertiary)] border-t border-[var(--gs-border-primary)]">
        <p class="text-xs text-[var(--gs-text-secondary)] text-center italic">
          Logs are retained for 30 days. For historical snapshots, refer to <code>docs/ci/</code>.
        </p>
      </footer>
    </section>
  </main>
</BaseLayout>

<style>
  :root {
    --gs-bg-tertiary: #f9fafb;
    --gs-border-primary: #e5e7eb;
    --gs-text-secondary: #6b7280;
  }
</style>
