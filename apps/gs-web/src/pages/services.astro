---
import WebLayout from '../layouts/WebLayout.astro';

export const prerender = true;
---

<WebLayout title="Services | Gold Shore" description="Capabilities spanning infrastructure automation, observability, and secure platform operations.">
  <section class="gs-section">
    <div class="gs-container">
      <h1>Capabilities &amp; Services</h1>

      <h2>Infrastructure Automation</h2>
      <p>Automate deployments, monitoring, scaling, and recovery with confidence. Reduce toil; increase reliability.</p>

      <h2>Real-Time Signal Processing</h2>
      <p>Capture, enrich, and route high-velocity signals with verification, observability, and operational clarity.</p>

      <h2>Resilient Platform Architecture</h2>
      <p>Build platforms designed for uptime, backed by defensive design and controlled complexity.</p>

      <h2>Developer Ecosystem &amp; Tooling</h2>
      <p>Empower engineering teams with extendable interfaces, SDKs, observability dashboards, and documentation built for scale.</p>

      <h2>Secure Access &amp; Identity Controls</h2>
      <p>Protect administrative surfaces with robust access controls, managed OAuth, and context-aware protections.</p>
    </div>
  </section>
</WebLayout>
