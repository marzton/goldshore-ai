---
import WebLayout from '../layouts/WebLayout.astro';

export const prerender = true;
---

<WebLayout title="Advisory Services | Gold Shore" description="Institutional advisory services built on rigorous intelligence, market-structure insight, and execution-aware strategy.">
  <section class="gs-section">
    <div class="gs-container">
      <h1>Advisory Services</h1>

      <h2>Regime &amp; Risk Advisory</h2>
      <p>Identify inflection points, stress pathways, and cross-asset vulnerabilities before they affect allocation outcomes.</p>

      <h2>Portfolio Steering Frameworks</h2>
      <p>Translate complex market signals into practical decision frameworks for exposure sizing, hedging posture, and liquidity planning.</p>

      <h2>Derivatives &amp; Overlay Strategy</h2>
      <p>Design options and futures overlays aligned with drawdown control, convexity objectives, and mandate constraints.</p>

      <h2>Liquidity &amp; Capital Efficiency</h2>
      <p>Improve deployment timing, collateral usage, and portfolio flexibility under volatile market conditions.</p>

      <h2>Custom Institutional Briefings</h2>
      <p>Deliver bespoke, high-conviction intelligence for CIOs, investment committees, and risk teams.</p>
    </div>
  </section>
</WebLayout>
