---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = true;

const sections = [
  {
    title: 'Mission',
    body: 'Build dependable AI-enabled systems that improve decision quality, reduce operational drag, and hold up under real production pressure.',
  },
  {
    title: 'Operating principles',
    body: 'We optimize for clarity, measurable outcomes, and maintainability: explicit ownership, observable workflows, and controls that operators can trust.',
  },
  {
    title: 'Delivery model',
    body: 'Every engagement starts with scoped discovery, moves into a tightly defined build sprint, and ends with hardening, handoff, and an adoption runway.',
  },
  {
    title: 'Trust & security stance',
    body: 'Security is part of system design—not a final checklist. Least-privilege access, auditable automation, and policy-aware defaults are built in from day one.',
  },
];
---

<BaseLayout title="About | GoldShore" description="What GoldShore builds and how the team works.">
  <section class="page-shell gs-shell-section info-page">
    <p class="gs-eyebrow">About</p>
    <h1>High-trust systems built for use, not theater.</h1>
    <p class="page-intro">GoldShore works at the intersection of resilient operations, decision support, and applied intelligence.</p>

    <div class="info-grid">
      {sections.map((section) => (
        <article class="info-card">
          <h2>{section.title}</h2>
          <p>{section.body}</p>
        </article>
      ))}
    </div>
  </section>

  <style>
    .info-page {
      padding: var(--gs-space-9) 0 calc(var(--gs-space-10) + var(--gs-space-1));
    }

    .info-page h1 {
      max-width: 12ch;
      margin: 0.75rem 0 1rem;
      font-size: clamp(2.5rem, 6vw, 4.6rem);
      line-height: 0.98;
      letter-spacing: -0.04em;
    }

    .page-intro {
      max-width: 60ch;
      color: var(--gs-text-dim);
      line-height: 1.75;
    }

    .info-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 2rem;
    }

    .info-card {
      padding: var(--gs-space-6);
      border-radius: var(--gs-radius-lg);
      border: 1px solid var(--gs-border);
      background: var(--gs-surface);
      box-shadow: var(--gs-shadow);
    }

    .info-card h2 {
      margin-top: 0;
      margin-bottom: 0.75rem;
      font-size: 1.3rem;
    }

    .info-card p {
      margin: 0;
      color: var(--gs-text-dim);
      line-height: 1.7;
    }

    @media (max-width: 900px) {
      .info-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>
