---
import WebLayout from '../layouts/WebLayout.astro';

export const prerender = true;
---

<WebLayout title="About | Gold Shore" description="Gold Shore builds operator-grade infrastructure for resilient operations.">
  <section class="gs-section">
    <div class="gs-container">
      <h1>Our Approach</h1>
      <p>
        We do not chase buzzwords or fashionable patterns. We solve real operational problems with thoughtful
        engineering, disciplined design, and predictable execution.
      </p>

      <ul>
        <li><strong>Measured:</strong> performance and reliability you can verify.</li>
        <li><strong>Predictable:</strong> designed for known outcomes instead of unknown side effects.</li>
        <li><strong>Auditable:</strong> traceable deployments, observability, and status reporting.</li>
        <li><strong>Responsible:</strong> security, compliance, and controlled access top-to-bottom.</li>
      </ul>
    </div>
  </section>

  <section class="gs-section">
    <div class="gs-container">
      <h2>Built for Operators &amp; Decision Makers</h2>
      <p>
        Whether you are an engineering organization scaling globally, a platform team seeking deterministic delivery,
        or an operations leader demanding uptime under pressure, Gold Shore infrastructure delivers clarity where
        others deliver complexity.
      </p>
    </div>
  </section>
</WebLayout>
