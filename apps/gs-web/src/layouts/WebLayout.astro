---
import '../styles/global.css';

const { title = 'Gold Shore', description = '' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>

  <body>
    <header class="gs-header">
      <a href="/" class="gs-logo">
        <img src="/logo.svg" alt="Gold Shore" />
      </a>

      <nav class="gs-nav">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/services">Services</a>
        <a href="/team">Team</a>
        <a href="/contact">Contact</a>
        <a href="/apps/risk-radar">Risk Radar</a>
        <a href="/developer">Developer</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="gs-footer">
      <p>Applied intelligence. Resilient infrastructure. Responsive operations.</p>
    </footer>
  </body>
</html>
