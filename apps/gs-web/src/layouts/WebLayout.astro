---
import '@goldshore/theme';

const { title = 'Gold Shore', description = '' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>

  <body>
    <header class="gs-header">
      <a href="/" class="gs-logo">
        <img src="/logo.svg" alt="Gold Shore" />
      </a>

      <nav class="gs-nav">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/services">Services</a>
        <a href="/team">Team</a>
        <a href="/contact">Contact</a>
        <a href="/apps/risk-radar">Risk Radar</a>
        <a href="/developer">Developer</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="gs-footer">
      <p>Applied intelligence. Resilient infrastructure. Responsive operations.</p>
    </footer>
  </body>
</html>

<style is:global>
  main {
    padding-top: 80px;
  }

  .gs-container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .gs-header {
    position: fixed;
    top: 0;
    width: 100%;
    height: 80px;
  }

  .gs-logo img {
    height: 32px;
  }

  .gs-nav a {
    margin-left: 2rem;
  }

  .gs-section + .gs-section {
    border-top: 1px solid var(--gs-color-border);
  }

  .gs-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 10%;
    width: 80%;
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--gs-accent),
      color-mix(in srgb, var(--gs-accent) 50%, var(--gs-warning)),
      transparent
    );
    opacity: 0.25;
  }
</style>
