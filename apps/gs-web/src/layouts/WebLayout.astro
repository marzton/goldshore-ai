---
import '@goldshore/theme';
import '../styles/brand.css';
import '../styles/home.css';
import SiteNav from '../components/SiteNav.astro';
import GlobalModal from '../components/GlobalModal.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Gold Shore',
  description = 'Institutional-grade automation and intelligence.',
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/logo/gs-penrose.svg" type="image/svg+xml" />
    <link rel="icon" href="/logo/gs-penrose.png" type="image/png" />
    <slot name="head" />
  </head>
  <body class="gs-theme-root">
    <SiteNav />

    <slot name="hero" />

    <main id="main-content">
      <slot />
    </main>

    <footer class="gs-footer">
      <div class="gs-container">
        <img src="/logo/gs-penrose.svg" class="footer-logo" alt="GoldShore logo" />
        <p>Gold Shore — Designed not to manage capital, but to steer it.</p>
        <p>
          <a href="/status">System Status</a> |
          <a href="/legal/compliance">Legal &amp; Compliance</a> |
          <a href="/legal/privacy">Privacy Policy</a> |
          <a href="/legal/terms">Terms of Service</a>
        </p>
        <p>
          <a href="/disclosure-policy">Disclosure Policy</a> |
          <a href="/careers">Careers</a> |
          <a href="/pgp-key.txt">PGP Key</a> |
          <a href="/security-policy">Security Policy</a>
        </p>
      </div>
    </footer>

    <GlobalModal />

    <script>
      import { initGoldShoreUI } from '@goldshore/theme/runtime';
      initGoldShoreUI();
    </script>
  </body>
</html>
