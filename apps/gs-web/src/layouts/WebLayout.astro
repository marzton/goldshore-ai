---
import '@goldshore/theme';
import '../styles/brand.css';
import '../styles/home.css';
import SiteNav from '../components/SiteNav.astro';
import GlobalModal from '../components/GlobalModal.astro';
import themeRuntimeUrl from '../scripts/theme-runtime.ts?url';

interface Props {
  title?: string;
  description?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = 'Gold Shore',
  description = 'Strategic advisory and intelligence for institutional capital.',
  structuredData,
} = Astro.props;

const siteUrl = 'https://goldshore.ai';
const organizationId = `${siteUrl}#organization`;
const sameAs: string[] = [];

const organizationSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': organizationId,
  name: 'Gold Shore',
  url: siteUrl,
  logo: `${siteUrl}/assets/brand/logo-penrose.svg`,
  ...(sameAs.length > 0 ? { sameAs } : {}),
};

const pageSchemas = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)}></script>
    {pageSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
    ))}
    <slot name="head" />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Gold Shore',
      url: 'https://goldshore.ai',
      logo: 'https://goldshore.ai/assets/brand/logo-penrose.svg',
      description: 'Strategic advisory and intelligence systems for capital allocation decisions.',
      potentialAction: {
        '@type': 'SearchAction',
        target: 'https://goldshore.ai/developer/docs/search?q={search_term_string}',
        'query-input': 'required name=search_term_string'
      }
    })} />
  </head>
  <body class="gs-theme-root">
    <SiteNav />

    <slot name="hero" />

    <main id="main-content">
      <slot />
    </main>

    <footer class="gs-footer">
      <div class="gs-container">
        <p>Gold Shore — Designed to manage, balance and create capital.</p>
        <p>
          <a href="/status">System Status</a> |
          <a href="/legal/compliance">Legal &amp; Compliance</a> |
          <a href="/legal/privacy">Privacy Policy</a> |
          <a href="/legal/terms">Terms of Service</a> |
          <a href="/legal/disclaimer">Disclaimer</a>
        </p>
        <p>
          <a href="/contact?intent=partnership" data-gs-outbound-label="partnership">Partnership</a> |
          <a href="/media-kit" data-gs-outbound-label="media_kit">Media Kit</a> |
          <a href="/affiliates" data-gs-outbound-label="affiliates">Affiliates</a>
        </p>
        <p class="gs-footer-utility">
          <a href="https://admin.goldshore.ai" rel="nofollow">Admin Login</a>
        </p>
      </div>
    </footer>

    <GlobalModal />

    <script>
      import { initGoldShoreUI } from '@goldshore/theme/runtime';
      import { initParallax } from '@goldshore/config/parallax';

      initGoldShoreUI();
      initParallax();

      document.querySelectorAll('[data-gs-outbound-label]').forEach((node) => {
        node.addEventListener('click', () => {
          const label = node.getAttribute('data-gs-outbound-label');
          if (!label || typeof window.gtag !== 'function') return;
          window.gtag('event', 'outbound_link', {
            event_category: 'engagement',
            event_label: label,
            link_text: label,
          });
        });
      });
    </script>
    <script type="module" src={themeRuntimeUrl}></script>
  </body>
</html>
