---
import "@goldshore/theme";
import { initGoldShoreUI } from "@goldshore/theme/runtime";
import SiteNav from "../components/SiteNav.astro";
import GlobalModal from "../components/GlobalModal.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>
  <body>
    <SiteNav />
    <slot />
    <footer class="gs-footer">
      <div class="gs-container gs-muted">
        Gold Shore — Designed not to manage capital, but to steer it.
      </div>
    </footer>

    <GlobalModal />

    <script is:inline>
      import { initGoldShoreUI } from "@goldshore/theme/runtime";
      initGoldShoreUI();
    </script>
  </body>
</html>
