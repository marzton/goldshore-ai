---
import '@goldshore/theme';
import SiteNav from '../components/SiteNav.astro';
import GlobalModal from '../components/GlobalModal.astro';

const { title = 'Gold Shore', description = 'Designed not to manage capital, but to steer it.' } = Astro.props;
---

<html lang="en" data-gs-skin="defense">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <SiteNav />
    <slot />

    <footer class="gs-footer">
      <div class="gs-container gs-muted">Gold Shore — Designed not to manage capital, but to steer it.</div>
    </footer>

    <GlobalModal />

    <script type="module">
      import { initGoldShoreUI } from '@goldshore/theme/runtime';
      import { initWebGLField } from '@goldshore/theme/runtime-webgl';

      initGoldShoreUI();
      initWebGLField();
    </script>
  </body>
</html>
