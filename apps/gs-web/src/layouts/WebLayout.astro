---
import '@goldshore/theme';
import '../styles/brand.css';
import '../styles/home.css';
import SiteNav from '../components/SiteNav.astro';
import GlobalModal from '../components/GlobalModal.astro';
import themeRuntimeUrl from '../scripts/theme-runtime.ts?url';

interface Props {
  title?: string;
  description?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title = 'Gold Shore',
  description = 'Institutional-grade automation and intelligence.',
  structuredData,
} = Astro.props;

const siteUrl = 'https://goldshore.ai';
const organizationId = `${siteUrl}#organization`;
const sameAs: string[] = [];

const organizationSchema: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': organizationId,
  name: 'Gold Shore',
  url: siteUrl,
  logo: `${siteUrl}/logo/gs-penrose.svg`,
  ...(sameAs.length > 0 ? { sameAs } : {}),
};

const pageSchemas = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/logo/gs-penrose.svg" type="image/svg+xml" />
    <link rel="icon" href="/logo/gs-penrose.png" type="image/png" />
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)}></script>
    {pageSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
    ))}
    <slot name="head" />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Gold Shore',
      url: 'https://goldshore.ai',
      logo: 'https://goldshore.ai/logo/gs-penrose.svg',
      description: 'Institutional-grade automation and intelligence systems.',
      potentialAction: {
        '@type': 'SearchAction',
        target: 'https://goldshore.ai/developer/docs/search?q={search_term_string}',
        'query-input': 'required name=search_term_string'
      }
    })} />
  </head>
  <body class="gs-theme-root">
    <SiteNav />

    <slot name="hero" />

    <main id="main-content">
      <slot />
    </main>

    <footer class="gs-footer">
      <div class="gs-container">
        <img src="/logo/gs-penrose.svg" class="footer-logo" alt="GoldShore logo" />
        <p>Gold Shore — Designed not to manage capital, but to steer it.</p>
        <p>
          <a href="/status">System Status</a> |
          <a href="/legal/compliance">Legal &amp; Compliance</a> |
          <a href="/legal/privacy">Privacy Policy</a> |
          <a href="/legal/terms">Terms of Service</a>
        </p>
        <p class="gs-footer-utility">
          <a href="https://admin.goldshore.ai" rel="nofollow">Admin Login</a>
        </p>
      </div>
    </footer>

    <GlobalModal />

    <script>
      import { initGoldShoreUI } from '@goldshore/theme/runtime';
      import { initParallax } from '../components/parallax';

      initGoldShoreUI();
      initParallax();

      // Mobile nav toggle logic
      document.addEventListener('astro:page-load', () => {
        const toggle = document.querySelector('[data-gs-nav-toggle]');
        const close = document.querySelector('[data-gs-nav-close]');
        const panel = document.querySelector('[data-gs-mobile-panel]');

        if (toggle && panel) {
          toggle.addEventListener('click', () => {
            document.body.classList.add('nav-open');
            panel.setAttribute('aria-hidden', 'false');
            toggle.setAttribute('aria-expanded', 'true');
          });
        }

        if (close && panel) {
          close.addEventListener('click', () => {
            document.body.classList.remove('nav-open');
            panel.setAttribute('aria-hidden', 'true');
            if (toggle) toggle.setAttribute('aria-expanded', 'false');
          });
        }
      });
    </script>
    <script type="module">
      import { initStarField, initTilt, cleanupUI } from '/src/scripts/init-ui.ts';

      function init() {
        cleanupUI();
        initStarField('hero-stars');
        initTilt('[data-gs-tilt]');
      }

      document.addEventListener('astro:page-load', init);
      document.addEventListener('astro:before-swap', cleanupUI);
    </script>
    <script type="module" src={themeRuntimeUrl}></script>
  </body>
</html>
