---
import { SharedHeader } from '@goldshore/ui';
import '../styles/global.css';

const { title = 'Gold Shore', description = '' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>

  <body>
    <SharedHeader class="gs-header" logoAlt="Gold Shore">
      <nav class="gs-nav">
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/services">Services</a>
        <a href="/team">Team</a>
        <a href="/contact">Contact</a>
        <a href="/apps/risk-radar">Risk Radar</a>
        <a href="/developer">Developer</a>
      </nav>
    </SharedHeader>

    <main>
      <slot />
    </main>

    <footer class="gs-footer">
      <p>Designed not to manage capital, but to steer it.</p>
    </footer>
  </body>
</html>
