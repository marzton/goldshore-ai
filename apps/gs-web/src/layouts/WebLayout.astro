---
import Logo from '../components/brand/Logo.astro';
import '../styles/global.css';
import { WEB_CONTENT_SECURITY_POLICY } from '../utils/csp';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/team', label: 'Team' },
  { href: '/contact', label: 'Contact' },
  { href: '/apps/risk-radar', label: 'Risk Radar' },
  { href: '/developer', label: 'Developer Hub' },
];

const {
  title = 'GoldShore',
  description = 'GoldShore AI',
  currentPath = Astro.url.pathname,
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const socialImage = new URL('/logo.svg', Astro.site ?? Astro.url);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta http-equiv="Content-Security-Policy" content={WEB_CONTENT_SECURITY_POLICY} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0f18" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImage} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImage} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" sizes="any" type="image/svg+xml" />
    <link rel="shortcut icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Lexend:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#content" class="skip-link">Skip to content</a>
    <div class="gs-page-shell">
      <header class="header" data-menu-open="false">
        <div class="header__inner">
          <a href="/" class="gs-logo-link" aria-label="GoldShore home">
            <Logo class="gs-logo" title="GoldShore" />
            <div class="brand-lockup">
              <span class="brand-name">GoldShore</span>
              <span class="brand-tagline">Institutional AI systems</span>
            </div>
          </a>

          <nav class="desktop-nav" aria-label="Primary navigation">
            <div class="desktop-nav__links">
              {
                navLinks.map((link) => (
                  <a
                    href={link.href}
                    aria-current={
                      currentPath === link.href ? 'page' : undefined
                    }
                  >
                    {link.label}
                  </a>
                ))
              }
            </div>
            <a href="/contact" class="header-cta">Request Briefing</a>
          </nav>

          <button
            class="menu-button"
            type="button"
            aria-expanded="false"
            aria-controls="primary-navigation"
            aria-label="Toggle navigation"
          >
            <div class="menu-button__box">
              <span class="line line--1"></span>
              <span class="line line--2"></span>
              <span class="line line--3"></span>
            </div>
          </button>
        </div>

        <nav
          id="primary-navigation"
          class="menu-panel"
          aria-label="Mobile navigation"
        >
          <div class="menu-panel__inner">
            <div class="menu-panel__header">
              <a
                href="/"
                class="gs-logo-link"
                aria-label="GoldShore home"
              >
                <Logo class="gs-logo" title="GoldShore" />
                <div class="brand-lockup">
                  <span class="brand-name">GoldShore</span>
                  <span class="brand-tagline">Institutional AI systems</span>
                </div>
              </a>
              <button
                class="menu-button menu-button--mobile"
                type="button"
                aria-expanded="false"
                aria-controls="primary-navigation"
                aria-label="Toggle navigation"
              >
                <div class="menu-button__box">
                  <span class="line line--1"></span>
                  <span class="line line--2"></span>
                  <span class="line line--3"></span>
                </div>
              </button>
            </div>

            <div class="menu-panel__links">
              {
                navLinks.map((link) => (
                  <a
                    href={link.href}
                    aria-current={
                      currentPath === link.href ? 'page' : undefined
                    }
                  >
                    {link.label}
                  </a>
                ))
              }
            </div>

            <div class="menu-panel__actions">
              <a href="/contact" class="header-cta header-cta--mobile"
                >Request Briefing</a
              >
              <a href="/developer" class="menu-secondary-link"
                >Open Developer Hub</a
              >
            </div>
          </div>
        </nav>
      </header>

      <main id="content" class="gs-page-content">
        <slot />
      </main>

      <footer class="gs-footer">
        <div class="gs-footer__inner">
          <div class="gs-footer__brand">
            <div class="footer-logo-wrap">
               <Logo class="gs-logo gs-logo--footer" title="GoldShore" />
               <div class="brand-lockup">
                  <span class="brand-name">GoldShore</span>
                  <span class="brand-tagline">Operational AI and control systems</span>
               </div>
            </div>
            <p class="footer-desc">
              Infrastructure for high-trust AI, risk tooling, and resilient
              operator systems.
            </p>
          </div>
          <div class="gs-footer__nav">
            <div class="footer-nav-group">
              <span class="footer-label">Platform</span>
              <a href="/apps/risk-radar">Risk Radar</a>
              <a href="/developer">Developer Hub</a>
              <a href="/status">System Status</a>
            </div>
            <div class="footer-nav-group">
              <span class="footer-label">Company</span>
              <a href="/about">About</a>
              <a href="/team">Team</a>
              <a href="/contact">Contact</a>
            </div>
          </div>
        </div>
        <div class="gs-footer__bottom">
          <p>&copy; {new Date().getFullYear()} GoldShore AI. All rights reserved.</p>
        </div>
      </footer>
    </div>

    <script is:inline>
      const menuGlobal = window;

      const bindMenu = () => {
        if (menuGlobal.__gsMenuBound) return;
        menuGlobal.__gsMenuBound = true;

        const setMenu = (isOpen) => {
          const header = document.querySelector('.header');
          const toggles = document.querySelectorAll('.menu-button');
          if (!(header instanceof HTMLElement)) return;
          header.dataset.menuOpen = String(isOpen);
          toggles.forEach(toggle => {
            toggle.setAttribute('aria-expanded', String(isOpen));
          });
          document.body.classList.toggle('menu-open', isOpen);
        };

        const handleToggle = () => {
          const header = document.querySelector('.header');
          const next = header?.dataset.menuOpen !== 'true';
          setMenu(next);
        };

        document.addEventListener('click', (event) => {
          const target = event.target;
          if (!(target instanceof Element)) return;

          if (target.closest('.menu-button')) {
            handleToggle();
            return;
          }

          if (
            target.closest('.menu-panel__links a') ||
            target.classList.contains('menu-panel')
          ) {
            setMenu(false);
          }
        });

        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            setMenu(false);
          }
        });

        window.addEventListener('resize', () => {
          if (window.innerWidth > 960) {
            setMenu(false);
          }
        });

        document.addEventListener('astro:before-swap', () => {
          setMenu(false);
        });
      };

      bindMenu();
    </script>

    <style is:global>
      :root {
        --gs-header-height: 5rem;
      }

      .skip-link {
        position: absolute;
        left: 1rem;
        top: -3rem;
        z-index: 1200;
        padding: 0.75rem 1rem;
        background: var(--gs-surface-strong);
        color: var(--gs-text);
        border-radius: 999px;
        border: 1px solid var(--gs-border);
        text-decoration: none;
      }

      .skip-link:focus {
        top: 1rem;
      }

      .gs-page-shell {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      .gs-page-content {
        flex: 1;
      }

      .header {
        position: sticky;
        top: 0;
        z-index: 1100;
        background: rgba(8, 12, 22, 0.82);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        height: var(--gs-header-height);
        display: flex;
        align-items: center;
      }

      .header__inner {
        width: min(100%, var(--gs-max-width));
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 clamp(1rem, 3vw, 2rem);
        gap: 2rem;
      }

      .gs-logo-link {
        display: inline-flex;
        align-items: center;
        gap: 0.9rem;
        text-decoration: none;
        flex-shrink: 0;
      }

      .gs-logo {
        width: 38px;
        height: auto;
        color: var(--gs-primary);
        filter: drop-shadow(0 0 12px rgba(90, 162, 255, 0.2));
      }

      .brand-lockup {
        display: grid;
        line-height: 1.1;
      }

      .brand-name {
        font-family: 'Lexend', var(--font-sans);
        font-weight: 700;
        font-size: 1.2rem;
        letter-spacing: -0.01em;
        color: var(--gs-text);
      }

      .brand-tagline {
        color: var(--gs-text-dim);
        font-size: 0.72rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        margin-top: 0.1rem;
      }

      .desktop-nav {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }

      .desktop-nav__links {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .desktop-nav__links a {
        padding: 0.5rem 0.9rem;
        border-radius: 999px;
        color: var(--gs-text-dim);
        font-size: 0.92rem;
        font-weight: 500;
        text-decoration: none;
        transition: all 160ms ease;
      }

      .desktop-nav__links a:hover,
      .desktop-nav__links a[aria-current='page'] {
        color: var(--gs-text);
        background: rgba(255, 255, 255, 0.04);
      }

      .header-cta {
        display: inline-flex;
        align-items: center;
        padding: 0.75rem 1.4rem;
        border-radius: 999px;
        background: var(--gs-primary);
        color: #020617;
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        transition: all 160ms ease;
        box-shadow: 0 8px 20px rgba(90, 162, 255, 0.2);
      }

      .header-cta:hover {
        transform: translateY(-1px);
        filter: brightness(1.1);
        box-shadow: 0 10px 24px rgba(90, 162, 255, 0.3);
      }

      .menu-button {
        display: none;
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        z-index: 1200;
      }

      .menu-button__box {
        width: 24px;
        height: 18px;
        position: relative;
      }

      .line {
        position: absolute;
        width: 100%;
        height: 2px;
        background: var(--gs-text);
        border-radius: 2px;
        transition: all 200ms ease;
      }

      .line--1 { top: 0; }
      .line--2 { top: 8px; }
      .line--3 { top: 16px; }

      .header[data-menu-open='true'] .line--1 { transform: translateY(8px) rotate(45deg); }
      .header[data-menu-open='true'] .line--2 { opacity: 0; }
      .header[data-menu-open='true'] .line--3 { transform: translateY(-8px) rotate(-45deg); }

      .menu-panel {
        position: fixed;
        inset: 0;
        z-index: 1150;
        background: rgba(5, 8, 14, 0);
        pointer-events: none;
        transition: background 300ms ease;
        display: grid;
        justify-items: end;
      }

      .menu-panel__inner {
        width: min(400px, 100%);
        height: 100%;
        background: #0a0f1b;
        border-left: 1px solid rgba(255, 255, 255, 0.08);
        padding: 2rem;
        transform: translateX(100%);
        transition: transform 300ms cubic-bezier(0.16, 1, 0.3, 1);
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
      }

      .menu-panel__header {
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .menu-panel__links {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      .menu-panel__links a {
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--gs-text-dim);
        text-decoration: none;
      }

      .menu-panel__links a[aria-current='page'] {
        color: var(--gs-primary);
      }

      .menu-panel__actions {
        margin-top: auto;
        display: grid;
        gap: 1rem;
      }

      .header-cta--mobile {
        justify-content: center;
      }

      .menu-secondary-link {
        text-align: center;
        color: var(--gs-text-dim);
        text-decoration: none;
        padding: 0.75rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 999px;
      }

      .header[data-menu-open='true'] .menu-panel {
        pointer-events: auto;
        background: rgba(5, 8, 14, 0.6);
      }

      .header[data-menu-open='true'] .menu-panel__inner {
        transform: translateX(0);
      }

      .gs-footer {
        padding: 5rem clamp(1rem, 3vw, 2rem) 3rem;
        background: #060910;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
      }

      .gs-footer__inner {
        width: min(100%, var(--gs-max-width));
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 4rem;
        align-items: start;
      }

      .gs-footer__brand {
        display: grid;
        gap: 1.5rem;
      }

      .footer-logo-wrap {
        display: flex;
        align-items: center;
        gap: 0.8rem;
      }

      .gs-logo--footer {
        width: 32px;
      }

      .footer-desc {
        max-width: 40ch;
        color: var(--gs-text-dim);
        line-height: 1.6;
        font-size: 0.95rem;
      }

      .gs-footer__nav {
        display: flex;
        gap: 4rem;
      }

      .footer-nav-group {
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
      }

      .footer-label {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--gs-primary);
        margin-bottom: 0.5rem;
      }

      .footer-nav-group a {
        color: var(--gs-text-dim);
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 160ms ease;
      }

      .footer-nav-group a:hover {
        color: var(--gs-text);
      }

      .gs-footer__bottom {
        width: min(100%, var(--gs-max-width));
        margin: 4rem auto 0;
        padding-top: 2rem;
        border-top: 1px solid rgba(255, 255, 255, 0.04);
        color: rgba(255, 255, 255, 0.3);
        font-size: 0.85rem;
        text-align: center;
      }

      @media (max-width: 960px) {
        .desktop-nav {
          display: none;
        }

        .menu-button {
          display: block;
        }
      }

      @media (max-width: 768px) {
        .gs-footer__inner {
          grid-template-columns: 1fr;
          gap: 3rem;
        }

        .gs-footer__nav {
          gap: 2rem;
          flex-wrap: wrap;
        }
      }
    </style>
  </body>
</html>
