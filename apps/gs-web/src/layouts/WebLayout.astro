---
import "@goldshore/theme";
import { initGoldShoreUI } from "@goldshore/theme/runtime";
import SiteNav from "../components/SiteNav.astro";
import GlobalModal from "../components/GlobalModal.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
  </head>
  <body>
    <SiteNav />
    <footer class="gs-footer">
      <p>Gold Shore — Designed not to manage capital, but to steer it. All rights reserved.</p>
      <p><a href="/legal/privacy">Privacy Policy</a> | <a href="/legal/terms">Terms of Service</a></p>
    </footer>

    <GlobalModal />

    <script is:inline>
      import { initGoldShoreUI } from "@goldshore/theme/runtime";
      initGoldShoreUI();
    </script>
  </body>
</html>
