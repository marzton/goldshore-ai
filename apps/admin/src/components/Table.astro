---
const { headers, rows } = Astro.props;
---
<table class="gs-table">
  <thead>
    <tr>
      {headers.map((h: string) => <th>{h}</th>)}
    </tr>
  </thead>
  <tbody>
    {rows.map((row: unknown[]) => (
      <tr>
        {row.map((cell) => <td>{cell as string}</td>)}
      </tr>
    ))}
  </tbody>
</table>
