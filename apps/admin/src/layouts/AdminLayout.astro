---
import Sidebar from '../components/Sidebar.astro';
import Topbar from '../components/Topbar.astro';

interface Props {
  title?: string;
}

import '@goldshore/theme';
import logo from '../assets/logo.svg';

const { title = 'GoldShore Admin' } = Astro.props;
const favicon = '/logo.png';

---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={favicon} type="image/png" />
    <link rel="icon" href={logo} type="image/svg+xml" />
    <script is:inline>
      (function () {
        var STORAGE_KEY = 'goldshore:theme';
        var defaults = { mode: 'dark', density: 'comfortable', accent: 'blue' };

        function readSettings() {
          var settings = defaults;
          try {
            var stored = localStorage.getItem(STORAGE_KEY);
            if (stored) settings = Object.assign({}, defaults, JSON.parse(stored));
          } catch (e) {
            // Ignore malformed or inaccessible localStorage content.
          }
          return settings;
        }

        function removeAccentOverrides(root) {
          root.style.removeProperty('--gs-accent');
          root.style.removeProperty('--gs-accent-strong');
          root.style.removeProperty('--gs-accent-soft');
          root.style.removeProperty('--gs-accent-contrast');
        }

        function setDataAccent(root, accent) {
          if (root.getAttribute('data-accent') !== accent) root.setAttribute('data-accent', accent);
        }

        function clearDataAccent(root) {
          if (root.hasAttribute('data-accent')) root.removeAttribute('data-accent');
        }

        function applyAccent(root, accent) {
          if (accent === 'gold') {
            setDataAccent(root, 'gold');
            removeAccentOverrides(root);
          } else if (accent === 'cyan') {
            setDataAccent(root, 'cyan');
            removeAccentOverrides(root);
          } else if (accent === 'violet') {
            clearDataAccent(root);
            root.style.setProperty('--gs-accent', '#a855f7');
            root.style.setProperty('--gs-accent-strong', '#9333ea');
            root.style.setProperty('--gs-accent-soft', 'rgba(168,85,247,0.18)');
            root.style.setProperty('--gs-accent-contrast', '#0f172a');
          } else {
            clearDataAccent(root);
            removeAccentOverrides(root);
          }
        }

        var settings = readSettings();
        var root = document.documentElement;
        root.setAttribute('data-theme', settings.mode);
        if (settings.density === 'compact') root.setAttribute('data-density', 'compact');
        else root.removeAttribute('data-density');
        applyAccent(root, settings.accent);

        new MutationObserver(function (mutations) {
          for (var i = 0; i < mutations.length; i++) {
            if (mutations[i].attributeName === 'data-accent') {
              var accent = readSettings().accent;
              var currentAccent = root.getAttribute('data-accent');
              if ((accent === 'gold' || accent === 'cyan') && currentAccent === accent) break;
              if (accent !== 'gold' && accent !== 'cyan' && currentAccent === null) break;
              applyAccent(root, accent);
              break;
            }
          }
        }).observe(root, { attributes: true, attributeFilter: ['data-accent'] });
        root.classList.add('gs-theme-ready');
      })();
    </script>
  </head>
  <body>
    <a href="#admin-content" class="skip-link">Skip to content</a>
    <div class="gs-admin-grid">
      <Sidebar logo={logo} />
      <div class="gs-admin-main">
        <Topbar title={title} />
        <main id="admin-content" class="gs-admin-content">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>
