---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { Card, Table } from '@goldshore/ui';

const mediaAssets = [
  { id: 'asset-410', name: 'Brand hero video', type: 'video/mp4', status: 'approved' },
  { id: 'asset-411', name: 'Partner logo pack', type: 'image/svg+xml', status: 'review' },
  { id: 'asset-412', name: 'Platform screenshots', type: 'image/png', status: 'approved' }
];
---
<AdminLayout title="Media | GoldShore Admin" requiredPermission="media:read">
  <section class="max-w-6xl mx-auto py-16 px-6">
    <h1 class="text-3xl gs-heading mb-4">Media</h1>
    <p class="text-[var(--gs-text-secondary)] mb-8">
      Curate approved media assets with structured access controls for editors and viewers.
    </p>

    <Card class="gs-table-card">
      <Table>
        <thead>
          <tr>
            <th>Asset ID</th>
            <th>Name</th>
            <th>Type</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {mediaAssets.map((asset) => (
            <tr>
              <td>{asset.id}</td>
              <td>{asset.name}</td>
              <td>{asset.type}</td>
              <td class="capitalize">{asset.status}</td>
            </tr>
          ))}
        </tbody>
      </Table>
    </Card>
  </section>
</AdminLayout>
