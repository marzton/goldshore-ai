---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { team } from '../data/site-content';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Team | GoldShore.ai"
      description="Meet the GoldShore.ai team."
    />
  </head>
  <body>
    <Header />
    <main>
      <h1>Team</h1>
      <p class="small">
        A multidisciplinary group focused on resilient operational AI systems.
      </p>
      <section>
        <div class="grid">
          {
            team.map((member) => (
              <article class="card">
                <h2>{member.name}</h2>
                <p class="small">{member.role}</p>
                <p>{member.bio}</p>
              </article>
            ))
          }
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
