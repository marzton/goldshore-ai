---
import AdminLayout from '../../layouts/AdminLayout.astro';
import StatCard from '../../components/StatCard.astro';
import Table from '../../components/Table.astro';

const headers = ['Module', 'Owner', 'Status', 'Notes'];
const rows = [
  ['Navigation + Shell', 'Admin UI', 'Ready', 'Sidebar + topbar are layout-driven.'],
  ['Search Module', 'Platform', 'Pluggable', 'Embed shared search in admin or docs.'],
  ['Cloudflare Workers', 'Platform', 'Live', 'Gateway + API templates are versioned.'],
  ['Integrations', 'Ops', 'Planned', 'Gemini, ChatGPT, Alpaca, Thinkorswim.']
];
---

<AdminLayout title="Admin Template">
  <section class="gs-section">
    <h1>Admin template overview</h1>
    <p class="gs-subtitle">
      This dashboard template keeps navigation, menus, tables, and status cards modular so teams can extend
      operations, personnel, and infrastructure views without reworking the shell.
    </p>
  </section>

  <section class="gs-section">
    <div class="gs-grid columns-3">
      <StatCard label="Active Workflows" value="7" help="Includes GitHub Actions + Cloudflare deploys" />
      <StatCard label="Open Reviews" value="4" help="Track PRs, issues, and runbooks" />
      <StatCard label="Integrations" value="12" help="API + AI partnerships in flight" />
    </div>
  </section>

  <section class="gs-section">
    <div class="gs-card">
      <h2>Template modules</h2>
      <p>
        Keep operational modules grouped as independent components. Table data highlights how layouts,
        API services, and AI integrations align with admin workflows.
      </p>
      <Table headers={headers} rows={rows} />
    </div>
  </section>

  <section class="gs-section">
    <div class="gs-grid columns-2">
      <div class="gs-card">
        <h3>People + Roles</h3>
        <p>Map personnel permissions, approvals, and workflow ownership for HITL oversight.</p>
      </div>
      <div class="gs-card">
        <h3>Operations + Observability</h3>
        <p>Surface logs, incidents, and infrastructure posture for secure Cloudflare delivery.</p>
      </div>
    </div>
  </section>
</AdminLayout>
