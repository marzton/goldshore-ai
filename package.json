{
  "name": "goldshore-ai",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    // Core development script
    "dev": "turbo run dev --parallel",

    // Unified build script; uses turbo to orchestrate per-package builds.
    "build": "turbo run build",

    // Build individual Cloudflare workers.  In GoldShore v2, worker names use the
    // `gs-` prefix.  These scripts replace the previous @goldshore/* filters.
    "build:gs-web": "turbo run build --filter=gs-web",
    "build:gs-admin": "turbo run build --filter=gs-admin",
    "build:gs-api": "turbo run build --filter=gs-api",
    "build:gs-gateway": "turbo run build --filter=gs-gateway",
    "build:gs-control": "turbo run build --filter=gs-control",
    "build:gs-mail": "turbo run build --filter=gs-mail",

    // Lint and test tasks remain, as they are essential for code quality.
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@astrojs/mdx": "^4.0.8",
    "@astrojs/sitemap": "^3.6.0",
    "@astrojs/tailwind": "^6.0.2",
    "@types/node": "^25.0.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "astro": "^5.15.9",
    "eslint": "^8.57.0",
    "eslint-plugin-astro": "^1.5.0",
    "form-data": "^4.0.5",
    "octokit": "^5.0.5",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.13.0",
    // Pin tailwindcss to a specific minor version instead of the ambiguous "^3"
    "tailwindcss": "^3.4.4",
    "tsx": "^4.21.0",
    "typescript": "^5.4.2",
    "wrangler": "^4.63.0",
    "yaml": "^2.8.2"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/adapter-cloudflare": "^12.6.12",
    "turbo": "^2.7.5"
  },
  "pnpm": {
    "overrides": {
      // Align overrides with declared versions to avoid unexpected upgrades.
      "@astrojs/cloudflare": "^12.6.12",
      "@astrojs/adapter-cloudflare": "^12.6.12",
      "postal-mime": "2.7.3"
    }
  }
}
