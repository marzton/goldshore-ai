{
  "name": "goldshore-ai",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build:openapi": "node scripts/build-openapi.mjs",
    "build": "pnpm build:openapi && turbo run build",
    "build:web": "turbo run build --filter=@goldshore/gs-web",
    "build:admin": "turbo run build --filter=@goldshore/gs-admin",
    "build:api": "turbo run build --filter=@goldshore/gs-api",
    "build:gateway": "turbo run build --filter=@goldshore/gs-gateway",
    "build:control": "turbo run build --filter=@goldshore/gs-control",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "scan:pii": "node scripts/pii-scan.mjs --mode local --output apps/gs-admin/src/data/pii-scan-results.json --summary reports/pii-scan-summary.md",
    "workspaces:list": "pnpm -r list --depth -1",
    "verify:workspace-contract": "tsx scripts/validate-workspace-contract.ts",
    "verify:workspace-filters": "pnpm verify:workspace-contract && turbo run build --filter=@goldshore/gs-api --dry && turbo run build --filter=@goldshore/gs-control --dry"
    "verify:workspace-filters": "turbo run build --filter=@goldshore/gs-api --dry && turbo run build --filter=@goldshore/gs-control --dry",
    "validate:structure": "tsx scripts/validate-worker-structure.ts",
    "validate:workers": "tsx scripts/validate-worker-names.ts",
    "validate:workspace": "tsx scripts/validate-workspace-contract.ts"
  },
  "devDependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.55.0",
    "astro": "^5.15.9",
    "eslint": "^8.57.0",
    "eslint-plugin-astro": "^1.6.0",
    "form-data": "^4.0.5",
    "octokit": "^5.0.5",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.4.2",
    "yaml": "^2.8.2"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "turbo": "^2.8.9"
  },
  "pnpm": {
    "overrides": {
      "@astrojs/cloudflare": "latest",
      "@astrojs/adapter-cloudflare": "latest"
    }
  }
}
