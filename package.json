{
  "name": "goldshore-ai",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "pnpm build:openapi && turbo run build",
    "build:openapi": "node scripts/build-openapi.mjs",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check:pages": "tsx scripts/check-pages-200.ts",
    "scan:pii": "node scripts/pii-scan.mjs --mode local --output apps/gs-admin/src/data/pii-scan-results.json --summary reports/pii-scan-summary.md",
    "check:docs-consistency": "node scripts/check-doc-consistency.mjs",
    "check:theme-exports": "node scripts/check-theme-exports.mjs",
    "check:naming": "node scripts/lint-naming.mjs",
    "validate:structure": "tsx scripts/validate-worker-structure.ts",
    "validate:names": "tsx scripts/validate-worker-names.ts",
    "validate:workers": "tsx scripts/validate-worker-names.ts",
    "validate:workspace": "tsx scripts/validate-workspace-contract.ts",
    "validate": "pnpm check:naming && pnpm validate:workspace && pnpm validate:structure && pnpm validate:names",
    "branch:bootstrap": "bash scripts/branch-bootstrap.sh",
    "scaffold:worker": "node scripts/scaffold-worker.mjs",
    "workspaces:list": "pnpm -r list --depth -1",
    "verify:workspace-filters": "turbo run build --filter=@goldshore/gs-api --dry && turbo run build --filter=@goldshore/gs-control --dry",
    "verify:web-dist": "node scripts/verify-web-dist.mjs",
    "memory:check": "node scripts/validate-canonical-structure.mjs",
    "sync:infra": "tsx scripts/sync-gateway.ts",
    "sync:cf": "echo 'Run codex sync script here' && tsx scripts/sync-gateway.ts",
    "repo:clean": "git clean -xfd -e .env -e env.secrets.runtime.json",
    "repo:install": "pnpm install --frozen-lockfile",
    "repo:health": "node scripts/repo-health.mjs",
    "audit": "pnpm run repo:health",
    "build:api": "turbo run build --filter=@goldshore/gs-api",
    "build:control": "turbo run build --filter=@goldshore/gs-control"
  },
  "devDependencies": {
    "@astrojs/mdx": "^4.0.8",
    "@astrojs/sitemap": "^3.6.0",
    "@astrojs/tailwind": "^6.0.2",
    "@types/node": "^25.3.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.56.1",
    "astro": "^5.17.1",
    "eslint": "^8.57.0",
    "eslint-plugin-astro": "^1.6.0",
    "form-data": "^4.0.5",
    "octokit": "^5.0.5",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.14.1",
    "svgo": "^4.0.1",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.4.2",
    "wrangler": "^4.75.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "p-limit": "^7.3.0",
    "turbo": "^2.8.20"
  },
  "pnpm": {
    "overrides": {
      "@astrojs/cloudflare": "12.6.12",
      "@astrojs/adapter-cloudflare": "12.6.12",
      "postal-mime": "2.7.3",
      "wrangler": "^4.63.0",
      "typescript": "^5.4.2",
      "esbuild": "0.25.12"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
