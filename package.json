{
  "name": "goldshore-ai",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build:openapi": "node scripts/build-openapi.mjs",
    "build": "pnpm build:openapi && turbo run build",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@goldshore/gs-web",
    "build:admin": "turbo run build --filter=@goldshore/gs-admin",
    "build:api": "turbo run build --filter=@goldshore/gs-api-worker",
    "build:gateway": "turbo run build --filter=@goldshore/gs-gateway",
    "build:control": "turbo run build --filter=@goldshore/gs-control-worker",
    "build:mail": "turbo run build --filter=@goldshore/gs-mail-worker",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:integration": "pnpm --filter gs-api test && pnpm --filter @goldshore/control test && pnpm --filter ./apps/gs-web test:e2e",
    "validate:workers": "python3 scripts/validate-worker-configs.py",
    "test:visual": "node scripts/run-visual-gate.mjs",
    "smoke:post-merge": "tsx scripts/post-merge-smoke.ts",
    "gate:typecheck": "pnpm typecheck",
    "gate:lint": "pnpm lint",
    "gate:test:unit": "pnpm test",
    "gate:test:integration": "pnpm test:integration",
    "gate:validate:workers": "pnpm validate:workers",
    "gate:test:visual": "pnpm test:visual",
    "gate:matrix": "pnpm gate:typecheck && pnpm gate:lint && pnpm gate:test:unit && pnpm gate:test:integration && pnpm gate:validate:workers && pnpm gate:test:visual",
    "check:pages": "tsx scripts/check-pages-200.ts",
    "scan:pii": "node scripts/pii-scan.mjs --mode local --output apps/gs-admin/src/data/pii-scan-results.json --summary reports/pii-scan-summary.md",
    "validate:instructions": "python scripts/validate_instruction_refs.py",
    "validate:structure": "tsx scripts/validate-worker-structure.ts"
  },
  "devDependencies": {
    "@astrojs/mdx": "^4.0.8",
    "@astrojs/sitemap": "^3.6.0",
    "@astrojs/tailwind": "^6.0.2",
    "@types/node": "^25.0.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "astro": "^5.15.9",
    "eslint": "^8.57.0",
    "eslint-plugin-astro": "^1.5.0",
    "form-data": "^4.0.5",
    "octokit": "^5.0.5",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.13.0",
    "tailwindcss": "^3",
    "tsx": "^4.21.0",
    "typescript": "^5.4.2",
    "wrangler": "^4.63.0",
    "yaml": "^2.8.2"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "turbo": "^2.7.5"
  },
  "pnpm": {
    "overrides": {
      "@astrojs/cloudflare": "latest",
      "@astrojs/adapter-cloudflare": "latest",
      "postal-mime": "2.7.3"
    }
  }
}
