{
  "name": "astro-goldshore",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build:openapi": "node scripts/build-openapi.mjs",
    "build": "pnpm build:openapi && turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "validate": "tsx scripts/validate-worker-structure.ts",
    "scan:pii": "node scripts/pii-scan.mjs --mode local --output apps/gs-admin/src/data/pii-scan-results.json --summary reports/pii-scan-summary.md",
    "workspaces:list": "pnpm -r list --depth -1"
  },
  "devDependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.55.0",
    "astro": "^5.15.9",
    "eslint": "^8.57.0",
    "eslint-plugin-astro": "^1.6.0",
    "form-data": "^4.0.5",
    "octokit": "^5.0.5",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.4.2",
    "yaml": "^2.8.2"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.12",
    "turbo": "^2.8.9"
  },
  "pnpm": {
    "overrides": {
      "@astrojs/cloudflare": "latest",
      "@astrojs/adapter-cloudflare": "latest",
      "wrangler": "^4.65.0"
    }
  }
}
