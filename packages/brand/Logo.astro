---
interface Props {
  variant?: "mark" | "horizontal";
  class?: string;
}

const { variant = "mark", class: className = "" } = Astro.props;
---

{variant === "horizontal" ? (
  <svg viewBox="0 0 540 160" fill="none" xmlns="http://www.w3.org/2000/svg" class={className} aria-label="Gold Shore logo">
    <path d="m111.87 92.5-41-72A1 1 0 0 0 70 20H57a1 1 0 0 0-.87.5l-41 72a1 1 0 0 0 0 1l6.5 11.41a1 1 0 0 0 .87.5h82a1 1 0 0 0 .87-.5l6.5-11.41a1 1 0 0 0 0-1M109.28 92H43.72l5.36-9.42H91.5a1 1 0 0 0 .87-1.49L58.72 22h10.7ZM63.5 57.27l13.28 23.31H50.22ZM17.15 93 57 23.02l32.78 57.56h-10.7L57.87 43.34a1.04 1.04 0 0 0-1.74 0L22.5 102.39Zm86.77 10.41H24.22L57 45.85l5.35 9.39-21.22 37.26A1 1 0 0 0 42 94h67.28Z" stroke="url(#markGradient)" stroke-width="3" stroke-linejoin="round" />
    <text x="170" y="98" fill="url(#wordGradient)" font-size="44" font-weight="600" letter-spacing="6" font-family="Cinzel, Cormorant Garamond, Playfair Display, serif">GOLD SHORE</text>
    <defs>
      <linearGradient id="markGradient" x1="15" y1="20" x2="120" y2="110" gradientUnits="userSpaceOnUse">
        <stop stop-color="#e6f3ff" />
        <stop offset=".5" stop-color="#4da3ff" />
        <stop offset="1" stop-color="#0a4c8a" />
      </linearGradient>
      <linearGradient id="wordGradient" x1="170" y1="40" x2="480" y2="110" gradientUnits="userSpaceOnUse">
        <stop stop-color="#e6f3ff" />
        <stop offset=".5" stop-color="#4da3ff" />
        <stop offset="1" stop-color="#0a4c8a" />
      </linearGradient>
    </defs>
  </svg>
) : (
  <svg viewBox="0 0 160 160" fill="none" xmlns="http://www.w3.org/2000/svg" class={className} aria-label="Gold Shore mark">
    <path class="penrose-stroke" d="m111.87 92.5-41-72A1 1 0 0 0 70 20H57a1 1 0 0 0-.87.5l-41 72a1 1 0 0 0 0 1l6.5 11.41a1 1 0 0 0 .87.5h82a1 1 0 0 0 .87-.5l6.5-11.41a1 1 0 0 0 0-1M109.28 92H43.72l5.36-9.42H91.5a1 1 0 0 0 .87-1.49L58.72 22h10.7ZM63.5 57.27l13.28 23.31H50.22ZM17.15 93 57 23.02l32.78 57.56h-10.7L57.87 43.34a1.04 1.04 0 0 0-1.74 0L22.5 102.39Zm86.77 10.41H24.22L57 45.85l5.35 9.39-21.22 37.26A1 1 0 0 0 42 94h67.28Z" stroke="url(#markGradient2)" stroke-width="3" stroke-linejoin="round" />
    <defs>
      <linearGradient id="markGradient2" x1="15" y1="20" x2="120" y2="110" gradientUnits="userSpaceOnUse">
        <stop stop-color="#e6f3ff" />
        <stop offset=".5" stop-color="#4da3ff" />
        <stop offset="1" stop-color="#0a4c8a" />
      </linearGradient>
    </defs>
  </svg>
)}
