---
import HorizontalLogo from './logo-horizontal.svg';
import MarkLogo from './logo-penrose.svg';

interface Props {
  variant?: "mark" | "horizontal";
  class?: string;
  width?: number;
  height?: number;
}

const { 
  variant = "mark", 
  class: className,
  ...rest
} = Astro.props;

const logo = variant === 'horizontal' ? HorizontalLogo : MarkLogo;
const altText = variant === 'horizontal' ? 'Gold Shore logo' : 'Gold Shore mark';
---

<img src={logo.src} alt={altText} class:list={[className]} {...rest} />

