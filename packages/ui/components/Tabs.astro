---
const { tabs = [] } = Astro.props;
---

<div class="gs-tabs">
  <div class="gs-tabs-header">
    {tabs.map((t) => (
      <button
        class="gs-button gs-button--ghost gs-button--small gs-tab-trigger"
        data-target={t.id}
        type="button"
      >
        {t.label}
      </button>
    ))}
  </div>

  <div class="gs-tab-content">
      <slot />
  </div>
</div>

<script is:inline>
  window.showTab = function(event, id) {
    const container = event.target.closest('.gs-tabs');
    if (!container) return;

    // Deactivate all content tabs in this container
    const contentTabs = container.querySelectorAll('.gs-tab');
    contentTabs.forEach((el) => {
        el.classList.toggle('is-active', el.id === id);
    });
  }
</script>

<style>
  .gs-tabs-header {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--color-border, #333);
  }
  /* Removed unused .gs-tab-trigger styles as the button uses gs-button classes */

  /* Add styles for active state if not covered by gs-button active variants */
  .gs-tabs-header button.active {
      color: var(--color-utility-orange, #f59e0b);
      border-bottom: 2px solid var(--color-utility-orange, #f59e0b);
  }
</style>
