---
const { tabs = [] } = Astro.props;
---

<div class="gs-tabs">
  <div class="gs-tabs-header" role="tablist">
    {tabs.map((t: any) => (
      <button
        class="gs-tab-trigger"
        data-target={t.id}
        role="tab"
        aria-selected="false"
        aria-controls={t.id}
      >
        {t.label}
      </button>
    ))}
  </div>

  <div class="gs-tab-content">
      <slot />
  </div>
</div>

<script>
  function initTabs() {
    document.querySelectorAll('.gs-tabs').forEach(container => {
      const triggers = container.querySelectorAll<HTMLElement>('.gs-tab-trigger');
      const panels = container.querySelectorAll<HTMLElement>('.gs-tab');

      if (triggers.length === 0) return;

      const setActive = (id: string | null, shouldFocus = false) => {
          if(!id) return;
          // Toggle triggers
          triggers.forEach(t => {
              if(t.getAttribute('data-target') === id) {
                  t.classList.add('active');
                  t.setAttribute('aria-selected', 'true');
                  t.setAttribute('tabindex', '0');
                  if (shouldFocus) {
                      t.focus();
                  }
              } else {
                  t.classList.remove('active');
                  t.setAttribute('aria-selected', 'false');
                  t.setAttribute('tabindex', '-1');
              }
          });
          // Toggle panels
          panels.forEach(p => {
             if(p.id === id) {
                 p.style.display = 'block';
             } else {
                 p.style.display = 'none';
             }
          });
      };

      // Bind events
      triggers.forEach((t) => {
          t.addEventListener('click', (e) => {
              const targetId = (e.currentTarget as HTMLElement).getAttribute('data-target');
              // Click naturally focuses, but we ensure state is correct
              setActive(targetId, false);
          });
      });

      // Init: Activate first tab if none active
      const firstTrigger = triggers[0];
      if (firstTrigger) {
         setActive(firstTrigger.getAttribute('data-target'));
      }
    });
  }

  // Run on load and after Astro swaps
  initTabs();
  document.addEventListener('astro:page-load', initTabs);
  <div class="gs-tabs-header">
    {
      tabs.map((t) => (
        <button onclick={`showTab(event, '${t.id}')`}>{t.label}</button>
      ))
    }
  </div>

  {
    tabs.map((t) => (
      <div
        id={t.id}
        class="gs-tab"
        style={tabs.indexOf(t) === 0 ? 'display: block;' : 'display: none;'}
      >
        <slot name={t.id} />
      </div>
    ))
  }
</div>

<script is:inline>
  window.showTab = function (event, id) {
    const container = event.target.closest('.gs-tabs');
    if (!container) return;

    // Deactivate all content tabs in this container
    const contentTabs = container.querySelectorAll('.gs-tab');
    contentTabs.forEach((el) => {
      if (el.id === id) {
        el.style.display = 'block';
      } else {
        el.style.display = 'none';
      }
    });

    // Optional: Update active state of buttons?
    // The prompt didn't specify active state styles for buttons, but it's good UX.
    // The prompt CSS has no active class for buttons.
    // I will stick to just switching content.
  };
</script>

<style>
  .gs-tabs-header {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--gs-color-border, #333);
  }
  .gs-tab-trigger {
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 0.5rem 1rem;
    color: var(--gs-color-text-subtle, #888);
    cursor: pointer;
    font-family: inherit;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .gs-tab-trigger:hover {
      color: var(--gs-color-text, #fff);
  }
  .gs-tab-trigger.active {
      color: var(--gs-color-primary, #f59e0b);
      border-bottom-color: var(--gs-color-primary, #f59e0b);
  .gs-tabs-header button:hover {
    background: var(--gs-bg-elevated);
    color: var(--gs-fg);
  }
</style>
