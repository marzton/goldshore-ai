---
const { tabs = [] } = Astro.props;
---

<div class="gs-tabs">
  <div class="gs-tabs-header" role="tablist">
    {tabs.map((t: any) => (
      <button
        class="gs-tab-trigger"
        data-target={t.id}
        role="tab"
        aria-selected="false"
        aria-controls={t.id}
        tabindex="-1"
      >
        {t.label}
      </button>
    ))}
  </div>

  <div class="gs-tab-content">
      <slot />
  </div>
</div>

<script>
  function initTabs() {
    document.querySelectorAll('.gs-tabs').forEach(container => {
      const triggers = container.querySelectorAll<HTMLElement>('.gs-tab-trigger');
      const panels = container.querySelectorAll<HTMLElement>('.gs-tab');

      if (triggers.length === 0) return;

      const setActive = (id: string | null, shouldFocus = false) => {
          if(!id) return;
          // Toggle triggers
          triggers.forEach(t => {
              if(t.getAttribute('data-target') === id) {
                  t.classList.add('active');
                  t.setAttribute('aria-selected', 'true');
                  t.setAttribute('tabindex', '0');
                  if (shouldFocus) {
                      t.focus();
                  }
              } else {
                  t.classList.remove('active');
                  t.setAttribute('aria-selected', 'false');
                  t.setAttribute('tabindex', '-1');
              }
          });
          // Toggle panels
          panels.forEach(p => {
             if(p.id === id) {
                 p.style.display = 'block';
             } else {
                 p.style.display = 'none';
             }
          });
      };

      // Bind events
      triggers.forEach((t, index) => {
          t.addEventListener('click', (e) => {
              const targetId = (e.currentTarget as HTMLElement).getAttribute('data-target');
              // Click naturally focuses, but we ensure state is correct
              setActive(targetId, false);
          });

          t.addEventListener('keydown', (e) => {
              let targetIndex: number | null = null;

              if (e.key === 'ArrowRight') {
                  targetIndex = (index + 1) % triggers.length;
              } else if (e.key === 'ArrowLeft') {
                  targetIndex = (index - 1 + triggers.length) % triggers.length;
              } else if (e.key === 'Home') {
                  targetIndex = 0;
              } else if (e.key === 'End') {
                  targetIndex = triggers.length - 1;
              }

              if (targetIndex !== null) {
                  e.preventDefault();
                  const targetTrigger = triggers[targetIndex];
                  const targetId = targetTrigger.getAttribute('data-target');
                  setActive(targetId, true);
              }
          });
      });

      // Init: Activate first tab if none active
      const firstTrigger = triggers[0];
      if (firstTrigger && !container.querySelector('.gs-tab-trigger.active')) {
         setActive(firstTrigger.getAttribute('data-target'), false);
      }
    });
  }

  // Run on load and after Astro swaps
  initTabs();
  document.addEventListener('astro:page-load', initTabs);
</script>

<style>
  .gs-tabs-header {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--gs-color-border, #333);
  }
  .gs-tab-trigger {
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 0.5rem 1rem;
    color: var(--gs-color-text-subtle, #888);
    cursor: pointer;
    font-family: inherit;
    font-weight: 500;
    transition: all 0.2s ease;
  }
  .gs-tab-trigger:hover {
      color: var(--gs-color-text, #fff);
  }
  .gs-tab-trigger:focus-visible {
      outline: 2px solid var(--gs-color-primary, #f59e0b);
      outline-offset: -2px;
      border-radius: 2px;
  }
  .gs-tab-trigger.active {
      color: var(--gs-color-primary, #f59e0b);
      border-bottom-color: var(--gs-color-primary, #f59e0b);
  }
</style>
