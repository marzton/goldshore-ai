---
interface Props {
  ariaLabel?: string;
}

const { ariaLabel = "Data table" } = Astro.props;
---

<div class="gs-table-container" role="region" aria-label={ariaLabel} tabindex="0">
  <table class="gs-table">
    <slot />
  </table>
</div>

<style>
  .gs-table-container {
    width: 100%;
    overflow-x: auto;
    /* Ensure focus visibility for keyboard users */
    outline: none;
  }
  .gs-table-container:focus-visible {
    outline: 2px solid var(--gs-accent);
    outline-offset: 2px;
    border-radius: var(--gs-radius-sm);
  }
</style>
