---
/**
 * Definitive GoldShore SVG Logo (Institutional Standard)
 */
---
<svg
  viewBox="0 0 100 100"
  class="gs-logo"
  aria-label="GoldShore"
  xmlns="http://www.w3.org/2000/svg"
>
  <g stroke="currentColor" stroke-width="2" fill="none">
    <path d="M50 10 L90 80 L10 80 Z" />
    <path d="M50 25 L75 75 L25 75 Z" opacity="0.6"/>
    <path d="M50 40 L60 70 L40 70 Z" opacity="0.3"/>
  </g>
</svg>

<style>
  .gs-logo {
    width: 28px;
    height: 28px;
    color: #9fdcff;
    filter: drop-shadow(0 0 6px rgba(120,180,255,0.4));
    transition: all 0.3s ease;
  }

  .gs-logo:hover {
    color: #cfe9ff;
    filter: drop-shadow(0 0 12px rgba(120,180,255,0.7));
  }
</style>
