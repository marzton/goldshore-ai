---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contact | Gold Shore Labs</title>
  </head>
  <body>
    <header class="hero" style="min-height: 55vh;">
      <nav class="container nav">
        <a class="brand" href="/">Gold Shore Labs</a>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </nav>

      <div class="container hero-content" style="padding-bottom: 72px;">
        <h1>Let’s Connect</h1>
        <p class="positioning">
          Whether you're validating an idea, scaling infrastructure, or planning your next AI initiative,
          we'd love to hear what you're building.
        </p>
      </div>
    </header>

    <main>
      <section class="section engage">
        <div class="container">
          <h2>Contact Gold Shore Labs</h2>
          <p>
            Email us directly at
            <a class="cta" style="margin-top: 0; margin-left: 8px;" href="mailto:hello@goldshore.ai">hello@goldshore.ai</a>
          </p>
          <p>
            Prefer to share project details first?
            <a href="https://cal.com" target="_blank" rel="noreferrer">Book a short intro call</a>.
          </p>
        </div>
      </section>
    </main>
  </body>
</html>
