---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import AdminSidebar from '../components/AdminSidebar.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={`${title} | Goldshore Admin`} description="Internal Operations" />
  </head>
  <body class="bg-slate-50 text-slate-900 antialiased dark:bg-slate-900 dark:text-slate-100">
    <Header />
    <div class="flex h-screen overflow-hidden pt-16">
      <AdminSidebar />
      <main
        id="main-content"
        class="relative h-full w-full overflow-y-auto bg-slate-50 dark:bg-slate-900 lg:ml-64"
      >
        <div class="px-4 pt-6">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
