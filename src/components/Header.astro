---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
import siteConfig from '../data/site-config.json';
---

<header>
  <nav>
    <a class="brand-lockup" href="/" aria-label={SITE_TITLE}>
      <img
        src="/assets/brand/logo-horizontal.svg"
        alt="GoldShore.ai"
        width="540"
        height="160"
      />
    </a>
    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/services">Services</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
      <HeaderLink href="/team">Team</HeaderLink>
      <HeaderLink href="/risk-radar">Risk Radar</HeaderLink>
      <HeaderLink href="/developer-hub">Developer Hub</HeaderLink>
      <HeaderLink href="/contact">Contact</HeaderLink>
    </div>
    <a class="button button-secondary" href="/contact"
      >{siteConfig.cta.secondary}</a
    >
  </nav>
</header>
<style>
  header {
    margin: 0;
    padding: 0 1em;
    position: sticky;
    top: 0;
    z-index: 10;
    background: rgba(7, 16, 30, 0.88);
    border-bottom: 1px solid rgba(123, 158, 204, 0.18);
    backdrop-filter: blur(18px);
  }
  .brand-lockup {
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    text-decoration: none;
  }
  .brand-lockup img {
    width: clamp(180px, 20vw, 260px);
    height: auto;
    display: block;
  }
  nav {
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    padding: 0.8rem 0;
  }
  .internal-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.35rem;
  }
  @media (max-width: 980px) {
    nav {
      flex-direction: column;
      align-items: stretch;
    }
    .internal-links {
      justify-content: flex-start;
    }
  }
</style>
