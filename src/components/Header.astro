---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
import siteConfig from '../data/site-config.json';
---

<header>
  <nav>
    <h2><a href="/">{SITE_TITLE}</a></h2>
    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/services">Services</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
      <HeaderLink href="/team">Team</HeaderLink>
      <HeaderLink href="/risk-radar">Risk Radar</HeaderLink>
      <HeaderLink href="/developer">Developer Hub</HeaderLink>
      <HeaderLink href="/contact">Contact</HeaderLink>
    </div>
    <a class="button button-secondary" href="/contact"
      >{siteConfig.cta.secondary}</a
    >
  </nav>
</header>
<style>
  header {
    margin: 0;
    padding: 0 1em;
    background: rgb(var(--surface));
    border-bottom: 1px solid rgb(var(--border));
  }
  h2 {
    margin: 0;
    font-size: 1.1rem;
  }

  h2 a,
  h2 a.active {
    text-decoration: none;
    color: rgb(var(--black));
  }
  nav {
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    padding: 0.4rem 0;
  }
  .internal-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.2rem;
  }
  @media (max-width: 980px) {
    nav {
      flex-direction: column;
      align-items: flex-start;
    }
    .internal-links {
      justify-content: flex-start;
    }
  }
</style>
