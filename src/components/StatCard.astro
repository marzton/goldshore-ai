---
interface Props {
  title: string;
  value: string;
  trend: string;
}

const { title, value, trend } = Astro.props;
---

<article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-800">
  <h2 class="mb-1 text-sm font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-300">{title}</h2>
  <p class="text-3xl font-bold text-slate-900 dark:text-slate-100">{value}</p>
  <p class="mt-2 text-sm text-emerald-600 dark:text-emerald-400">{trend}</p>
</article>
