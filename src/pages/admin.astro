---
import AdminLayout from '../layouts/AdminLayout.astro';
import SystemHealth from '../components/SystemHealth.astro';

export const prerender = false;

const clientCertHeader = Astro.request.headers.get('cf-client-cert-base64');
const isAdmin = clientCertHeader !== null;
---

<AdminLayout title="Admin Dashboard">
  <section class="mx-auto max-w-5xl space-y-6 pb-8">
    <h1 class="text-2xl font-semibold">Goldshore Command Center</h1>

    {
      isAdmin ? (
        <div class="grid gap-4 md:grid-cols-2">
          <SystemHealth />
        </div>
      ) : (
        <p class="rounded-lg border border-red-300 bg-red-50 text-red-800 px-4 py-3">
          Access Denied: Secure Identity Not Found.
        </p>
      )
    }
  </section>
</AdminLayout>
