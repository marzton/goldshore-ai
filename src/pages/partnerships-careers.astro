---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Partnerships & Careers | GoldShore.ai"
      description="Join Gold Shore's next generation advisory and intelligence partnership network."
    />
  </head>
  <body>
    <Header />
    <main>
      <section>
        <p class="eyebrow">Partnerships &amp; Careers</p>
        <h1>Join the next generation of capital steering.</h1>
        <p>
          We provide high-fidelity intelligence; you provide strategic guidance.
          Gold Shore partners with institutional-caliber advisors who can bridge
          technology with client outcomes.
        </p>
      </section>

      <section class="card">
        <h2>Ideal profiles</h2>
        <ul>
          <li>
            <strong>Chartered Financial Analysts (CFA):</strong> deploying Risk Radar
            across institutional mandates.
          </li>
          <li>
            <strong>Certified Financial Planners (CFP):</strong> designing bespoke
            allocations for UHNW clients.
          </li>
          <li>
            <strong>Quantitative Strategists:</strong> refining GS-API signals into
            regime-aware advisory products.
          </li>
        </ul>
      </section>

      <section>
        <h2>Partnership model tiers</h2>
        <div class="grid tiers">
          <article class="card">
            <h3>Associate Advisor</h3>
            <p class="small">Target: Individual CFAs/CFPs</p>
            <p>Direct hire to manage Gold Shore advisory relationships.</p>
          </article>
          <article class="card">
            <h3>Strategic Partner</h3>
            <p class="small">Target: Independent RIAs</p>
            <p>
              White-label access to Gold Shore workflows and intelligence rails.
            </p>
          </article>
          <article class="card">
            <h3>Quant Partner</h3>
            <p class="small">Target: Technical strategists</p>
            <p>Collaborative development of new regime and risk models.</p>
          </article>
        </div>
      </section>

      <section class="card">
        <h2>Apply for a strategic briefing</h2>
        <p>
          Use our Advisor Inquiry route and include your credentials,
          implementation horizon, and how you plan to leverage Gold Shore
          intelligence.
        </p>
        <a class="button button-primary" href="/contact">Request Briefing</a>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgb(var(--accent-strong));
    font-weight: 700;
    font-size: 0.82rem;
  }

  ul {
    padding-left: 1.1rem;
  }

  li + li {
    margin-top: 0.45rem;
  }

  .tiers {
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 260px), 1fr));
  }
</style>
