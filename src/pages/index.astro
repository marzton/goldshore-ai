---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const routingApiBase = import.meta.env.GS_ROUTING_API_BASE?.replace(/\/$/, '');
const primaryCtaHref = routingApiBase ? `${routingApiBase}/services` : '/services';

const landingCards = [
  {
    title: 'Advisory Services',
    description:
      'Explore structured advisory tracks for infrastructure resilience, risk governance, and deployment operations.',
    href: '/services',
    cta: 'Explore services',
  },
  {
    title: 'Briefing Requests',
    description:
      'Submit a briefing request for targeted market and operations intelligence aligned to your mandate.',
    href: '/admin/forms',
    cta: 'Open briefing intake',
  },
  {
    title: 'PII Scans',
    description:
      'Review privacy posture and data handling risk with rapid detection workflows for sensitive information.',
    href: '/risk-radar',
    cta: 'View risk workflows',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="landing-main">
      <section class="hero" aria-labelledby="hero-title">
        <p class="kicker">GoldShore intelligence systems</p>
        <h1 id="hero-title">Institutional clarity at operational speed.</h1>
        <p class="lede">
          A high-performance front door for advisory delivery, briefing intake, and trusted
          technical guidance.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href={primaryCtaHref}>Find your service path</a>
          <a class="button button-secondary" href="/contact">Contact the team</a>
        </div>
      </section>

      <section class="search-block" aria-labelledby="search-title">
        <h2 id="search-title">Global search</h2>
        <p>Search imported legacy content instantly with Pagefind.</p>
        <label for="global-search" class="sr-only">Search site content</label>
        <input id="global-search" type="search" placeholder="Search advisory notes, workflows, and briefings" autocomplete="off" />
        <div id="search-results" aria-live="polite"></div>
      </section>

      <section class="content-grid" aria-labelledby="grid-title">
        <h2 id="grid-title">Core access points</h2>
        <div class="grid">
          {
            landingCards.map((card) => (
              <article class="card card-panel">
                <h3>{card.title}</h3>
                <p>{card.description}</p>
                <a href={card.href}>{card.cta} →</a>
              </article>
            ))
          }
        </div>
      </section>
    </main>
    <Footer />

    <script>
      const searchInput = document.getElementById('global-search');
      const searchResults = document.getElementById('search-results');

      const renderResults = (results) => {
        if (!(searchResults instanceof HTMLElement)) return;

        if (!results.length) {
          searchResults.innerHTML = '<p class="search-empty">No results found.</p>';
          return;
        }

        searchResults.innerHTML = results
          .slice(0, 6)
          .map(
            (result) => `
              <article class="search-result">
                <a href="${result.url}">${result.meta.title || result.url}</a>
                <p>${result.excerpt || ''}</p>
              </article>
            `,
          )
          .join('');
      };

      const bootSearch = async () => {
        if (!(searchInput instanceof HTMLInputElement) || !(searchResults instanceof HTMLElement)) {
          return;
        }

        try {
          const pagefind = await import('/pagefind/pagefind.js');
          const searchEngine = await pagefind.options({});

          searchInput.addEventListener('input', async () => {
            const term = searchInput.value.trim();
            if (!term) {
              searchResults.innerHTML = '';
              return;
            }

            const search = await searchEngine.search(term);
            const data = await Promise.all(search.results.map((item) => item.data()));
            renderResults(data);
          });
        } catch (error) {
          searchResults.innerHTML = '<p class="search-empty">Search is temporarily unavailable.</p>';
        }
      };

      bootSearch();
    </script>
  </body>
</html>

<style>
  .landing-main {
    display: grid;
    gap: 2rem;
  }

  .hero,
  .search-block,
  .card-panel {
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 12px;
    background: #10141e;
  }

  .hero {
    padding: clamp(1.5rem, 5vw, 3rem);
    color: #f9fbff;
  }

  .kicker {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    color: #c8d3e7;
  }

  .hero h1 {
    margin: 0.4rem 0 0.75rem;
    font-size: clamp(2rem, 5vw, 3.3rem);
    line-height: 1.05;
  }

  .lede {
    max-width: 48ch;
    color: #d5dff0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.1rem;
  }

  .search-block {
    padding: 1.25rem;
  }

  .search-block h2,
  .content-grid h2 {
    margin-top: 0;
  }

  #global-search {
    width: 100%;
    margin-top: 0.6rem;
    margin-bottom: 0.9rem;
  }

  #search-results {
    display: grid;
    gap: 0.6rem;
  }

  .search-result {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 10px;
    padding: 0.6rem 0.75rem;
    background: #0a0d14;
  }

  .search-result a {
    color: #ffffff;
    font-weight: 700;
  }

  .search-empty {
    margin: 0;
    color: #c8d3e7;
  }

  .content-grid .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 0.9rem;
  }

  .card-panel {
    padding: 1rem;
    background: #0c111a;
  }

  .card-panel a {
    color: #b7dcff;
    text-decoration: none;
    font-weight: 600;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
