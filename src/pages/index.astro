---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import siteConfig from '../data/site-config.json';
import { offerings } from '../data/site-content';

const signalStrip = [
  { label: 'Deployment posture', value: 'Auditable by design' },
  { label: 'Runtime focus', value: 'AI systems in production' },
  { label: 'Control model', value: 'Operator in the loop' },
];

const proofPoints = [
  {
    title: 'Decision systems with traceable outcomes',
    body: 'We design operating flows that keep models, people, and incident controls aligned under real load.',
  },
  {
    title: 'Observability built for action',
    body: 'Signals, thresholds, and escalation paths are structured for fast interpretation rather than dashboard sprawl.',
  },
  {
    title: 'Resilience patterns that survive handoffs',
    body: 'Recovery logic, ownership boundaries, and deployment checks are encoded so teams can move without guesswork.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="hero" id="hero">
        <canvas id="wave-field" aria-hidden="true"></canvas>
        <div class="hero-glow" aria-hidden="true"></div>
        <div class="hero-mark-wrap" aria-hidden="true">
          <svg
            class="gs-logo-reactive"
            viewBox="0 0 128 160"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linejoin="round"
            stroke-linecap="square"
            vector-effect="non-scaling-stroke"
            shape-rendering="geometricPrecision"
          >
            <path
              class="gs-logo-path"
              d="M64 20 L17 93 H103 L64 20 M64 20 L103 93 M64 20 L17 93 M64 58 L49 83 H79 L64 58"
            ></path>
            <path class="gs-logo-seam" d="M64 58 L49 83"></path>
          </svg>
        </div>
        <div class="hero-content">
          <p class="eyebrow">
            Institutional-grade operational AI
          </p>
          <h1>Clarity, control, and trust for live AI systems.</h1>
          <p>
            GoldShore.ai delivers resilient infrastructure, observability, and
            operator-grade workflows for teams deploying AI where reliability is
            not optional.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href="/contact"
              >{siteConfig.cta.primary}</a
            >
            <a class="button button-secondary" href="/contact"
              >{siteConfig.cta.secondary}</a
            >
          </div>
        </div>
        <a
          class="scroll-cue"
          href="#offerings"
          aria-label="Scroll to core offerings"
        >
          <span>Scroll</span>
          <span class="arrow">↓</span>
        </a>
      </section>

      <section class="signal-strip" aria-label="Operating signals">
        {
          signalStrip.map((signal) => (
            <article class="signal-tile">
              <span>{signal.label}</span>
              <strong>{signal.value}</strong>
            </article>
          ))
        }
      </section>

      <section id="offerings">
        <div class="section-heading">
          <p class="section-kicker">Core offerings</p>
          <h2>Operational systems shaped for high-trust environments.</h2>
          <p class="section-intro">
            We combine applied intelligence, observability engineering, and
            resilience architecture into delivery patterns that hold up in live
            production settings.
          </p>
        </div>
        <div class="grid">
          {
            offerings.map((offering) => (
              <article class="card">
                <h3>{offering.title}</h3>
                <p>{offering.summary}</p>
                <p class="metric">{offering.metric}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="proof-section" aria-labelledby="proof-title">
        <div class="section-heading">
          <p class="section-kicker">Why GoldShore</p>
          <h2 id="proof-title">Designed for operators who can’t afford guesswork.</h2>
          <p class="section-intro">
            We bring a systems-first perspective to every engagement — one that
            prioritises clarity, accountability, and durable controls over
            short-lived solutions.
          </p>
        </div>
        <div class="grid">
          {
            proofPoints.map((point) => (
              <article class="card proof-card">
                <h3>{point.title}</h3>
                <p>{point.body}</p>
              </article>
            ))
          }
        </div>
      </section>
    </main>
    <Footer />

    <script type="module">
      const hero = document.getElementById('hero');
      const canvas = document.getElementById('wave-field');
      const ctx = canvas?.getContext('2d');
      const logo = document.querySelector('.gs-logo-reactive');
      const seam = document.querySelector('.gs-logo-seam');
      const reduceMotion = window.matchMedia(
        '(prefers-reduced-motion: reduce)',
      );

      if (hero && canvas && ctx && logo) {
        let rafId = 0;
        let fadeTicking = false;
        let time = 0;
        let width = 0;
        let height = 0;
        let cssWidth = 0;
        let cssHeight = 0;
        const dpr = Math.min(window.devicePixelRatio || 1, 2);

        const state = {
          energy: 0,
          dx: 0,
          dy: 0,
          rot: 0,
          glow: 4,
          glowAlpha: 0.18,
          opacity: 0.88,
          seamOpacity: 0.26,
        };

        const resize = () => {
          cssWidth = hero.clientWidth;
          cssHeight = hero.clientHeight;
          width = Math.max(1, Math.floor(cssWidth * dpr));
          height = Math.max(1, Math.floor(cssHeight * dpr));
          canvas.width = width;
          canvas.height = height;
          canvas.style.width = `${cssWidth}px`;
          canvas.style.height = `${cssHeight}px`;
          ctx.setTransform(1, 0, 0, 1, 0, 0);
          ctx.scale(dpr, dpr);
        };

        const sampleWave = (x, y, currentTime) =>
          Math.sin(x * 0.0105 + currentTime * 1.08) * 7 +
          Math.cos(y * 0.017 + currentTime * 0.74) * 4 +
          Math.sin((x + y) * 0.0042 + currentTime * 0.49) * 3;

        const sampleWaveEnergy = (currentTime) => {
          const heroRect = hero.getBoundingClientRect();
          const logoRect = logo.getBoundingClientRect();
          const sx = Math.min(
            Math.max(logoRect.left + logoRect.width * 0.5 - heroRect.left, 0),
            cssWidth,
          );
          const sy = Math.min(
            Math.max(logoRect.top + logoRect.height * 0.5 - heroRect.top, 0),
            cssHeight,
          );

          const wave = sampleWave(sx, sy, currentTime);
          return Math.min(1, Math.abs(wave) / 14);
        };

        const drawWaveField = (currentTime) => {
          ctx.clearRect(0, 0, cssWidth, cssHeight);
          ctx.fillStyle = '#050816';
          ctx.fillRect(0, 0, cssWidth, cssHeight);

          const step = cssWidth < 720 ? 12 : 10;
          for (let y = 0; y <= cssHeight + step; y += step) {
            ctx.beginPath();

            for (let x = 0; x <= cssWidth + step; x += step) {
              const wave = sampleWave(x, y, currentTime);
              if (x === 0) {
                ctx.moveTo(x, y + wave);
              } else {
                ctx.lineTo(x, y + wave);
              }
            }

            const alpha = 0.035 + (y / cssHeight) * 0.08;
            ctx.strokeStyle = `rgba(90, 162, 255, ${alpha.toFixed(3)})`;
            ctx.lineWidth = 1;
            ctx.stroke();
          }
        };

        const applyLogoState = () => {
          logo.style.transform = `translate(${state.dx.toFixed(2)}px, ${state.dy.toFixed(2)}px) rotate(${state.rot.toFixed(2)}deg)`;
          logo.style.filter = `drop-shadow(0 0 ${state.glow.toFixed(1)}px rgba(90, 162, 255, ${state.glowAlpha.toFixed(3)}))`;
          logo.style.opacity = state.opacity.toFixed(3);

          if (seam) {
            seam.style.opacity = state.seamOpacity.toFixed(3);
          }
        };

        const updateLogo = (currentTime) => {
          const targetEnergy = sampleWaveEnergy(currentTime);
          state.energy += (targetEnergy - state.energy) * 0.08;

          const targetX = Math.sin(currentTime * 1.18) * 1.15 * state.energy;
          const targetY = Math.cos(currentTime * 0.93) * 1.55 * state.energy;
          const targetRot = Math.sin(currentTime * 0.67) * 0.8 * state.energy;

          state.dx += (targetX - state.dx) * 0.12;
          state.dy += (targetY - state.dy) * 0.12;
          state.rot += (targetRot - state.rot) * 0.12;

          state.glow += (4 + state.energy * 7.5 - state.glow) * 0.14;
          state.glowAlpha +=
            (0.16 + state.energy * 0.28 - state.glowAlpha) * 0.14;
          state.opacity += (0.84 + state.energy * 0.13 - state.opacity) * 0.12;
          state.seamOpacity +=
            (0.22 +
              state.energy * 0.38 +
              Math.sin(currentTime * 1.8) * 0.04 -
              state.seamOpacity) *
            0.12;

          applyLogoState();
        };

        const handleFade = () => {
          fadeTicking = false;
          const heroHeight = hero.clientHeight;
          const progress = Math.min(window.scrollY / (heroHeight * 0.75), 1);
          hero.style.opacity = String(1 - progress);
          hero.style.transform = `translateY(${progress * 28}px)`;
        };

        const onScroll = () => {
          if (fadeTicking) return;
          fadeTicking = true;
          window.requestAnimationFrame(handleFade);
        };

        const renderStatic = () => {
          drawWaveField(0);
          state.dx = 0;
          state.dy = 0;
          state.rot = 0;
          state.glow = 5.5;
          state.glowAlpha = 0.2;
          state.opacity = 0.92;
          state.seamOpacity = 0.3;
          applyLogoState();
        };

        const frame = () => {
          time += 0.016;
          drawWaveField(time);
          updateLogo(time);
          rafId = window.requestAnimationFrame(frame);
        };

        resize();
        handleFade();
        window.addEventListener('resize', resize);
        window.addEventListener('scroll', onScroll, { passive: true });

        if (reduceMotion.matches) {
          renderStatic();
        } else {
          frame();
        }

        reduceMotion.addEventListener('change', (event) => {
          if (event.matches) {
            if (rafId) {
              window.cancelAnimationFrame(rafId);
              rafId = 0;
            }
            renderStatic();
            return;
          }

          if (!rafId) {
            frame();
          }
        });
      }
    </script>
  </body>
</html>

<style>
  .hero {
    position: relative;
    min-height: calc(100vh - 6rem);
    border: 1px solid rgba(120, 157, 204, 0.18);
    border-radius: 1.5rem;
    overflow: hidden;
    isolation: isolate;
    display: grid;
    place-items: center;
    margin-top: 0.5rem;
    box-shadow: 0 28px 72px rgba(0, 0, 0, 0.28);
    transition:
      opacity 180ms linear,
      transform 180ms linear;
  }

  #wave-field,
  .hero-glow {
    position: absolute;
    inset: 0;
  }

  #wave-field {
    z-index: 0;
  }

  .hero-glow {
    background:
      radial-gradient(
        circle at 80% 25%,
        rgba(76, 152, 255, 0.25),
        transparent 48%
      ),
      radial-gradient(
        circle at 18% 74%,
        rgba(24, 198, 196, 0.2),
        transparent 42%
      );
    z-index: 0;
  }

  .hero-mark-wrap {
    position: absolute;
    left: clamp(1.5rem, 8vw, 6rem);
    top: clamp(1.75rem, 18vh, 9rem);
    z-index: 1;
    pointer-events: none;
  }

  .gs-logo-reactive {
    width: clamp(72px, 10vw, 132px);
    height: auto;
    color: #5aa2ff;
    transform-origin: 50% 50%;
    will-change: transform, filter, opacity;
    transition:
      transform 120ms linear,
      filter 160ms linear,
      opacity 160ms linear;
  }

  .gs-logo-path,
  .gs-logo-seam {
    vector-effect: non-scaling-stroke;
  }

  .gs-logo-seam {
    opacity: 0.26;
    transition: opacity 160ms linear;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    width: min(42rem, calc(100% - 2.5rem));
    text-align: center;
    color: #e8edf7;
  }

  .hero-content h1 {
    margin-top: 0.5rem;
    color: white;
    font-size: clamp(2.2rem, 4vw, 3.7rem);
  }

  .hero-content p {
    margin: 0.75rem 0;
  }

  .signal-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .signal-tile {
    border: 1px solid rgba(120, 157, 204, 0.18);
    border-radius: 1rem;
    padding: 1rem 1.15rem;
    background: rgba(10, 18, 34, 0.72);
    backdrop-filter: blur(10px);
  }

  .signal-tile span {
    display: block;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(171, 194, 223, 0.78);
    margin-bottom: 0.45rem;
  }

  .signal-tile strong {
    color: #f6fbff;
    font-size: 1.05rem;
  }

  .section-heading {
    margin-bottom: 1.2rem;
    max-width: 46rem;
  }

  .section-kicker {
    margin: 0 0 0.45rem;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    color: rgba(120, 184, 255, 0.88);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .section-intro {
    color: rgba(197, 212, 232, 0.82);
    max-width: 42rem;
  }

  .proof-card {
    min-height: 100%;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.78rem;
    color: rgba(203, 220, 242, 0.95);
  }

  .hero-content .small {
    color: rgba(224, 234, 249, 0.9);
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1.15rem;
  }

  .scroll-cue {
    position: absolute;
    z-index: 2;
    left: 50%;
    transform: translateX(-50%);
    bottom: 1.1rem;
    color: rgba(224, 239, 255, 0.9);
    text-decoration: none;
    font-size: 0.83rem;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
  }

  .arrow {
    animation: bounce 1.4s ease-in-out infinite;
    font-size: 1.1rem;
  }

  @keyframes bounce {
    0%,
    100% {
      transform: translateY(0);
    }

    50% {
      transform: translateY(5px);
    }
  }

  @media (max-width: 720px) {
    .hero {
      min-height: 82vh;
    }

    .signal-strip {
      grid-template-columns: 1fr;
    }

    .hero-mark-wrap {
      top: clamp(1.5rem, 11vh, 3rem);
      left: clamp(1rem, 7vw, 2rem);
    }
  }
</style>
