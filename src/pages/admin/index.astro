---
import AdminLayout from '../../layouts/AdminLayout.astro';
import StatCard from '../../components/StatCard.astro';

export const prerender = false;

const clientCertHeader = Astro.request.headers.get('cf-client-cert-base64');
const isAdmin = clientCertHeader !== null;
---

<AdminLayout title="Overview">
  {
    isAdmin ? (
      <>
        <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
          <StatCard title="Active Agents" value="3" trend="+1" />
          <StatCard title="API Requests (24h)" value="12.4k" trend="Stable" />
          <StatCard title="Gateway Latency" value="42ms" trend="Optimal" />
        </div>

        <div class="mt-8 rounded-lg border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-700 dark:bg-slate-800">
          <h3 class="mb-4 text-xl font-bold">Live Agent Deployment (Jules/Codex)</h3>
          <div class="h-64 overflow-y-scroll rounded bg-black p-4 font-mono text-sm text-green-400">
            <p>[SYSTEM] goldshore-ai monorepo detected...</p>
            <p>[JULES] Analyzing apps/gs-api/src/server.ts</p>
            <p>[CODEX] Generating mapping for api.goldshore.ai</p>
            <p class="animate-pulse">_</p>
          </div>
        </div>
      </>
    ) : (
      <section class="max-w-3xl rounded-lg border border-red-300 bg-red-50 p-6 text-red-800 dark:border-red-700 dark:bg-red-900/30 dark:text-red-100">
        <h1 class="mb-2 text-2xl font-bold">Access Denied</h1>
        <p>Secure identity certificate not found for this request.</p>
      </section>
    )
  }
</AdminLayout>
