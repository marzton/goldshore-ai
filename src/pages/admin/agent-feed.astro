---
import AdminLayout from "../../layouts/AdminLayout.astro";

// Mock data: In production, this fetches from your R2/KV log store via gs-api
const activeTasks = [
  { agent: "Jules", task: "Optimizing Cloudflare Routing", status: "In-Progress", time: "2m ago" },
  { agent: "Codex", task: "Refactoring AdminSidebar.astro", status: "Completed", time: "15m ago" },
  { agent: "Jules", task: "Security Audit: media.ts regex", status: "Flagged", time: "1h ago" }
];
---

<AdminLayout title="Agent Feed">
  <div class="mb-6 flex justify-between items-center">
    <h1 class="text-2xl font-bold">Live Agent Activity</h1>
    <div class="flex space-x-2">
      <span class="flex items-center text-sm font-medium text-green-500">
        <span class="w-2 h-2 bg-green-500 rounded-full mr-2 animate-ping"></span>
        Live Stream Active
      </span>
    </div>
  </div>

  <div class="grid gap-4">
    {activeTasks.map((task) => (
      <div class="p-4 bg-white border border-slate-200 rounded-lg shadow-sm dark:bg-slate-800 dark:border-slate-700 flex justify-between items-center">
        <div class="flex items-center space-x-4">
          <div class={`w-10 h-10 rounded-full flex items-center justify-center font-bold ${task.agent === 'Jules' ? 'bg-blue-100 text-blue-600' : 'bg-purple-100 text-purple-600'}`}>
            {task.agent[0]}
          </div>
          <div>
            <p class="font-semibold text-slate-900 dark:text-white">{task.task}</p>
            <p class="text-xs text-slate-500">{task.agent} • {task.time}</p>
          </div>
        </div>
        <span class={`px-3 py-1 rounded-full text-xs font-medium ${
          task.status === 'Completed' ? 'bg-green-100 text-green-800' :
          task.status === 'Flagged' ? 'bg-red-100 text-red-800' : 'bg-blue-100 text-blue-800'
        }`}>
          {task.status}
        </span>
      </div>
    ))}
  </div>

  <div class="mt-8">
    <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-500 mb-2">Raw Logic Stream</h3>
    <div class="bg-slate-950 text-slate-300 p-4 rounded-lg font-mono text-xs h-96 overflow-y-auto border border-slate-800">
      <div class="space-y-1">
        <p><span class="text-blue-400">[Jules]</span> Initializing VM for pull request #3268...</p>
        <p><span class="text-purple-400">[Codex]</span> Context match found in AGENTS.md. Mapping apps/gs-api.</p>
        <p><span class="text-yellow-400">[System]</span> Syncing variables from GS_ROUTING_API_BASE...</p>
        <p><span class="text-green-400">[Success]</span> Build initialized in 1.2s.</p>
        <p class="animate-pulse">_</p>
      </div>
    </div>
  </div>
</AdminLayout>
