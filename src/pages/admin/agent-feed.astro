---
import DefaultPageTemplate from '../../components/DefaultPageTemplate.astro';

const feedItems = [
  {
    id: 'evt-1',
    source: 'jules',
    summary: 'Policy drift detected in deployment workflow.',
    severity: 'flagged',
    status: 'open',
    timestamp: '2026-03-10T14:02:00Z',
  },
  {
    id: 'evt-2',
    source: 'codex',
    summary: 'Agent coordination latency recovered after retry.',
    severity: 'info',
    status: 'resolved',
    timestamp: '2026-03-10T13:44:00Z',
  },
  {
    id: 'evt-3',
    source: 'jules',
    summary: 'Manual review requested for elevated risk response.',
    severity: 'review',
    status: 'investigating',
    timestamp: '2026-03-10T13:22:00Z',
  },
];

const sourceStyles = {
  jules: 'bg-fuchsia-500/15 text-fuchsia-200 border border-fuchsia-400/40',
  codex: 'bg-cyan-500/15 text-cyan-200 border border-cyan-400/40',
};

const severityStyles = {
  flagged: 'bg-red-500/15 text-red-200 border border-red-400/40',
  review: 'bg-amber-500/15 text-amber-200 border border-amber-400/40',
  info: 'bg-emerald-500/15 text-emerald-200 border border-emerald-400/40',
};

const statusBadgeStyles = {
  open: 'bg-red-500/15 text-red-200 border border-red-400/40',
  investigating: 'bg-yellow-500/15 text-yellow-200 border border-yellow-400/40',
  resolved: 'bg-green-500/15 text-green-200 border border-green-400/40',
};
---

<DefaultPageTemplate
  title="Agent Feed"
  description="Operational feed for agent activity."
>
  <section class="mx-auto max-w-5xl px-4 py-10">
    <h1 class="text-2xl font-semibold text-white">Agent Feed</h1>
    <p class="mt-2 text-sm text-slate-300">
      Recent activity from Jules and Codex across workflows.
    </p>

    <div
      class="mt-6 overflow-hidden rounded-xl border border-white/10 bg-slate-900/60"
    >
      <table class="min-w-full text-left text-sm">
        <thead
          class="border-b border-white/10 text-xs uppercase tracking-wide text-slate-400"
        >
          <tr>
            <th class="px-4 py-3">Source</th>
            <th class="px-4 py-3">Summary</th>
            <th class="px-4 py-3">Severity</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Timestamp</th>
          </tr>
        </thead>
        <tbody>
          {
            feedItems.map((item) => (
              <tr class="border-b border-white/5">
                <td class="px-4 py-3">
                  <span
                    class={`inline-flex rounded-full px-2.5 py-1 text-xs font-medium ${sourceStyles[item.source]}`}
                  >
                    {item.source}
                  </span>
                </td>
                <td class="px-4 py-3 text-slate-100">{item.summary}</td>
                <td class="px-4 py-3">
                  <span
                    class={`inline-flex rounded-full px-2.5 py-1 text-xs font-medium ${severityStyles[item.severity]}`}
                  >
                    {item.severity}
                  </span>
                </td>
                <td class="px-4 py-3">
                  <span
                    class={`inline-flex rounded-full px-2.5 py-1 text-xs font-medium ${statusBadgeStyles[item.status]}`}
                  >
                    {item.status}
                  </span>
                </td>
                <td class="px-4 py-3 text-slate-300">
                  {new Date(item.timestamp).toLocaleString()}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>
</DefaultPageTemplate>
