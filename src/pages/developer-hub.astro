---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import siteConfig from '../data/site-config.json';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Developer Hub | GoldShore.ai"
      description="Developer onboarding and API overview."
    />
  </head>
  <body>
    <Header />
    <main>
      <h1>Developer Hub</h1>
      <p>
        Implementation notes, integration surfaces, and API onboarding
        references.
      </p>
      <section id="api-overview" class="card">
        <h2>API overview (preview)</h2>
        <p class="small">
          A provisional API index is available for interface planning. Contact
          the team for early access and environment credentials.
        </p>
        <pre
          class="code-block"
          aria-label="API schema preview"><code><span class="token-method">GET</span> <span class="token-path">/v1/systems/{'{'}id{'}'}/status</span>
<span class="token-status">200 OK</span>
{'{'}
  <span class="token-key">"systemId"</span>: <span class="token-value">"ops-17"</span>,
  <span class="token-key">"health"</span>: <span class="token-value">"degraded"</span>,
  <span class="token-key">"riskScore"</span>: <span class="token-number">0.62</span>,
  <span class="token-key">"updatedAt"</span>: <span class="token-value">"2026-02-10T10:45:00Z"</span>
{'}'}</code></pre>
        <p>
          <a class="button button-secondary" href="/contact"
            >{siteConfig.cta.secondary} for API access</a
          >
        </p>
      </section>
    </main>
    <Footer />
    <style>
      .code-block {
        line-height: 1.5;
        background: #0f172a;
        color: #e2e8f0;
        border: 1px solid #1e293b;
        border-radius: 12px;
        padding: 1rem;
        overflow-x: auto;
      }
      .token-method {
        color: #93c5fd;
        font-weight: 700;
      }
      .token-path {
        color: #c4b5fd;
      }
      .token-status {
        color: #86efac;
      }
      .token-key {
        color: #f9a8d4;
      }
      .token-value {
        color: #fde68a;
      }
      .token-number {
        color: #67e8f9;
      }
    </style>
  </body>
</html>
